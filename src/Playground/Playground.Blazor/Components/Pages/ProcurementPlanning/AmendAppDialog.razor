@using MudBlazor
@using FSH.Modules.ProcurementPlanning.Contracts.v1.AnnualProcurementPlans
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" />
            Amend @DocumentNumber (v@CurrentVersion → v@(CurrentVersion + 1))
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudAlert Severity="Severity.Warning" Dense="true">
                This will <strong>supersede</strong> v@CurrentVersion and create a new Draft.
                The new version must go through the approval workflow again.
            </MudAlert>
            <MudSelect T="AppRevisionType" @bind-Value="_revisionType" Label="Revision Type *"
                       Variant="Variant.Outlined">
                <MudSelectItem Value="AppRevisionType.Supplemental">Supplemental</MudSelectItem>
                <MudSelectItem Value="AppRevisionType.Revised">Revised</MudSelectItem>
            </MudSelect>
            <MudTextField @bind-Value="_reason" Label="Reason for Amendment *"
                          Variant="Variant.Outlined" Lines="3"
                          Placeholder="e.g. Additional procurement items, budget realignment..." />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Warning" Variant="Variant.Filled"
                   Disabled="@(string.IsNullOrWhiteSpace(_reason))"
                   OnClick="Confirm">
            Create v@(CurrentVersion + 1) Draft
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string DocumentNumber { get; set; } = string.Empty;
    [Parameter] public int CurrentVersion { get; set; }

    private string _reason = string.Empty;
    private AppRevisionType _revisionType = AppRevisionType.Supplemental;

    private void Confirm() => MudDialog.Close(DialogResult.Ok((_reason, _revisionType)));
    private void Cancel()  => MudDialog.Cancel();
}
