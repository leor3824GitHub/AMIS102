    // ── Select / version loading ─────────────────────────────────────
    private async Task SelectPpmpAsync(Guid id)
    {
        _busy = true;
        try
        {
            _editing = await PpmpClient.GetAsync(id);
            if (_editing is null) return;
            _selectedVersionId = _editing.Id;
            _versions = (await PpmpClient.GetVersionsAsync(_editing.VersionChainId)).ToList();
            PopulateForm(_editing);
            _activeTab = 1;
        }
        catch (Exception ex) { Snackbar.Add($"Error loading PPMP: {ex.Message}", Severity.Error); }
        finally { _busy = false; }
    }

    private async Task LoadVersionAsync(Guid id)
    {
        if (id == _editing?.Id) return;
        _busy = true;
        try
        {
            _editing = await PpmpClient.GetAsync(id);
            if (_editing is not null) PopulateForm(_editing);
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _busy = false; }
    }

    private void PopulateForm(PpmpDto dto)
    {
        _form = new PpmpFormModel
        {
            FiscalYear = dto.FiscalYear,
            Phase = dto.Phase,
            OfficeCode = dto.OfficeCode,
            EndUserUnit = dto.EndUserUnit,
            Items = dto.Items.Select(i => new PpmpItemFormModel
            {
                GeneralDescription = i.GeneralDescription,
                ProjectType = i.ProjectType,
                Quantity = i.Quantity,
                Unit = i.Unit,
                ModeOfProcurement = i.ModeOfProcurement,
                PreProcurementConference = i.PreProcurementConference,
                ProcurementStart = i.ProcurementStart,
                ProcurementEnd = i.ProcurementEnd,
                ExpectedDelivery = i.ExpectedDelivery,
                SourceOfFunds = i.SourceOfFunds,
                EstimatedBudget = i.EstimatedBudget,
                Remarks = i.Remarks ?? string.Empty
            }).ToList()
        };

        foreach (var item in _form.Items.Where(i => !string.IsNullOrWhiteSpace(i.GeneralDescription)))
            _usedDescriptions.Add(item.GeneralDescription);
    }

    // ── Item dialog ──────────────────────────────────────────────────
    private void OpenAddItemDialog()
    {
        _editingItemIdx = null;
        _itemForm = new PpmpItemFormModel();
        _itemDialogOpen = true;
    }

    private void OpenEditItemDialog(int idx)
    {
        var src = _form.Items[idx];
        _editingItemIdx = idx;
        _itemForm = new PpmpItemFormModel
        {
            GeneralDescription    = src.GeneralDescription,
            ProjectType           = src.ProjectType,
            Quantity              = src.Quantity,
            Unit                  = src.Unit,
            ModeOfProcurement     = src.ModeOfProcurement,
            PreProcurementConference = src.PreProcurementConference,
            ProcurementStart      = src.ProcurementStart,
            ProcurementEnd        = src.ProcurementEnd,
            ExpectedDelivery      = src.ExpectedDelivery,
            SourceOfFunds         = src.SourceOfFunds,
            EstimatedBudget       = src.EstimatedBudget,
            Remarks               = src.Remarks
        };
        _itemDialogOpen = true;
    }

    private void SaveItemDialog()
    {
        if (string.IsNullOrWhiteSpace(_itemForm.GeneralDescription))
        {
            Snackbar.Add("Description is required.", Severity.Warning);
            return;
        }
        if (_itemForm.EstimatedBudget <= 0)
        {
            Snackbar.Add("Estimated budget must be greater than zero.", Severity.Warning);
            return;
        }

        if (!string.IsNullOrWhiteSpace(_itemForm.GeneralDescription))
            _usedDescriptions.Add(_itemForm.GeneralDescription);

        if (_editingItemIdx.HasValue)
        {
            var target = _form.Items[_editingItemIdx.Value];
            target.GeneralDescription    = _itemForm.GeneralDescription;
            target.ProjectType           = _itemForm.ProjectType;
            target.Quantity              = _itemForm.Quantity;
            target.Unit                  = _itemForm.Unit;
            target.ModeOfProcurement     = _itemForm.ModeOfProcurement;
            target.PreProcurementConference = _itemForm.PreProcurementConference;
            target.ProcurementStart      = _itemForm.ProcurementStart;
            target.ProcurementEnd        = _itemForm.ProcurementEnd;
            target.ExpectedDelivery      = _itemForm.ExpectedDelivery;
            target.SourceOfFunds         = _itemForm.SourceOfFunds;
            target.EstimatedBudget       = _itemForm.EstimatedBudget;
            target.Remarks               = _itemForm.Remarks;
        }
        else
        {
            _form.Items.Add(new PpmpItemFormModel
            {
                GeneralDescription    = _itemForm.GeneralDescription,
                ProjectType           = _itemForm.ProjectType,
                Quantity              = _itemForm.Quantity,
                Unit                  = _itemForm.Unit,
                ModeOfProcurement     = _itemForm.ModeOfProcurement,
                PreProcurementConference = _itemForm.PreProcurementConference,
                ProcurementStart      = _itemForm.ProcurementStart,
                ProcurementEnd        = _itemForm.ProcurementEnd,
                ExpectedDelivery      = _itemForm.ExpectedDelivery,
                SourceOfFunds         = _itemForm.SourceOfFunds,
                EstimatedBudget       = _itemForm.EstimatedBudget,
                Remarks               = _itemForm.Remarks
            });
        }

        _itemDialogOpen = false;
    }

    private void CloseItemDialog() => _itemDialogOpen = false;

    // ── Autocomplete search functions ────────────────────────────────
    private Task<IEnumerable<string>> SearchUnits(string value, CancellationToken _)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult<IEnumerable<string>>(_unitCodes.Take(20));

        var matches = _unitCodes
            .Where(c => c.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Take(20);
        return Task.FromResult<IEnumerable<string>>(matches);
    }

    private Task<IEnumerable<string>> SearchDescriptions(string value, CancellationToken _)
    {
        var all = _usedDescriptions
            .Concat(_form.Items.Select(i => i.GeneralDescription))
            .Where(d => !string.IsNullOrWhiteSpace(d))
            .Distinct(StringComparer.OrdinalIgnoreCase);

        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult<IEnumerable<string>>(all.Take(15));

        var matches = all.Where(d => d.Contains(value, StringComparison.OrdinalIgnoreCase)).Take(15);
        return Task.FromResult<IEnumerable<string>>(matches);
    }

