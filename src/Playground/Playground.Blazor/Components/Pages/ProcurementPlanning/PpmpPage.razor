    // ── Helpers ──────────────────────────────────────────────────────
    private RenderFragment StatusChip(PpmpStatus status) =>
        @<MudChip T="string" Size="Size.Small" Color="@StatusColor(status)"
                  Icon="@StatusIcon(status)" Label="true">@status</MudChip>;

    private static Color StatusColor(PpmpStatus s) => s switch
    {
        PpmpStatus.Draft        => Color.Default,
        PpmpStatus.Submitted    => Color.Info,
        PpmpStatus.Approved     => Color.Success,
        PpmpStatus.Consolidated => Color.Primary,
        PpmpStatus.Superseded   => Color.Warning,
        PpmpStatus.Returned     => Color.Error,
        _                       => Color.Default
    };

    private static string StatusIcon(PpmpStatus s) => s switch
    {
        PpmpStatus.Draft        => Icons.Material.Outlined.EditNote,
        PpmpStatus.Submitted    => Icons.Material.Outlined.HourglassTop,
        PpmpStatus.Approved     => Icons.Material.Filled.CheckCircle,
        PpmpStatus.Consolidated => Icons.Material.Filled.LibraryAddCheck,
        PpmpStatus.Superseded   => Icons.Material.Outlined.History,
        PpmpStatus.Returned     => Icons.Material.Filled.Undo,
        _                       => Icons.Material.Outlined.Circle
    };
