@page "/procurement-planning/ppmps"
@using FSH.Modules.ProcurementPlanning.Contracts.v1.Ppmps
@using FSH.Framework.Shared.Persistence
@using FSH.Playground.Blazor.ApiClient
@using FSH.Playground.Blazor.Components.Shared
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IPpmpClient PpmpClient
@inject IOrganizationProfileClient OrgProfileClient
@inject ILookupClient LookupClient
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<FshPageHeader Title="Project Procurement Management Plan (PPMP)"
               Description="Manage per-section procurement plans for the fiscal year" />

<!-- ══ Add / Edit Line Item Dialog ══════════════════════════════════ -->
<MudDialog @bind-Visible="_itemDialogOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(_editingItemIdx.HasValue ? Icons.Material.Filled.Edit : Icons.Material.Filled.Add)" Class="mr-2" Style="vertical-align:middle" />
            @(_editingItemIdx.HasValue ? "Edit Line Item" : "Add Line Item")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid Spacing="2" Class="mt-1">
            <MudItem xs="12">
                <MudAutocomplete T="string"
                                 @bind-Value="_itemForm.GeneralDescription"
                                 Label="Description / Objective"
                                 Variant="Variant.Outlined"
                                 SearchFunc="SearchDescriptions"
                                 ResetValueOnEmptyText="false"
                                 CoerceText="true"
                                 CoerceValue="true"
                                 Required="true"
                                 HelperText="Start typing — previous descriptions will appear"
                                 Placeholder="Describe the procurement item or objective" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudSelect @bind-Value="_itemForm.ProjectType" Label="Type"
                           Variant="Variant.Outlined" T="ProjectType">
                    <MudSelectItem Value="ProjectType.Goods">Goods</MudSelectItem>
                    <MudSelectItem Value="ProjectType.Infrastructure">Infrastructure</MudSelectItem>
                    <MudSelectItem Value="ProjectType.ConsultingServices">Consulting Services</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudSelect @bind-Value="_itemForm.ModeOfProcurement" Label="Mode of Procurement"
                           Variant="Variant.Outlined" T="ModeOfProcurement">
                    <MudSelectItem Value="ModeOfProcurement.PublicBidding">Public Bidding</MudSelectItem>
                    <MudSelectItem Value="ModeOfProcurement.LimitedSourceBidding">Limited Source Bidding</MudSelectItem>
                    <MudSelectItem Value="ModeOfProcurement.DirectContracting">Direct Contracting</MudSelectItem>
                    <MudSelectItem Value="ModeOfProcurement.RepeatOrder">Repeat Order</MudSelectItem>
                    <MudSelectItem Value="ModeOfProcurement.Shopping">Shopping</MudSelectItem>
                    <MudSelectItem Value="ModeOfProcurement.NegotiatedProcurement">Negotiated Procurement</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="4">
                <MudNumericField @bind-Value="_itemForm.Quantity" Label="Quantity"
                                 Variant="Variant.Outlined" Min="0.01m" />
            </MudItem>

            <MudItem xs="12" sm="4">
                <MudAutocomplete T="string"
                                 @bind-Value="_itemForm.Unit"
                                 Label="Unit of Measure"
                                 Variant="Variant.Outlined"
                                 SearchFunc="SearchUnits"
                                 ResetValueOnEmptyText="false"
                                 CoerceText="true"
                                 CoerceValue="true"
                                 Placeholder="e.g. LOT, PCS, BOX..."
                                 HelperText="Select from master data or type a unit" />
            </MudItem>

            <MudItem xs="12" sm="4">
                <MudNumericField @bind-Value="_itemForm.EstimatedBudget" Label="Estimated Budget (₱)"
                                 Variant="Variant.Outlined" Min="0m" Format="N2" />
            </MudItem>

            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="_itemForm.ProcurementStart" Label="Procurement Start"
                              Variant="Variant.Outlined" Placeholder="MM/YYYY" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="_itemForm.ProcurementEnd" Label="Procurement End"
                              Variant="Variant.Outlined" Placeholder="MM/YYYY" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="_itemForm.ExpectedDelivery" Label="Expected Delivery"
                              Variant="Variant.Outlined" Placeholder="MM/YYYY" />
            </MudItem>

            <MudItem xs="12" sm="9">
                <MudTextField @bind-Value="_itemForm.SourceOfFunds" Label="Source of Funds"
                              Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" sm="3" Style="display:flex;align-items:center">
                <MudCheckBox @bind-Value="_itemForm.PreProcurementConference"
                             Label="Pre-Proc Conference" Color="Color.Primary" />
            </MudItem>

            <MudItem xs="12">
                <MudTextField @bind-Value="_itemForm.Remarks" Label="Remarks"
                              Variant="Variant.Outlined" Lines="2" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseItemDialog" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveItemDialog">
            @(_editingItemIdx.HasValue ? "Update Item" : "Add Item")
        </MudButton>
    </DialogActions>
</MudDialog>

<MudCard Elevation="1">
    <MudTabs @bind-ActivePanelIndex="_activeTab" Elevation="0" Rounded="false"
             ApplyEffectsToContainer="true" PanelClass="pa-4" Color="Color.Primary">

        <!-- ══ LIST TAB ══════════════════════════════════════════════════ -->
        <MudTabPanel Text="List" Icon="@Icons.Material.Outlined.ListAlt">
            <MudStack Row="true" Spacing="2" Class="mb-3" AlignItems="AlignItems.Center">
                <MudTextField @bind-Value="_search" Placeholder="Search PPMP number or unit..."
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              Variant="Variant.Outlined" Immediate="true" DebounceInterval="400"
                              OnDebounceIntervalElapsed="LoadAsync" Class="flex-1" />
                <MudSelect Value="@_filterFiscalYear" Label="FY" Variant="Variant.Outlined"
                           T="int?" Style="width:100px" ValueChanged="OnFilterChanged">
                    <MudSelectItem T="int?" Value="null">All</MudSelectItem>
                    @foreach (var fy in _fiscalYears)
                    {
                        <MudSelectItem T="int?" Value="fy">@fy</MudSelectItem>
                    }
                </MudSelect>
                <MudSelect Value="@_filterStatus" Label="Status" Variant="Variant.Outlined"
                           T="PpmpStatus?" Style="width:150px" ValueChanged="OnStatusFilterChanged">
                    <MudSelectItem T="PpmpStatus?" Value="null">All</MudSelectItem>
                    @foreach (PpmpStatus s in Enum.GetValues<PpmpStatus>())
                    {
                        <MudSelectItem T="PpmpStatus?" Value="s">@s</MudSelectItem>
                    }
                </MudSelect>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add" OnClick="StartNew">
                    New PPMP
                </MudButton>
            </MudStack>

            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (_items.Count == 0)
            {
                <MudAlert Severity="Severity.Info">No PPMPs found.</MudAlert>
            }
            else
            {
                <MudSimpleTable Dense="true" Hover="true" Striped="true" Style="overflow-x:auto">
                    <thead>
                        <tr>
                            <th>PPMP No.</th>
                            <th>FY</th>
                            <th>Office</th>
                            <th>End-User / Section</th>
                            <th>Type</th>
                            <th>Ver.</th>
                            <th>Status</th>
                            <th>Total Budget</th>
                            <th style="width:110px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _items)
                        {
                            <tr style="cursor:pointer" @onclick="@(() => SelectPpmpAsync(row.Id))">
                                <td><strong>@row.PpmpNumber</strong></td>
                                <td>@row.FiscalYear</td>
                                <td>@row.OfficeCode</td>
                                <td>@row.EndUserUnit</td>
                                <td>
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(row.Phase == PpmpPhase.Final ? Color.Primary : Color.Default)">
                                        @row.Phase
                                    </MudChip>
                                </td>
                                <td>v@(row.VersionNumber)</td>
                                <td>@StatusChip(row.Status)</td>
                                <td>₱ @row.TotalEstimatedBudget.ToString("N2")</td>
                                <td @onclick:stopPropagation="true">
                                    @if (row.Status is PpmpStatus.Draft or PpmpStatus.Returned)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                       Color="Color.Primary"
                                                       OnClick="@(() => SelectPpmpAsync(row.Id))" />
                                    }
                                    @if (row.Status is PpmpStatus.Draft or PpmpStatus.Returned)
                                    {
                                        <MudTooltip Text="Submit for Approval">
                                            <MudIconButton Icon="@Icons.Material.Filled.Send" Size="Size.Small"
                                                           Color="Color.Info"
                                                           OnClick="@(() => QuickSubmitAsync(row))" />
                                        </MudTooltip>
                                    }
                                    @if (row.Status == PpmpStatus.Submitted)
                                    {
                                        <MudTooltip Text="Recall (return to Draft)">
                                            <MudIconButton Icon="@Icons.Material.Filled.Undo" Size="Size.Small"
                                                           Color="Color.Warning"
                                                           OnClick="@(() => QuickRecallAsync(row))" />
                                        </MudTooltip>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>

                <MudStack Row="true" Class="mt-2" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.caption">@_totalCount total</MudText>
                    <MudSpacer />
                    <MudPagination Selected="@_page" Count="_totalPages" SelectedChanged="OnPageChanged" />
                </MudStack>
            }
        </MudTabPanel>

        <!-- ══ FORM TAB ══════════════════════════════════════════════════ -->
        <MudTabPanel Text="@(_editing is null ? "+ New PPMP" : $"Edit {_editing.PpmpNumber}")"
                     Icon="@(_editing is null ? Icons.Material.Outlined.Add : Icons.Material.Outlined.Edit)">

            <!-- ── Action bar ─────────────────────────────────────────── -->
            <MudPaper Elevation="0" Class="pa-3 mb-3 rounded"
                      Style="background:var(--mud-palette-background-grey); border:1px solid var(--mud-palette-lines-default)">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">

                    @if (_editing is not null)
                    {
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.subtitle1" Style="font-weight:700">@_editing.PpmpNumber</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">v@(_editing.VersionNumber)</MudText>
                        </MudStack>
                        @StatusChip(_editing.Status)
                    }
                    else
                    {
                        <MudText Typo="Typo.subtitle1" Style="font-weight:700">New PPMP</MudText>
                    }

                    @if (_versions.Count > 1)
                    {
                        <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
                        <MudChipSet T="Guid" @bind-SelectedValue="_selectedVersionId"
                                    SelectionMode="SelectionMode.SingleSelection">
                            @foreach (var v in _versions)
                            {
                                <MudChip T="Guid" Value="v.Id" Size="Size.Small"
                                         Color="@(v.IsCurrentVersion ? Color.Primary : Color.Default)"
                                         OnClick="@(() => LoadVersionAsync(v.Id))">
                                    v@(v.VersionNumber) · @v.Status
                                </MudChip>
                            }
                        </MudChipSet>
                    }

                    <MudSpacer />

                    <!-- Workflow actions -->
                    @if (_editing is not null && _editing.Status is PpmpStatus.Draft or PpmpStatus.Returned)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Info"
                                   StartIcon="@Icons.Material.Filled.Send"
                                   OnClick="SubmitAsync" Disabled="_busy" Size="Size.Small">
                            Submit for Approval
                        </MudButton>
                    }
                    @if (_editing is not null && _editing.Status == PpmpStatus.Submitted)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.Undo"
                                   OnClick="RecallAsync" Disabled="_busy" Size="Size.Small">
                            Recall
                        </MudButton>
                    }
                    @if (_editing is not null && _editing.Status is PpmpStatus.Approved or PpmpStatus.Consolidated)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.Edit"
                                   OnClick="ShowAmendDialogAsync" Disabled="_busy" Size="Size.Small">
                            Amend
                        </MudButton>
                    }

                    <!-- Edit actions -->
                    @if (!_isReadOnly)
                    {
                        <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Save"
                                   OnClick="SaveAsync" Disabled="_busy" Size="Size.Small">
                            @if (_busy)
                            {
                                <MudProgressCircular Size="Size.Small" Class="mr-1" Indeterminate="true" />
                            }
                            @(_editing is null ? "Create" : "Save")
                        </MudButton>
                        <MudButton Variant="Variant.Text" OnClick="ClearForm"
                                   Disabled="_busy" Size="Size.Small">
                            Cancel
                        </MudButton>
                    }
                </MudStack>
            </MudPaper>

            <!-- ── Return reason alert ────────────────────────────────── -->
            @if (_editing is not null && _editing.Status == PpmpStatus.Returned)
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3"
                          Icon="@Icons.Material.Filled.Undo">
                    <strong>Returned for revision</strong> — please address the feedback and resubmit.
                    @if (!string.IsNullOrWhiteSpace(_editing.ReturnReason))
                    {
                        <div Class="mt-1"><em>"@_editing.ReturnReason"</em></div>
                    }
                </MudAlert>
            }
            else if (_editing is not null && _editing.Status is PpmpStatus.Submitted or PpmpStatus.Approved or PpmpStatus.Consolidated or PpmpStatus.Superseded)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                    This PPMP is <strong>@_editing.Status</strong> and cannot be edited.
                    @if (_editing.Status is PpmpStatus.Approved or PpmpStatus.Consolidated)
                    {
                        <span> Use <strong>Amend</strong> to create a new version.</span>
                    }
                </MudAlert>
            }

            <!-- ── Details row ────────────────────────────────────────── -->
            <MudGrid Spacing="2" Class="mb-3">
                <MudItem xs="6" sm="3">
                    <MudNumericField @bind-Value="_form.FiscalYear" Label="Fiscal Year"
                                     Variant="Variant.Outlined" Min="2000" Max="2100"
                                     Disabled="_isReadOnly" />
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudSelect @bind-Value="_form.Phase" Label="PPMP Phase"
                               Variant="Variant.Outlined" T="PpmpPhase" Disabled="_isReadOnly">
                        <MudSelectItem Value="PpmpPhase.Indicative">Indicative</MudSelectItem>
                        <MudSelectItem Value="PpmpPhase.Final">Final</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudTextField @bind-Value="_form.OfficeCode" Label="Office Code"
                                  Variant="Variant.Outlined" Required="true" Disabled="_isReadOnly"
                                  HelperText="@(_orgOfficeCode != null ? "From Organization Profile" : null)" />
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudTextField @bind-Value="_form.EndUserUnit" Label="End-User / Section"
                                  Variant="Variant.Outlined" Required="true" Disabled="_isReadOnly"
                                  HelperText="@(_employeeDepartment != null ? "From your employee profile" : null)" />
                </MudItem>
            </MudGrid>

            <!-- ── Line Items (full width) ────────────────────────────── -->
            <MudItem xs="12">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                        <MudText Typo="Typo.subtitle1" Style="font-weight:600">Line Items</MudText>
                        <MudSpacer />
                        @if (!_isReadOnly)
                        {
                            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled"
                                       Color="Color.Primary" Size="Size.Small" OnClick="OpenAddItemDialog">
                                Add Item
                            </MudButton>
                        }
                    </MudStack>

                    @if (_form.Items.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">
                            @(!_isReadOnly ? "Click \"+ Add Item\" to add procurement line items." : "No items.")
                        </MudAlert>
                    }
                    else
                    {
                        <div style="overflow-x:auto">
                            <MudSimpleTable Dense="true" Hover="true" Striped="true" Style="min-width:900px">
                                <thead>
                                    <tr>
                                        <th style="width:36px">#</th>
                                        <th style="min-width:220px">Description / Objective</th>
                                        <th style="min-width:110px">Type</th>
                                        <th style="width:60px; text-align:right">Qty</th>
                                        <th style="width:70px">Unit</th>
                                        <th style="min-width:130px">Mode of Procurement</th>
                                        <th style="width:55px; text-align:center">Pre-Proc</th>
                                        <th style="width:130px; text-align:right">Est. Budget (₱)</th>
                                        @if (!_isReadOnly)
                                        {
                                            <th style="width:80px; text-align:center">Actions</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (var i = 0; i < _form.Items.Count; i++)
                                    {
                                        var idx = i;
                                        var item = _form.Items[idx];
                                        <tr>
                                            <td style="vertical-align:middle; color:var(--mud-palette-text-secondary)">
                                                @(idx + 1)
                                            </td>
                                            <td style="vertical-align:middle">
                                                <MudText Typo="Typo.body2">@item.GeneralDescription</MudText>
                                                @if (!string.IsNullOrWhiteSpace(item.Remarks))
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@item.Remarks</MudText>
                                                }
                                            </td>
                                            <td style="vertical-align:middle">
                                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Label="true">
                                                    @item.ProjectType
                                                </MudChip>
                                            </td>
                                            <td style="vertical-align:middle; text-align:right">@item.Quantity.ToString("N2")</td>
                                            <td style="vertical-align:middle">
                                                <MudText Typo="Typo.body2" Style="font-family:monospace">@item.Unit</MudText>
                                            </td>
                                            <td style="vertical-align:middle">
                                                <MudText Typo="Typo.caption">@item.ModeOfProcurement</MudText>
                                            </td>
                                            <td style="vertical-align:middle; text-align:center">
                                                @if (item.PreProcurementConference)
                                                {
                                                    <MudIcon Icon="@Icons.Material.Filled.CheckBox" Size="Size.Small" Color="Color.Success" />
                                                }
                                                else
                                                {
                                                    <MudIcon Icon="@Icons.Material.Filled.CheckBoxOutlineBlank" Size="Size.Small" Color="Color.Default" />
                                                }
                                            </td>
                                            <td style="vertical-align:middle; text-align:right; font-weight:600">
                                                ₱ @item.EstimatedBudget.ToString("N2")
                                            </td>
                                            @if (!_isReadOnly)
                                            {
                                                <td style="vertical-align:middle; text-align:center">
                                                    <MudIconButton Icon="@Icons.Material.Filled.EditNote"
                                                                   Size="Size.Small" Color="Color.Primary"
                                                                   OnClick="@(() => OpenEditItemDialog(idx))" />
                                                    <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                                                   Size="Size.Small" Color="Color.Error"
                                                                   OnClick="@(() => RemoveItem(idx))" />
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </div>

                        <MudStack Row="true" Class="mt-2 pa-2 rounded"
                                  Style="background:var(--mud-palette-background-grey)"
                                  AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.subtitle2">Total Estimated Budget</MudText>
                            <MudSpacer />
                            <MudText Typo="Typo.subtitle2" Color="Color.Primary">
                                ₱ @_form.Items.Sum(i => i.EstimatedBudget).ToString("N2")
                            </MudText>
                        </MudStack>
                    }
                </MudItem>
        </MudTabPanel>
    </MudTabs>
</MudCard>

@code {
    // ── State ────────────────────────────────────────────────────────
    private int _activeTab;
    private List<PpmpSummaryDto> _items = [];
    private List<PpmpSummaryDto> _versions = [];
    private PpmpDto? _editing;
    private bool _loading;
    private bool _busy;
    private bool _isReadOnly => _editing is not null &&
        _editing.Status is not (PpmpStatus.Draft or PpmpStatus.Returned);
    private string? _search;
    private int? _filterFiscalYear;
    private PpmpStatus? _filterStatus;
    private int _page = 1;
    private int _totalCount;
    private int _totalPages = 1;
    private const int PageSize = 15;
    private Guid _selectedVersionId;

    private string? _orgOfficeCode;
    private string? _employeeDepartment;
    private Guid _preparedById;

    private readonly int[] _fiscalYears = Enumerable.Range(DateTime.Now.Year - 2, 5).ToArray();

    // ── Master data for autocomplete ─────────────────────────────────
    private List<string> _unitCodes = [];
    private readonly HashSet<string> _usedDescriptions = new(StringComparer.OrdinalIgnoreCase);

    // ── Item dialog state ────────────────────────────────────────────
    private bool _itemDialogOpen;
    private int? _editingItemIdx;
    private PpmpItemFormModel _itemForm = new();

    // ── Form model ───────────────────────────────────────────────────
    private PpmpFormModel _form = new();

    private sealed class PpmpFormModel
    {
        public int FiscalYear { get; set; } = DateTime.Now.Year + 1;
        public PpmpPhase Phase { get; set; } = PpmpPhase.Indicative;
        public string OfficeCode { get; set; } = string.Empty;
        public string EndUserUnit { get; set; } = string.Empty;
        public List<PpmpItemFormModel> Items { get; set; } = [];
    }

    private sealed class PpmpItemFormModel
    {
        public string GeneralDescription { get; set; } = string.Empty;
        public ProjectType ProjectType { get; set; } = ProjectType.Goods;
        public decimal Quantity { get; set; } = 1;
        public string Unit { get; set; } = "LOT";
        public ModeOfProcurement ModeOfProcurement { get; set; } = ModeOfProcurement.Shopping;
        public bool PreProcurementConference { get; set; }
        public string ProcurementStart { get; set; } = $"01/{DateTime.Now.Year + 1}";
        public string ProcurementEnd { get; set; } = $"03/{DateTime.Now.Year + 1}";
        public string ExpectedDelivery { get; set; } = $"04/{DateTime.Now.Year + 1}";
        public string SourceOfFunds { get; set; } = "General Fund";
        public decimal EstimatedBudget { get; set; }
        public string Remarks { get; set; } = string.Empty;
    }

    // ── Lifecycle ────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadDefaultsAsync(), LoadUnitsAsync(), LoadAsync());
    }

    private async Task LoadDefaultsAsync()
    {
        try
        {
            var profile = await OrgProfileClient.GetAsync();
            if (!string.IsNullOrWhiteSpace(profile?.AnnexECode))
            {
                _orgOfficeCode = profile.AnnexECode;
                if (string.IsNullOrWhiteSpace(_form.OfficeCode))
                    _form.OfficeCode = _orgOfficeCode;
            }
        }
        catch { /* non-critical */ }

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var identityUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrWhiteSpace(identityUserId))
            {
                var result = await LookupClient.EmployeesGetAsync(identityUserId: identityUserId, pageSize: 1);
                var employee = result.Items?.FirstOrDefault();
                if (employee is not null)
                {
                    _preparedById = employee.Id;
                    if (!string.IsNullOrWhiteSpace(employee.DepartmentName))
                    {
                        _employeeDepartment = employee.DepartmentName;
                        if (string.IsNullOrWhiteSpace(_form.EndUserUnit))
                            _form.EndUserUnit = _employeeDepartment;
                    }
                }
            }
        }
        catch { /* non-critical */ }
    }

    private async Task LoadUnitsAsync()
    {
        try
        {
            var result = await LookupClient.UnitOfMeasuresAsync(isActive: true, pageSize: 200);
            _unitCodes = result?.Items?
                .Where(u => !string.IsNullOrWhiteSpace(u.Code))
                .Select(u => u.Code!)
                .OrderBy(c => c)
                .ToList() ?? [];
        }
        catch { /* non-critical */ }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var result = await PpmpClient.SearchAsync(
                keyword: _search, fiscalYear: _filterFiscalYear,
                status: _filterStatus, page: _page, pageSize: PageSize);
            _items = result.Items.ToList();
            _totalCount = (int)result.TotalCount;
            _totalPages = (int)Math.Ceiling(_totalCount / (double)PageSize);
        }
        catch (Exception ex) { Snackbar.Add($"Error loading PPMPs: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    // ── Navigation ───────────────────────────────────────────────────
    private void StartNew()
    {
        _editing = null;
        _versions.Clear();
        _form = new PpmpFormModel
        {
            OfficeCode = _orgOfficeCode ?? string.Empty,
            EndUserUnit = _employeeDepartment ?? string.Empty
        };
