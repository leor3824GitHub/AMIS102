                    <div style="@StepCircleStyle(step >= 3, step == 1 || step == 2)">@(step >= 3 ? "✓" : "2")</div>
                    <span style="@StepLabelStyle(step == 1 || step == 2)">Add PPMPs</span>
                </div>
                <MudDivider Style="flex:1;min-width:24px" />
