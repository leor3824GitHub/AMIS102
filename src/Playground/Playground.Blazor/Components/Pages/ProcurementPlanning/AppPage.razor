@page "/procurement-planning/apps"
@using FSH.Modules.ProcurementPlanning.Contracts.v1.AnnualProcurementPlans
@using FSH.Modules.ProcurementPlanning.Contracts.v1.Ppmps
@using FSH.Framework.Shared.Persistence
@using FSH.Playground.Blazor.ApiClient
@using FSH.Playground.Blazor.Components.Shared
@inject IAppClient AppClient
@inject IPpmpClient PpmpClient
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<FshPageHeader Title="Annual Procurement Plan (APP)"
               Description="Consolidate approved PPMPs from all offices into the Annual Procurement Plan" />

<MudCard Elevation="1">
    <MudTabs @bind-ActivePanelIndex="_activeTab" Elevation="0" Rounded="false"
             ApplyEffectsToContainer="true" PanelClass="pa-4" Color="Color.Primary">

        <!-- ══ LIST TAB ══════════════════════════════════════════════════ -->
        <MudTabPanel Text="All APPs" Icon="@Icons.Material.Outlined.ListAlt">
            <MudStack Row="true" Spacing="2" Class="mb-3" AlignItems="AlignItems.Center">
                <MudSelect Value="@_filterFiscalYear" Label="Fiscal Year" Variant="Variant.Outlined"
                           T="int?" Style="width:120px" ValueChanged="OnFilterChanged">
                    <MudSelectItem T="int?" Value="null">All FY</MudSelectItem>
                    @foreach (var fy in _fiscalYears)
                    {
                        <MudSelectItem T="int?" Value="fy">@fy</MudSelectItem>
                    }
                </MudSelect>
                <MudSelect Value="@_filterStatus" Label="Status" Variant="Variant.Outlined"
                           T="AppStatus?" Style="width:150px" ValueChanged="OnStatusFilterChanged">
                    <MudSelectItem T="AppStatus?" Value="null">All</MudSelectItem>
                    @foreach (AppStatus s in Enum.GetValues<AppStatus>())
                    {
                        <MudSelectItem T="AppStatus?" Value="s">@s</MudSelectItem>
                    }
                </MudSelect>
                <MudSpacer />
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add" OnClick="StartNew">
                    New APP
                </MudButton>
            </MudStack>

            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (_apps.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Class="mt-2">
                    No APPs found. Click <strong>+ New APP</strong> to create one for the fiscal year.
                </MudAlert>
            }
            else
            {
                <MudSimpleTable Dense="true" Hover="true" Striped="true" Style="overflow-x:auto">
                    <thead>
                        <tr>
                            <th>APP No.</th>
                            <th>FY</th>
                            <th>Revision</th>
                            <th>Ver.</th>
                            <th>Status</th>
                            <th style="text-align:right">Items</th>
                            <th style="text-align:right">Total Budget</th>
                            <th style="width:60px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in _apps)
                        {
                            <tr style="cursor:pointer" @onclick="@(() => SelectAppAsync(app.Id))">
                                <td><strong>@app.AppNumber</strong></td>
                                <td>@app.FiscalYear</td>
                                <td>
                                    <MudChip T="string" Size="Size.Small" Label="true"
                                             Color="@RevisionColor(app.RevisionType)">
                                        @app.RevisionType
                                    </MudChip>
                                </td>
                                <td>v@(app.VersionNumber)</td>
                                <td>
                                    <MudChip T="string" Size="Size.Small" Label="true"
                                             Icon="@AppStatusIcon(app.Status)"
                                             Color="@AppStatusColor(app.Status)">
                                        @app.Status
                                    </MudChip>
                                </td>
                                <td style="text-align:right">@app.ItemCount</td>
                                <td style="text-align:right; font-weight:600">₱ @app.TotalEstimatedBudget.ToString("N2")</td>
                                <td @onclick:stopPropagation="true">
                                    <MudIconButton Icon="@Icons.Material.Outlined.OpenInNew" Size="Size.Small"
                                                   Color="Color.Primary"
                                                   OnClick="@(() => SelectAppAsync(app.Id))" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>

                <MudStack Row="true" Class="mt-2" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.caption">@_totalCount total</MudText>
                    <MudSpacer />
                    <MudPagination Selected="@_page" Count="_totalPages" SelectedChanged="OnPageChanged" />
                </MudStack>
            }
        </MudTabPanel>

        <!-- ══ EDITOR TAB ════════════════════════════════════════════════ -->
        <MudTabPanel Text="@(_editing is null ? "+ New APP" : _editing.AppNumber)"
                     Icon="@(_editing is null ? Icons.Material.Outlined.Add : Icons.Material.Outlined.Edit)">

            <!-- ── Action bar ─────────────────────────────────────────── -->
            <MudPaper Elevation="0" Class="pa-3 mb-4 rounded"
                      Style="background:var(--mud-palette-background-grey); border:1px solid var(--mud-palette-lines-default)">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                    @if (_editing is not null)
                    {
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.subtitle1" Style="font-weight:700">@_editing.AppNumber</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                FY @_editing.FiscalYear · v@(_editing.VersionNumber) · @_editing.RevisionType
                            </MudText>
                        </MudStack>
                        <MudChip T="string" Size="Size.Small" Label="true"
                                 Icon="@AppStatusIcon(_editing.Status)"
                                 Color="@AppStatusColor(_editing.Status)">
                            @_editing.Status
                        </MudChip>
                    }
                    else
                    {
                        <MudText Typo="Typo.subtitle1" Style="font-weight:700">New APP</MudText>
                    }

                    @if (_versions.Count > 1)
                    {
                        <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
                        <MudChipSet T="Guid" @bind-SelectedValue="_selectedVersionId"
                                    SelectionMode="SelectionMode.SingleSelection">
                            @foreach (var v in _versions)
                            {
                                <MudChip T="Guid" Value="v.Id" Size="Size.Small"
                                         Color="@(v.IsCurrentVersion ? Color.Primary : Color.Default)"
                                         OnClick="@(() => LoadVersionAsync(v.Id))">
                                    v@(v.VersionNumber) · @v.Status
                                </MudChip>
                            }
                        </MudChipSet>
                    }

                    <MudSpacer />

                    @if (_editing is not null && _editing.Status == AppStatus.Draft && _editing.Items.Count > 0)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Publish"
                                   OnClick="ShowPublishConfirmAsync" Disabled="_busy">
                            Publish APP
                        </MudButton>
                    }
                    @if (_editing is not null &&
                         _editing.Status is AppStatus.Published or AppStatus.Approved &&
                         _editing.IsCurrentVersion)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Edit"
                                   OnClick="ShowAmendDialogAsync" Disabled="_busy">
                            Amend
                        </MudButton>
                    }
                    <MudButton Variant="Variant.Text" Size="Size.Small"
                               OnClick="ClearForm" Disabled="_busy">
                        Close
                    </MudButton>
                </MudStack>
            </MudPaper>

            <!-- ── Workflow progress ──────────────────────────────────── -->
            @{
                var step = _editing is null ? 0
                    : _editing.Status == AppStatus.Draft ? (_editing.Items.Count == 0 ? 1 : 2)
                    : 3;
            }
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0" Class="mb-4">
                @StepBadge(1, "Create Draft", step >= 1, step == 0)
                <MudDivider Style="flex:1;min-width:24px" />
                @StepBadge(2, "Add PPMPs", step >= 3, step == 1 || step == 2)
                <MudDivider Style="flex:1;min-width:24px" />
                @StepBadge(3, "Publish", step == 3, step == 2)
            </MudStack>

            <!-- ── Step 0: Create new APP ─────────────────────────────── -->
            @if (_editing is null)
            {
                <MudGrid Spacing="3" Justify="Justify.Center">
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="2">
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight:600">
                                    APP Details
                                </MudText>
                                <MudStack Spacing="3">
                                    <MudNumericField @bind-Value="_form.FiscalYear" Label="Fiscal Year"
                                                     Variant="Variant.Outlined" Min="2000" Max="2100" />
                                    <MudSelect @bind-Value="_form.RevisionType" Label="Revision Type"
                                               Variant="Variant.Outlined" T="AppRevisionType">
                                        <MudSelectItem Value="AppRevisionType.Original">Original</MudSelectItem>
                                        <MudSelectItem Value="AppRevisionType.Supplemental">Supplemental</MudSelectItem>
                                        <MudSelectItem Value="AppRevisionType.Revised">Revised</MudSelectItem>
                                    </MudSelect>
                                    <MudAlert Severity="Severity.Info" Dense="true">
                                        After creating the draft, you will select which approved PPMPs to include.
                                    </MudAlert>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                               StartIcon="@Icons.Material.Filled.CreateNewFolder"
                                               OnClick="CreateAppAsync" Disabled="_busy">
                                        @if (_busy) { <MudProgressCircular Size="Size.Small" Class="mr-1" Indeterminate="true" /> }
                                        Create APP Draft
                                    </MudButton>
                                </MudStack>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                </MudGrid>
            }

            <!-- ── Step 1 & 2: Draft — consolidate PPMPs ─────────────── -->
            else if (_editing.Status == AppStatus.Draft)
            {
                <MudGrid Spacing="3">
                    <!-- Available PPMPs -->
                    <MudItem xs="12" md="5">
                        <MudCard Elevation="1" Style="height:100%">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudText Typo="Typo.subtitle2" Style="font-weight:600">
                                            Available Approved PPMPs
                                        </MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">— FY @_editing.FiscalYear</MudText>
                                        <MudSpacer />
                                        <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                                                       OnClick="LoadAvailablePpmpsAsync" Disabled="_busy" />
                                    </MudStack>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent Class="pa-0">
                                @if (_availablePpmps.Count == 0)
                                {
                                    <div Class="pa-4">
                                        <MudAlert Severity="Severity.Info" Dense="true">
                                            Click refresh to load approved PPMPs for FY @_editing.FiscalYear.
                                        </MudAlert>
                                    </div>
                                }
                                else
                                {
                                    <MudList T="SelectablePpmp" Dense="true">
                                        @foreach (var ppmp in _availablePpmps)
                                        {
                                            <MudListItem T="SelectablePpmp">
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                    <MudCheckBox @bind-Value="ppmp.Selected" Dense="true" Color="Color.Primary" />
                                                    <MudStack Spacing="0" Style="flex:1; min-width:0">
                                                        <MudText Typo="Typo.body2" Style="font-weight:600">@ppmp.PpmpNumber</MudText>
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                            @ppmp.EndUserUnit
                                                        </MudText>
                                                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="mt-1">
                                                            <MudChip T="string" Size="Size.Small" Label="true"
                                                                     Style="font-family:monospace; font-size:10px">
                                                                @ppmp.OfficeCode
                                                            </MudChip>
                                                            <MudText Typo="Typo.caption">@ppmp.ItemCount items</MudText>
                                                            <MudSpacer />
                                                            <MudText Typo="Typo.caption" Style="font-weight:600; color:var(--mud-palette-primary)">
                                                                ₱ @ppmp.TotalEstimatedBudget.ToString("N0")
                                                            </MudText>
                                                        </MudStack>
                                                    </MudStack>
                                                </MudStack>
                                            </MudListItem>
                                            <MudDivider />
                                        }
                                    </MudList>
                                }
                            </MudCardContent>
                            @if (_availablePpmps.Any(p => p.Selected))
                            {
                                <MudCardActions>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                               StartIcon="@Icons.Material.Filled.MergeType"
                                               OnClick="ConsolidateAsync" Disabled="_busy">
                                        @if (_busy) { <MudProgressCircular Size="Size.Small" Class="mr-1" Indeterminate="true" /> }
                                        Add @_availablePpmps.Count(p => p.Selected) Selected to APP
                                    </MudButton>
                                </MudCardActions>
                            }
                        </MudCard>
                    </MudItem>

                    <!-- Consolidated items -->
                    <MudItem xs="12" md="7">
                        <MudCard Elevation="1" Style="height:100%">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudText Typo="Typo.subtitle2" Style="font-weight:600">
                                            Consolidated Items
                                        </MudText>
                                        @if (_editing.Items.Count > 0)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Label="true">
                                                @_editing.Items.Count
                                            </MudChip>
                                        }
                                        <MudSpacer />
                                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Style="font-weight:700">
                                            ₱ @_editing.TotalEstimatedBudget.ToString("N2")
                                        </MudText>
                                    </MudStack>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent Class="pa-0">
                                @if (_editing.Items.Count == 0)
                                {
                                    <div Class="pa-4">
                                        <MudAlert Severity="Severity.Info" Dense="true">
                                            No items yet — select PPMPs from the left panel and click <strong>Add to APP</strong>.
                                        </MudAlert>
                                    </div>
                                }
                                else
                                {
                                    <div style="overflow-x:auto">
                                        <MudSimpleTable Dense="true" Hover="true" Striped="true" Style="min-width:500px">
                                            <thead>
                                                <tr>
                                                    <th style="width:36px">#</th>
                                                    <th>Office</th>
                                                    <th style="min-width:180px">Description</th>
                                                    <th>Type</th>
                                                    <th style="text-align:right">Qty</th>
                                                    <th>Unit</th>
                                                    <th style="text-align:right">Budget (₱)</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in _editing.Items)
                                                {
                                                    <tr>
                                                        <td style="color:var(--mud-palette-text-secondary)">@item.ItemNo</td>
                                                        <td>
                                                            <MudChip T="string" Size="Size.Small" Label="true"
                                                                     Style="font-family:monospace; font-size:10px">
                                                                @item.OfficeCode
                                                            </MudChip>
                                                        </td>
                                                        <td>
                                                            <MudText Typo="Typo.body2">@item.GeneralDescription</MudText>
                                                        </td>
                                                        <td>
                                                            <MudChip T="string" Size="Size.Small" Label="true">@item.ProjectType</MudChip>
                                                        </td>
                                                        <td style="text-align:right">@item.Quantity.ToString("N2")</td>
                                                        <td style="font-family:monospace">@item.Unit</td>
                                                        <td style="text-align:right; font-weight:600">
                                                            ₱ @item.EstimatedBudget.ToString("N2")
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </MudSimpleTable>
                                    </div>
                                }
                            </MudCardContent>
                            @if (_editing.Items.Count > 0)
                            {
                                <MudCardActions Class="pa-3">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Style="width:100%">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            Ready to publish? This locks the APP.
                                        </MudText>
                                        <MudSpacer />
                                        <MudButton Variant="Variant.Filled" Color="Color.Success"
                                                   StartIcon="@Icons.Material.Filled.Publish"
                                                   OnClick="ShowPublishConfirmAsync" Disabled="_busy">
                                            Publish APP
                                        </MudButton>
                                    </MudStack>
                                </MudCardActions>
                            }
                        </MudCard>
                    </MudItem>
                </MudGrid>
            }

            <!-- ── Step 3: Published / Approved — read-only view ─────── -->
            else
            {
                <MudCard Elevation="1">
                    <MudCardContent>
                        <MudGrid Spacing="2" Class="mb-3">
                            <MudItem xs="6" sm="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Fiscal Year</MudText>
                                <MudText Typo="Typo.body1" Style="font-weight:600">@_editing.FiscalYear</MudText>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Revision Type</MudText>
                                <MudText Typo="Typo.body1">@_editing.RevisionType</MudText>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Total Items</MudText>
                                <MudText Typo="Typo.body1" Style="font-weight:600">@_editing.Items.Count</MudText>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Total Budget</MudText>
                                <MudText Typo="Typo.body1" Style="font-weight:700; color:var(--mud-palette-primary)">
                                    ₱ @_editing.TotalEstimatedBudget.ToString("N2")
                                </MudText>
                            </MudItem>
                        </MudGrid>

                        <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight:600">
                            All Line Items (@_editing.Items.Count)
                        </MudText>
                        <div style="overflow-x:auto">
                            <MudSimpleTable Dense="true" Hover="true" Striped="true" Style="min-width:600px">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Office</th>
                                        <th>Description</th>
                                        <th>Type</th>
                                        <th style="text-align:right">Qty</th>
                                        <th>Unit</th>
                                        <th>Mode</th>
                                        <th>Period</th>
                                        <th style="text-align:right">Budget (₱)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in _editing.Items)
                                    {
                                        <tr>
                                            <td>@item.ItemNo</td>
                                            <td>
                                                <MudChip T="string" Size="Size.Small" Label="true"
                                                         Style="font-family:monospace; font-size:10px">
                                                    @item.OfficeCode
                                                </MudChip>
                                            </td>
                                            <td>@item.GeneralDescription</td>
                                            <td><MudChip T="string" Size="Size.Small" Label="true">@item.ProjectType</MudChip></td>
                                            <td style="text-align:right">@item.Quantity.ToString("N2")</td>
                                            <td style="font-family:monospace">@item.Unit</td>
                                            <td><MudText Typo="Typo.caption">@item.ModeOfProcurement</MudText></td>
                                            <td>
                                                <MudText Typo="Typo.caption">@item.ProcurementStart – @item.ProcurementEnd</MudText>
                                            </td>
                                            <td style="text-align:right; font-weight:600">₱ @item.EstimatedBudget.ToString("N2")</td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        </div>
                    </MudCardContent>
                </MudCard>
            }

        </MudTabPanel>
    </MudTabs>
</MudCard>

@code {
    private int _activeTab;
    private List<AnnualProcurementPlanSummaryDto> _apps = [];
    private List<AnnualProcurementPlanSummaryDto> _versions = [];
    private AnnualProcurementPlanDto? _editing;
    private List<SelectablePpmp> _availablePpmps = [];
    private bool _loading;
    private bool _busy;
    private int? _filterFiscalYear;
    private AppStatus? _filterStatus;
    private int _page = 1;
    private int _totalCount;
    private int _totalPages = 1;
    private const int PageSize = 15;
    private Guid _selectedVersionId;

    private readonly int[] _fiscalYears = Enumerable.Range(DateTime.Now.Year - 2, 5).ToArray();

    private sealed class SelectablePpmp
    {
        public Guid Id { get; init; }
        public string PpmpNumber { get; init; } = string.Empty;
        public string OfficeCode { get; init; } = string.Empty;
        public string EndUserUnit { get; init; } = string.Empty;
        public int ItemCount { get; init; }
        public decimal TotalEstimatedBudget { get; init; }
        public bool Selected { get; set; }
    }

    private sealed class AppFormModel
    {
        public int FiscalYear { get; set; } = DateTime.Now.Year + 1;
        public AppRevisionType RevisionType { get; set; } = AppRevisionType.Original;
    }

    private AppFormModel _form = new();

    protected override async Task OnInitializedAsync() => await LoadAppsAsync();

    private void StartNew()
    {
        _editing = null;
        _versions.Clear();
        _availablePpmps.Clear();
        _form = new AppFormModel();
        _activeTab = 1;
    }

    private async Task LoadAppsAsync()
    {
        _loading = true;
        try
        {
            var result = await AppClient.SearchAsync(
                fiscalYear: _filterFiscalYear, status: _filterStatus,
                page: _page, pageSize: PageSize);
            _apps = result.Items.ToList();
            _totalCount = (int)result.TotalCount;
            _totalPages = (int)Math.Ceiling(_totalCount / (double)PageSize);
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task SelectAppAsync(Guid id)
    {
        _busy = true;
        try
        {
            _editing = await AppClient.GetAsync(id);
            if (_editing is null) return;
            _selectedVersionId = _editing.Id;
            _versions = (await AppClient.SearchAsync(currentOnly: false, fiscalYear: _editing.FiscalYear)).Items
                .Where(a => a.VersionChainId == _editing.VersionChainId)
                .OrderBy(a => a.VersionNumber)
                .ToList();
            _availablePpmps.Clear();
            _activeTab = 1;
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _busy = false; }
    }

    private async Task LoadVersionAsync(Guid id)
    {
        if (id == _editing?.Id) return;
        _busy = true;
        try
        {
            _editing = await AppClient.GetAsync(id);
            _availablePpmps.Clear();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _busy = false; }
    }

    private void ClearForm()
    {
        _form = new AppFormModel();
        _editing = null;
        _versions.Clear();
        _availablePpmps.Clear();
        _activeTab = 0;
    }

    private async Task CreateAppAsync()
    {
        _busy = true;
        try
        {
            _editing = await AppClient.CreateAsync(
                new CreateAnnualProcurementPlanCommand(_form.FiscalYear, _form.RevisionType));
            Snackbar.Add($"APP {_editing.AppNumber} created. Now add approved PPMPs.", Severity.Success);
            await LoadAppsAsync();
            await LoadAvailablePpmpsAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _busy = false; }
    }

    private async Task LoadAvailablePpmpsAsync()
    {
        if (_editing is null) return;
        _busy = true;
        try
        {
            var list = await AppClient.GetAvailablePpmpsAsync(_editing.FiscalYear);
            _availablePpmps = list.Select(p => new SelectablePpmp
            {
                Id = p.Id,
                PpmpNumber = p.PpmpNumber,
                OfficeCode = p.OfficeCode,
                EndUserUnit = p.EndUserUnit,
                ItemCount = p.ItemCount,
                TotalEstimatedBudget = p.TotalEstimatedBudget,
                Selected = false
            }).ToList();
            if (_availablePpmps.Count == 0)
                Snackbar.Add($"No approved PPMPs available for FY {_editing.FiscalYear}.", Severity.Warning);
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _busy = false; }
    }

    private async Task ConsolidateAsync()
    {
        if (_editing is null) return;
        var ids = _availablePpmps.Where(p => p.Selected).Select(p => p.Id).ToList();
        if (ids.Count == 0) return;
        _busy = true;
        try
        {
            _editing = await AppClient.ConsolidateAsync(_editing.Id, ids);
            Snackbar.Add($"Added {ids.Count} PPMP(s) — {_editing.Items.Count} total items now in APP.", Severity.Success);
            _availablePpmps.RemoveAll(p => p.Selected);
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _busy = false; }
    }

    private async Task ShowPublishConfirmAsync()
    {
        if (_editing is null) return;
        var confirmed = await DialogService.ShowMessageBox(
            "Publish APP",
            $"Publish {_editing.AppNumber}?\n\nThis will lock the APP. Further changes require creating an amendment.",
            yesText: "Publish", cancelText: "Cancel");
        if (confirmed != true) return;

        _busy = true;
        try
        {
            _editing = await AppClient.PublishAsync(_editing.Id);
            Snackbar.Add($"{_editing.AppNumber} published successfully.", Severity.Success);
            await LoadAppsAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _busy = false; }
    }

    private async Task ShowAmendDialogAsync()
    {
        if (_editing is null) return;
        var parameters = new DialogParameters<AmendAppDialog>
        {
            { x => x.DocumentNumber, _editing.AppNumber },
            { x => x.CurrentVersion, _editing.VersionNumber }
        };
        var dialog = await DialogService.ShowAsync<AmendAppDialog>("Amend APP", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false } && result.Data is (string reason, AppRevisionType revType))
        {
            _busy = true;
            try
            {
                _editing = await AppClient.AmendAsync(_editing.Id, reason, revType);
                _versions = (await AppClient.SearchAsync(currentOnly: false, fiscalYear: _editing.FiscalYear)).Items
                    .Where(a => a.VersionChainId == _editing.VersionChainId)
                    .OrderBy(a => a.VersionNumber)
                    .ToList();
                _selectedVersionId = _editing.Id;
                Snackbar.Add($"Amendment v{_editing.VersionNumber} created.", Severity.Success);
                await LoadAppsAsync();
                await LoadAvailablePpmpsAsync();
            }
            catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
            finally { _busy = false; }
        }
    }

    private async Task OnFilterChanged(int? val) { _filterFiscalYear = val; _page = 1; await LoadAppsAsync(); }
    private async Task OnStatusFilterChanged(AppStatus? val) { _filterStatus = val; _page = 1; await LoadAppsAsync(); }
    private async Task OnPageChanged(int page) { _page = page; await LoadAppsAsync(); }

    private static Color AppStatusColor(AppStatus s) => s switch
    {
        AppStatus.Draft      => Color.Default,
        AppStatus.Published  => Color.Success,
        AppStatus.Approved   => Color.Primary,
        AppStatus.Superseded => Color.Warning,
        _                    => Color.Default
    };

    private static string AppStatusIcon(AppStatus s) => s switch
    {
        AppStatus.Draft      => Icons.Material.Outlined.EditNote,
        AppStatus.Published  => Icons.Material.Filled.CheckCircle,
        AppStatus.Approved   => Icons.Material.Filled.LibraryAddCheck,
        AppStatus.Superseded => Icons.Material.Outlined.History,
        _                    => Icons.Material.Outlined.Circle
    };

    private RenderFragment StepBadge(int number, string label, bool done, bool active) => __builder =>
    {
        var color = done ? "var(--mud-palette-success)" : active ? "var(--mud-palette-primary)" : "var(--mud-palette-lines-default)";
        var textColor = (done || active) ? "#fff" : "var(--mud-palette-text-secondary)";
        __builder.AddMarkupContent(0, $"""
            <div style="display:flex;flex-direction:column;align-items:center;gap:2px;min-width:72px">
                <div style="width:28px;height:28px;border-radius:50%;background:{color};display:flex;align-items:center;justify-content:center;font-weight:700;font-size:12px;color:{textColor}">
                    {(done ? "✓" : number.ToString())}
                </div>
                <span style="font-size:11px;white-space:nowrap;color:{(active ? "var(--mud-palette-primary)" : "var(--mud-palette-text-secondary)")}">
                    {label}
                </span>
            </div>
            """);
    };

    private static Color RevisionColor(AppRevisionType t) => t switch
    {
        AppRevisionType.Original     => Color.Default,
        AppRevisionType.Supplemental => Color.Info,
        AppRevisionType.Revised      => Color.Warning,
        _                            => Color.Default
    };
}
