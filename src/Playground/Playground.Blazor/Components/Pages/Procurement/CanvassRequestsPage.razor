@page "/procurement/canvass-requests"
@using AMIS.Playground.Blazor.Components.Pages.Procurement
@using AMIS.Modules.ProcurementAcquisition.Contracts.v1.Canvass
@using AMIS.Modules.ProcurementAcquisition.Contracts.v1.PurchaseRequests
@using AMIS.Framework.Shared.Persistence
@using AMIS.Playground.Blazor.ApiClient
@inject ICanvassRequestClient Client
@inject IPurchaseRequestClient PurchaseRequestClient
@inject IMaster_dataClient MasterDataClient
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Nav

<AMISPageHeader Title="Canvass Requests (RIV)" Description="Request for Issuance of Voucher • manage supplier quotations and award" />

<MudGrid Spacing="3">
    <!-- Create Form -->
    <MudItem xs="12" md="4">
        <MudCard Elevation="1">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-3">New Canvass Request</MudText>
                <MudStack Spacing="2">
                    <MudAutocomplete T="PurchaseRequestSummaryDto"
                                     Value="_selectedPurchaseRequest"
                                     ValueChanged="OnPurchaseRequestChanged"
                                     SearchFunc="SearchPurchaseRequests"
                                     ToStringFunc="FormatPurchaseRequest"
                                     Label="Purchase Request"
                                     Variant="Variant.Outlined"
                                     Placeholder="Search PR number or purpose..."
                                     Required="true"
                                     Clearable="true"
                                     CoerceValue="true"
                                     ResetValueOnEmptyText="true" />
                    <MudDatePicker @bind-Date="_returnDeadlineNullable" Label="Return Deadline"
                                   Variant="Variant.Outlined" Required="true" DateFormat="MM/dd/yyyy" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                               OnClick="CreateAsync" Disabled="_busy">
                        @if (_busy) { <MudProgressCircular Size="Size.Small" Class="mr-1" Indeterminate="true" /> }
                        Create Canvass Request
                    </MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>

        <!-- Add Quotation Dialog Trigger (shows when a request is selected) -->
        @if (_selected is not null)
        {
            <MudCard Elevation="1" Class="mt-3">
                <MudCardContent>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                        <MudText Typo="Typo.h6" Class="flex-grow-1">Add Quotation</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@_selected.RivNumber</MudText>
                    </MudStack>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="OpenQuotationDialog">
                        Add Quotation
                    </MudButton>
                    <MudButton Variant="Variant.Text" FullWidth="true" OnClick="@(() => _selected = null)">
                        Deselect Request
                    </MudButton>
                </MudCardContent>
            </MudCard>
        }

    </MudItem>

    <!-- List Panel -->
    <MudItem xs="12" md="8">
        <MudCard Elevation="1">
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                    <MudText Typo="Typo.h6" Class="flex-grow-1">Canvass Requests</MudText>
                    <MudTextField @bind-Value="_keyword" Label="Search" Variant="Variant.Outlined" Size="Size.Small"
                                  Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                                  Style="max-width:220px" DebounceInterval="400"
                                  OnDebounceIntervalElapsed="@(async () => await LoadAsync())" />
                </MudStack>

                <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" Class="mb-3">
                    @foreach (var s in _statusFilters)
                    {
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(_statusFilter == s ? Color.Primary : Color.Default)"
                                 OnClick="@(() => SetStatusFilter(s))">@s</MudChip>
                    }
                </MudStack>

                @if (!_loaded)
                {
                    <MudProgressLinear Indeterminate="true" />
                }
                else if (_items.Count == 0)
                {
                    <MudAlert Severity="Severity.Info">No canvass requests found.</MudAlert>
                }
                else
                {
                    <MudSimpleTable Dense="true" Hover="true" Striped="true">
                        <thead>
                            <tr>
                                <th>RIV #</th>
                                <th>PR #</th>
                                <th>Deadline</th>
                                <th>Quotations</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _items)
                            {
                                var isSelected = _selected?.Id == item.Id;
                                <tr style="@(isSelected ? "background:var(--mud-palette-primary-lighten)" : "")">
                                    <td><b>@item.RivNumber</b></td>
                                    <td>@item.PrNumber</td>
                                    <td>@item.ReturnDeadline.ToString("MM/dd/yyyy")</td>
                                    <td>@item.QuotationCount</td>
                                    <td>@CanvassStatusChip(item.Status)</td>
                                    <td>
                                        <MudStack Row="true" Spacing="0">
                                            <MudTooltip Text="Manage Quotations">
                                                <MudIconButton Icon="@Icons.Material.Filled.RequestQuote" Size="Size.Small"
                                                               Color="Color.Primary"
                                                               OnClick="@(async () => await SelectCanvass(item.Id))" />
                                            </MudTooltip>
                                            @if (item.Status == CanvassRequestStatus.Open && item.QuotationCount > 0)
                                            {
                                                <MudTooltip Text="Award to Supplier">
                                                    <MudIconButton Icon="@Icons.Material.Filled.EmojiEvents" Size="Size.Small"
                                                                   Color="Color.Success"
                                                                   OnClick="@(async () => await AwardAsync(item.Id))" />
                                                </MudTooltip>
                                            }
                                            @if (item.Status == CanvassRequestStatus.Awarded)
                                            {
                                                <MudTooltip Text="Create Purchase Order from awarded quotation">
                                                    <MudIconButton Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Small"
                                                                   Color="Color.Primary"
                                                                   OnClick="@(() => GoToPurchaseOrder(item.Id))" />
                                                </MudTooltip>
                                            }
                                        </MudStack>
                                    </td>
                                </tr>
                                <!-- Inline quotation list if selected -->
                                @if (isSelected && _selectedDetail is not null)
                                {
                                    <tr>
                                        <td colspan="6">
                                            <MudPaper Outlined="true" Class="pa-3 ma-1">
                                                <MudText Typo="Typo.subtitle2" Class="mb-2">Quotations for @_selectedDetail.RivNumber</MudText>
                                                @if (_selectedDetail.Quotations.Count == 0)
                                                {
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">No quotations yet. Add one using the form on the left.</MudText>
                                                }
                                                else
                                                {
                                                    <MudSimpleTable Dense="true" Hover="true">
                                                        <thead>
                                                            <tr>
                                                                <th>Supplier</th>
                                                                <th>Date</th>
                                                                <th style="text-align:right">Total</th>
                                                                <th>Terms</th>
                                                                <th>Awarded</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var q in _selectedDetail.Quotations)
                                                            {
                                                                <tr>
                                                                    <td>
                                                                        <MudText Typo="Typo.body2"><b>@q.SupplierName</b></MudText>
                                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@q.SupplierAddress</MudText>
                                                                    </td>
                                                                    <td>@q.QuotationDate.ToString("MM/dd/yyyy")</td>
                                                                    <td style="text-align:right">₱@q.LineItems.Sum(li => li.Total).ToString("N2")</td>
                                                                    <td>@(q.DeliveryTerms ?? "—")</td>
                                                                    <td>
                                                                        @if (q.IsAwarded)
                                                                        {
                                                                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                                                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.Star">Awarded</MudChip>
                                                                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                                                                           StartIcon="@Icons.Material.Filled.ShoppingCart"
                                                                                           OnClick="@(() => GoToPurchaseOrder(_selectedDetail.Id))">
                                                                                    Create PO
                                                                                </MudButton>
                                                                            </MudStack>
                                                                        }
                                                                        else if (_selectedDetail.Status == CanvassRequestStatus.Open)
                                                                        {
                                                                            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Success"
                                                                                       OnClick="@(async () => await AwardToQuotation(_selectedDetail.Id, q.Id))">
                                                                                Award
                                                                            </MudButton>
                                                                        }
                                                                    </td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </MudSimpleTable>
                                                }
                                            </MudPaper>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </MudSimpleTable>

                    @if (_totalCount > _pageSize)
                    {
                        <MudStack Row="true" JustifyContent="JustifyContent.Center" Class="mt-3">
                            <MudPagination Count="@((_totalCount + _pageSize - 1) / _pageSize)"
                                           Selected="_page" SelectedChanged="@(async p => { _page = p; await LoadAsync(); })" />
                        </MudStack>
                    }
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private List<CanvassRequestSummaryDto> _items = [];
    private CanvassRequestDto? _selected, _selectedDetail;
    private PurchaseRequestSummaryDto? _selectedPurchaseRequest;
    private DateTime? _returnDeadlineNullable;
    private bool _busy, _loaded;
    private string _keyword = string.Empty;
    private string _statusFilter = "All";
    private int _page = 1, _pageSize = 15, _totalCount;

    private static readonly string[] _statusFilters = ["All", "Open", "Evaluated", "Awarded", "Cancelled"];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task<IEnumerable<PurchaseRequestSummaryDto>> SearchPurchaseRequests(string value, CancellationToken token)
    {
        try
        {
            var result = await PurchaseRequestClient.SearchAsync(
                keyword: string.IsNullOrWhiteSpace(value) ? null : value,
                status: null,
                page: 1,
                pageSize: 20);

            return result.Items ?? Enumerable.Empty<PurchaseRequestSummaryDto>();
        }
        catch
        {
            return Enumerable.Empty<PurchaseRequestSummaryDto>();
        }
    }

    private Task OnPurchaseRequestChanged(PurchaseRequestSummaryDto? request)
    {
        _selectedPurchaseRequest = request;
        return Task.CompletedTask;
    }

    private static string FormatPurchaseRequest(PurchaseRequestSummaryDto? request)
    {
        if (request is null)
        {
            return string.Empty;
        }

        return string.IsNullOrWhiteSpace(request.Purpose)
            ? request.PrNumber
            : $"{request.PrNumber} - {request.Purpose}";
    }

    private async Task OpenQuotationDialog()
    {
        if (_selected is null) return;

        var parameters = new DialogParameters
        {
            [nameof(CanvassQuotationDialog.CanvassRequestId)] = _selected.Id,
            [nameof(CanvassQuotationDialog.PurchaseRequestId)] = _selected.PurchaseRequestId,
            [nameof(CanvassQuotationDialog.Form)] = new QuotationForm()
        };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CanvassQuotationDialog>("Add Quotation", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await SelectCanvass(_selected.Id);
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _loaded = false;
        try
        {
            CanvassRequestStatus? filter = _statusFilter == "All" ? null : Enum.Parse<CanvassRequestStatus>(_statusFilter);
            var result = await Client.SearchAsync(_keyword, filter, _page, _pageSize);
            _items = result.Items?.ToList() ?? [];
            _totalCount = (int)result.TotalCount;
        }
        catch (Exception ex) { Snackbar.Add($"Load failed: {ex.Message}", Severity.Error); }
        finally { _loaded = true; }
    }

    private async Task SetStatusFilter(string s) { _statusFilter = s; _page = 1; await LoadAsync(); }

    private async Task CreateAsync()
    {
        if (_selectedPurchaseRequest is null || !_returnDeadlineNullable.HasValue)
        {
            Snackbar.Add("Select a purchase request and return deadline.", Severity.Warning);
            return;
        }
        _busy = true;
        try
        {
            await Client.CreateAsync(new CreateCanvassRequestCommand(_selectedPurchaseRequest.Id, DateOnly.FromDateTime(_returnDeadlineNullable.Value)));
            Snackbar.Add("Canvass request created.", Severity.Success);
            _selectedPurchaseRequest = null;
            _returnDeadlineNullable = null;
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Failed: {ex.Message}", Severity.Error); }
        finally { _busy = false; }
    }

    private async Task SelectCanvass(Guid id)
    {
        var detail = await Client.GetAsync(id);
        if (detail is null) { Snackbar.Add("Canvass request not found.", Severity.Error); return; }
        _selected = detail;
        _selectedDetail = detail;
    }

    private async Task AwardAsync(Guid canvassId)
    {
        var detail = await Client.GetAsync(canvassId);
        if (detail is null || detail.Quotations.Count == 0) { Snackbar.Add("No quotations to award.", Severity.Warning); return; }
        // Award to the lowest-priced quotation
        var lowest = detail.Quotations.OrderBy(q => q.LineItems.Sum(li => li.Total)).First();
        await AwardToQuotation(canvassId, lowest.Id);
    }

    private async Task AwardToQuotation(Guid canvassId, Guid quotationId)
    {
        var ok = await DialogService.ShowMessageBox("Award Canvass", "Award this canvass to the selected supplier?", "Award", cancelText: "Cancel");
        if (ok is not true) return;
        _busy = true;
        try
        {
            await Client.AwardAsync(canvassId, quotationId);
            Snackbar.Add("Canvass awarded.", Severity.Success);
            if (_selected?.Id == canvassId) await SelectCanvass(canvassId);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Award failed: {ex.Message}", Severity.Error); }
        finally { _busy = false; }
    }

    private void GoToPurchaseOrder(Guid canvassId) =>
        Nav.NavigateTo($"/procurement/purchase-orders?canvassId={canvassId}");

    private static RenderFragment CanvassStatusChip(CanvassRequestStatus status) => __builder =>
    {
        var (color, icon) = status switch
        {
            CanvassRequestStatus.Open => (Color.Info, Icons.Material.Filled.HourglassTop),
            CanvassRequestStatus.Evaluated => (Color.Warning, Icons.Material.Filled.Assessment),
            CanvassRequestStatus.Awarded => (Color.Success, Icons.Material.Filled.EmojiEvents),
            CanvassRequestStatus.Cancelled => (Color.Error, Icons.Material.Filled.Cancel),
            _ => (Color.Default, Icons.Material.Filled.Help)
        };
        __builder.OpenComponent<MudChip<string>>(0);
        __builder.AddAttribute(1, "Size", Size.Small);
        __builder.AddAttribute(2, "Color", color);
        __builder.AddAttribute(3, "Icon", icon);
        __builder.AddAttribute(4, "ChildContent", (RenderFragment)(b => b.AddContent(0, status.ToString())));
        __builder.CloseComponent();
    };

    // QuotationForm and QLineItemRow moved to QuotationForm.cs for sharing with dialog
}

