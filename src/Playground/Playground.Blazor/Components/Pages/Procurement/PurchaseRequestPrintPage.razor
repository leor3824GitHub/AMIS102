    <div class="pr-page pr-screen" id="pr-exhibit4">
        @{
            var _org = OrgProfileState.Profile;
            var screenRows = Math.Max(20, _pr.LineItems.Count);
        }
        @if (_org is not null)
        {
            <div style="text-align:center; margin-bottom:6px; line-height:1.4;">
                <div style="font-size:11px;">Republic of the Philippines</div>
                <div style="font-size:13px; font-weight:700;">@_org.Name</div>
                @if (!string.IsNullOrWhiteSpace(_org.ShortName))
                {
                    <div style="font-size:11px;">(@_org.ShortName)</div>
                }
                @if (!string.IsNullOrWhiteSpace(_org.Address))
                {
                    <div style="font-size:11px;">@_org.Address</div>
                }
            </div>
        }
        <div class="pr-exhibit">Exhibit 4</div>
        <div class="pr-title">PURCHASE REQUEST</div>

        <div class="pr-form">
            <div class="pr-header">
                <div class="pr-header-cell">
                    <div class="pr-header-label">Name of Department/<br />Office/Section:</div>
                    <div class="pr-header-value">@_pr.DepartmentName@(string.IsNullOrWhiteSpace(_pr.ResponsibilityCenterCode) ? "" : $" / {_pr.ResponsibilityCenterCode}")</div>
                </div>
                <div class="pr-header-cell">
                    <div class="pr-header-label">PR No.</div>
                    <div class="pr-header-value">@_pr.PrNumber</div>
                    <div class="pr-header-label" style="margin-top:4px">Responsibility Center Code :</div>
                    <div class="pr-header-value">&nbsp;</div>
                </div>
                <div class="pr-header-cell">
                    <div class="pr-header-label">Date :</div>
                    <div class="pr-header-value">@_pr.PrDate.ToString("MM/dd/yyyy")</div>
                </div>
            </div>

            <table class="pr-table">
                <thead>
                    <tr>
                        <th style="width:10%">Stock Property<br />No.</th>
                        <th style="width:8%">Unit</th>
                        <th>Item Description</th>
                        <th style="width:9%">Quantity</th>
                        <th style="width:11%">Unit Cost</th>
                        <th style="width:11%">Total Cost</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in _pr.LineItems)
                    {
                        <tr>
                            <td class="pr-ctr">&nbsp;</td>
                            <td class="pr-ctr">@line.UnitOfIssue</td>
                            <td>@line.ItemDescription</td>
                            <td class="pr-ctr">@line.Quantity.ToString("N2")</td>
                            <td class="pr-right">@line.EstimatedUnitCost.ToString("N2")</td>
                            <td class="pr-right">@line.EstimatedTotalCost.ToString("N2")</td>
                        </tr>
                    }
                    @for (var i = _pr.LineItems.Count; i < screenRows; i++)
                    {
                        <tr>
                            <td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td>
                            <td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="pr-purpose">
                <div class="pr-purpose-row">
                    <span>Purpose :</span>
                    <div class="pr-purpose-line">@_pr.Purpose</div>
                </div>
                <div class="pr-purpose-row" style="margin-top:4px">
                    <span style="visibility:hidden">Purpose :</span>
                    <div class="pr-purpose-line">&nbsp;</div>
                </div>
                <div class="pr-purpose-row" style="margin-top:4px">
                    <span style="visibility:hidden">Purpose :</span>
                    <div class="pr-purpose-line">&nbsp;</div>
                </div>
            </div>

            <div class="pr-signatories">
                <div class="pr-sig-block">
                    <div class="pr-sig-title">Requested by :</div>
                    <div class="pr-sig-row">
                        <span class="pr-sig-label">Signature :</span>
                        <div class="pr-sig-line">&nbsp;</div>
                    </div>
                    <div class="pr-sig-row">
                        <span class="pr-sig-label">Printed Name :</span>
                        <div class="pr-sig-line">@_pr.RequestedByName</div>
                    </div>
                    <div class="pr-sig-row">
                        <span class="pr-sig-label">Designation :</span>
                        <div class="pr-sig-line">@(_requestedByDesignation ?? string.Empty)</div>
                    </div>
                </div>
                <div class="pr-sig-block">
                    <div class="pr-sig-title">Approved by :</div>
                    <div class="pr-sig-row">
                        <span class="pr-sig-label">Signature :</span>
                        <div class="pr-sig-line">&nbsp;</div>
                    </div>
                    <div class="pr-sig-row">
                        <span class="pr-sig-label">Printed Name :</span>
                        <div class="pr-sig-line">@(_pr.ApprovedByName ?? OrgProfileState.Profile?.RegionalManagerName ?? string.Empty)</div>
                    </div>
                    <div class="pr-sig-row">
                        <span class="pr-sig-label">Designation :</span>
                        <div class="pr-sig-line">@(OrgProfileState.Profile?.RegionalManagerDesignation ?? "Regional Manager II")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Print layout: two compact copies on one A4 page -->
    <div class="pr-print">
        @{
            var _orgP = OrgProfileState.Profile;
            var compactRows = Math.Max(10, _pr.LineItems.Count);
        }
        @for (var copyIndex = 0; copyIndex < 2; copyIndex++)
        {
            if (copyIndex == 1)
            {
                <div class="pr-cut-line"></div>
            }
            <div class="pr-page pr-compact">
                @if (_orgP is not null)
                {
                    <div style="text-align:center; margin-bottom:4px; line-height:1.3;">
                        <div style="font-size:9px;">Republic of the Philippines</div>
                        <div style="font-size:11px; font-weight:700;">@_orgP.Name</div>
                        @if (!string.IsNullOrWhiteSpace(_orgP.ShortName))
                        {
                            <div style="font-size:9px;">(@_orgP.ShortName)</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_orgP.Address))
                        {
                            <div style="font-size:9px;">@_orgP.Address</div>
                        }
                    </div>
                }
                <div class="pr-exhibit">Exhibit 4</div>
                <div class="pr-title">PURCHASE REQUEST</div>

                <div class="pr-form">
                    <div class="pr-header">
                        <div class="pr-header-cell">
                            <div class="pr-header-label">Name of Department/<br />Office/Section:</div>
                            <div class="pr-header-value">@_pr.DepartmentName@(string.IsNullOrWhiteSpace(_pr.ResponsibilityCenterCode) ? "" : $" / {_pr.ResponsibilityCenterCode}")</div>
                        </div>
                        <div class="pr-header-cell">
                            <div class="pr-header-label">PR No.</div>
                            <div class="pr-header-value">@_pr.PrNumber</div>
                            <div class="pr-header-label" style="margin-top:3px">Responsibility Center Code :</div>
                            <div class="pr-header-value">&nbsp;</div>
                        </div>
                        <div class="pr-header-cell">
                            <div class="pr-header-label">Date :</div>
                            <div class="pr-header-value">@_pr.PrDate.ToString("MM/dd/yyyy")</div>
                        </div>
                    </div>

                    <table class="pr-table">
                        <thead>
                            <tr>
                                <th style="width:10%">Stock Property<br />No.</th>
                                <th style="width:8%">Unit</th>
                                <th>Item Description</th>
                                <th style="width:9%">Quantity</th>
                                <th style="width:11%">Unit Cost</th>
                                <th style="width:11%">Total Cost</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in _pr.LineItems)
                            {
                                <tr>
                                    <td class="pr-ctr">&nbsp;</td>
                                    <td class="pr-ctr">@line.UnitOfIssue</td>
                                    <td>@line.ItemDescription</td>
                                    <td class="pr-ctr">@line.Quantity.ToString("N2")</td>
                                    <td class="pr-right">@line.EstimatedUnitCost.ToString("N2")</td>
                                    <td class="pr-right">@line.EstimatedTotalCost.ToString("N2")</td>
                                </tr>
                            }
                            @for (var i = _pr.LineItems.Count; i < compactRows; i++)
                            {
                                <tr>
                                    <td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td>
                                    <td>&nbsp;</td><td>&nbsp;</td><td>&nbsp;</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <div class="pr-purpose">
                        <div class="pr-purpose-row">
                            <span>Purpose :</span>
                            <div class="pr-purpose-line">@_pr.Purpose</div>
                        </div>
                        <div class="pr-purpose-row" style="margin-top:3px">
                            <span style="visibility:hidden">Purpose :</span>
                            <div class="pr-purpose-line">&nbsp;</div>
                        </div>
                    </div>

                    <div class="pr-signatories">
                        <div class="pr-sig-block">
                            <div class="pr-sig-title">Requested by :</div>
                            <div class="pr-sig-row">
                                <span class="pr-sig-label">Signature :</span>
                                <div class="pr-sig-line">&nbsp;</div>
                            </div>
                            <div class="pr-sig-row">
                                <span class="pr-sig-label">Printed Name :</span>
                                <div class="pr-sig-line">@_pr.RequestedByName</div>
                            </div>
                            <div class="pr-sig-row">
                                <span class="pr-sig-label">Designation :</span>
                                <div class="pr-sig-line">@(_requestedByDesignation ?? string.Empty)</div>
                            </div>
                        </div>
                        <div class="pr-sig-block">
                            <div class="pr-sig-title">Approved by :</div>
                            <div class="pr-sig-row">
                                <span class="pr-sig-label">Signature :</span>
                                <div class="pr-sig-line">&nbsp;</div>
                            </div>
                            <div class="pr-sig-row">
                                <span class="pr-sig-label">Printed Name :</span>
                                <div class="pr-sig-line">@(_pr.ApprovedByName ?? OrgProfileState.Profile?.RegionalManagerName ?? string.Empty)</div>
                            </div>
                            <div class="pr-sig-row">
                                <span class="pr-sig-label">Designation :</span>
                                <div class="pr-sig-line">@(OrgProfileState.Profile?.RegionalManagerDesignation ?? "Regional Manager II")</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _loading = true;
    private PurchaseRequestDto? _pr;
    private string? _requestedByDesignation;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var prTask = Client.GetAsync(Id);
            var designationTask = ResolveCurrentUserDesignationAsync();
            await Task.WhenAll(prTask, designationTask);

            _pr = await prTask;
            _requestedByDesignation = await designationTask;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load Purchase Request: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task<string?> ResolveCurrentUserDesignationAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var identityUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (string.IsNullOrWhiteSpace(identityUserId)) return null;
            var employee = await EmployeesClient.ByIdentityAsync(identityUserId);
            return employee?.PositionName;
        }
        catch { return null; }
    }

    private async Task PrintAsync() => await JS.InvokeVoidAsync("print");

    private Task DownloadA4PdfAsync() => DownloadPdfAsync("a4");

    private Task DownloadLongBondPdfAsync() => DownloadPdfAsync("longbond");

    private async Task DownloadPdfAsync(string size)
    {
        if (_pr is null)
        {
            return;
        }

        _loading = true;
        try
        {
            var bytes = await Client.GetPrintPdfAsync(Id, pageWidth: size);
            var dataUrl = $"data:application/pdf;base64,{Convert.ToBase64String(bytes)}";
            await JS.InvokeVoidAsync("open", dataUrl, "_blank");
            Snackbar.Add("PDF ready.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"PDF generation failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}
