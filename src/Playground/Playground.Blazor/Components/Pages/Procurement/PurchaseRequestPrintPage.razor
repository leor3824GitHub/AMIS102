@page "/procurement/purchase-requests/{Id:guid}/print"
@using AMIS.Playground.Blazor.ApiClient
@using AMIS.Modules.ProcurementAcquisition.Contracts.v1.PurchaseRequests
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IPurchaseRequestClient Client
@inject IOrganizationProfileState OrgProfileState
@inject IEmployeesClient EmployeesClient
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Purchase Request - @(_pr?.PrNumber ?? "Print")</PageTitle>

<style>
    .pr-page {
        background: white;
        color: #111;
        max-width: 900px;
        margin: 0 auto;
        padding: 8px;
        font-family: "Times New Roman", serif;
        font-size: 12px;
    }

    .pr-exhibit {
        text-align: right;
        font-size: 13px;
        margin-bottom: 4px;
        font-weight: 600;
    }

    .pr-title {
        text-align: center;
        font-size: 20px;
        font-weight: 700;
        letter-spacing: 2px;
        margin-bottom: 8px;
    }

    .pr-form {
        border: 2px solid #222;
    }

    .pr-header {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        border-bottom: 2px solid #222;
    }

    .pr-header-cell {
        padding: 6px 8px;
    }

    .pr-header-cell:not(:last-child) {
        border-right: 1px solid #222;
    }

    .pr-header-label {
        font-size: 11px;
    }

    .pr-header-value {
        border-bottom: 1px solid #333;
        min-height: 16px;
        padding: 1px 2px;
        font-size: 12px;
    }

    .pr-table {
        width: 100%;
        border-collapse: collapse;
        table-layout: fixed;
    }

    .pr-table th,
    .pr-table td {
        border: 1px solid #222;
        padding: 3px 5px;
        vertical-align: middle;
        word-wrap: break-word;
    }

    .pr-table th {
        text-align: center;
        font-weight: 700;
        font-size: 11px;
        background: #f5f5f5;
    }

    .pr-table td {
        height: 22px;
        font-size: 12px;
    }

    .pr-ctr {
        text-align: center;
    }

    .pr-right {
        text-align: right;
    }

    .pr-purpose {
        border-top: 2px solid #222;
        padding: 6px 8px;
        min-height: 60px;
    }

    .pr-purpose-row {
        display: flex;
        gap: 8px;
        align-items: baseline;
    }

    .pr-purpose-line {
        border-bottom: 1px solid #333;
        flex: 1;
        min-height: 16px;
    }

    .pr-signatories {
        display: grid;
        grid-template-columns: 1fr 1fr;
        border-top: 2px solid #222;
    }

    .pr-sig-block {
        padding: 8px 20px;
    }

    .pr-sig-block:first-child {
        border-right: 1px solid #222;
    }

    .pr-sig-title {
        font-weight: 700;
        margin-bottom: 24px;
        font-size: 12px;
    }

    .pr-sig-row {
        display: flex;
        gap: 8px;
        align-items: baseline;
        margin-bottom: 4px;
    }

    .pr-sig-label {
        white-space: nowrap;
        font-size: 11px;
        width: 110px;
    }

    .pr-sig-line {
        border-bottom: 1px solid #333;
        flex: 1;
        min-height: 16px;
    }

    /* === Compact overrides for 2-per-landscape-page print copies === */
    .pr-compact {
        font-size: 7.5px;
    }
    .pr-compact .pr-exhibit {
        font-size: 9px;
        margin-bottom: 1px;
    }
    .pr-compact .pr-title {
        font-size: 13px;
        letter-spacing: 1px;
        margin-bottom: 2px;
    }
    .pr-compact .pr-form {
        border-width: 1.5px;
    }
    .pr-compact .pr-header {
        border-bottom-width: 1.5px;
    }
    .pr-compact .pr-header-cell {
        padding: 2px 4px;
    }
    .pr-compact .pr-header-label {
        font-size: 7.5px;
    }
    .pr-compact .pr-header-value {
        font-size: 7.5px;
        min-height: 10px;
    }
    .pr-compact .pr-table th {
        font-size: 7.5px;
        padding: 1px 2px;
    }
    .pr-compact .pr-table td {
        height: 10px;
        font-size: 7.5px;
        padding: 0px 2px;
    }
    .pr-compact .pr-purpose {
        border-top-width: 1.5px;
        padding: 2px 4px;
        min-height: 18px;
    }
    .pr-compact .pr-purpose-line {
        min-height: 10px;
    }
    .pr-compact .pr-signatories {
        border-top-width: 1.5px;
    }
    .pr-compact .pr-sig-block {
        padding: 3px 8px;
    }
    .pr-compact .pr-sig-title {
        margin-bottom: 7px;
        font-size: 7.5px;
    }
    .pr-compact .pr-sig-label {
        font-size: 7.5px;
        width: 70px;
    }
    .pr-compact .pr-sig-line {
        min-height: 10px;
    }
    .pr-compact .pr-sig-row {
        margin-bottom: 2px;
    }

    /* Vertical cut line — hidden on screen */
    .pr-cut-line {
        display: none;
    }

    /* Hide print copies on screen */
    .pr-print {
        display: none;
    }

    @@media print {
        @@page {
            size: landscape;
            margin: 5mm;
        }

        .no-print {
            display: none !important;
        }

        /* Hide MudBlazor navigation chrome, NOT the main content */
        .mud-drawer,
        .mud-appbar,
        .mud-app-bar,
        .mud-snackbar-container,
        #blazor-error-ui,
        [id^="blazor"] {
            display: none !important;
        }

        /* Remove drawer-offset margins from main content */
        .mud-main-content {
            margin-left: 0 !important;
            padding-top: 0 !important;
            padding-bottom: 0 !important;
            min-height: 0 !important;
        }

        /* Remove max-width container constraints */
        .mud-container,
        .mud-container-maxwidth-lg,
        .mud-container-maxwidth-xl,
        .mud-container-maxwidth-md {
            max-width: none !important;
            padding: 0 !important;
            margin: 0 !important;
        }

        body {
            margin: 0;
        }

        /* Switch visibility: hide screen preview, show two-up print layout */
        .pr-screen {
            display: none !important;
        }

        /* Side-by-side layout: two columns with vertical cut line — fills full page height */
        .pr-print {
            display: grid !important;
            grid-template-columns: 1fr auto 1fr;
            align-items: stretch;
            width: 100%;
            height: 100vh;
            overflow: hidden;
        }

        /* Each copy is a flex column that fills its grid cell */
        .pr-page.pr-compact {
            height: 100%;
            display: flex;
            flex-direction: column;
            box-sizing: border-box;
        }

        /* The form box grows to fill space below the org header / title */
        .pr-compact .pr-form {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        /* Purpose section stretches to fill space between the item table and signatures */
        .pr-compact .pr-purpose {
            flex: 1;
        }

        /* Vertical dashed cut line — stretches full height via align-items: stretch */
        .pr-cut-line {
            display: block !important;
            width: 0;
            border-left: 1px dashed #bbb;
            margin: 0 4mm;
        }

        .pr-page {
            max-width: 100%;
            padding: 0;
            margin: 0;
        }
    }
</style>

<div class="no-print">
    <MudPaper Class="pa-3 mb-3" Elevation="1">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudButton Variant="Variant.Outlined" OnClick="@(() => Navigation.NavigateTo("/procurement/purchase-requests"))">
                BACK
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Secondary"
                       StartIcon="@Icons.Material.Filled.Print"
                       OnClick="PrintAsync"
                       Disabled="@(_pr is null || _loading)">
                PRINT PURCHASE REQUEST
            </MudButton>
            <MudMenu Icon="@Icons.Material.Filled.Download"
                     Variant="Variant.Filled"
                     Color="Color.Primary"
                     Label="DOWNLOAD PDF"
                     Disabled="@(_pr is null || _loading)">
                <MudMenuItem OnClick="@DownloadA4PdfAsync">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Size="Size.Small" />
                        <MudText>Download PDF (RDLC) - A4</MudText>
                    </MudStack>
                </MudMenuItem>
                <MudMenuItem OnClick="@DownloadLongBondPdfAsync">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Size="Size.Small" />
                        <MudText>Download PDF (RDLC) - Long Bond</MudText>
                    </MudStack>
                </MudMenuItem>
            </MudMenu>
            @if (_pr is not null)
            {
                <MudText Typo="Typo.body2" Class="ml-2">PR: @_pr.PrNumber</MudText>
            }
        </MudStack>
    </MudPaper>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_pr is null)
{
    <MudAlert Severity="Severity.Error">Unable to load Purchase Request for printing.</MudAlert>
}
else
{
