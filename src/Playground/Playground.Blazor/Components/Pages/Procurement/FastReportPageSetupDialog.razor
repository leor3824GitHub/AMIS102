@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Page Setup</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width: 380px;">
            <MudSelect T="string"
                       Label="Paper size"
                       @bind-Value="PaperSize"
                       Dense="true"
                       Margin="Margin.Dense"
                       Variant="Variant.Outlined">
                @foreach (var p in _paperOptions)
                {
                    <MudSelectItem Value="@p.Value">@p.Label</MudSelectItem>
                }
            </MudSelect>

            <MudField Label="Orientation" Variant="Variant.Outlined" DisableUnderLine="true" InnerPadding="false">
                <MudRadioGroup T="string" @bind-Value="Orientation">
                    <MudRadio Value="@("landscape")" Color="Color.Primary" Size="Size.Small">Landscape</MudRadio>
                    <MudRadio Value="@("portrait")" Color="Color.Primary" Size="Size.Small">Portrait</MudRadio>
                </MudRadioGroup>
            </MudField>

            <MudField Label="Copies per page" Variant="Variant.Outlined" DisableUnderLine="true" InnerPadding="false">
                <MudRadioGroup T="int" @bind-Value="Copies">
                    <MudRadio Value="@(2)" Color="Color.Primary" Size="Size.Small" Disabled="@(Orientation == "portrait")">2 copies (cut in half)</MudRadio>
                    <MudRadio Value="@(1)" Color="Color.Primary" Size="Size.Small">1 copy</MudRadio>
                </MudRadioGroup>
                @if (Orientation == "portrait")
                {
                    <MudText Typo="Typo.caption" Color="Color.Default" Class="mt-1">
                        Portrait orientation forces 1 copy per page.
                    </MudText>
                }
            </MudField>

            <MudNumericField T="int"
                             Label="Rows per page"
                             @bind-Value="MinRows"
                             Min="1"
                             Max="20"
                             Step="1"
                             Dense="true"
                             Margin="Margin.Dense"
                             Variant="Variant.Outlined"
                             HelperText="Pads the line-item table with empty rows up to this count." />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="Submit" Color="Color.Primary" Variant="Variant.Filled">
            Download PDF
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string PaperSize { get; set; } = "a4";
    [Parameter] public string Orientation { get; set; } = "landscape";
    [Parameter] public int Copies { get; set; } = 2;
    [Parameter] public int MinRows { get; set; } = 10;

    private readonly (string Value, string Label)[] _paperOptions =
    {
        ("a4",       "A4 — 210 × 297 mm (8.27 × 11.69 in)"),
        ("letter",   "Letter — 216 × 279 mm (8.5 × 11 in)"),
        ("longbond", "Long Bond — 216 × 330 mm (8.5 × 13 in)"),
        ("legal",    "Legal — 216 × 356 mm (8.5 × 14 in)")
    };

    public sealed record Result(string PaperSize, string Orientation, int Copies, int MinRows);

    private void Submit()
    {
        var copies = Orientation == "portrait" ? 1 : Copies;
        var rows = Math.Clamp(MinRows, 1, 20);
        MudDialog.Close(DialogResult.Ok(new Result(PaperSize, Orientation, copies, rows)));
    }

    private void Cancel() => MudDialog.Cancel();
}
