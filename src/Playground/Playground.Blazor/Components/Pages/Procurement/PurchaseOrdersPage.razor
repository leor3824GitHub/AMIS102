    private async Task CreateWithDuplicateRetryAsync(List<PurchaseOrderLineItemRequest> lineItems, bool allowDuplicate)
    {
        try
        {
            await Client.CreateAsync(new PurchaseOrderContracts.CreatePurchaseOrderCommand(
                _selectedPurchaseRequest!.Id,
                string.IsNullOrWhiteSpace(_form.CanvassRequestId) ? null : Guid.Parse(_form.CanvassRequestId),
                _selectedSupplier!.Id,
                _form.SupplierName, _form.SupplierAddress, _form.SupplierTin,
                _form.ModeOfProcurement, _form.PlaceOfDelivery,
                ToDateOnly(_form.DateOfDeliveryNullable),
                _form.DeliveryTerm, _form.PaymentTerm, _form.FundCluster, _form.OursBursNumber, lineItems,
                allowDuplicate));
        }
        catch (DuplicatePurchaseOrderException dup) when (!allowDuplicate)
        {
            var confirmed = await DialogService.ShowMessageBox(
                "Possible Duplicate Purchase Order",
                $"{dup.Message} Do you still want to create this PO?",
                yesText: "Create anyway",
                cancelText: "Cancel");

            if (confirmed is not true)
            {
                throw new OperationCanceledException("Cancelled by user after duplicate warning.");
            }

            await Client.CreateAsync(new PurchaseOrderContracts.CreatePurchaseOrderCommand(
                _selectedPurchaseRequest!.Id,
                string.IsNullOrWhiteSpace(_form.CanvassRequestId) ? null : Guid.Parse(_form.CanvassRequestId),
                _selectedSupplier!.Id,
                _form.SupplierName, _form.SupplierAddress, _form.SupplierTin,
                _form.ModeOfProcurement, _form.PlaceOfDelivery,
                ToDateOnly(_form.DateOfDeliveryNullable),
                _form.DeliveryTerm, _form.PaymentTerm, _form.FundCluster, _form.OursBursNumber, lineItems,
                AllowDuplicate: true));
        }
    }

    private async Task<(bool Proceed, bool AllowDuplicate)> ConfirmNoDuplicateAsync()
    {
        if (_selectedPurchaseRequest is null || _selectedSupplier is null)
        {
            return (true, false);
        }

        var newDescriptions = _form.LineItems
            .Select(li => NormalizeItem(li.Description))
            .Where(d => d.Length > 0)
            .ToHashSet();

        if (newDescriptions.Count == 0)
        {
            return (true, false);
        }

        Guid? canvassId = Guid.TryParse(_form.CanvassRequestId, out var cid) ? cid : null;

        List<PurchaseOrderSummaryDto> candidates;
        try
        {
            var result = await Client.SearchAsync(
                purchaseRequestId: _selectedPurchaseRequest.Id,
                supplierId: _selectedSupplier.Id,
                page: 1,
                pageSize: 50);
            candidates = result.Items?
                .Where(p => p.Status != PurchaseOrderStatus.Cancelled)
                .ToList() ?? [];
        }
        catch
        {
            return (true, false);
        }

        if (candidates.Count == 0)
        {
            return (true, false);
        }

        var duplicates = new List<(PurchaseOrderSummaryDto Po, List<string> Items)>();
        foreach (var c in candidates)
        {
            PurchaseOrderDto? detail;
            try { detail = await Client.GetAsync(c.Id); }
            catch { continue; }
            if (detail is null) continue;

            if (canvassId.HasValue && detail.CanvassRequestId != canvassId)
            {
                continue;
            }

            var overlap = detail.LineItems
                .Select(li => li.Description)
                .Where(d => newDescriptions.Contains(NormalizeItem(d)))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            if (overlap.Count > 0)
            {
                duplicates.Add((c, overlap));
            }
        }

        if (duplicates.Count == 0)
        {
            return (true, false);
        }

        var poList = string.Join(", ", duplicates.Select(d => $"{d.Po.PoNumber} ({d.Po.Status})"));
        var sampleItems = duplicates
            .SelectMany(d => d.Items)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(3)
            .ToList();
        var itemPreview = string.Join(", ", sampleItems);

        var message = $"A purchase order already exists for this purchase request and supplier ({_selectedSupplier.Name}) with overlapping item(s): {itemPreview}. Existing PO(s): {poList}. Do you still want to create this PO?";

        var confirmed = await DialogService.ShowMessageBox(
            "Possible Duplicate Purchase Order",
            message,
            yesText: "Create anyway",
            cancelText: "Cancel");

        return confirmed is true ? (true, true) : (false, false);
    }

    private static string NormalizeItem(string? value) =>
        string.IsNullOrWhiteSpace(value) ? string.Empty : value.Trim().ToLowerInvariant();

    private bool IsFormValid() =>
        _selectedPurchaseRequest is not null &&
        _selectedSupplier is not null &&
        !string.IsNullOrWhiteSpace(_form.SupplierName) &&
        !string.IsNullOrWhiteSpace(_form.SupplierAddress) &&
        !string.IsNullOrWhiteSpace(_form.PlaceOfDelivery) &&
        !string.IsNullOrWhiteSpace(_form.DeliveryTerm) &&
        !string.IsNullOrWhiteSpace(_form.PaymentTerm) &&
        _form.LineItems.Any(li => !string.IsNullOrWhiteSpace(li.Description));

    private static DateOnly? ToDateOnly(DateTime? d) => d.HasValue ? DateOnly.FromDateTime(d.Value) : null;

    private static RenderFragment PoStatusChip(PurchaseOrderStatus status) => __builder =>
    {
        var (color, icon) = status switch
        {
            PurchaseOrderStatus.Draft => (Color.Default, Icons.Material.Filled.Edit),
            PurchaseOrderStatus.Issued => (Color.Info, Icons.Material.Filled.Send),
            PurchaseOrderStatus.PartiallyDelivered => (Color.Warning, Icons.Material.Filled.LocalShipping),
            PurchaseOrderStatus.Fulfilled => (Color.Success, Icons.Material.Filled.CheckCircle),
            PurchaseOrderStatus.Cancelled => (Color.Error, Icons.Material.Filled.Cancel),
            _ => (Color.Default, Icons.Material.Filled.Help)
        };
        __builder.OpenComponent<MudChip<string>>(0);
        __builder.AddAttribute(1, "Size", Size.Small);
        __builder.AddAttribute(2, "Color", color);
        __builder.AddAttribute(3, "Icon", icon);
        __builder.AddAttribute(4, "ChildContent", (RenderFragment)(b => b.AddContent(0, status.ToString())));
        __builder.CloseComponent();
    };

