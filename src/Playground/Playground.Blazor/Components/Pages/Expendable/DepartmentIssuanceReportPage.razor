@page "/expendable/reports/department"
@using AMIS.Modules.Expendable.Contracts.v1.Requests
@using AMIS.Playground.Blazor.ApiClient
@using System.Globalization
@using System.Text
@inherits ComponentBase
@inject IReportsClient ReportsClient
@inject ILookupClient LookupClient
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<style>
    .report-page {
        background: white;
        max-width: 900px;
        margin: 0 auto;
        padding: 0;
        font-family: Arial, sans-serif;
        font-size: 12px;
    }

    .report-header {
        text-align: center;
        margin-bottom: 8px;
    }

    .report-title {
        font-size: 14px;
        font-weight: bold;
        letter-spacing: 1px;
    }

    .report-appendix {
        text-align: right;
        font-style: italic;
        font-size: 11px;
        margin-bottom: 4px;
    }

    .report-meta {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4px 0;
        margin-bottom: 8px;
        font-size: 12px;
    }

    .report-meta-label { font-weight: bold; }

    .report-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 11px;
    }

    .report-table th,
    .report-table td {
        border: 1px solid #333;
        padding: 3px 5px;
    }

    .report-table th {
        background: #f0f0f0;
        text-align: center;
        font-weight: bold;
    }

    .report-table td.num { text-align: right; }
    .report-table td.center { text-align: center; }

    .dept-header td {
        background: #dde4f0;
        font-weight: bold;
        font-size: 11px;
        padding: 4px 5px;
    }

    .subtotal-row td {
        background: #f5f5f5;
        font-weight: bold;
        border-top: 2px solid #333;
    }

    .grand-total-row td {
        background: #e0e0e0;
        font-weight: bold;
        border-top: 2px solid #333;
    }

    .col-header-group {
        background: #e8e8e8 !important;
        font-size: 10px;
        text-align: center;
        font-style: italic;
    }

    @@media print {
        .no-print { display: none !important; }
        .report-page { max-width: 100%; }
        body { margin: 0; }
        .mud-main-content, .mud-nav-menu { display: none !important; }
    }
</style>

<div class="no-print">
    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudGrid Spacing="2" AlignItems="AlignItems.Center">
            <MudItem xs="12" sm="4">
                <MudDatePicker @bind-Date="_filterFrom" Label="Date From" Variant="Variant.Outlined"
                               DateFormat="yyyy-MM-dd" Clearable="true" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudDatePicker @bind-Date="_filterTo" Label="Date To" Variant="Variant.Outlined"
                               DateFormat="yyyy-MM-dd" Clearable="true" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="Guid?" Value="_selectedDepartmentId" ValueChanged="OnDepartmentChanged"
                           Label="Department (All)" Variant="Variant.Outlined" Clearable="true">
                    @foreach (var dept in _departments)
                    {
                        <MudSelectItem Value="@((Guid?)dept.Id)">@dept.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadReportAsync"
                               StartIcon="@Icons.Material.Filled.Refresh" Disabled="_loading">
                        Generate Report
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="PrintReport"
                               StartIcon="@Icons.Material.Filled.Print" Disabled="_loading || _reportData.Count == 0">
                        Print
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ExportCsvAsync"
                               StartIcon="@Icons.Material.Filled.Download" Disabled="_loading || _reportData.Count == 0">
                        Export CSV
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DownloadPdfAsync"
                               StartIcon="@Icons.Material.Filled.PictureAsPdf" Disabled="_loading || _reportData.Count == 0">
                        Download PDF
                    </MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }
</div>

@if (_reportData.Count > 0)
{
    <div class="report-page" id="print-area">
        <div class="report-appendix">Appendix 64</div>
        <div class="report-header">
            <div class="report-title">REPORT OF SUPPLIES AND MATERIALS ISSUED</div>
        </div>

        <div class="report-meta">
            <div><span class="report-meta-label">Entity Name: </span>NATIONAL FOOD AUTHORITY</div>
            <div style="text-align:right"><span class="report-meta-label">Serial No.: </span>@_serialNo</div>
            <div><span class="report-meta-label">Fund Cluster: </span>GENERAL OPERATING FUND</div>
            <div style="text-align:right"><span class="report-meta-label">Date: </span>@_dateRangeLabel</div>
        </div>

        <table class="report-table">
            <thead>
                <tr>
                    <th colspan="6" class="col-header-group">To be filled up by the Supply and/or Property Division/Unit</th>
                    <th colspan="2" class="col-header-group">To be filled up by the Accounting Division/Unit</th>
                </tr>
                <tr>
                    <th style="width:60px">Stock No.</th>
                    <th>Item</th>
                    <th style="width:50px">Unit</th>
                    <th style="width:70px">Department</th>
                    <th style="width:60px">Qty Issued</th>
                    <th style="width:80px">Unit Cost</th>
                    <th style="width:90px">Amount</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dept in _reportData)
                {
                    var deptName = GetDepartmentDisplay(dept.DepartmentId);
                    <tr class="dept-header">
                        <td colspan="7">@deptName</td>
                    </tr>
                    @foreach (var item in dept.Products)
                    {
                        <tr>
                            <td class="center">@item.ProductCode</td>
                            <td>@item.ProductName</td>
                            <td class="center">@item.Unit</td>
                            <td class="center"></td>
                            <td class="num">@item.TotalQuantityIssued</td>
                            <td class="num">@item.UnitCost.ToString("N2")</td>
                            <td class="num">@item.TotalValue.ToString("N2")</td>
                        </tr>
                    }
                    <tr class="subtotal-row">
                        <td colspan="4" style="text-align:right">Subtotal — @deptName</td>
                        <td class="num">@dept.TotalItemsIssued</td>
                        <td></td>
                        <td class="num">@dept.TotalValue.ToString("N2")</td>
                    </tr>
                }

                <tr class="grand-total-row">
                    <td colspan="4" style="text-align:right">GRAND TOTAL</td>
                    <td class="num">@_reportData.Sum(d => d.TotalItemsIssued)</td>
                    <td></td>
                    <td class="num">@_reportData.Sum(d => d.TotalValue).ToString("N2")</td>
                </tr>
            </tbody>
        </table>
    </div>
}
else if (!_loading)
{
    <MudText Typo="Typo.body2" Class="mt-4 ml-2 no-print" Color="Color.Secondary">
        No issuance data found for the selected filters.
    </MudText>
}

@code {
    private bool _loading;
    private List<DepartmentIssuanceSummaryDto> _reportData = [];
    private List<DepartmentReferenceDto> _departments = [];
    private Guid? _selectedDepartmentId;
    private DateTime? _filterFrom;
    private DateTime? _filterTo;
    private string _serialNo = string.Empty;
    private string _dateRangeLabel = string.Empty;

    [Parameter]
    [SupplyParameterFromQuery(Name = "from")]
    public string? QueryFrom { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "to")]
    public string? QueryTo { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "departmentId")]
    public string? QueryDepartmentId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await LookupClient.DepartmentsAsync(isActive: true, pageNumber: 1, pageSize: 200);
            _departments = result.Items?.ToList() ?? [];
            ApplyQueryFilters();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load departments: {ex.Message}", Severity.Warning);
        }

        await LoadReportAsync();
    }

    private void ApplyQueryFilters()
    {
        if (!string.IsNullOrWhiteSpace(QueryDepartmentId) && Guid.TryParse(QueryDepartmentId, out var id))
            _selectedDepartmentId = id;

        if (TryParseDate(QueryFrom, out var from)) _filterFrom = from;
        if (TryParseDate(QueryTo, out var to)) _filterTo = to;
    }

    private async Task LoadReportAsync()
    {
        if (!IsDateRangeValid()) return;

        _loading = true;
        _reportData = [];
        try
        {
            var items = new List<DepartmentIssuanceSummaryDto>();
            var page = 1;
            const int pageSize = 100;

            while (true)
            {
                var from = _filterFrom.HasValue ? new DateTimeOffset(_filterFrom.Value, TimeSpan.Zero) : (DateTimeOffset?)null;
                var to = _filterTo.HasValue ? new DateTimeOffset(_filterTo.Value, TimeSpan.Zero) : (DateTimeOffset?)null;

                var result = await ReportsClient.GetDepartmentIssuanceReportAsync(
                    departmentId: _selectedDepartmentId?.ToString(),
                    from: from,
                    toDate: to,
                    pageNumber: page,
                    pageSize: pageSize);

                var batch = result.Items?.ToList() ?? [];
                if (batch.Count == 0) break;
                items.AddRange(batch);
                if (batch.Count < pageSize) break;
                page++;
            }

            _reportData = items;
            BuildMetadata();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load report: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void BuildMetadata()
    {
        var now = DateTime.Now;
        _serialNo = $"{now.Year}-{now.Month:D2}-{_reportData.Count:D3}";

        if (_filterFrom.HasValue && _filterTo.HasValue)
            _dateRangeLabel = $"{_filterFrom.Value:MMMM d} - {_filterTo.Value:d, yyyy}";
        else if (_filterFrom.HasValue)
            _dateRangeLabel = $"From {_filterFrom.Value:MMMM d, yyyy}";
        else if (_filterTo.HasValue)
            _dateRangeLabel = $"Up to {_filterTo.Value:MMMM d, yyyy}";
        else
            _dateRangeLabel = now.ToString("MMMM yyyy");
    }

    private async Task OnDepartmentChanged(Guid? id) => _selectedDepartmentId = id;

    private async Task PrintReport() => await JS.InvokeVoidAsync("print");

    private async Task ExportCsvAsync()
    {
        if (_reportData.Count == 0) return;

        var sb = new StringBuilder();
        sb.AppendLine("Department,Stock No.,Item,Unit,Qty Issued,Unit Cost,Amount");

        foreach (var dept in _reportData)
        {
            var deptName = GetDepartmentDisplay(dept.DepartmentId);
            foreach (var item in dept.Products)
            {
                sb.AppendLine(string.Join(",",
                    Quote(deptName),
                    Quote(item.ProductCode),
                    Quote(item.ProductName),
                    Quote(item.Unit),
                    item.TotalQuantityIssued.ToString(),
                    item.UnitCost.ToString("N2"),
                    item.TotalValue.ToString("N2")));
            }
        }

        var dataUrl = $"data:text/csv;base64,{Convert.ToBase64String(Encoding.UTF8.GetBytes(sb.ToString()))}";
        await JS.InvokeVoidAsync("open", dataUrl, "_blank");
        Snackbar.Add("CSV export ready.", Severity.Success);
    }

    private bool IsDateRangeValid()
    {
        if (_filterFrom.HasValue && _filterTo.HasValue && _filterFrom.Value.Date > _filterTo.Value.Date)
        {
            Snackbar.Add("From date cannot be later than To date.", Severity.Warning);
            return false;
        }
        return true;
    }

    private string GetDepartmentDisplay(string departmentId)
    {
        if (Guid.TryParse(departmentId, out var id))
        {
            var match = _departments.FirstOrDefault(d => d.Id == id);
            if (match != null) return match.Name;
        }
        return departmentId;
    }

    private async Task DownloadPdfAsync()
    {
        if (_reportData.Count == 0) return;
        try
        {
            var from = _filterFrom.HasValue ? new DateTimeOffset(_filterFrom.Value, TimeSpan.Zero) : (DateTimeOffset?)null;
            var to = _filterTo.HasValue ? new DateTimeOffset(_filterTo.Value, TimeSpan.Zero) : (DateTimeOffset?)null;

            var bytes = await ReportsClient.GenerateDepartmentIssuancePdfAsync(
                departmentId: _selectedDepartmentId?.ToString(),
                from: from,
                to: to);

            var dataUrl = $"data:application/pdf;base64,{Convert.ToBase64String(bytes)}";
            await JS.InvokeVoidAsync("open", dataUrl, "_blank");
            Snackbar.Add("PDF ready.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"PDF generation failed: {ex.Message}", Severity.Error);
        }
    }

    private static bool TryParseDate(string? value, out DateTime date) =>
        DateTime.TryParseExact(value, "yyyy-MM-dd", CultureInfo.InvariantCulture, DateTimeStyles.None, out date);

    private static string Quote(string? v) =>
        string.IsNullOrEmpty(v) ? "\"\"" : $"\"{v.Replace("\"", "\"\"")}\"";
}

