@page "/expendable/cart"
@using MudBlazor
@using FSH.Playground.Blazor.ApiClient
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IEmployeeClient _employeeClient
@inject IEmployeesClient _employeesClient
@inject ICartClient _cartClient
@inject IProductsClient _productsClient
@inject ILookupClient _lookupClient
@inject IInventoryClient _inventoryClient
@inject IWarehouseClient _warehouseClient
@inject AuthenticationStateProvider _authenticationStateProvider
@inject NavigationManager _navigationManager
@inject ISnackbar _snackbar

<PageTitle>Shopping Basket</PageTitle>

<style>
    /* Allow the table to be fluid but wrap text effectively */
    .cart-table { width: 100%; table-layout: auto; }
    .product-cell-text { white-space: normal !important; word-break: break-word; display: block; font-weight: 500; }
    
    /* Sticky sidebar for desktop, normal flow for mobile */
    @@media (min-width: 960px) {
        .sticky-card { position: sticky; top: 24px; }
    }
    
    .cart-table-wrap { width: 100%; overflow-x: auto; border-radius: 8px; }
    .qty-input { width: 100px; }
    
    /* Ensure the container uses all horizontal space */
    .full-width-container { padding-left: 24px; padding-right: 24px; max-width: 100% !important; }
</style>

<MudContainer MaxWidth="MaxWidth.False" Class="full-width-container mt-4">
    <MudBreadcrumbs Items="_breadcrumbs" Class="pa-0 mb-6"></MudBreadcrumbs>

    @if (_loading)
    {
        <MudGrid>
            <MudItem xs="12" md="8">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="400px" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="250px" />
            </MudItem>
        </MudGrid>
    }
    else if (_cart?.Items == null || !_cart.Items.Any())
    {
        <MudPaper Class="pa-12 d-flex flex-column align-center justify-center" Elevation="0" Outlined="true">
            <MudIcon Icon="@Icons.Material.Filled.ShoppingBasket" Color="Color.Surface" Style="font-size: 5rem;" />
            <MudText Typo="Typo.h5" Class="mt-4">Your basket is empty</MudText>
            <MudText Color="Color.Secondary" Class="mb-6">Add some products to get started.</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="@(() => _navigationManager.NavigateTo("/expendable/shopping"))">
                Browse Products
            </MudButton>
        </MudPaper>
    }
    else
    {
        <MudGrid Spacing="4">
            <MudItem xs="12" md="8" lg="9">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h5">Items (@(_cart.Items.Count))</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        <div class="cart-table-wrap">
                            @* Breakpoint.Sm makes the table responsive cards on mobile *@
                            <MudTable Items="_cart.Items.OrderBy(i => GetProductName(i.ProductId))" Hover="true" Breakpoint="Breakpoint.Sm" Striped="true" Dense="true" Elevation="0" Class="cart-table">
                                <HeaderContent>
                                    <MudTh>Product</MudTh>
                                    <MudTh Style="text-align:right;">Avg Cost</MudTh>
                                    <MudTh Style="text-align:right;">In Stock</MudTh>
                                    <MudTh Style="text-align:center;">Qty</MudTh>
                                    <MudTh Style="text-align:right;">Subtotal</MudTh>
                                    <MudTh Style="text-align:center;">Actions</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Product">
                                        <MudButton Variant="Variant.Text" Size="Size.Small"
                                                   Style="text-transform:none; font-weight:500; padding:0; min-width:0; text-align:left; justify-content:flex-start;"
                                                   Title="Click to view stock details"
                                                   OnClick="@(() => TogglePopover(context.ProductId))">
                                            @GetProductName(context.ProductId)
                                        </MudButton>
                                        @if (_popoverProductId == context.ProductId)
                                        {
                                            <MudPaper Elevation="8" Class="pa-3 mt-1" Style="min-width:320px; max-width:420px; z-index:1000; position:relative;">
                                                @{
                                                    var inv = GetInventory(context.ProductId);
                                                }
                                                @if (inv is null)
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">No inventory data available.</MudText>
                                                }
                                                else
                                                {
                                                    <MudStack Spacing="1">
                                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                                            <MudText Typo="Typo.subtitle2">@inv.WarehouseLocationName</MudText>
                                                            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                                                           OnClick="@(() => _popoverProductId = null)" />
                                                        </MudStack>
                                                        <MudDivider />
                                                        <MudGrid Spacing="1" Class="mt-1">
                                                            <MudItem xs="4"><MudText Typo="Typo.caption" Color="Color.Tertiary">Available</MudText><MudText Typo="Typo.body2"><b>@inv.QuantityAvailable</b></MudText></MudItem>
                                                            <MudItem xs="4"><MudText Typo="Typo.caption" Color="Color.Tertiary">Reserved</MudText><MudText Typo="Typo.body2" Color="Color.Warning"><b>@inv.QuantityReserved</b></MudText></MudItem>
                                                            <MudItem xs="4"><MudText Typo="Typo.caption" Color="Color.Tertiary">On Hand</MudText><MudText Typo="Typo.body2"><b>@inv.QuantityOnHand</b></MudText></MudItem>
                                                        </MudGrid>
                                                    </MudStack>
                                                }
                                            </MudPaper>
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Avg Cost" Style="text-align:right;">$@context.UnitPrice.ToString("F2")</MudTd>
                                    <MudTd DataLabel="In Stock" Style="text-align:right;">
                                        @{
                                            var balance = GetProductBalance(context.ProductId);
                                            if (balance <= 0) { <MudText Color="Color.Error"><b>Out</b></MudText> }
                                            else if (balance < context.Quantity) { <MudText Color="Color.Warning"><b>@balance</b></MudText> }
                                            else { <MudText>@balance</MudText> }
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Qty" Style="text-align:center;">
                                        <div class="qty-input mx-auto">
                                            <MudNumericField T="int" Value="context.Quantity"
                                                            ValueChanged="@((v) => UpdateQuantity(context.ProductId, v))"
                                                            Variant="Variant.Outlined" Margin="Margin.Dense" Min="1"
                                                            Disabled="_isUpdating" />
                                        </div>
                                    </MudTd>
                                    <MudTd DataLabel="Subtotal" Style="text-align:right;">$@context.LineTotal.ToString("F2")</MudTd>
                                    <MudTd DataLabel="Actions" Style="text-align:center;">
                                        <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error" Size="Size.Small" AriaLabel="delete"
                                                       OnClick="@(() => RemoveItem(context.ProductId))" />
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        </div>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton StartIcon="@Icons.Material.Filled.ClearAll" Color="Color.Error" OnClick="@ClearCartConfirm" Disabled="_isUpdating">Clear Basket</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="4" lg="3">
                <div class="sticky-card">
                    <MudCard Elevation="4">
                        <MudCardHeader><CardHeaderContent><MudText Typo="Typo.h6">Checkout Summary</MudText></CardHeaderContent></MudCardHeader>
                        <MudCardContent>
                            <MudStack Spacing="3">
                                <div class="d-flex justify-space-between">
                                    <MudText Typo="Typo.body1">Subtotal</MudText>
                                    <MudText Typo="Typo.h6"><b>$@(_cart.Items.Sum(x => x.LineTotal).ToString("F2"))</b></MudText>
                                </div>
                                <MudDivider />
                                
                                <MudSelect T="Guid" @bind-Value="_selectedDepartmentId" Label="Charge to Department" Required="true" Dense="false" AnchorOrigin="Origin.BottomCenter">
                                    <MudSelectItem Value="Guid.Empty">Select Department...</MudSelectItem>
                                    @foreach (var dept in _departmentList)
                                    {
                                        <MudSelectItem Value="@dept.Id">@dept.Name</MudSelectItem>
                                    }
                                </MudSelect>

                                <MudTextField @bind-Value="_businessJustification" Label="Justification" Lines="3" Variant="Variant.Outlined" Placeholder="Purpose of request" />
                                <MudDatePicker @bind-Date="_neededByDate" Label="Needed By" Editable="true" Placeholder="Select Date" />

                                <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Large" Class="mt-2 py-3"
                                           FullWidth="true" StartIcon="@Icons.Material.Filled.Send"
                                           Disabled="@(_selectedDepartmentId == Guid.Empty || _isUpdating)"
                                           OnClick="CheckoutAsync">
                                    Submit Request
                                </MudButton>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </div>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

<MudDialog @bind-IsOpen="_showClearConfirmDialog">
    <TitleContent><MudText Typo="Typo.h6">Empty Basket?</MudText></TitleContent>
    <DialogContent><MudText>Remove all items from your basket?</MudText></DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showClearConfirmDialog = false)">Cancel</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="@ClearCartAsync">Clear Basket</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private EmployeeShoppingCartDto? _cart;
    private string _currentEmployeeId = string.Empty;
    private Guid _selectedDepartmentId = Guid.Empty;
    private string? _businessJustification = "";
    private DateTime? _neededByDate = DateTime.Today.AddDays(1);
    private bool _showClearConfirmDialog = false;
    private bool _loading = true;
    private bool _isUpdating = false;
    
    private Dictionary<Guid, string> _productNameCache = new();
    private Dictionary<Guid, int> _productBalances = new();
    private Dictionary<Guid, ProductInventoryDto> _productInventories = new();
    private List<DepartmentReferenceDto> _departmentList = new();

    // Popover state
    private Guid? _popoverProductId;
    private bool _popoverOpen => _popoverProductId.HasValue;
    
    private List<BreadcrumbItem> _breadcrumbs = new()
    {
        new BreadcrumbItem("Expendable", href: "/expendable"),
        new BreadcrumbItem("Cart", href: null, disabled: true)
    };

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try {
            await Task.WhenAll(ResolveCurrentEmployeeContext(), LoadProducts(), LoadDepartments());
            await LoadCart();
            await LoadInventoryBalancesAsync();
        } finally {
            _loading = false;
        }
    }

    private async Task ResolveCurrentEmployeeContext()
    {
        try
        {
            var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
            var identityUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrWhiteSpace(identityUserId))
            {
                _snackbar.Add("Unable to resolve signed-in user identity.", Severity.Warning);
                return;
            }

            var employee = await _employeesClient.ByIdentityAsync(identityUserId);
            _currentEmployeeId = employee.Id.ToString();
            _selectedDepartmentId = employee.DepartmentId;
        }
        catch (ApiException ex) when (ex.StatusCode == 404)
        {
            _snackbar.Add("No employee profile linked to this user. Please contact an administrator.", Severity.Warning);
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Failed to resolve employee context: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadCart()
    {
        if (string.IsNullOrWhiteSpace(_currentEmployeeId))
        {
            _cart = null;
            return;
        }

        _cart = await _employeeClient.CartAsync(_currentEmployeeId);
    }

    private async Task UpdateQuantity(Guid productId, int newQty)
    {
        if (_cart == null || _isUpdating) return;
        var item = _cart.Items.FirstOrDefault(x => x.ProductId == productId);
        if (item == null || newQty == item.Quantity) return;
        if (newQty <= 0) { await RemoveItem(productId); return; }

        _isUpdating = true;
        try
        {
            // Replace the product line with the requested quantity.
            await _cartClient.ItemsDeleteAsync(_cart.Id, productId);

            await _cartClient.ItemsPostAsync(_cart.Id, new AddToCartCommand
            {
                CartId = _cart.Id,
                ProductId = productId,
                Quantity = newQty,
                UnitPrice = item.UnitPrice
            });

            _snackbar.Add("Basket updated", Severity.Info);

            await LoadCart();
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Update failed: {ex.Message}", Severity.Error);
            await LoadCart();
        }
        finally
        {
            _isUpdating = false;
        }
    }

    private async Task RemoveItem(Guid productId)
    {
        if (_cart == null || _isUpdating) return;
        _isUpdating = true;
        try
        {
            await _cartClient.ItemsDeleteAsync(_cart.Id, productId);
            _snackbar.Add("Item removed", Severity.Warning);
            await LoadCart();
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Remove failed: {ex.Message}", Severity.Error);
            await LoadCart();
        }
        finally { _isUpdating = false; }
    }

    private async Task ClearCartAsync()
    {
        if (_cart == null || _isUpdating) return;

        _isUpdating = true;
        try
        {
            await _cartClient.ClearAsync(_cart.Id);
            await LoadCart();
            _snackbar.Add("Basket cleared", Severity.Success);
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Could not clear basket: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isUpdating = false;
        }
    }

    private async Task CheckoutAsync()
    {
        if (_cart == null) return;
        try {
            var command = new ConvertCartToSupplyRequestCommand {
                CartId = _cart.Id,
                DepartmentId = _selectedDepartmentId.ToString(),
                BusinessJustification = _businessJustification,
                NeededByDate = _neededByDate.HasValue
                    ? new DateTimeOffset(DateTime.SpecifyKind(_neededByDate.Value.Date, DateTimeKind.Utc))
                    : null
            };
            await _cartClient.ConvertToRequestAsync(_cart.Id, command);
            _snackbar.Add("Request submitted successfully!", Severity.Success);
            _navigationManager.NavigateTo("/expendable");
        } catch (Exception ex) {
            _snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task LoadInventoryBalancesAsync()
    {
        try
        {
            var inventoryList = await _inventoryClient.SearchAsync(new SearchProductInventoryQuery
            {
                PageNumber = 1,
                PageSize = 1000
            });

            if (inventoryList.Items != null)
            {
                // Cache full inventory DTOs (with batches) keyed by ProductId
                _productInventories = inventoryList.Items
                    .GroupBy(i => i.ProductId)
                    .ToDictionary(g => g.Key, g => g.First());

                _productBalances = inventoryList.Items
                    .GroupBy(x => x.ProductId)
                    .ToDictionary(g => g.Key, g => g.Sum(i => i.QuantityAvailable));
            }
        }
        catch
        {
            _productBalances.Clear();
            _productInventories.Clear();
        }
    }

    private async Task LoadProducts()
    {
        var result = await _productsClient.ActiveAsync(1, 1000);
        _productNameCache = result.Items?.ToDictionary(p => p.Id, p => p.Name) ?? new();
    }

    private async Task LoadDepartments()
    {
        // API signature: DepartmentsAsync(string keyword = null, bool? isActive = null, int? pageNumber = null, int? pageSize = null)
        var result = await _lookupClient.DepartmentsAsync(null, true, 1, 100);
        _departmentList = result.Items?.ToList() ?? new();
    }

    private string GetProductName(Guid id) => _productNameCache.TryGetValue(id, out var name) ? name : "Unknown Product";
    private int GetProductBalance(Guid id) => _productBalances.TryGetValue(id, out var b) ? b : 0;
    private ProductInventoryDto? GetInventory(Guid id) => _productInventories.TryGetValue(id, out var inv) ? inv : null;
    private void TogglePopover(Guid productId) =>
        _popoverProductId = _popoverProductId == productId ? null : productId;
    private void ClearCartConfirm() => _showClearConfirmDialog = true;
}