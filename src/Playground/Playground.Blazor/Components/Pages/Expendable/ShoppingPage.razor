@page "/expendable/shopping"
@using System.Timers
@using MudBlazor
@using FSH.Playground.Blazor.ApiClient
@using FSH.Playground.Blazor.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IProductsClient _productsClient
@inject IEmployeeClient _employeeClient
@inject IEmployeesClient _employeesClient
@inject ICartClient _cartClient
@inject IInventoryClient _inventoryClient
@inject IWarehouseClient _warehouseClient
@inject AuthenticationStateProvider _authenticationStateProvider
@inject NavigationManager _navigationManager
@inject MasterDataService MasterDataService
@inject ISnackbar _snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    <MudGrid>
        <MudItem xs="12">
            <div class="d-flex justify-space-between align-center">
                <MudText Typo="Typo.h4" Class="mb-6">Product Catalog</MudText>
                <MudBadge Content="@_cartItemCount" Color="Color.Primary" Overlap="true" Class="mb-6">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => _navigationManager.NavigateTo("/expendable/cart"))">
                        <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" /> Basket
                    </MudButton>
                </MudBadge>
            </div>
        </MudItem>
        
    <MudItem xs="12" Class="mb-2">
        <MudChipSet T="string"
                    SelectedValue="_selectedCategory"
                    SelectedValueChanged="OnCategoryChanged"
                    CheckMark="true"
                    Variant="Variant.Text"
                    Color="Color.Primary">
           <MudChip Value="@("All")" Default="true">All Categories</MudChip>
    @foreach (var cat in _categories)
    {
        <MudChip Value="@cat.Id.ToString()">@cat.Name</MudChip>
    }
        </MudChipSet>
    </MudItem>
    <MudItem xs="12" Class="mb-4">
        <MudChipSet T="string"
                    SelectedValue="_stockFilter"
                    SelectedValueChanged="OnStockFilterChanged"
                    CheckMark="true"
                    Variant="Variant.Text"
                    Color="Color.Secondary">
            <MudChip Value="@("All")" Default="true">All Stock</MudChip>
            <MudChip Value="@("InStock")" Color="Color.Success">In Stock</MudChip>
            <MudChip Value="@("OutOfStock")" Color="Color.Error">Out of Stock</MudChip>
        </MudChipSet>
    </MudItem>
        <!-- Search Box -->
        <MudItem xs="12">
            <MudTextField @bind-Value="_searchKeyword"
                          Placeholder="Search products..."
                          DebounceInterval="300"
                          OnDebounceIntervalElapsed="SearchProductsDebounce"
                          Adornment="Adornment.End"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Class="mb-4" />
        </MudItem>

        <!-- Product Grid -->
        @if (_products != null && _products.Any())
        {
            <MudItem xs="12">
                <MudGrid Spacing="3">
                    @foreach (var product in _products)
                    {
                        <MudItem xs="12" sm="6" md="4" lg="3">
                            <MudCard Class="h-100 d-flex flex-column" Style="transition: all 0.3s ease; cursor: pointer;">
                                <MudCardMedia Image="@(product.ImageUrl ?? "/images/placeholder.png")"
                                              Height="250" />
                                <MudCardContent Class="flex-grow-1">
                                    <MudGrid>
                                        <MudItem xs="12" sm="7">
                                            <MudText Typo="Typo.body2" Class="mb-1">
                                                <strong>@product.Name</strong>
                                            </MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Default">
                                                SKU: @product.Sku
                                            </MudText>
                                        </MudItem>
                                        <MudItem xs="12" sm="5" Class="text-sm-right">
                                            <MudText Typo="Typo.h6" Color="Color.Primary" Class="mb-0">
                                                @($"${product.UnitPrice:F2}")
                                            </MudText>
                                            @{var bal = GetProductBalance(product);}
                                            @if (bal <= 0)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Error" Class="pa-0 mt-1">Out of Stock</MudChip>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Balance: @bal</MudText>
                                            }
                                        </MudItem>
                                    </MudGrid>
                                </MudCardContent>
                                <MudCardActions>
                                    <MudButton Variant="Variant.Text"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               OnClick="@(() => OpenProductDetails(product))">
                                        Details
                                    </MudButton>
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               OnClick="@(() => QuickAddToCart(product))"
                                               Class="ml-auto">
                                        Add
                                    </MudButton>
                                </MudCardActions>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            </MudItem>
        }
        else if (_isLoading)
        {
            <MudItem xs="12">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </MudItem>
        }
        else
        {
            <MudItem xs="12">
                <MudAlert Severity="Severity.Info">No products found</MudAlert>
            </MudItem>
        }
    </MudGrid>

    <!-- Product Details Modal -->
    <MudDialog @bind-IsOpen="_showProductDetailsDialog">
        <TitleContent>
            <MudText Typo="Typo.h6">@_selectedProduct?.Name</MudText>
        </TitleContent>
        <DialogContent>
            @if (_selectedProduct != null)
            {
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudImage Src="@(_selectedProduct.ImageUrl ?? "/images/placeholder.png")"
                                  Alt="@_selectedProduct.Name"
                                  Style="width: 100%; border-radius: 8px;" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudText Typo="Typo.caption" Color="Color.Default">SKU: @_selectedProduct.Sku</MudText>
                        <MudText Typo="Typo.h5" Class="my-3">@($"${_selectedProduct.UnitPrice:F2}")</MudText>
                        <MudText Typo="Typo.body2" Class="mb-4">@_selectedProduct.Description</MudText>
                        
                        <MudStack>
                            <MudField Label="Unit of Measure">
                                <MudText>@_selectedProduct.UnitOfMeasure</MudText>
                            </MudField>
                            <MudField Label="Status">
                                <MudChip T="string" Size="Size.Small"
                                         Color="@(_selectedProduct.Status == "Active" ? Color.Success : Color.Error)">
                                    @_selectedProduct.Status
                                </MudChip>
                            </MudField>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _showProductDetailsDialog = false)">Close</MudButton>
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       OnClick="@(() => OpenAddToCartDialog(_selectedProduct))">
                Add to Basket
            </MudButton>
        </DialogActions>
    </MudDialog>

    <!-- Add to Cart Dialog -->
    <MudDialog @bind-IsOpen="_showAddToCartDialog">
        <TitleContent>
            <MudText Typo="Typo.h6">Add to Basket</MudText>
        </TitleContent>
        <DialogContent>
            @if (_selectedProductForCart != null)
            {
                <MudGrid>
                    <MudItem xs="12" sm="4">
                        <MudImage Src="@(_selectedProductForCart.ImageUrl ?? "/images/placeholder.png")"
                                  Alt="@_selectedProductForCart.Name"
                                  Style="width: 100%; border-radius: 4px;" />
                    </MudItem>
                    <MudItem xs="12" sm="8">
                        <MudText Typo="Typo.body2"><strong>@_selectedProductForCart.Name</strong></MudText>
                        <MudText Typo="Typo.caption" Color="Color.Default">Price: @($"${_selectedProductForCart.UnitPrice:F2}")</MudText>
                        <MudNumericField @bind-Value="_cartQuantity"
                                        Label="Quantity"
                                        Min="1"
                                        Class="my-3" />
                        <MudText Typo="Typo.h6">
                            Subtotal: @($"${(_selectedProductForCart.UnitPrice * _cartQuantity):F2}")
                        </MudText>
                    </MudItem>
                </MudGrid>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _showAddToCartDialog = false)">Cancel</MudButton>
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       OnClick="AddToCart">
                Add to Basket
            </MudButton>
        </DialogActions>
    </MudDialog>
</MudContainer>

@code {
    private List<ProductDto>? _products = new();
    private string _searchKeyword = "";
    private bool _isLoading = false;
    private int _cartItemCount = 0;
    private Guid? _warehouseLocationId = null;
    private Dictionary<Guid, int> _productBalances = new();

    private bool _showProductDetailsDialog = false;
    private ProductDto? _selectedProduct;

    private bool _showAddToCartDialog = false;
    private ProductDto? _selectedProductForCart;
    private int _cartQuantity = 1;

    private List<CategoryDto> _categories = new();
    private string _selectedCategory = "All"; // holds either "All" or Category.Id.ToString()
    private string _stockFilter = "All"; // "All", "InStock", "OutOfStock"

    private string _currentEmployeeId = string.Empty;

    private int GetProductBalance(ProductDto product)
    {
        return _productBalances.TryGetValue(product.Id, out var balance) ? balance : 0;
    }

    private Guid? _currentCartId;

    private async Task OnSearchTriggered()
    {
        await LoadProducts();
    }

    private async Task LoadCategories()
    {
        try 
        {
            _isLoading = true;
            // Use the same service and method from your Master Data page
            var response = await MasterDataService.GetCategoriesAsync(pageSize: 100);

            _categories = new List<CategoryDto>();
            if (response?.Items != null)
            {
                // Keep the full CategoryDto so we can map ids for filtering
                _categories = response.Items
                    .Where(x => !string.IsNullOrWhiteSpace(x.Name))
                    .ToList();
            }
        }
        catch (Exception)
        {
            _categories = new List<CategoryDto>();
            _snackbar.Add("Could not load categories", Severity.Warning);
        }
        finally
        {
            _isLoading = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true; // Start loading state
        await LoadCategories(); // MUST call this to see chips!
        await ResolveCurrentEmployeeContext();
        await GetOrCreateCart();
        await LoadProductBalancesAsync();
        await LoadProducts();
        _isLoading = false;
    }

    private async Task ResolveCurrentEmployeeContext()
    {
        try
        {
            var authState = await _authenticationStateProvider.GetAuthenticationStateAsync();
            var identityUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (string.IsNullOrWhiteSpace(identityUserId))
            {
                _snackbar.Add("Unable to resolve signed-in user identity.", Severity.Warning);
                return;
            }

            var employee = await _employeesClient.ByIdentityAsync(identityUserId);
            _currentEmployeeId = employee.Id.ToString();
        }
        catch (ApiException ex) when (ex.StatusCode == 404)
        {
            _snackbar.Add("No employee profile linked to this user. Please contact an administrator.", Severity.Warning);
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Failed to resolve employee context: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadProducts()
{
    try
    {
        _isLoading = true;

        // 1. Fetch products based on the search keyword
        var query = new SearchProductsQuery
        {
            Keyword = _searchKeyword,
            PageSize = 100 
        };

        var result = await _productsClient.SearchAsync(query);
        var allItems = result.Items?.ToList() ?? new List<ProductDto>();

        // 2. Apply the Category Filter locally
        // We compare the ProductDto.CategoryId (string) to our _selectedCategory (string)
        if (_selectedCategory != "All")
        {
            allItems = allItems
                .Where(p => string.Equals(p.CategoryId, _selectedCategory, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }

        _products = _stockFilter switch
        {
            "InStock"    => allItems.Where(p => GetProductBalance(p) > 0).ToList(),
            "OutOfStock" => allItems.Where(p => GetProductBalance(p) <= 0).ToList(),
            _            => allItems
        };
    }
    catch (Exception ex)
    {
        _snackbar.Add($"Error loading products: {ex.Message}", Severity.Error);
    }
    finally
    {
        _isLoading = false;
        // In Blazor, StateHasChanged is usually automatic after Task-based events, 
        // but it doesn't hurt to ensure the UI updates here.
    }
}
    private async Task OnCategoryChanged(string category)
    {
        _selectedCategory = string.IsNullOrEmpty(category) ? "All" : category;
        await LoadProducts();
    }

    private async Task OnStockFilterChanged(string filter)
    {
        _stockFilter = string.IsNullOrEmpty(filter) ? "All" : filter;
        await LoadProducts();
    }

    private async Task LoadProductBalancesAsync()
    {
        try
        {
            // Find a warehouse location from inventory data, if available.
            if (!_warehouseLocationId.HasValue || _warehouseLocationId == Guid.Empty)
            {
                var inventoryList = await _inventoryClient.SearchAsync(new SearchProductInventoryQuery
                {
                    PageNumber = 1,
                    PageSize = 1000
                });

                _warehouseLocationId = inventoryList.Items?.FirstOrDefault()?.WarehouseLocationId;
            }

            if (_warehouseLocationId.HasValue && _warehouseLocationId.Value != Guid.Empty)
            {
                var stockLevels = await _warehouseClient.StockLevelsAsync(_warehouseLocationId.Value, pageNumber: 1, pageSize: 1000);
                _productBalances = stockLevels.Items?.ToDictionary(i => i.ProductId, i => i.QuantityAvailable) ?? new Dictionary<Guid, int>();
            }
            else
            {
                _productBalances.Clear();
            }
        }
        catch (Exception ex)
        {
            // fallback: show product minimum stock level as balance
            _snackbar.Add($"Unable to load warehouse balance; fallback to product minimum stock: {ex.Message}", Severity.Warning);
            _productBalances.Clear();
        }
    }


    private async Task GetOrCreateCart()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(_currentEmployeeId))
            {
                _currentCartId = null;
                _cartItemCount = 0;
                return;
            }

            var cart = await _employeeClient.CartAsync(_currentEmployeeId);
            _currentCartId = cart.Id;
            _cartItemCount = cart.Items?.Count ?? 0;
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Error loading basket: {ex.Message}", Severity.Error);
        }
    }

    private async Task SearchProducts(ElapsedEventArgs args)
    {
        await LoadProducts();
    }

    private async Task SearchProductsDebounce()
    {
        await LoadProducts();
    }

    private void OpenProductDetails(ProductDto? product)
    {
        if (product != null)
        {
            _selectedProduct = product;
            _showProductDetailsDialog = true;
        }
    }

    private void OpenAddToCartDialog(ProductDto? product)
    {
        if (product != null)
        {
            _selectedProductForCart = product;
            _cartQuantity = 1;
            _showProductDetailsDialog = false;
            _showAddToCartDialog = true;
        }
    }

    private async Task QuickAddToCart(ProductDto? product)
    {
        if (product == null || !_currentCartId.HasValue)
            return;

        try
        {
            var command = new AddToCartCommand
            {
                CartId = _currentCartId.Value,
                ProductId = product.Id,
                Quantity = 1,
                UnitPrice = product.UnitPrice
            };

            await _cartClient.ItemsPostAsync(_currentCartId.Value, command);
            await GetOrCreateCart();
            _snackbar.Add($"Added {product.Name} to basket!", Severity.Success);
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Error adding to basket: {ex.Message}", Severity.Error);
        }
    }

    private async Task AddToCart()
    {
        if (_selectedProductForCart == null || !_currentCartId.HasValue)
            return;

        try
        {
            var command = new AddToCartCommand
            {
                CartId = _currentCartId.Value,
                ProductId = _selectedProductForCart.Id,
                Quantity = _cartQuantity,
                UnitPrice = _selectedProductForCart.UnitPrice
            };

            await _cartClient.ItemsPostAsync(_currentCartId.Value, command);
            await GetOrCreateCart();
            _snackbar.Add("Item added to basket!", Severity.Success);
            _showAddToCartDialog = false;
        }
        catch (Exception ex)
        {
            _snackbar.Add($"Error adding to basket: {ex.Message}", Severity.Error);
        }
    }
}
