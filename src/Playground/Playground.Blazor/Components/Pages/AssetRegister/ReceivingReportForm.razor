@using AMIS.Playground.Blazor.ApiClient
@using Microsoft.AspNetCore.Components.Authorization
@using ReceivingDocumentKind = AMIS.Modules.AssetRegister.Contracts.v1.ReceivingDocumentKind
@using ReceiptType = AMIS.Modules.AssetRegister.Contracts.v1.ReceiptType
@using System.Security.Claims
@inject IArReceivingReportClient Client
@inject IArReceivingReportClient ArReceivingReportClient
@inject ILookupClient LookupClient
@inject IEmployeesClient EmployeesClient
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ISnackbar Snackbar

<MudCard Elevation="2">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">@Title</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        <MudGrid Spacing="2">
            <MudItem xs="12" md="3">
                <MudDatePicker @bind-Date="_date" Label="Date" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect @bind-Value="_receiptType" Label="Type" Variant="Variant.Outlined" T="ReceiptType" Required="true">
                    <MudSelectItem T="ReceiptType" Value="@ReceiptType.Purchase">Purchase</MudSelectItem>
                    <MudSelectItem T="ReceiptType" Value="@ReceiptType.Transfer">Transfer</MudSelectItem>
                    <MudSelectItem T="ReceiptType" Value="@ReceiptType.Donation">Donation</MudSelectItem>
                    <MudSelectItem T="ReceiptType" Value="@ReceiptType.Other">Other</MudSelectItem>
                </MudSelect>
            </MudItem>
            @if (_receiptType == ReceiptType.Other)
            {
                <MudItem xs="12" md="3">
                    <MudTextField @bind-Value="_otherReceiptType" Label="Specify Other" Variant="Variant.Outlined" Required="true" />
                </MudItem>
            }
            <MudItem xs="12" md="3">
                <MudTextField @bind-Value="_fundCluster" Label="Fund Cluster" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_receivedFrom" Label="Received From" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_address" Label="Address" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField Value="@(_receivedBy is null ? "Loading..." : FormatEmployee(_receivedBy))"
                              Label="Received By" Variant="Variant.Outlined" ReadOnly="true"
                              HelperText="Auto-assigned to the currently logged-in user" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudAutocomplete T="EmployeeReferenceDto" @bind-Value="_notedBy" Label="Noted By (Head of Office)" Variant="Variant.Outlined"
                                 SearchFunc="SearchEmployeesAsync" ToStringFunc="FormatEmployee"
                                 CoerceText="false" />
            </MudItem>
            @if (DocumentKind == ReceivingDocumentKind.SMRR)
            {
                <MudItem xs="12" md="3">
                    <MudDatePicker @bind-Date="_dateReceived" Label="Date Received" Variant="Variant.Outlined" />
                </MudItem>
            }

            <MudItem xs="12">
                <MudDivider Class="my-2" />
                <MudText Typo="Typo.subtitle1" Class="mb-2">Items</MudText>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudAutocomplete T="SupplierInfo" Value="_selectedSupplier"
                                 ValueChanged="@(async s => await OnSupplierSelectedAsync(s))"
                                 Label="Supplier" Variant="Variant.Outlined"
                                 SearchFunc="SearchSuppliersAsync"
                                 ToStringFunc="@(s => s?.Name ?? string.Empty)"
                                 CoerceText="false"
                                 HelperText="Search supplier to load available IAR items below" />
            </MudItem>

            @if (_loadingItems)
            {
                <MudItem xs="12">
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                </MudItem>
            }
            else if (_availableItems.Count > 0)
            {
                <MudItem xs="12">
                    <MudTable T="AcceptedIARLineItemDto" Items="_availableItems"
                              MultiSelection="true" @bind-SelectedItems="_selectedItems"
                              Dense="true" Hover="true" Elevation="0"
                              Style="background: var(--mud-palette-surface);">
                        <HeaderContent>
                            <MudTh>Property No</MudTh>
                            <MudTh>Description</MudTh>
                            <MudTh>Date Acquired</MudTh>
                            <MudTh Style="text-align:right">Unit Cost</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Property No"><MudText Typo="Typo.body2">@context.StockPropertyNo</MudText></MudTd>
                            <MudTd DataLabel="Description"><MudText Typo="Typo.body2">@context.Description</MudText></MudTd>
                            <MudTd DataLabel="Date Acquired"><MudText Typo="Typo.body2">@context.IARDate.ToString("yyyy-MM-dd")</MudText></MudTd>
                            <MudTd DataLabel="Unit Cost" Style="text-align:right"><MudText Typo="Typo.body2">@context.UnitCost.ToString("N2")</MudText></MudTd>
                        </RowTemplate>
                    </MudTable>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                        @_selectedItems.Count of @_availableItems.Count item(s) selected
                    </MudText>
                </MudItem>
            }
            else if (_selectedSupplier is not null && !_loadingItems)
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">
                        No accepted IAR items found for this supplier.
                    </MudText>
                </MudItem>
            }

            <MudItem xs="12" Class="d-flex justify-end">
                <MudButton OnClick="OnCancel" Variant="Variant.Text" Class="mr-2">Cancel</MudButton>
                <MudButton OnClick="SaveAsync" Variant="Variant.Filled" Color="Color.Success"
                           Disabled="_busy" StartIcon="@Icons.Material.Outlined.Save">
                    @(_busy ? "Saving..." : "Save")
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public ReceivingDocumentKind DocumentKind { get; set; }
    [Parameter] public string Title { get; set; } = "Create Receiving Report";
    [Parameter] public EventCallback<ArReceivingReportDto> OnCreated { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private sealed record SupplierInfo(string Name, string? Address);

    private DateTime? _date = DateTime.Today;
    private ReceiptType _receiptType;
    private string? _otherReceiptType;
    private string? _fundCluster;
    private string _receivedFrom = string.Empty;
    private string? _address;
    private EmployeeReferenceDto? _receivedBy;
    private EmployeeReferenceDto? _notedBy;
    private DateTime? _dateReceived;
    private bool _busy;
    private bool _loadingItems;

    private SupplierInfo? _selectedSupplier;
    private readonly List<AcceptedIARLineItemDto> _availableItems = [];
    private HashSet<AcceptedIARLineItemDto> _selectedItems = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var identityUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrWhiteSpace(identityUserId))
                _receivedBy = await EmployeesClient.ByIdentityAsync(identityUserId);
        }
        catch
        {
            Snackbar.Add("Could not load current user employee record.", Severity.Warning);
        }
    }

    private static string FormatEmployee(EmployeeReferenceDto? e) =>
        e is null ? string.Empty : $"{e.LastName}, {e.FirstName} ({e.EmployeeNumber})";

    private static string PrintedName(EmployeeReferenceDto e) => $"{e.FirstName} {e.LastName}".Trim();

    private async Task<IEnumerable<SupplierInfo>> SearchSuppliersAsync(string value, CancellationToken ct)
    {
        try
        {
            var res = await ArReceivingReportClient.SearchAcceptedIARItemsAsync(value, page: 1, pageSize: 100, ct: ct);
            return (res?.Items ?? [])
                .GroupBy(x => x.SupplierName, StringComparer.OrdinalIgnoreCase)
                .Select(g => new SupplierInfo(g.Key, g.First().SupplierAddress))
                .ToList();
        }
        catch { return []; }
    }

    private async Task OnSupplierSelectedAsync(SupplierInfo? supplier)
    {
        _selectedSupplier = supplier;
        _availableItems.Clear();
        _selectedItems = [];

        if (supplier is null) return;

        _receivedFrom = supplier.Name;
        _address = supplier.Address;

        _loadingItems = true;
        try
        {
            var res = await ArReceivingReportClient.SearchAcceptedIARItemsAsync(
                supplier.Name, page: 1, pageSize: 200);
            _availableItems.AddRange(res?.Items ?? []);
        }
        catch
        {
            Snackbar.Add("Failed to load IAR items for this supplier.", Severity.Error);
        }
        finally { _loadingItems = false; }
    }

    private async Task<IEnumerable<EmployeeReferenceDto>> SearchEmployeesAsync(string value, CancellationToken ct)
    {
        try
        {
            var result = await LookupClient.EmployeesGetAsync(
                keyword: string.IsNullOrWhiteSpace(value) ? null : value,
                isActive: true, pageNumber: 1, pageSize: 20, cancellationToken: ct);
            return result?.Items ?? [];
        }
        catch { return []; }
    }

    private async Task SaveAsync()
    {
        if (_date is null)
        {
            Snackbar.Add("Date is required.", Severity.Warning);
            return;
        }
        if (_receivedBy is null)
        {
            Snackbar.Add("Could not determine the current user. Please refresh and try again.", Severity.Warning);
            return;
        }
        if (string.IsNullOrWhiteSpace(_receivedFrom))
        {
            Snackbar.Add("Received From is required.", Severity.Warning);
            return;
        }
        if (_selectedItems.Count == 0)
        {
            Snackbar.Add("Select at least one item to register.", Severity.Warning);
            return;
        }

        _busy = true;
        try
        {
            var request = new CreateReceivingReportRequest(
                DocumentKind,
                DateOnly.FromDateTime(_date.Value),
                _receivedFrom,
                _address,
                _receiptType,
                _receiptType == ReceiptType.Other ? _otherReceiptType : null,
                _fundCluster,
                new ArEmployeeRefDto(_receivedBy.Id, PrintedName(_receivedBy), _receivedBy.PositionName),
                _notedBy is null ? null : new ArEmployeeRefDto(_notedBy.Id, PrintedName(_notedBy), _notedBy.PositionName),
                _dateReceived is null ? null : DateOnly.FromDateTime(_dateReceived.Value),
                _selectedItems.Select(item => new CreateReceivingReportItemRequest(
                    CatalogItemId: null,
                    Reference: item.IARNumber,
                    Description: item.Description,
                    AcquisitionDate: item.IARDate,
                    UnitCost: item.UnitCost,
                    PropertyNo: item.StockPropertyNo!,
                    SerialNo: item.SerialNo,
                    Brand: item.Brand,
                    Model: item.Model,
                    SourceIARId: item.IARId,
                    PropertyClassHint: item.PropertyClassHint)).ToList());

            var created = await Client.CreateAsync(request);
            await OnCreated.InvokeAsync(created);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
        finally { _busy = false; }
    }
}
