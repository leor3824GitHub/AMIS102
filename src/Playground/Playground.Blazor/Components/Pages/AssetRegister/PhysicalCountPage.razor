@page "/asset-register/physical-count"
@using AMIS.Playground.Blazor.ApiClient
@using PhysicalCountStatus = AMIS.Modules.AssetRegister.Contracts.v1.PhysicalCountStatus
@using PhysicalCountScope = AMIS.Modules.AssetRegister.Contracts.v1.PhysicalCountScope
@using PhysicalCountCondition = AMIS.Modules.AssetRegister.Contracts.v1.PhysicalCountCondition
@inject IArPhysicalCountClient Client
@inject ISnackbar Snackbar

<AMISPageHeader Title="Physical Count Sessions (RPCSEMEX / RPCPPE)"
               Description="Manage physical count sessions per COA 2022-004. Produces RPCSEMEX (SE) and RPCPPE (PPE) reports." />

<MudGrid Spacing="3">
    <!-- Filters -->
    <MudItem xs="12">
        <MudCard Elevation="1">
            <MudCardContent>
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="_keyword" Label="Session Code" Variant="Variant.Outlined"
                                      Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Outlined.Search"
                                      OnKeyDown="OnSearchKeyDown" Immediate="false" />
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudSelect @bind-Value="_statusFilter" Label="Status" Variant="Variant.Outlined" T="PhysicalCountStatus?" Clearable="true">
                            <MudSelectItem Value="@((PhysicalCountStatus?)null)">All</MudSelectItem>
                            <MudSelectItem Value="@((PhysicalCountStatus?)PhysicalCountStatus.Ongoing)">Ongoing</MudSelectItem>
                            <MudSelectItem Value="@((PhysicalCountStatus?)PhysicalCountStatus.Reconciled)">Reconciled</MudSelectItem>
                            <MudSelectItem Value="@((PhysicalCountStatus?)PhysicalCountStatus.Closed)">Closed</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudSelect @bind-Value="_scopeFilter" Label="Scope" Variant="Variant.Outlined" T="PhysicalCountScope?" Clearable="true">
                            <MudSelectItem Value="@((PhysicalCountScope?)null)">All</MudSelectItem>
                            <MudSelectItem Value="@((PhysicalCountScope?)PhysicalCountScope.SEOnly)">Semi-Expendable</MudSelectItem>
                            <MudSelectItem Value="@((PhysicalCountScope?)PhysicalCountScope.PPEOnly)">PPE</MudSelectItem>
                            <MudSelectItem Value="@((PhysicalCountScope?)PhysicalCountScope.Both)">All Assets</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="2" Class="d-flex align-end">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                   StartIcon="@Icons.Material.Outlined.Search" OnClick="LoadAsync" Disabled="_busy">
                            Search
                        </MudButton>
                    </MudItem>
                    <MudItem xs="12" md="2" Class="d-flex align-end">
                        <MudButton Variant="Variant.Outlined" Color="Color.Success" FullWidth="true"
                                   StartIcon="@Icons.Material.Outlined.PlayCircle" OnClick="@(() => _showStartForm = true)">
                            Start Session
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- Start Form -->
    @if (_showStartForm)
    {
        <MudItem xs="12" md="5">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent><MudText Typo="Typo.h6">Start Physical Count Session</MudText></CardHeaderContent>
                    <CardHeaderActions>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                       OnClick="@(() => _showStartForm = false)" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudStack Spacing="2">
                        <MudTextField @bind-Value="_startForm.Code" Label="Session Code" Variant="Variant.Outlined"
                                      MaxLength="50" Required="true" Placeholder="e.g. PC-2026-Q1-SE" />
                        <MudSelect @bind-Value="_startForm.Scope" Label="Scope" Variant="Variant.Outlined" T="PhysicalCountScope" Required="true">
                            <MudSelectItem T="PhysicalCountScope" Value="@PhysicalCountScope.SEOnly">Semi-Expendable (RPCSEMEX)</MudSelectItem>
                            <MudSelectItem T="PhysicalCountScope" Value="@PhysicalCountScope.PPEOnly">PPE (RPCPPE)</MudSelectItem>
                            <MudSelectItem T="PhysicalCountScope" Value="@PhysicalCountScope.Both">All Assets</MudSelectItem>
                        </MudSelect>
                        <MudTextField @bind-Value="_startForm.FundCluster" Label="Fund Cluster" Variant="Variant.Outlined"
                                      MaxLength="50" Required="true" />
                        <MudDatePicker @bind-Date="_startForm.AsAtNullable" Label="As At Date" Variant="Variant.Outlined"
                                       DateFormat="MM/dd/yyyy" Required="true" />
                        <MudDatePicker @bind-Date="_startForm.StartedOnNullable" Label="Started On" Variant="Variant.Outlined"
                                       DateFormat="MM/dd/yyyy" Required="true" />
                        <MudTextField @bind-Value="_startForm.Remarks" Label="Remarks (optional)" Variant="Variant.Outlined"
                                      Lines="2" MaxLength="500" />
                        <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true"
                                   OnClick="StartSessionAsync" Disabled="_busy">
                            Start Session
                        </MudButton>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }

    <!-- Results -->
    <MudItem xs="12">
        <MudCard Elevation="1">
            <MudCardContent>
                @if (_busy)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else if (!string.IsNullOrEmpty(_error))
                {
                    <MudAlert Severity="Severity.Error" Dense="true">@_error</MudAlert>
                }
                else
                {
                    <MudTable Items="_items" Dense="true" Hover="true" Striped="true"
                              OnRowClick="OnRowClick" T="ArPhysicalCountSummaryDto" RowClass="cursor-pointer">
                        <HeaderContent>
                            <MudTh>Code</MudTh>
                            <MudTh>Scope</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>As At</MudTh>
                            <MudTh>Started On</MudTh>
                            <MudTh>Closed On</MudTh>
                            <MudTh Style="text-align:right">Entries</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><strong>@context.Code</strong></MudTd>
                            <MudTd>@FormatScope(context.Scope)</MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small"
                                         Color="@CountStatusColor(context.Status)"
                                         Variant="Variant.Filled">
                                    @FormatCountStatus(context.Status)
                                </MudChip>
                            </MudTd>
                            <MudTd>@context.AsAt.ToString("yyyy-MM-dd")</MudTd>
                            <MudTd>@context.StartedOn.ToString("yyyy-MM-dd")</MudTd>
                            <MudTd>@(context.ClosedOn?.ToString("yyyy-MM-dd") ?? "—")</MudTd>
                            <MudTd Style="text-align:right">@context.EntryCount</MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <MudText Color="Color.Secondary">No physical count sessions found.</MudText>
                        </NoRecordsContent>
                    </MudTable>

                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mt-3">
                        <MudText Typo="Typo.caption">Page @_page of @_totalPages (@_totalCount total)</MudText>
                        <MudStack Row="true" Spacing="1">
                            <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Size="Size.Small"
                                           Disabled="_page <= 1 || _busy" OnClick="PrevPage" />
                            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small"
                                           Disabled="_page >= _totalPages || _busy" OnClick="NextPage" />
                        </MudStack>
                    </MudStack>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- Detail Panel -->
    @if (_selected is not null)
    {
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudText Typo="Typo.h6">Session: @_selected.Code</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@CountStatusColor(_selected.Status)" Variant="Variant.Filled">
                                @FormatCountStatus(_selected.Status)
                            </MudChip>
                        </MudStack>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                       OnClick="@(() => _selected = null)" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Class="mb-3">
                        <MudItem xs="6" md="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Scope</MudText>
                            <MudText Typo="Typo.body2">@FormatScope(_selected.Scope)</MudText>
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Fund Cluster</MudText>
                            <MudText Typo="Typo.body2">@_selected.FundCluster</MudText>
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">As At</MudText>
                            <MudText Typo="Typo.body2">@_selected.AsAt.ToString("yyyy-MM-dd")</MudText>
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Conducted By</MudText>
                            <MudText Typo="Typo.body2">@string.Join(", ", _selected.ConductedBy.Select(c => c.PrintedName))</MudText>
                        </MudItem>
                        @if (_selected.ApprovedBy is not null)
                        {
                            <MudItem xs="6" md="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Approved By</MudText>
                                <MudText Typo="Typo.body2">@_selected.ApprovedBy.PrintedName</MudText>
                            </MudItem>
                        }
                        @if (!string.IsNullOrEmpty(_selected.Remarks))
                        {
                            <MudItem xs="12">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Remarks</MudText>
                                <MudText Typo="Typo.body2">@_selected.Remarks</MudText>
                            </MudItem>
                        }
                    </MudGrid>

                    <!-- Entries summary -->
                    <MudText Typo="Typo.subtitle2" Class="mb-2">
                        Count Entries (@_selected.Entries.Count)
                        <MudLink Href="@($"/asset-register/reports?sessionId={_selected.Id}")" Class="ml-2" Typo="Typo.caption">
                            View Full Report ?
                        </MudLink>
                    </MudText>

                    <MudTable Items="_selected.Entries.Take(10)" Dense="true" Striped="true">
                        <HeaderContent>
                            <MudTh>Property No.</MudTh>
                            <MudTh>Article</MudTh>
                            <MudTh>Unit</MudTh>
                            <MudTh Style="text-align:right">Unit Cost (?)</MudTh>
                            <MudTh>Condition</MudTh>
                            <MudTh>Scanned On</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@(context.Snapshot?.PropertyNo ?? "—")</MudTd>
                            <MudTd>@context.SnapshotArticle</MudTd>
                            <MudTd>@context.SnapshotUnit</MudTd>
                            <MudTd Style="text-align:right">@context.SnapshotUnitCost.ToString("N2")</MudTd>
                            <MudTd>@FormatCountCondition(context.Condition)</MudTd>
                            <MudTd>@(context.ScannedOnUtc?.LocalDateTime.ToString("yyyy-MM-dd HH:mm") ?? "—")</MudTd>
                        </RowTemplate>
                    </MudTable>
                    @if (_selected.Entries.Count > 10)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                            Showing first 10 of @_selected.Entries.Count entries.
                        </MudText>
                    }

                    <!-- Close session (only if Ongoing) -->
                    @if (_selected.Status == PhysicalCountStatus.Ongoing)
                    {
                        <MudDivider Class="my-3" />
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Close Session</MudText>
                        <MudGrid Spacing="2">
                            <MudItem xs="12" md="4">
                                <MudTextField @bind-Value="_closeForm.ApprovedByName" Label="Approved By (Name)" Variant="Variant.Outlined" MaxLength="100" Required="true" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField @bind-Value="_closeForm.ApprovedByDesignation" Label="Designation" Variant="Variant.Outlined" MaxLength="100" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudDatePicker @bind-Date="_closeForm.ClosedOnNullable" Label="Closed On" Variant="Variant.Outlined" DateFormat="MM/dd/yyyy" Required="true" />
                            </MudItem>
                            <MudItem xs="12" md="3" Class="d-flex align-end">
                                <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true"
                                           OnClick="CloseSessionAsync" Disabled="_busy">
                                    Close Session
                                </MudButton>
                            </MudItem>
                        </MudGrid>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    private bool _busy;
    private string? _error;
    private string? _keyword;
    private PhysicalCountStatus? _statusFilter;
    private PhysicalCountScope? _scopeFilter;
    private int _page = 1;
    private int _totalPages = 1;
    private int _totalCount;
    private const int PageSize = 15;
    private IReadOnlyList<ArPhysicalCountSummaryDto> _items = [];
    private ArPhysicalCountSessionDto? _selected;
    private bool _showStartForm;

    private StartFormModel _startForm = new();
    private CloseFormModel _closeForm = new();

    private sealed class StartFormModel
    {
        public string Code { get; set; } = "";
        public PhysicalCountScope Scope { get; set; }
        public string FundCluster { get; set; } = "";
        public DateTime? AsAtNullable { get; set; }
        public DateTime? StartedOnNullable { get; set; }
        public string? Remarks { get; set; }
    }

    private sealed class CloseFormModel
    {
        public string ApprovedByName { get; set; } = "";
        public string? ApprovedByDesignation { get; set; }
        public DateTime? ClosedOnNullable { get; set; }
    }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var result = await Client.SearchAsync(_keyword, _statusFilter, _scopeFilter, _page, PageSize);
            _items = result.Items;
            _totalCount = result.TotalCount;
            _totalPages = result.TotalPages > 0 ? result.TotalPages : 1;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task OnRowClick(TableRowClickEventArgs<ArPhysicalCountSummaryDto> args)
    {
        _busy = true;
        try
        {
            _selected = await Client.GetAsync(args.Item.Id);
            _closeForm = new();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task StartSessionAsync()
    {
        if (string.IsNullOrWhiteSpace(_startForm.Code) || !_startForm.AsAtNullable.HasValue || !_startForm.StartedOnNullable.HasValue)
        {
            Snackbar.Add("Code, As At date, and Started On are required.", Severity.Warning);
            return;
        }

        _busy = true;
        try
        {
            var req = new StartPhysicalCountRequest(
                _startForm.Code.Trim(),
                _startForm.Scope,
                _startForm.FundCluster,
                DateOnly.FromDateTime(_startForm.AsAtNullable.Value),
                DateOnly.FromDateTime(_startForm.StartedOnNullable.Value),
                [],
                _startForm.Remarks);

            await Client.StartAsync(req);
            Snackbar.Add("Physical count session started.", Severity.Success);
            _showStartForm = false;
            _startForm = new();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task CloseSessionAsync()
    {
        if (_selected is null) return;
        if (string.IsNullOrWhiteSpace(_closeForm.ApprovedByName) || !_closeForm.ClosedOnNullable.HasValue)
        {
            Snackbar.Add("Approved By and Closed On are required.", Severity.Warning);
            return;
        }

        _busy = true;
        try
        {
            var approvedBy = new ArEmployeeRefDto(Guid.Empty, _closeForm.ApprovedByName.Trim(), _closeForm.ApprovedByDesignation);
            var req = new ClosePhysicalCountRequest(approvedBy, null, DateOnly.FromDateTime(_closeForm.ClosedOnNullable.Value));
            _selected = await Client.CloseAsync(_selected.Id, req);
            Snackbar.Add("Session closed.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task PrevPage() { _page--; await LoadAsync(); }
    private async Task NextPage() { _page++; await LoadAsync(); }
    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { _page = 1; await LoadAsync(); }
    }

    private static string FormatScope(PhysicalCountScope v) => v switch
    {
        PhysicalCountScope.PPEOnly => "PPE",
        PhysicalCountScope.SEOnly => "Semi-Expendable",
        PhysicalCountScope.Both => "All Assets",
        _ => v.ToString()
    };
    private static string FormatCountStatus(PhysicalCountStatus v) => v switch
    {
        PhysicalCountStatus.Ongoing => "Ongoing",
        PhysicalCountStatus.Reconciled => "Reconciled",
        PhysicalCountStatus.Closed => "Closed",
        _ => v.ToString()
    };
    private static Color CountStatusColor(PhysicalCountStatus v) => v switch
    {
        PhysicalCountStatus.Ongoing => Color.Info,
        PhysicalCountStatus.Reconciled => Color.Warning,
        PhysicalCountStatus.Closed => Color.Success,
        _ => Color.Default
    };
    private static string FormatCountCondition(PhysicalCountCondition v) => v switch
    {
        PhysicalCountCondition.InGoodCondition => "Good",
        PhysicalCountCondition.NeedingRepair => "Needs Repair",
        PhysicalCountCondition.Unserviceable => "Unserviceable",
        PhysicalCountCondition.Missing => "Missing",
        PhysicalCountCondition.FoundAtStation => "Found at Station",
        _ => v.ToString()
    };
}

