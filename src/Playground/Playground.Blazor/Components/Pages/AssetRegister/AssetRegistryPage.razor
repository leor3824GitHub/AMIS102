@page "/asset-register/assets"
@using FSH.Playground.Blazor.ApiClient
@inject IAssetRegistryClient Client
@inject ISnackbar Snackbar

<FshPageHeader Title="Asset Registry"
               Description="Master ledger of individual physical units — one row per asset (COA 2020-006, 2022-004)." />

<MudGrid Spacing="3">
    <!-- Search filters -->
    <MudItem xs="12">
        <MudCard Elevation="1">
            <MudCardContent>
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="_keyword" Label="Keyword / Property No." Variant="Variant.Outlined"
                                      Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Outlined.Search"
                                      OnKeyDown="OnSearchKeyDown" Immediate="false" />
                    </MudItem>
                    <MudItem xs="6" md="3">
                        <MudSelect @bind-Value="_assetTypeFilter" Label="Asset Type" Variant="Variant.Outlined" T="int?" Clearable="true">
                            <MudSelectItem Value="@((int?)null)">All</MudSelectItem>
                            <MudSelectItem Value="@((int?)0)">SE (Semi-Expendable)</MudSelectItem>
                            <MudSelectItem Value="@((int?)1)">PPE (Property, Plant & Equipment)</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" md="3">
                        <MudSelect @bind-Value="_lifecycleFilter" Label="Lifecycle State" Variant="Variant.Outlined" T="int?" Clearable="true">
                            <MudSelectItem Value="@((int?)null)">All</MudSelectItem>
                            <MudSelectItem Value="@((int?)0)">InStock</MudSelectItem>
                            <MudSelectItem Value="@((int?)1)">Issued</MudSelectItem>
                            <MudSelectItem Value="@((int?)2)">UnderInvestigation</MudSelectItem>
                            <MudSelectItem Value="@((int?)3)">Unserviceable</MudSelectItem>
                            <MudSelectItem Value="@((int?)4)">Disposed</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="2" Class="d-flex align-end">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                   StartIcon="@Icons.Material.Outlined.Search" OnClick="LoadAsync" Disabled="_busy">
                            Search
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- Results table -->
    <MudItem xs="12">
        <MudCard Elevation="1">
            <MudCardContent>
                @if (_busy)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else if (!string.IsNullOrEmpty(_error))
                {
                    <MudAlert Severity="Severity.Error" Dense="true">@_error</MudAlert>
                }
                else
                {
                    <MudTable Items="_items" Dense="true" Hover="true" Striped="true"
                              OnRowClick="OnRowClick" T="AssetRegistrySummaryDto" RowClass="cursor-pointer">
                        <HeaderContent>
                            <MudTh>Property No.</MudTh>
                            <MudTh>Type</MudTh>
                            <MudTh>Description</MudTh>
                            <MudTh>Acquisition Date</MudTh>
                            <MudTh Style="text-align:right">Unit Cost (₱)</MudTh>
                            <MudTh>Lifecycle</MudTh>
                            <MudTh>Condition</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <MudText Typo="Typo.body2"><strong>@context.PropertyNo</strong></MudText>
                            </MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small"
                                         Color="@(context.AssetType == 0 ? Color.Info : Color.Secondary)"
                                         Variant="Variant.Outlined">
                                    @FormatAssetType(context.AssetType)
                                </MudChip>
                            </MudTd>
                            <MudTd>@context.Description</MudTd>
                            <MudTd>@context.AcquisitionDate.ToString("yyyy-MM-dd")</MudTd>
                            <MudTd Style="text-align:right">@context.UnitCost.ToString("N2")</MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small"
                                         Color="@LifecycleColor(context.LifecycleState)"
                                         Variant="Variant.Filled">
                                    @FormatLifecycle(context.LifecycleState)
                                </MudChip>
                            </MudTd>
                            <MudTd>@FormatCondition(context.CurrentCondition)</MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <MudText Color="Color.Secondary">No assets found.</MudText>
                        </NoRecordsContent>
                    </MudTable>

                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mt-3">
                        <MudText Typo="Typo.caption">
                            Page @_page of @_totalPages (@_totalCount total records)
                        </MudText>
                        <MudStack Row="true" Spacing="1">
                            <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Size="Size.Small"
                                           Disabled="_page <= 1 || _busy" OnClick="PrevPage" />
                            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small"
                                           Disabled="_page >= _totalPages || _busy" OnClick="NextPage" />
                        </MudStack>
                    </MudStack>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- Detail panel -->
    @if (_selected is not null)
    {
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@_selected.PropertyNo — Detail</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                       OnClick="@(() => _selected = null)" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid>
                        <MudItem xs="12" md="4">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Description</MudText>
                            <MudText Typo="Typo.body2">@_selected.Description</MudText>
                        </MudItem>
                        <MudItem xs="6" md="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Asset Type</MudText>
                            <MudText Typo="Typo.body2">@FormatAssetType(_selected.AssetType)</MudText>
                        </MudItem>
                        <MudItem xs="6" md="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Category</MudText>
                            <MudText Typo="Typo.body2">@FormatCategory(_selected.Category)</MudText>
                        </MudItem>
                        <MudItem xs="6" md="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Fund Cluster</MudText>
                            <MudText Typo="Typo.body2">@_selected.FundCluster</MudText>
                        </MudItem>
                        <MudItem xs="6" md="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">UACS Object Code</MudText>
                            <MudText Typo="Typo.body2">@(_selected.UacsObjectCode ?? "—")</MudText>
                        </MudItem>
                        <MudItem xs="6" md="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Unit Cost (₱)</MudText>
                            <MudText Typo="Typo.body2">@_selected.UnitCost.ToString("N2")</MudText>
                        </MudItem>
                        <MudItem xs="6" md="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Carrying Amount (₱)</MudText>
                            <MudText Typo="Typo.body2">@_selected.CarryingAmount.ToString("N2")</MudText>
                        </MudItem>
                        <MudItem xs="6" md="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Accum. Depreciation (₱)</MudText>
                            <MudText Typo="Typo.body2">@_selected.AccumulatedDepreciation.ToString("N2")</MudText>
                        </MudItem>
                        <MudItem xs="6" md="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Useful Life (years)</MudText>
                            <MudText Typo="Typo.body2">@_selected.EstimatedUsefulLifeYears</MudText>
                        </MudItem>
                        @if (_selected.SerialNo is not null)
                        {
                            <MudItem xs="6" md="2">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Serial No.</MudText>
                                <MudText Typo="Typo.body2">@_selected.SerialNo</MudText>
                            </MudItem>
                        }
                        @if (_selected.Brand is not null)
                        {
                            <MudItem xs="6" md="2">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Brand / Model</MudText>
                                <MudText Typo="Typo.body2">@_selected.Brand @_selected.Model</MudText>
                            </MudItem>
                        }
                        <MudItem xs="6" md="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Lifecycle</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@LifecycleColor(_selected.LifecycleState)" Variant="Variant.Filled">
                                @FormatLifecycle(_selected.LifecycleState)
                            </MudChip>
                        </MudItem>
                        <MudItem xs="6" md="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Condition</MudText>
                            <MudText Typo="Typo.body2">@FormatCondition(_selected.CurrentCondition)</MudText>
                        </MudItem>
                        @if (_selected.CurrentCustodianId.HasValue)
                        {
                            <MudItem xs="6" md="2">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Custodian Id</MudText>
                                <MudText Typo="Typo.body2">@_selected.CurrentCustodianId</MudText>
                            </MudItem>
                        }
                        @if (_selected.CurrentAccountabilityId.HasValue)
                        {
                            <MudItem xs="12" md="4">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Current Accountability</MudText>
                                <MudLink Href="@($"/asset-register/accountability?id={_selected.CurrentAccountabilityId}")">
                                    @_selected.CurrentAccountabilityId
                                </MudLink>
                            </MudItem>
                        }
                    </MudGrid>

                    <!-- Update condition inline -->
                    <MudDivider Class="my-3" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Update Condition</MudText>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End">
                        <MudSelect @bind-Value="_newCondition" Label="New Condition" Variant="Variant.Outlined" T="int" Style="min-width:200px;">
                            <MudSelectItem Value="0">Good</MudSelectItem>
                            <MudSelectItem Value="1">Fair</MudSelectItem>
                            <MudSelectItem Value="2">Poor</MudSelectItem>
                            <MudSelectItem Value="3">Unserviceable</MudSelectItem>
                        </MudSelect>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                   OnClick="UpdateConditionAsync" Disabled="_busy">
                            Save Condition
                        </MudButton>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    private bool _busy;
    private string? _error;
    private string? _keyword;
    private int? _assetTypeFilter;
    private int? _lifecycleFilter;
    private int _page = 1;
    private int _totalPages = 1;
    private int _totalCount;
    private const int PageSize = 15;
    private IReadOnlyList<AssetRegistrySummaryDto> _items = [];
    private AssetRegistryDto? _selected;
    private int _newCondition;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var result = await Client.SearchAsync(_keyword, _assetTypeFilter, _lifecycleFilter, _page, PageSize);
            _items = result.Items;
            _totalCount = result.TotalCount;
            _totalPages = result.TotalPages > 0 ? result.TotalPages : 1;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task OnRowClick(TableRowClickEventArgs<AssetRegistrySummaryDto> args)
    {
        _busy = true;
        try
        {
            _selected = await Client.GetAsync(args.Item.Id);
            if (_selected is not null)
            {
                _newCondition = _selected.CurrentCondition;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task UpdateConditionAsync()
    {
        if (_selected is null) return;
        _busy = true;
        try
        {
            _selected = await Client.UpdateConditionAsync(_selected.Id, _newCondition);
            Snackbar.Add("Condition updated.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task PrevPage() { _page--; await LoadAsync(); }
    private async Task NextPage() { _page++; await LoadAsync(); }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { _page = 1; await LoadAsync(); }
    }

    private static string FormatAssetType(int v) => v switch { 0 => "SE", 1 => "PPE", _ => v.ToString() };
    private static string FormatCategory(int v) => v switch
    {
        0 => "LowValuedSemi",
        1 => "HighValuedSemi",
        2 => "PPE",
        _ => v.ToString()
    };
    private static string FormatLifecycle(int v) => v switch
    {
        0 => "InStock",
        1 => "Issued",
        2 => "UnderInvestigation",
        3 => "Unserviceable",
        4 => "Disposed",
        _ => v.ToString()
    };
    private static Color LifecycleColor(int v) => v switch
    {
        0 => Color.Default,
        1 => Color.Success,
        2 => Color.Warning,
        3 => Color.Error,
        4 => Color.Dark,
        _ => Color.Default
    };
    private static string FormatCondition(int v) => v switch { 0 => "Good", 1 => "Fair", 2 => "Poor", 3 => "Unserviceable", _ => v.ToString() };
}
