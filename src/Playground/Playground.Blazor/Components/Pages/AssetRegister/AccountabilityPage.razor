@page "/asset-register/accountability"
@using AMIS.Playground.Blazor.ApiClient
@inject IArAccountabilityClient Client
@inject ISnackbar Snackbar

<AMISPageHeader Title="Property Accountability (ICS / PAR)"
               Description="Unified accountability tracking for Semi-Expendable (ICS) and PPE (PAR) per COA 2022-004." />

<MudGrid Spacing="3">
    <!-- Filters -->
    <MudItem xs="12">
        <MudCard Elevation="1">
            <MudCardContent>
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="_keyword" Label="Keyword / Document No." Variant="Variant.Outlined"
                                      Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Outlined.Search"
                                      OnKeyDown="OnSearchKeyDown" Immediate="false" />
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudSelect @bind-Value="_typeFilter" Label="Type" Variant="Variant.Outlined" T="int?" Clearable="true">
                            <MudSelectItem Value="@((int?)null)">All</MudSelectItem>
                            <MudSelectItem Value="@((int?)0)">ICS (SE)</MudSelectItem>
                            <MudSelectItem Value="@((int?)1)">PAR (PPE)</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudSelect @bind-Value="_statusFilter" Label="Status" Variant="Variant.Outlined" T="int?" Clearable="true">
                            <MudSelectItem Value="@((int?)null)">All</MudSelectItem>
                            <MudSelectItem Value="@((int?)0)">Active</MudSelectItem>
                            <MudSelectItem Value="@((int?)1)">PartiallyReturned</MudSelectItem>
                            <MudSelectItem Value="@((int?)2)">FullyReturned</MudSelectItem>
                            <MudSelectItem Value="@((int?)3)">Cancelled</MudSelectItem>
                            <MudSelectItem Value="@((int?)4)">Superseded</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="2" Class="d-flex align-end">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                   StartIcon="@Icons.Material.Outlined.Search" OnClick="LoadAsync" Disabled="_busy">
                            Search
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- Results -->
    <MudItem xs="12">
        <MudCard Elevation="1">
            <MudCardContent>
                @if (_busy)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else if (!string.IsNullOrEmpty(_error))
                {
                    <MudAlert Severity="Severity.Error" Dense="true">@_error</MudAlert>
                }
                else
                {
                    <MudTable Items="_items" Dense="true" Hover="true" Striped="true"
                              OnRowClick="OnRowClick" T="ArAccountabilitySummaryDto" RowClass="cursor-pointer">
                        <HeaderContent>
                            <MudTh>Document No.</MudTh>
                            <MudTh>Type</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Issued On</MudTh>
                            <MudTh>Expires On</MudTh>
                            <MudTh Style="text-align:right">Lines</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><strong>@context.DocumentNo</strong></MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small"
                                         Color="@(context.AccountabilityType == 0 ? Color.Info : Color.Secondary)"
                                         Variant="Variant.Outlined">
                                    @(context.AccountabilityType == 0 ? "ICS" : "PAR")
                                </MudChip>
                            </MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small"
                                         Color="@StatusColor(context.Status)"
                                         Variant="Variant.Filled">
                                    @FormatStatus(context.Status)
                                </MudChip>
                            </MudTd>
                            <MudTd>@context.IssuedOn.ToString("yyyy-MM-dd")</MudTd>
                            <MudTd>@(context.ExpiresOn?.ToString("yyyy-MM-dd") ?? "—")</MudTd>
                            <MudTd Style="text-align:right">@context.LineCount</MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <MudText Color="Color.Secondary">No accountability documents found.</MudText>
                        </NoRecordsContent>
                    </MudTable>

                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mt-3">
                        <MudText Typo="Typo.caption">
                            Page @_page of @_totalPages (@_totalCount total)
                        </MudText>
                        <MudStack Row="true" Spacing="1">
                            <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Size="Size.Small"
                                           Disabled="_page <= 1 || _busy" OnClick="PrevPage" />
                            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small"
                                           Disabled="_page >= _totalPages || _busy" OnClick="NextPage" />
                        </MudStack>
                    </MudStack>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- Detail panel -->
    @if (_selected is not null)
    {
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudText Typo="Typo.h6">
                                @(_selected.AccountabilityType == 0 ? "ICS" : "PAR") — @_selected.DocumentNo
                            </MudText>
                            <MudChip T="string" Size="Size.Small" Color="@StatusColor(_selected.Status)" Variant="Variant.Filled">
                                @FormatStatus(_selected.Status)
                            </MudChip>
                        </MudStack>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                       OnClick="@(() => _selected = null)" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Class="mb-3">
                        <MudItem xs="6" md="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Issued On</MudText>
                            <MudText Typo="Typo.body2">@_selected.IssuedOn.ToString("yyyy-MM-dd")</MudText>
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Expires On</MudText>
                            <MudText Typo="Typo.body2">@(_selected.ExpiresOn?.ToString("yyyy-MM-dd") ?? "—")</MudText>
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Fund Cluster</MudText>
                            <MudText Typo="Typo.body2">@_selected.FundCluster</MudText>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Issued By</MudText>
                            <MudText Typo="Typo.body2">@_selected.IssuedBy.PrintedName (@(_selected.IssuedBy.Designation ?? "—"))</MudText>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Received By</MudText>
                            <MudText Typo="Typo.body2">@_selected.ReceivedBy.PrintedName (@(_selected.ReceivedBy.Designation ?? "—"))</MudText>
                        </MudItem>
                        @if (!string.IsNullOrEmpty(_selected.CancellationReason))
                        {
                            <MudItem xs="12">
                                <MudAlert Severity="Severity.Warning" Dense="true">
                                    Cancellation reason: @_selected.CancellationReason
                                </MudAlert>
                            </MudItem>
                        }
                    </MudGrid>

                    <MudText Typo="Typo.subtitle2" Class="mb-2">Line Items</MudText>
                    <MudTable Items="_selected.Lines" Dense="true" Striped="true">
                        <HeaderContent>
                            <MudTh>Property No.</MudTh>
                            <MudTh>Description</MudTh>
                            <MudTh>Unit</MudTh>
                            <MudTh Style="text-align:right">Issued</MudTh>
                            <MudTh Style="text-align:right">Returned</MudTh>
                            <MudTh Style="text-align:right">Unit Cost (?)</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Returned On</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Snapshot.PropertyNo</MudTd>
                            <MudTd>@context.Snapshot.Description</MudTd>
                            <MudTd>@context.Snapshot.Unit</MudTd>
                            <MudTd Style="text-align:right">@context.IssuedQty</MudTd>
                            <MudTd Style="text-align:right">@context.ReturnedQty</MudTd>
                            <MudTd Style="text-align:right">@context.Snapshot.UnitCost.ToString("N2")</MudTd>
                            <MudTd>@FormatLineStatus(context.LineStatus)</MudTd>
                            <MudTd>@(context.ReturnedOn?.ToString("yyyy-MM-dd") ?? "—")</MudTd>
                        </RowTemplate>
                    </MudTable>

                    <!-- Cancel action (only for Active status = 0) -->
                    @if (_selected.Status == 0)
                    {
                        <MudDivider Class="my-3" />
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Cancel Accountability</MudText>
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End">
                            <MudTextField @bind-Value="_cancelReason" Label="Reason" Variant="Variant.Outlined"
                                          Style="flex:1;" MaxLength="500" />
                            <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                       OnClick="CancelAsync" Disabled="_busy || string.IsNullOrWhiteSpace(_cancelReason)">
                                Cancel ICS/PAR
                            </MudButton>
                        </MudStack>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@code {
    private bool _busy;
    private string? _error;
    private string? _keyword;
    private int? _typeFilter;
    private int? _statusFilter;
    private int _page = 1;
    private int _totalPages = 1;
    private int _totalCount;
    private const int PageSize = 15;
    private IReadOnlyList<ArAccountabilitySummaryDto> _items = [];
    private ArAccountabilityDto? _selected;
    private string? _cancelReason;

    [SupplyParameterFromQuery(Name = "id")]
    public Guid? QueryId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        if (QueryId.HasValue)
        {
            _selected = await Client.GetAsync(QueryId.Value);
        }
    }

    private async Task LoadAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var result = await Client.SearchAsync(_keyword, _typeFilter, _statusFilter, _page, PageSize);
            _items = result.Items;
            _totalCount = result.TotalCount;
            _totalPages = result.TotalPages > 0 ? result.TotalPages : 1;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task OnRowClick(TableRowClickEventArgs<ArAccountabilitySummaryDto> args)
    {
        _busy = true;
        try
        {
            _selected = await Client.GetAsync(args.Item.Id);
            _cancelReason = null;
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task CancelAsync()
    {
        if (_selected is null || string.IsNullOrWhiteSpace(_cancelReason)) return;
        _busy = true;
        try
        {
            _selected = await Client.CancelAsync(_selected.Id, _cancelReason);
            Snackbar.Add("Accountability cancelled.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task PrevPage() { _page--; await LoadAsync(); }
    private async Task NextPage() { _page++; await LoadAsync(); }
    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { _page = 1; await LoadAsync(); }
    }

    private static string FormatStatus(int v) => v switch
    {
        0 => "Active",
        1 => "PartiallyReturned",
        2 => "FullyReturned",
        3 => "Cancelled",
        4 => "Superseded",
        _ => v.ToString()
    };
    private static Color StatusColor(int v) => v switch
    {
        0 => Color.Success,
        1 => Color.Warning,
        2 => Color.Info,
        3 => Color.Error,
        4 => Color.Dark,
        _ => Color.Default
    };
    private static string FormatLineStatus(int v) => v switch
    {
        0 => "Active",
        1 => "Returned",
        2 => "Lost",
        _ => v.ToString()
    };
}

