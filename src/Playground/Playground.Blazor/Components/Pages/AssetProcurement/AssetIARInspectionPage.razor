@page "/asset-procurement/iars/{Id:guid}/inspect"
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using AMIS.Playground.Blazor.ApiClient
@using AMIS.Modules.ProcurementAcquisition.Contracts.v1.AssetInspectionAcceptanceReports
@inject IAssetIarClient IarClient
@inject IIdentityClient IdentityClient
@inject IEmployeesClient EmployeesClient
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Inspect Asset IAR</PageTitle>

<AMISPageHeader Title="IAR Inspection"
                Description="Inspector records pass or reject decisions for each IAR line item." />

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_iar is null)
{
    <MudAlert Severity="Severity.Error">IAR not found.</MudAlert>
}
else
{
    <AssetIARStageStepper Status="@_iar.Status" />

    @if (!_isAssignedInspector)
    {
        <MudAlert Severity="Severity.Error" Class="mb-3">
            You are not the assigned inspector for this IAR.
        </MudAlert>
    }
    else if (!_canInspectPermission)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-3">
            You do not have permission to record inspection actions.
        </MudAlert>
    }
    else if (_iar.Status != AssetIARStatus.PendingInspection)
    {
        <MudAlert Severity="Severity.Info" Class="mb-3">
            This IAR is in @_iar.Status state. Inspection decisions are read-only.
        </MudAlert>
    }

    <MudCard Elevation="1" Class="mb-3">
        <MudCardContent>
            <MudGrid Spacing="2">
                <MudItem xs="12" md="3"><MudText><b>IAR No:</b> @_iar.IarNumber</MudText></MudItem>
                <MudItem xs="12" md="3"><MudText><b>PO:</b> @_iar.PoNumber</MudText></MudItem>
                <MudItem xs="12" md="3"><MudText><b>Supplier:</b> @_iar.SupplierName</MudText></MudItem>
                <MudItem xs="12" md="3"><MudText><b>Assigned Inspector:</b> @_iar.InspectedByName</MudText></MudItem>
            </MudGrid>
        </MudCardContent>
    </MudCard>

    <MudCard Elevation="1">
        <MudCardContent>
            <MudStack Row="true" Spacing="1" Class="mb-2">
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="PassAll" Disabled="@(!_canEditInspection)">
                    Pass all
                </MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="ResetAll" Disabled="@(!_canEditInspection)">
                    Reset all
                </MudButton>
            </MudStack>

            <MudSimpleTable Dense="true" Hover="true" Striped="true">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Description</th>
                        <th>Qty</th>
                        <th>Result</th>
                        <th>Remarks</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in _iar.LineItems.OrderBy(x => x.ItemNo))
                    {
                        var decision = GetDecision(line.ItemNo);
                        <tr>
                            <td>@line.ItemNo</td>
                            <td>@line.Description</td>
                            <td>@line.Quantity</td>
                            <td>
                                <MudStack Row="true" Spacing="1">
                                    <MudTooltip Text="Pass">
                                        <MudIconButton Icon="@Icons.Material.Filled.CheckCircle"
                                                       Color="@(decision.Result == LineInspectionResult.Passed ? Color.Success : Color.Default)"
                                                       Size="Size.Small"
                                                       Variant="@(decision.Result == LineInspectionResult.Passed ? Variant.Filled : Variant.Outlined)"
                                                       OnClick="@(() => OnResultChanged(line.ItemNo, LineInspectionResult.Passed))"
                                                       Disabled="@(!_canEditInspection)" />
                                    </MudTooltip>
                                    <MudTooltip Text="Reject">
                                        <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                                                       Color="@(decision.Result == LineInspectionResult.Rejected ? Color.Error : Color.Default)"
                                                       Size="Size.Small"
                                                       Variant="@(decision.Result == LineInspectionResult.Rejected ? Variant.Filled : Variant.Outlined)"
                                                       OnClick="@(() => OnResultChanged(line.ItemNo, LineInspectionResult.Rejected))"
                                                       Disabled="@(!_canEditInspection)" />
                                    </MudTooltip>
                                </MudStack>
                            </td>
                            <td style="min-width:260px">
                                <MudTextField T="string" Value="decision.Remarks"
                                              ValueChanged="@(v => OnRemarksChanged(line.ItemNo, v))"
                                              Variant="Variant.Outlined"
                                              Dense="true"
                                              Placeholder="@(decision.Result == LineInspectionResult.Rejected ? "Required for rejected lines" : "Available when result is Reject")"
                                              Disabled="@(!_canEditInspection || !IsRemarksEditable(line.ItemNo))"
                                              MaxLength="500" />
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudCardContent>
        <MudCardActions>
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" OnClick="BackToList">Back</MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SubmitInspectionAsync"
                       Disabled="@(!_canEditInspection || _submitting)">
                Record inspection
            </MudButton>
        </MudCardActions>
    </MudCard>
}

@code {
    private const string PermissionInspect = "Permissions.Procurement.AssetIARs.Inspect";

    [Parameter] public Guid Id { get; set; }

    private AssetIARDto? _iar;
    private bool _loading = true;
    private bool _submitting;
    private Guid _currentUserEmployeeId;
    private readonly HashSet<string> _permissions = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<int, LineInspectionDecision> _decisions = [];

    private bool _isAssignedInspector => _iar is not null && _currentUserEmployeeId != Guid.Empty && _currentUserEmployeeId == _iar.InspectedById;
    private bool _canInspectPermission => HasPermission(PermissionInspect);
    private bool _canEditInspection => _iar is not null && _iar.Status == AssetIARStatus.PendingInspection && _isAssignedInspector && _canInspectPermission;

    protected override async Task OnInitializedAsync()
    {
        await ResolveCurrentUserEmployeeAsync();
        await LoadPermissionsAsync();
        await LoadAsync();
    }

    private async Task ResolveCurrentUserEmployeeAsync()
    {
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var identityId = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrWhiteSpace(identityId))
            {
                var employee = await EmployeesClient.ByIdentityAsync(identityId);
                if (employee is not null)
                    _currentUserEmployeeId = employee.Id;
            }
        }
        catch
        {
            // Falls back to Guid.Empty; inspection actions will be hidden.
        }
    }

    private async Task LoadPermissionsAsync()
    {
        try
        {
            var permissions = await IdentityClient.PermissionsGetAsync();
            _permissions.Clear();

            foreach (var permission in permissions)
            {
                if (!string.IsNullOrWhiteSpace(permission))
                {
                    _permissions.Add(permission.Trim());
                }
            }
        }
        catch (Exception ex)
        {
            _permissions.Clear();
            Snackbar.Add($"Unable to load permissions. Inspection actions may be limited: {ex.Message}", Severity.Warning);
        }
    }

    private bool HasPermission(string permission) => _permissions.Contains(permission);

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _iar = await IarClient.GetAsync(Id);
            if (_iar is not null)
            {
                _decisions.Clear();
                foreach (var line in _iar.LineItems)
                {
                    _decisions[line.ItemNo] = new LineInspectionDecision(
                        line.ItemNo,
                        line.InspectionResult == LineInspectionResult.Pending ? LineInspectionResult.Pending : line.InspectionResult,
                        line.InspectionRemarks);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load IAR: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private LineInspectionDecision GetDecision(int itemNo) =>
        _decisions.TryGetValue(itemNo, out var decision)
            ? decision
            : new LineInspectionDecision(itemNo, LineInspectionResult.Pending, null);

    private void OnResultChanged(int itemNo, LineInspectionResult result)
    {
        var current = GetDecision(itemNo);
        var remarks = result == LineInspectionResult.Rejected ? current.Remarks : null;
        _decisions[itemNo] = current with { Result = result, Remarks = remarks };
    }

    private void OnRemarksChanged(int itemNo, string? remarks)
    {
        var current = GetDecision(itemNo);
        _decisions[itemNo] = current with { Remarks = string.IsNullOrWhiteSpace(remarks) ? null : remarks.Trim() };
    }

    private bool IsRemarksEditable(int itemNo) => GetDecision(itemNo).Result == LineInspectionResult.Rejected;

    private void PassAll()
    {
        if (_iar is null) return;

        foreach (var line in _iar.LineItems)
        {
            _decisions[line.ItemNo] = new LineInspectionDecision(line.ItemNo, LineInspectionResult.Passed, null);
        }
    }

    private void ResetAll()
    {
        if (_iar is null) return;

        foreach (var line in _iar.LineItems)
        {
            _decisions[line.ItemNo] = new LineInspectionDecision(line.ItemNo, LineInspectionResult.Pending, null);
        }
    }

    private async Task SubmitInspectionAsync()
    {
        if (_iar is null)
        {
            return;
        }

        if (_iar.Status != AssetIARStatus.PendingInspection)
        {
            Snackbar.Add("Inspection can only be recorded while status is PendingInspection.", Severity.Warning);
            return;
        }

        if (!_isAssignedInspector)
        {
            Snackbar.Add("Only the assigned inspector can record inspection.", Severity.Warning);
            return;
        }

        if (!_canInspectPermission)
        {
            Snackbar.Add("You do not have permission to record inspection actions.", Severity.Warning);
            return;
        }

        var decisions = _iar.LineItems
            .Select(li => GetDecision(li.ItemNo))
            .ToList();

        if (decisions.Any(d => d.Result == LineInspectionResult.Pending))
        {
            Snackbar.Add("Every line must be marked Pass or Reject.", Severity.Warning);
            return;
        }

        var rejectedWithoutRemarks = decisions
            .Where(d => d.Result == LineInspectionResult.Rejected && string.IsNullOrWhiteSpace(d.Remarks))
            .Select(d => d.ItemNo)
            .ToList();

        if (rejectedWithoutRemarks.Count > 0)
        {
            Snackbar.Add($"Rejected lines require remarks. Missing on: {string.Join(", ", rejectedWithoutRemarks)}", Severity.Warning);
            return;
        }

        _submitting = true;
        try
        {
            await IarClient.RecordInspectionAsync(_iar.Id, decisions);
            Snackbar.Add("Inspection recorded.", Severity.Success);
            Navigation.NavigateTo("/asset-procurement/iars");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Record inspection failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }

    private void BackToList() => Navigation.NavigateTo("/asset-procurement/iars");
}
