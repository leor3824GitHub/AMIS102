@page "/asset-procurement/iars"
@using AMIS.Playground.Blazor.ApiClient
@using AMIS.Playground.Blazor.Components.Pages.Procurement
@using AMIS.Modules.ProcurementAcquisition.Contracts.v1.AssetInspectionAcceptanceReports
@inject IAssetIarClient IarClient
@inject IUserProfileState UserProfileState
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<AMISPageHeader Title="Inspection &amp; Acceptance Reports"
                Description="Track IARs from Draft to Inspection and Acceptance." />

<MudCard Elevation="1" Class="mb-3">
    <MudCardContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudTextField @bind-Value="_keyword" Label="Search IAR No / Supplier" Variant="Variant.Outlined"
                          Size="Size.Small" Margin="Margin.Dense"
                          Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                          DebounceInterval="350" OnDebounceIntervalElapsed="@(() => LoadAsync())"
                          Style="max-width:320px" />
            <MudSpacer />
            @if (_canCreate)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
                    New IAR
                </MudButton>
            }
        </MudStack>
    </MudCardContent>
</MudCard>

<MudTabs Elevation="0" Rounded="true" PanelClass="pa-0" Class="mb-3" ActivePanelIndex="_activeTab" ActivePanelIndexChanged="OnTabChanged">
    <MudTabPanel Text="All" />
    <MudTabPanel Text="Draft" />
    <MudTabPanel Text="Pending Inspection" />
    <MudTabPanel Text="Inspected" />
    <MudTabPanel Text="Accepted" />
    <MudTabPanel Text="Cancelled" />
</MudTabs>

<MudCard Elevation="1">
    <MudCardContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_items.Count == 0)
        {
            <MudAlert Severity="Severity.Info">No IARs found.</MudAlert>
        }
        else
        {
            <MudSimpleTable Dense="true" Hover="true" Striped="true">
                <thead>
                    <tr>
                        <th>IAR No.</th>
                        <th>Date</th>
                        <th>PO</th>
                        <th>Supplier</th>
                        <th>Lines</th>
                        <th class="text-right">Total</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var iar in _items)
                    {
                        <tr>
                            <td><b>@iar.IarNumber</b></td>
                            <td>@iar.IarDate.ToString("MM/dd/yyyy")</td>
                            <td>@iar.PoNumber</td>
                            <td>@iar.SupplierName</td>
                            <td>@iar.LineItemCount</td>
                            <td class="text-right">@iar.TotalAmount.ToString("N2")</td>
                            <td>
                                <MudChip T="string" Size="Size.Small" Color="@StatusColor(iar.Status)">
                                    @iar.Status
                                </MudChip>
                            </td>
                            <td>
                                <MudStack Row="true" Spacing="0">
                                    @if (iar.Status == AssetIARStatus.Draft)
                                    {
                                        @if (_canUpdate)
                                        {
                                            <MudTooltip Text="Edit">
                                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                               Color="Color.Primary" Size="Size.Small"
                                                               OnClick="@(() => OpenEditDialog(iar.Id))" />
                                            </MudTooltip>
                                        }
                                        @if (_canSubmitForInspection)
                                        {
                                            <MudTooltip Text="Submit for Inspection">
                                                <MudIconButton Icon="@Icons.Material.Filled.Send"
                                                               Color="Color.Info" Size="Size.Small"
                                                               OnClick="@(() => SubmitForInspectionAsync(iar.Id))" />
                                            </MudTooltip>
                                        }
                                        @if (_canCancel)
                                        {
                                            <MudTooltip Text="Cancel">
                                                <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                                                               Color="Color.Error" Size="Size.Small"
                                                               OnClick="@(() => CancelIarAsync(iar.Id))" />
                                            </MudTooltip>
                                        }
                                    }
                                    else if (iar.Status == AssetIARStatus.PendingInspection)
                                    {
                                        @if (_canInspect)
                                        {
                                            <MudTooltip Text="@(IsAssignedInspector(iar) ? "Record Inspection" : "View Inspection")">
                                                <MudIconButton Icon="@Icons.Material.Filled.FactCheck"
                                                               Color="@(IsAssignedInspector(iar) ? Color.Primary : Color.Default)"
                                                               Size="Size.Small"
                                                               OnClick="@(() => OpenInspectionPage(iar.Id))" />
                                            </MudTooltip>
                                        }
                                        @if (_canSubmitForInspection)
                                        {
                                            <MudTooltip Text="Reassign Inspector">
                                                <MudIconButton Icon="@Icons.Material.Filled.SwitchAccount"
                                                               Color="Color.Warning" Size="Size.Small"
                                                               OnClick="@(() => OpenReassignInspectorDialog(iar.Id))" />
                                            </MudTooltip>
                                        }
                                        @if (_canCancel)
                                        {
                                            <MudTooltip Text="Cancel">
                                                <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                                                               Color="Color.Error" Size="Size.Small"
                                                               OnClick="@(() => CancelIarAsync(iar.Id))" />
                                            </MudTooltip>
                                        }
                                    }
                                    else if (iar.Status == AssetIARStatus.Inspected)
                                    {
                                        @if (_canAccept || _canAssignPropertyNo)
                                        {
                                            <MudTooltip Text="Accept">
                                                <MudIconButton Icon="@Icons.Material.Filled.CheckCircle"
                                                               Color="Color.Success" Size="Size.Small"
                                                               OnClick="@(() => OpenAcceptancePage(iar.Id))" />
                                            </MudTooltip>
                                        }
                                        @if (_canCancel)
                                        {
                                            <MudTooltip Text="Cancel">
                                                <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                                                               Color="Color.Error" Size="Size.Small"
                                                               OnClick="@(() => CancelIarAsync(iar.Id))" />
                                            </MudTooltip>
                                        }
                                    }
                                    else
                                    {
                                        <MudTooltip Text="View">
                                            <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                                           Color="Color.Default" Size="Size.Small"
                                                           OnClick="@(() => OpenDetailPage(iar.Id))" />
                                        </MudTooltip>
                                    }
                                    <MudMenu Icon="@Icons.Material.Filled.Print"
                                             Color="Color.Secondary"
                                             Size="Size.Small"
                                             Dense="true"
                                             AnchorOrigin="Origin.BottomLeft"
                                             TransformOrigin="Origin.TopLeft"
                                             ToolTip="Print">
                                        <MudMenuItem Icon="@Icons.Material.Filled.PictureAsPdf"
                                                     OnClick="@(() => DownloadFastReportPdfAsync(iar.Id))">
                                            Download PDF
                                        </MudMenuItem>
                                        <MudDivider />
                                        <MudMenuItem Icon="@Icons.Material.Filled.Settings"
                                                     OnClick="@(() => OpenFastReportSetupAsync(iar.Id))">
                                            Fast Report – Page Setup…
                                        </MudMenuItem>
                                    </MudMenu>
                                </MudStack>
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>

            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-2" Spacing="1">
                <MudText Typo="Typo.caption">@_totalCount IARs total</MudText>
                <MudSpacer />
                <MudPagination Count="@TotalPages" Selected="_page" ShowFirstButton="true" ShowLastButton="true"
                               SelectedChanged="@(async p => { _page = p; await LoadAsync(); })" />
            </MudStack>
        }
    </MudCardContent>
</MudCard>

@code {
    private const string PermissionCreate = "Permissions.Procurement.AssetIARs.Create";
    private const string PermissionUpdate = "Permissions.Procurement.AssetIARs.Update";
    private const string PermissionSubmitForInspection = "Permissions.Procurement.AssetIARs.SubmitForInspection";
    private const string PermissionInspect = "Permissions.Procurement.AssetIARs.Inspect";
    private const string PermissionAssignPropertyNo = "Permissions.Procurement.AssetIARs.AssignPropertyNo";
    private const string PermissionAccept = "Permissions.Procurement.AssetIARs.Accept";
    private const string PermissionCancel = "Permissions.Procurement.AssetIARs.Cancel";

    private List<AssetIARSummaryDto> _items = [];
    private string? _keyword;
    private AssetIARStatus? _statusFilter;
    private bool _loading;
    private int _activeTab;
    private int _page = 1;
    private int _totalCount;
    private const int PageSize = 15;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)PageSize));
    private bool _canCreate => UserProfileState.Permissions.Contains(PermissionCreate);
    private bool _canUpdate => UserProfileState.Permissions.Contains(PermissionUpdate);
    private bool _canSubmitForInspection => UserProfileState.Permissions.Contains(PermissionSubmitForInspection);
    private bool _canInspect => UserProfileState.Permissions.Contains(PermissionInspect);
    private bool _canAssignPropertyNo => UserProfileState.Permissions.Contains(PermissionAssignPropertyNo);
    private bool _canAccept => UserProfileState.Permissions.Contains(PermissionAccept);
    private bool _canCancel => UserProfileState.Permissions.Contains(PermissionCancel);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task OnTabChanged(int tab)
    {
        _activeTab = tab;
        _statusFilter = tab switch
        {
            1 => AssetIARStatus.Draft,
            2 => AssetIARStatus.PendingInspection,
            3 => AssetIARStatus.Inspected,
            4 => AssetIARStatus.Accepted,
            5 => AssetIARStatus.Cancelled,
            _ => null
        };
        _page = 1;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var response = await IarClient.SearchAsync(_keyword, _statusFilter, page: _page, pageSize: PageSize);
            _items = [.. response.Items];
            _totalCount = (int)response.TotalCount;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Load failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private bool IsAssignedInspector(AssetIARSummaryDto iar) =>
        UserProfileState.EmployeeId != Guid.Empty && iar.AssignedInspectorId == UserProfileState.EmployeeId;

    private async Task OpenCreateDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, FullWidth = true, MaxWidth = MaxWidth.Large };
        var dialog = await DialogService.ShowAsync<AssetIARDraftDialog>("New IAR Draft", options);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await LoadAsync();
        }
    }

    private async Task OpenEditDialog(Guid id)
    {
        var iar = await IarClient.GetAsync(id);
        if (iar is null)
        {
            Snackbar.Add("IAR not found.", Severity.Error);
            return;
        }

        var parameters = new DialogParameters { ["Existing"] = iar };
        var options = new DialogOptions { CloseOnEscapeKey = true, FullWidth = true, MaxWidth = MaxWidth.Large };
        var dialog = await DialogService.ShowAsync<AssetIARDraftDialog>($"IAR {iar.IarNumber}", parameters, options);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await LoadAsync();
        }
    }

    private void OpenDetailPage(Guid id) =>
        Navigation.NavigateTo($"/asset-procurement/iars/{id}/accept");

    private async Task SubmitForInspectionAsync(Guid id)
    {
        var ok = await DialogService.ShowMessageBox("Submit IAR", "Submit this draft for inspection?", yesText: "Submit", cancelText: "Cancel");
        if (ok != true)
        {
            return;
        }

        try
        {
            await IarClient.SubmitForInspectionAsync(id);
            Snackbar.Add("IAR submitted for inspection.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Submit failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task CancelIarAsync(Guid id)
    {
        var ok = await DialogService.ShowMessageBox("Cancel IAR", "Cancel this IAR? This action cannot be undone.", yesText: "Cancel IAR", cancelText: "Keep");
        if (ok != true)
        {
            return;
        }

        try
        {
            await IarClient.CancelAsync(id);
            Snackbar.Add("IAR cancelled.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Cancel failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenReassignInspectorDialog(Guid id)
    {
        var details = await IarClient.GetAsync(id);
        if (details is null)
        {
            Snackbar.Add("IAR not found.", Severity.Error);
            return;
        }

        var parameters = new DialogParameters
        {
            ["IarId"] = details.Id,
            ["CurrentInspectorId"] = details.InspectedById
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, FullWidth = true, MaxWidth = MaxWidth.Small };
        var dialog = await DialogService.ShowAsync<AssetIARReassignInspectorDialog>("Reassign Inspector", parameters, options);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await LoadAsync();
        }
    }

    private void OpenInspectionPage(Guid id)
    {
        Navigation.NavigateTo($"/asset-procurement/iars/{id}/inspect");
    }

    private void OpenAcceptancePage(Guid id)
    {
        Navigation.NavigateTo($"/asset-procurement/iars/{id}/accept");
    }

    private static Color StatusColor(AssetIARStatus status) => status switch
    {
        AssetIARStatus.Draft => Color.Default,
        AssetIARStatus.PendingInspection => Color.Warning,
        AssetIARStatus.Inspected => Color.Info,
        AssetIARStatus.Accepted => Color.Success,
        AssetIARStatus.Cancelled => Color.Error,
        _ => Color.Default
    };

    private async Task DownloadFastReportPdfAsync(Guid id)
    {
        try
        {
            var bytes = await IarClient.GetFastReportPdfAsync(id, pageWidth: "a4", orientation: "landscape", minRows: 12);
            var dataUrl = $"data:application/pdf;base64,{Convert.ToBase64String(bytes)}";
            await JS.InvokeVoidAsync("open", dataUrl, "_blank");
            Snackbar.Add("PDF ready.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"PDF generation failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenFastReportSetupAsync(Guid id)
    {
        // IAR is always 1 copy per page; the dialog's Copies field is ignored on submit.
        var parameters = new DialogParameters
        {
            [nameof(FastReportPageSetupDialog.PaperSize)] = "a4",
            [nameof(FastReportPageSetupDialog.Orientation)] = "landscape",
            [nameof(FastReportPageSetupDialog.Copies)] = 1,
            [nameof(FastReportPageSetupDialog.MinRows)] = 12
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = false, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<FastReportPageSetupDialog>("Page Setup", parameters, options);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;
        if (result.Data is not FastReportPageSetupDialog.Result r) return;

        try
        {
            var bytes = await IarClient.GetFastReportPdfAsync(id, pageWidth: r.PaperSize, orientation: r.Orientation, minRows: r.MinRows);
            var dataUrl = $"data:application/pdf;base64,{Convert.ToBase64String(bytes)}";
            await JS.InvokeVoidAsync("open", dataUrl, "_blank");
            Snackbar.Add("PDF ready.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fast report failed: {ex.Message}", Severity.Error);
        }
    }
}
