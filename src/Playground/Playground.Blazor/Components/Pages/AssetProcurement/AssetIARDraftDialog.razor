@using AMIS.Playground.Blazor.ApiClient
@using AMIS.Modules.ProcurementAcquisition.Contracts.v1.AssetInspectionAcceptanceReports
@using AMIS.Modules.ProcurementAcquisition.Contracts.v1.PurchaseOrders
@inject IAssetIarClient IarClient
@inject IPurchaseOrderClient PoClient
@inject ILookupClient LookupClient
@inject IIdentityClient IdentityClient
@inject IUsersClient UsersClient
@inject IEmployeesClient EmployeesClient
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_isLocked)
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                This IAR is @Existing!.Status and is no longer editable in Draft mode.
            </MudAlert>
        }

        <AssetIARStageStepper Status="@(_isLocked ? Existing!.Status : AssetIARStatus.Draft)" />

        <MudGrid Spacing="2">
            <MudItem xs="12" md="6">
                <MudAutocomplete T="PurchaseOrderSummaryDto"
                                 Value="_selectedPo"
                                 ValueChanged="OnPoSelectedAsync"
                                 SearchFunc="SearchPurchaseOrdersAsync"
                                 ToStringFunc="FormatPo"
                                 Label="Open Purchase Order *"
                                 Placeholder="Search recent open POs"
                                 Variant="Variant.Outlined"
                                 Dense="true"
                                 Required="true"
                                 Clearable="true"
                                 CoerceValue="true"
                                 ResetValueOnEmptyText="true"
                                 MinCharacters="0"
                                 CoerceText="false"
                                 Disabled="_isLocked" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField Value="@(Existing?.IarNumber ?? "(auto)")"
                              Label="IAR No."
                              Variant="Variant.Outlined"
                              Dense="true"
                              ReadOnly="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField Value="@((Existing?.IarDate ?? DateOnly.FromDateTime(DateTime.Today)).ToString("MM/dd/yyyy"))"
                              Label="IAR Date"
                              Variant="Variant.Outlined"
                              Dense="true"
                              ReadOnly="true" />
            </MudItem>

            <MudItem xs="12" md="6">
                <MudAutocomplete T="EmployeeReferenceDto"
                                 @bind-Value="_assignedInspector"
                                 SearchFunc="SearchInspectorsAsync"
                                 ToStringFunc="FormatEmployee"
                                 Label="Assigned Inspector *"
                                 Variant="Variant.Outlined"
                                 Dense="true"
                                 Required="true"
                                 CoerceText="false"
                                 Disabled="_isLocked" />
            </MudItem>
            @if (_selectedPoDetails is not null)
            {
                <MudItem xs="12" md="6">
                    <MudTextField Value="_selectedPoDetails.SupplierName"
                                  Label="Supplier"
                                  Variant="Variant.Outlined"
                                  Dense="true"
                                  ReadOnly="true" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudTextField Value="@_selectedPoDetails.PoDate.ToString("MM/dd/yyyy")"
                                  Label="PO Date"
                                  Variant="Variant.Outlined"
                                  Dense="true"
                                  ReadOnly="true" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudTextField Value="@_selectedPoDetails.TotalAmount.ToString("N2")"
                                  Label="PO Total"
                                  Variant="Variant.Outlined"
                                  Dense="true"
                                  ReadOnly="true" />
                </MudItem>
            }

            <MudItem xs="12">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-2 mb-2">
                    <MudText Typo="Typo.subtitle1" Class="flex-grow-1"><b>PO Line Items For Inspection</b></MudText>
                    @if (!_isLocked && _poLineChoices.Count > 0)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" OnClick="SelectAllPoLines">
                            Select All
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" OnClick="ClearPoLineSelection">
                            Clear
                        </MudButton>
                    }
                </MudStack>

                @if (_selectedPo is null)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">
                        Select an open Purchase Order first.
                    </MudAlert>
                }
                else if (_poLineChoices.Count == 0)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true">
                        The selected PO has no line items available.
                    </MudAlert>
                }
                else
                {
                    <MudSimpleTable Dense="true" Hover="true" Striped="true">
                        <thead>
                            <tr>
                                <th style="width:48px"></th>
                                <th>#</th>
                                <th>Description</th>
                                <th>Unit</th>
                                <th>Qty</th>
                                <th class="text-right">Unit Cost</th>
                                <th>Stock No.</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var choice in _poLineChoices)
                            {
                                <tr>
                                    <td>
                                        <MudCheckBox T="bool"
                                                     Value="choice.Selected"
                                                     ValueChanged="@(v => choice.Selected = v)"
                                                     Disabled="_isLocked" />
                                    </td>
                                    <td>@choice.ItemNo</td>
                                    <td>@choice.Description</td>
                                    <td>@choice.Unit</td>
                                    <td>@choice.Quantity</td>
                                    <td class="text-right">@choice.UnitCost.ToString("N2")</td>
                                    <td>@(string.IsNullOrWhiteSpace(choice.StockNumber) ? "-" : choice.StockNumber)</td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>

                    <MudText Typo="Typo.caption" Class="mt-2">
                        Selected for inspection: @SelectedPoLineCount
                    </MudText>
                }

                @if (_unmappedExistingLines.Count > 0)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2 mb-2">
                        This draft contains @(_unmappedExistingLines.Count) saved line(s) that do not match the current PO lines. They will be retained on save to avoid data loss.
                    </MudAlert>

                    <MudSimpleTable Dense="true" Hover="true" Striped="true">
                        <thead>
                            <tr>
                                <th>Description</th>
                                <th>Unit</th>
                                <th>Qty</th>
                                <th class="text-right">Unit Cost</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in _unmappedExistingLines)
                            {
                                <tr>
                                    <td>@line.Description</td>
                                    <td>@line.Unit</td>
                                    <td>@line.Quantity</td>
                                    <td class="text-right">@line.UnitCost.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }
            </MudItem>
        </MudGrid>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">@(_isLocked ? "Close" : "Cancel")</MudButton>
        @if (!_isLocked)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="SaveDraftAsync" Disabled="_busy">
                Save Draft
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SaveAndSubmitAsync" Disabled="_busy">
                Save &amp; Submit for Inspection
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;
    [Parameter] public AssetIARDto? Existing { get; set; }

    private bool _busy;
    private bool _isLocked => Existing is not null && Existing.Status != AssetIARStatus.Draft;

    private PurchaseOrderSummaryDto? _selectedPo;
    private PurchaseOrderDto? _selectedPoDetails;
    private EmployeeReferenceDto? _assignedInspector;
    private Guid _currentUserEmployeeId;
    private string? _deliveryReceiptNo;
    private DateTime? _deliveryDate;
    private string? _remarks;

    private string? _inspectorRoleId;
    private readonly Dictionary<string, EmployeeReferenceDto> _inspectorEmployeeCache = new(StringComparer.OrdinalIgnoreCase);
    private readonly List<PoLineChoice> _poLineChoices = [];
    private readonly List<LineModel> _unmappedExistingLines = [];
    private int SelectedPoLineCount => _poLineChoices.Count(x => x.Selected);

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(ResolveInspectorRoleAsync(), ResolveCurrentUserEmployeeAsync());

        if (Existing is null)
        {
            return;
        }

        try
        {
            _selectedPoDetails = await PoClient.GetAsync(Existing.PurchaseOrderId);
            if (_selectedPoDetails is not null)
            {
                _selectedPo = new PurchaseOrderSummaryDto(
                    _selectedPoDetails.Id,
                    _selectedPoDetails.PoNumber,
                    _selectedPoDetails.PoDate,
                    _selectedPoDetails.PrNumber,
                    _selectedPoDetails.SupplierName,
                    _selectedPoDetails.ModeOfProcurement,
                    _selectedPoDetails.Status,
                    _selectedPoDetails.TotalAmount,
                    _selectedPoDetails.CreatedOnUtc);

                HydratePoLineChoices(_selectedPoDetails.LineItems, Existing.LineItems);
            }
        }
        catch
        {
            // Ignore PO pre-load failures.
        }

        _deliveryReceiptNo = Existing.DeliveryReceiptNo;
        _deliveryDate = Existing.DeliveryDate?.ToDateTime(TimeOnly.MinValue);
        _remarks = Existing.Remarks;

        try { _assignedInspector = await LookupClient.EmployeesGetAsync(Existing.InspectedById); } catch { }

        if (!string.IsNullOrWhiteSpace(_assignedInspector?.IdentityUserId))
        {
            _inspectorEmployeeCache[_assignedInspector.IdentityUserId] = _assignedInspector;
        }

        if (_poLineChoices.Count == 0 && Existing.LineItems.Count > 0)
        {
            _unmappedExistingLines.AddRange(Existing.LineItems.Select(ToLineModel));
        }
    }

    private async Task ResolveInspectorRoleAsync()
    {
        try
        {
            var roles = await IdentityClient.RolesGetAsync();
            _inspectorRoleId = roles?
                .FirstOrDefault(r => string.Equals(r.Name, "Inspector", StringComparison.OrdinalIgnoreCase))?
                .Id;
        }
        catch
        {
            _inspectorRoleId = null;
        }
    }

    private async Task ResolveCurrentUserEmployeeAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var identityId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrWhiteSpace(identityId))
            {
                var employee = await EmployeesClient.ByIdentityAsync(identityId);
                if (employee is not null)
                    _currentUserEmployeeId = employee.Id;
            }
        }
        catch
        {
            // Falls back to Guid.Empty; server-side validation will catch it.
        }
    }

    private static string FormatPo(PurchaseOrderSummaryDto? po) =>
        po is null ? string.Empty : $"{po.PoNumber} - {po.SupplierName}";

    private static string FormatEmployee(EmployeeReferenceDto? employee) =>
        employee is null ? string.Empty : $"{employee.LastName}, {employee.FirstName} ({employee.EmployeeNumber})";

    private async Task<IEnumerable<PurchaseOrderSummaryDto>> SearchPurchaseOrdersAsync(string value, CancellationToken cancellationToken)
    {
        try
        {
            var keyword = string.IsNullOrWhiteSpace(value) ? null : value;
            var issued = await PoClient.SearchAsync(keyword, status: PurchaseOrderStatus.Issued, page: 1, pageSize: 20, ct: cancellationToken);
            var partiallyDelivered = await PoClient.SearchAsync(keyword, status: PurchaseOrderStatus.PartiallyDelivered, page: 1, pageSize: 20, ct: cancellationToken);

            return issued.Items
                .Concat(partiallyDelivered.Items)
                .OrderByDescending(x => x.PoDate)
                .ThenByDescending(x => x.CreatedOnUtc)
                .DistinctBy(x => x.Id)
                .Take(30)
                .ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load purchase orders: {ex.Message}", Severity.Error);
            return [];
        }
    }

    private async Task OnPoSelectedAsync(PurchaseOrderSummaryDto? po)
    {
        _selectedPo = po;
        _selectedPoDetails = null;
        _poLineChoices.Clear();
        _unmappedExistingLines.Clear();

        if (po is null)
        {
            return;
        }

        try
        {
            _selectedPoDetails = await PoClient.GetAsync(po.Id);
            if (_selectedPoDetails is null)
            {
                return;
            }

            var existingLines = Existing is not null && Existing.PurchaseOrderId == po.Id
                ? Existing.LineItems
                : null;

            HydratePoLineChoices(_selectedPoDetails.LineItems, existingLines);
        }
        catch
        {
            // Ignore PO line load failures.
        }
    }

    private void HydratePoLineChoices(
        IReadOnlyList<PurchaseOrderLineItemDto> poLines,
        IReadOnlyList<AssetIARLineItemDto>? existingLines)
    {
        _poLineChoices.Clear();
        _unmappedExistingLines.Clear();

        foreach (var poLine in poLines.OrderBy(x => x.ItemNo))
        {
            _poLineChoices.Add(new PoLineChoice
            {
                ItemNo = poLine.ItemNo,
                Unit = poLine.Unit,
                Description = poLine.Description,
                StockNumber = poLine.StockNumber,
                Quantity = poLine.Quantity,
                UnitCost = poLine.UnitCost,
                Selected = false
            });
        }

        if (existingLines is null || existingLines.Count == 0)
        {
            return;
        }

        var remainingExisting = existingLines.Select(ToLineModel).ToList();

        foreach (var choice in _poLineChoices)
        {
            var match = remainingExisting.FirstOrDefault(existing => IsSameLine(choice, existing));
            if (match is null)
            {
                continue;
            }

            choice.Selected = true;
            remainingExisting.Remove(match);
        }

        _unmappedExistingLines.AddRange(remainingExisting);
    }

    private static bool IsSameLine(PoLineChoice poLine, LineModel iarLine)
    {
        return string.Equals(Normalize(poLine.Description), Normalize(iarLine.Description), StringComparison.Ordinal)
            && string.Equals(Normalize(poLine.Unit), Normalize(iarLine.Unit), StringComparison.Ordinal)
            && poLine.Quantity == iarLine.Quantity
            && poLine.UnitCost == iarLine.UnitCost;
    }

    private static string Normalize(string? value) => (value ?? string.Empty).Trim().ToUpperInvariant();

    private static LineModel ToLineModel(AssetIARLineItemDto lineItem) => new()
    {
        Description = lineItem.Description,
        TechnicalSpecifications = lineItem.TechnicalSpecifications,
        Brand = lineItem.Brand,
        Model = lineItem.Model,
        SerialNo = lineItem.SerialNo,
        Unit = lineItem.Unit,
        Quantity = lineItem.Quantity,
        UnitCost = lineItem.UnitCost,
        PropertyClassHint = lineItem.PropertyClassHint
    };

    private void SelectAllPoLines()
    {
        foreach (var line in _poLineChoices)
        {
            line.Selected = true;
        }
    }

    private void ClearPoLineSelection()
    {
        foreach (var line in _poLineChoices)
        {
            line.Selected = false;
        }
    }

    private async Task<IEnumerable<EmployeeReferenceDto>> SearchEmployeesAsync(string value, CancellationToken cancellationToken)
    {
        try
        {
            var response = await LookupClient.EmployeesGetAsync(
                keyword: string.IsNullOrWhiteSpace(value) ? null : value,
                isActive: true,
                pageNumber: 1,
                pageSize: 20,
                cancellationToken: cancellationToken);
            return response?.Items ?? [];
        }
        catch
        {
            return [];
        }
    }

    private async Task<IEnumerable<EmployeeReferenceDto>> SearchInspectorsAsync(string value, CancellationToken cancellationToken)
    {
        if (string.IsNullOrWhiteSpace(_inspectorRoleId))
        {
            return await SearchEmployeesAsync(value, cancellationToken);
        }

        try
        {
            var users = await UsersClient.SearchAsync(
                pageNumber: 1,
                pageSize: 20,
                search: string.IsNullOrWhiteSpace(value) ? null : value,
                isActive: true,
                roleId: _inspectorRoleId,
                cancellationToken: cancellationToken);

            foreach (var user in users?.Items ?? [])
            {
                if (string.IsNullOrWhiteSpace(user.Id) || _inspectorEmployeeCache.ContainsKey(user.Id))
                {
                    continue;
                }

                try
                {
                    var employee = await EmployeesClient.ByIdentityAsync(user.Id, cancellationToken);
                    if (employee is not null)
                    {
                        _inspectorEmployeeCache[user.Id] = employee;
                    }
                }
                catch
                {
                    // Ignore users without linked employee records.
                }
            }

            return _inspectorEmployeeCache.Values
                .Where(e => e.IsActive)
                .Where(e => string.IsNullOrWhiteSpace(value)
                    || e.FirstName.Contains(value, StringComparison.OrdinalIgnoreCase)
                    || e.LastName.Contains(value, StringComparison.OrdinalIgnoreCase)
                    || e.EmployeeNumber.Contains(value, StringComparison.OrdinalIgnoreCase))
                .OrderBy(e => e.LastName)
                .ThenBy(e => e.FirstName)
                .Take(20)
                .ToList();
        }
        catch
        {
            return [];
        }
    }

    private bool ValidateDraft()
    {
        if (_selectedPo is null)
        {
            Snackbar.Add("Select a Purchase Order.", Severity.Warning);
            return false;
        }

        if (_assignedInspector is null)
        {
            Snackbar.Add("Assigned Inspector is required.", Severity.Warning);
            return false;
        }

        if (SelectedPoLineCount == 0)
        {
            Snackbar.Add("Select at least one PO line for inspection.", Severity.Warning);
            return false;
        }

        return true;
    }

    private async Task<AssetIARDto?> SaveDraftCoreAsync()
    {
        if (!ValidateDraft())
        {
            return null;
        }

        var lineRequests = _poLineChoices
            .Where(x => x.Selected)
            .Select(line => new AssetIARLineItemRequest(
                line.Description,
                null,
                null,
                null,
                null,
                null,
                line.Unit,
                line.Quantity,
                line.UnitCost,
                null,
                null))
            .Concat(_unmappedExistingLines.Select(line => new AssetIARLineItemRequest(
                line.Description!,
                line.TechnicalSpecifications,
                line.Brand,
                line.Model,
                line.SerialNo,
                line.PropertyClassHint,
                line.Unit!,
                line.Quantity,
                line.UnitCost,
                null,
                null)))
            .ToList();

        var deliveryDate = _deliveryDate is null ? (DateOnly?)null : DateOnly.FromDateTime(_deliveryDate.Value);

        if (Existing is null)
        {
            var createCommand = new CreateAssetIARCommand(
                _selectedPo!.Id,
                _assignedInspector!.Id,
                _currentUserEmployeeId,
                _deliveryReceiptNo,
                deliveryDate,
                _remarks,
                lineRequests);

            return await IarClient.CreateAsync(createCommand);
        }

        var updateCommand = new UpdateAssetIARCommand(
            Existing.Id,
            _assignedInspector!.Id,
            _currentUserEmployeeId,
            _deliveryReceiptNo,
            deliveryDate,
            _remarks,
            lineRequests);

        return await IarClient.UpdateAsync(Existing.Id, updateCommand);
    }

    private async Task SaveDraftAsync()
    {
        _busy = true;
        try
        {
            var saved = await SaveDraftCoreAsync();
            if (saved is null)
            {
                return;
            }

            Snackbar.Add("Draft saved.", Severity.Success);
            Dialog.Close(DialogResult.Ok(saved));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SaveAndSubmitAsync()
    {
        _busy = true;
        try
        {
            var saved = await SaveDraftCoreAsync();
            if (saved is null)
            {
                return;
            }

            var submitted = await IarClient.SubmitForInspectionAsync(saved.Id);
            Snackbar.Add("Draft submitted for inspection.", Severity.Success);
            Dialog.Close(DialogResult.Ok(submitted));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Submit failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private void Cancel() => Dialog.Cancel();

    private sealed class LineModel
    {
        public string? Description { get; set; }
        public string? TechnicalSpecifications { get; set; }
        public string? Brand { get; set; }
        public string? Model { get; set; }
        public string? SerialNo { get; set; }
        public string? PropertyClassHint { get; set; }
        public string? Unit { get; set; }
        public decimal Quantity { get; set; }
        public decimal UnitCost { get; set; }
    }

    private sealed class PoLineChoice
    {
        public int ItemNo { get; set; }
        public string Unit { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string? StockNumber { get; set; }
        public decimal Quantity { get; set; }
        public decimal UnitCost { get; set; }
        public bool Selected { get; set; }
    }
}
