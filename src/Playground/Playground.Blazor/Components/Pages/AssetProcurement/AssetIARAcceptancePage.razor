@page "/asset-procurement/iars/{Id:guid}/accept"
@using AMIS.Playground.Blazor.ApiClient
@using AMIS.Modules.ProcurementAcquisition.Contracts.v1.AssetInspectionAcceptanceReports
@inject IAssetIarClient IarClient
@inject IUserProfileState UserProfileState
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Navigation

<PageTitle>IAR Acceptance / View</PageTitle>

<AMISPageHeader Title="IAR Acceptance"
                Description="Assign property numbers, split multi-quantity lines, or review accepted/cancelled IAR details." />

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_iar is null)
{
    <MudAlert Severity="Severity.Error">IAR not found.</MudAlert>
}
else
{
    <AssetIARStageStepper Status="@_iar.Status" />

    @if (_iar.Status == AssetIARStatus.Accepted)
    {
        <MudAlert Severity="Severity.Success" Class="mb-3">
            This IAR is already <b>Accepted</b>. The page is in read-only mode.
        </MudAlert>
    }
    else if (_iar.Status == AssetIARStatus.Cancelled)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-3">
            This IAR is <b>Cancelled</b>. The page is in read-only mode.
        </MudAlert>
    }
    else if (_iar.Status != AssetIARStatus.Inspected)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-3">
            Acceptance actions are available only when IAR status is <b>Inspected</b>. Current page is read-only.
        </MudAlert>
    }
    else if (!_canAssignPropertyNoPermission && !_canAcceptPermission)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-3">
            You do not have permissions to assign Property No or accept this IAR. Current page is read-only.
        </MudAlert>
    }

    <MudCard Elevation="1" Class="mb-3">
        <MudCardContent Class="pb-2">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6" md="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">IAR No.</MudText>
                    <MudText Typo="Typo.body1"><b>@_iar.IarNumber</b></MudText>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">IAR Date</MudText>
                    <MudText Typo="Typo.body1">@_iar.IarDate.ToString("MMM dd, yyyy")</MudText>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Purchase Order</MudText>
                    <MudText Typo="Typo.body1">@_iar.PoNumber</MudText>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Supplier</MudText>
                    <MudText Typo="Typo.body1">@_iar.SupplierName</MudText>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Inspector</MudText>
                    <MudText Typo="Typo.body1">@(_iar.InspectedByName ?? "—")</MudText>
                </MudItem>
                @if (_iar.InspectedOnUtc.HasValue)
                {
                    <MudItem xs="12" sm="6" md="3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Inspected On</MudText>
                        <MudText Typo="Typo.body1">@_iar.InspectedOnUtc.Value.ToLocalTime().ToString("MMM dd, yyyy")</MudText>
                    </MudItem>
                }
                <MudItem xs="12" sm="6" md="3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                    <MudText Typo="Typo.body1">@_iar.Status</MudText>
                </MudItem>
            </MudGrid>
        </MudCardContent>
    </MudCard>

    <MudCard Elevation="1">
        <MudCardContent>
            <MudExpansionPanels Elevation="0">
                <MudExpansionPanel Text=$"Passed Lines ({PassedLines.Count})" Expanded="true">
                    @if (PassedLines.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">
                            No passed lines are available for acceptance in this IAR.
                        </MudAlert>
                    }
                    else
                    {
                        <MudSimpleTable Dense="true" Hover="true" Striped="true">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Description</th>
                                    <th>Qty</th>
                                    <th>Property No</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var line in PassedLines)
                                {
                                    var input = GetPropertyNoInput(line.ItemNo, line.StockPropertyNo);
                                    <tr>
                                        <td>@line.ItemNo</td>
                                        <td>@line.Description</td>
                                        <td>@line.Quantity</td>
                                        <td style="min-width: 320px;">
                                            @if (_canAssignActions)
                                            {
                                                <PropertyNoField Value="@input"
                                                                ValueChanged="@(v => OnPropertyNoChanged(line.ItemNo, v))"
                                                                Label="Property No."
                                                                Placeholder="Required for passed lines"
                                                                MaxLength="64"
                                                                InitialYear="@DateTime.Now.Year" />
                                            }
                                            else
                                            {
                                                <MudText>@(string.IsNullOrWhiteSpace(line.StockPropertyNo) ? "-" : line.StockPropertyNo)</MudText>
                                            }
                                        </td>
                                        <td>
                                            @if (_canAssignActions)
                                            {
                                                <MudStack Row="true" Spacing="1">
                                                    <MudButton Variant="Variant.Outlined"
                                                               Size="Size.Small"
                                                               Color="Color.Primary"
                                                               Disabled="@(!CanAssignPropertyNo(line))"
                                                               OnClick="@(() => AssignPropertyNoAsync(line.ItemNo))">
                                                        Assign
                                                    </MudButton>
                                                    <MudButton Variant="Variant.Outlined"
                                                               Size="Size.Small"
                                                               Color="Color.Secondary"
                                                               Disabled="@(!CanExpandLine(line))"
                                                               OnClick="@(() => ExpandLineAsync(line.ItemNo))">
                                                        Expand Qty
                                                    </MudButton>
                                                </MudStack>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                </MudExpansionPanel>

                <MudExpansionPanel Text=$"Rejected Lines ({RejectedLines.Count})">
                    @if (RejectedLines.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">
                            No rejected lines.
                        </MudAlert>
                    }
                    else
                    {
                        <MudSimpleTable Dense="true" Hover="true" Striped="true">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Description</th>
                                    <th>Qty</th>
                                    <th>Inspector Remarks</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var line in RejectedLines)
                                {
                                    <tr>
                                        <td>@line.ItemNo</td>
                                        <td>@line.Description</td>
                                        <td>@line.Quantity</td>
                                        <td>@(string.IsNullOrWhiteSpace(line.InspectionRemarks) ? "-" : line.InspectionRemarks)</td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                </MudExpansionPanel>
            </MudExpansionPanels>

            @if (PendingLines.Count > 0)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                    This IAR still has @PendingLines.Count line(s) without inspection decision. Acceptance is disabled until inspection is finalized.
                </MudAlert>
            }

            @if (_canAcceptActions && !CanAccept())
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                    Click <b>Assign</b> on each passed line to save its Property No — the Accept button becomes available once every passed line has one.
                </MudAlert>
            }
        </MudCardContent>
        <MudCardActions>
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" OnClick="BackToList">Back</MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Success"
                       Disabled="@(!_canAcceptActions || _busy || !CanAccept())"
                       OnClick="AcceptAsync">
                Accept IAR
            </MudButton>
        </MudCardActions>
    </MudCard>
}

@code {
    private const string PermissionAccept = "Permissions.Procurement.AssetIARs.Accept";
    private const string PermissionAssignPropertyNo = "Permissions.Procurement.AssetIARs.AssignPropertyNo";

    [Parameter] public Guid Id { get; set; }

    private AssetIARDto? _iar;
    private bool _loading = true;
    private bool _busy;
    private readonly Dictionary<int, string> _propertyNoInputs = [];
    private List<AssetIARLineItemDto> _passedLines = [];
    private List<AssetIARLineItemDto> _rejectedLines = [];
    private List<AssetIARLineItemDto> _pendingLines = [];
    private List<AssetIARLineItemDto> PassedLines => _passedLines;
    private List<AssetIARLineItemDto> RejectedLines => _rejectedLines;
    private List<AssetIARLineItemDto> PendingLines => _pendingLines;

    private bool _canAcceptPermission => UserProfileState.Permissions.Contains(PermissionAccept);
    private bool _canAssignPropertyNoPermission => UserProfileState.Permissions.Contains(PermissionAssignPropertyNo);
    private bool _canAssignActions => _iar is not null && _iar.Status == AssetIARStatus.Inspected && _canAssignPropertyNoPermission;
    private bool _canAcceptActions => _iar is not null && _iar.Status == AssetIARStatus.Inspected && _canAcceptPermission;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _iar = await IarClient.GetAsync(Id);
            SyncPropertyNoInputs();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load IAR: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void SyncPropertyNoInputs()
    {
        _propertyNoInputs.Clear();
        if (_iar is null)
        {
            _passedLines = [];
            _rejectedLines = [];
            _pendingLines = [];
            return;
        }

        foreach (var line in _iar.LineItems)
            _propertyNoInputs[line.ItemNo] = line.StockPropertyNo ?? string.Empty;

        var ordered = _iar.LineItems.OrderBy(li => li.ItemNo).ToList();
        _passedLines = ordered.Where(li => li.InspectionResult == LineInspectionResult.Passed).ToList();
        _rejectedLines = ordered.Where(li => li.InspectionResult == LineInspectionResult.Rejected).ToList();
        _pendingLines = ordered.Where(li => li.InspectionResult == LineInspectionResult.Pending).ToList();
    }

    private string GetPropertyNoInput(int itemNo, string? fallback)
    {
        if (_propertyNoInputs.TryGetValue(itemNo, out var value))
        {
            return value;
        }

        var initial = fallback ?? string.Empty;
        _propertyNoInputs[itemNo] = initial;
        return initial;
    }

    private void OnPropertyNoChanged(int itemNo, string? value)
    {
        _propertyNoInputs[itemNo] = value?.Trim() ?? string.Empty;
    }

    private bool CanAssignPropertyNo(AssetIARLineItemDto line)
        => _canAssignActions && line.InspectionResult == LineInspectionResult.Passed;

    private bool CanExpandLine(AssetIARLineItemDto line)
        => _canAssignActions && line.InspectionResult == LineInspectionResult.Passed && line.Quantity > 1m;

    private bool CanAccept()
    {
        if (_iar is null || _iar.Status != AssetIARStatus.Inspected)
        {
            return false;
        }

        if (_iar.LineItems.Count == 0)
        {
            return false;
        }

        return PassedLines
            .All(li => !string.IsNullOrWhiteSpace(li.StockPropertyNo));
    }

    private async Task AssignPropertyNoAsync(int itemNo)
    {
        if (_iar is null)
        {
            return;
        }

        if (!_propertyNoInputs.TryGetValue(itemNo, out var propertyNo) || string.IsNullOrWhiteSpace(propertyNo))
        {
            Snackbar.Add($"Item {itemNo}: Property No is required.", Severity.Warning);
            return;
        }

        _busy = true;
        try
        {
            _iar = await IarClient.AssignPropertyNoAsync(_iar.Id, itemNo, propertyNo.Trim());
            SyncPropertyNoInputs();
            Snackbar.Add($"Item {itemNo}: Property No assigned.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Assign property no failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ExpandLineAsync(int itemNo)
    {
        if (_iar is null)
        {
            return;
        }

        var ok = await DialogService.ShowMessageBox(
            "Expand Quantity",
            $"Expand item {itemNo} into one-line-per-unit entries?",
            yesText: "Expand",
            cancelText: "Cancel");

        if (ok != true)
        {
            return;
        }

        _busy = true;
        try
        {
            _iar = await IarClient.ExpandLineByQuantityAsync(_iar.Id, itemNo);
            SyncPropertyNoInputs();
            Snackbar.Add($"Item {itemNo} expanded.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Expand failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task AcceptAsync()
    {
        if (_iar is null)
        {
            return;
        }

        var ok = await DialogService.ShowMessageBox(
            "Accept IAR",
            "Confirm acceptance and publish accepted line items to AssetManagement?",
            yesText: "Accept",
            cancelText: "Cancel");

        if (ok != true)
        {
            return;
        }

        _busy = true;
        try
        {
            _iar = await IarClient.AcceptAsync(_iar.Id);
            Snackbar.Add("IAR accepted.", Severity.Success);
            Navigation.NavigateTo("/asset-procurement/iars");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Accept failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private void BackToList() => Navigation.NavigateTo("/asset-procurement/iars");

}