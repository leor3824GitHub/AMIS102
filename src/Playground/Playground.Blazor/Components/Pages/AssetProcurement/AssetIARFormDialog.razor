@using AMIS.Playground.Blazor.ApiClient
@using AMIS.Modules.AssetProcurement.Contracts.v1.AssetInspectionAcceptanceReports
@using AMIS.Modules.AssetProcurement.Contracts.v1.AssetPurchaseOrders
@inject IAssetIarClient IarClient
@inject IAssetPurchaseOrderClient PoClient
@inject ILookupClient LookupClient
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_isReadOnly)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                This IAR is <b>@Existing!.Status</b> and cannot be edited.
            </MudAlert>
        }

        <MudGrid Spacing="2">
            <MudItem xs="12" md="6">
                <MudAutocomplete T="AssetPurchaseOrderSummaryDto"
                                 @bind-Value="_selectedPo"
                                 SearchFunc="SearchPurchaseOrdersAsync"
                                 ToStringFunc="@(po => po is null ? "" : $"{po.PoNumber} – {po.SupplierName}")"
                                 Label="Asset Purchase Order *"
                                 Variant="Variant.Outlined" Dense="true"
                                 Disabled="@_isReadOnly"
                                 Required="true" CoerceText="false" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField Value="@(Existing?.IarNumber ?? "(auto)")" Label="IAR No."
                              Variant="Variant.Outlined" Dense="true" ReadOnly="true" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField Value="@((Existing?.IarDate ?? DateOnly.FromDateTime(DateTime.Today)).ToString("MM/dd/yyyy"))"
                              Label="IAR Date" Variant="Variant.Outlined" Dense="true" ReadOnly="true" />
            </MudItem>

            <MudItem xs="12" md="6">
                <MudAutocomplete T="EmployeeReferenceDto"
                                 @bind-Value="_inspectedBy"
                                 SearchFunc="SearchEmployeesAsync"
                                 ToStringFunc="FormatEmployee"
                                 Label="Inspection Officer *"
                                 Variant="Variant.Outlined" Dense="true"
                                 Disabled="@_isReadOnly"
                                 Required="true" CoerceText="false" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudAutocomplete T="EmployeeReferenceDto"
                                 @bind-Value="_receivedBy"
                                 SearchFunc="SearchEmployeesAsync"
                                 ToStringFunc="FormatEmployee"
                                 Label="Property Custodian *"
                                 Variant="Variant.Outlined" Dense="true"
                                 Disabled="@_isReadOnly"
                                 Required="true" CoerceText="false" />
            </MudItem>

            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_deliveryReceiptNo" Label="Delivery Receipt No."
                              Variant="Variant.Outlined" Dense="true"
                              Disabled="@_isReadOnly" MaxLength="64" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudDatePicker @bind-Date="_deliveryDate" Label="Delivery Date"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               DateFormat="MM/dd/yyyy" Disabled="@_isReadOnly" />
            </MudItem>

            <MudItem xs="12">
                <MudTextField @bind-Value="_remarks" Label="Remarks" Variant="Variant.Outlined"
                              Lines="2" MaxLength="1000" Disabled="@_isReadOnly" />
            </MudItem>

            <MudItem xs="12">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-2">
                    <MudText Typo="Typo.subtitle1" Class="flex-grow-1"><b>Line Items</b></MudText>
                    @if (!_isReadOnly)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add" OnClick="AddLine">
                            Add Line
                        </MudButton>
                    }
                </MudStack>
                <MudAlert Severity="Severity.Info" Dense="true" Class="my-2">
                    Per NFA policy: <b>one line per physical unit</b>. Each line carries its own Property No.
                    Use the ✨ generator on the Property No field.
                </MudAlert>

                @for (var idx = 0; idx < _lines.Count; idx++)
                {
                    var i = idx;
                    var line = _lines[i];
                    <MudPaper Elevation="0" Class="pa-2 mb-2"
                              Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 4px;">
                        <MudGrid Spacing="2">
                            <MudItem xs="12" md="4">
                                <PropertyNoField @bind-Value="line.StockPropertyNo"
                                                 Label="Stock / Property No. *"
                                                 Required="true" MaxLength="32"
                                                 Placeholder="e.g. 2026-NFA-00B-07-DSK-001"
                                                 Disabled="_isReadOnly"
                                                 InitialYear="@DateTime.Now.Year" />
                            </MudItem>
                            <MudItem xs="12" md="5">
                                <MudTextField @bind-Value="line.Description" Label="Description *"
                                              Variant="Variant.Outlined" Dense="true" Required="true"
                                              Disabled="@_isReadOnly" MaxLength="500" />
                            </MudItem>
                            <MudItem xs="6" md="1">
                                <MudTextField @bind-Value="line.Unit" Label="Unit *"
                                              Variant="Variant.Outlined" Dense="true" Required="true"
                                              Disabled="@_isReadOnly" MaxLength="64" />
                            </MudItem>
                            <MudItem xs="6" md="1">
                                <MudNumericField @bind-Value="line.Quantity" Label="Qty *"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 Min="1" Max="1" T="decimal" Disabled="@_isReadOnly" />
                            </MudItem>
                            <MudItem xs="12" md="1">
                                @if (!_isReadOnly)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                   Color="Color.Error" OnClick="@(() => RemoveLine(i))" />
                                }
                            </MudItem>

                            <MudItem xs="12" md="3">
                                <MudTextField @bind-Value="line.Brand" Label="Brand"
                                              Variant="Variant.Outlined" Dense="true"
                                              Disabled="@_isReadOnly" MaxLength="200" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudTextField @bind-Value="line.Model" Label="Model"
                                              Variant="Variant.Outlined" Dense="true"
                                              Disabled="@_isReadOnly" MaxLength="200" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudTextField @bind-Value="line.SerialNo" Label="Serial No."
                                              Variant="Variant.Outlined" Dense="true"
                                              Disabled="@_isReadOnly" MaxLength="200" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudNumericField @bind-Value="line.UnitCost" Label="Unit Cost *"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 Min="0.01m" T="decimal" Format="N2"
                                                 Required="true" Disabled="@_isReadOnly" />
                            </MudItem>

                            <MudItem xs="12" md="9">
                                <MudTextField @bind-Value="line.TechnicalSpecifications" Label="Technical Specifications"
                                              Variant="Variant.Outlined" Dense="true"
                                              Disabled="@_isReadOnly" MaxLength="1000" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudTextField @bind-Value="line.PropertyClassHint" Label="Property Class Hint"
                                              Variant="Variant.Outlined" Dense="true"
                                              Disabled="@_isReadOnly" MaxLength="64" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField @bind-Value="line.InspectionRemarks" Label="Inspection Remarks"
                                              Variant="Variant.Outlined" Dense="true"
                                              Disabled="@_isReadOnly" MaxLength="500" />
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                }
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@(_isReadOnly ? "Close" : "Cancel")</MudButton>
        @if (!_isReadOnly)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="_busy">
                @(Existing is null ? "Create" : "Update")
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;
    [Parameter] public AssetIARDto? Existing { get; set; }

    private bool _isReadOnly => Existing is not null && Existing.Status != AssetIARStatus.Draft;
    private bool _busy;

    private AssetPurchaseOrderSummaryDto? _selectedPo;
    private EmployeeReferenceDto? _inspectedBy;
    private EmployeeReferenceDto? _receivedBy;
    private string? _deliveryReceiptNo;
    private DateTime? _deliveryDate;
    private string? _remarks;

    private readonly List<LineModel> _lines = [];

    protected override async Task OnInitializedAsync()
    {
        if (Existing is not null)
        {
            // Resolve PO summary from list (best-effort — falls back to PoNumber-only if not found)
            try
            {
                var pos = await PoClient.SearchAsync(keyword: Existing.PoNumber, page: 1, pageSize: 5);
                _selectedPo = pos.Items.FirstOrDefault(p => p.Id == Existing.PurchaseOrderId)
                              ?? pos.Items.FirstOrDefault();
            }
            catch { /* ignored */ }

            _deliveryReceiptNo = Existing.DeliveryReceiptNo;
            _deliveryDate = Existing.DeliveryDate?.ToDateTime(TimeOnly.MinValue);
            _remarks = Existing.Remarks;

            foreach (var li in Existing.LineItems)
                _lines.Add(new LineModel
                {
                    Description = li.Description,
                    TechnicalSpecifications = li.TechnicalSpecifications,
                    Brand = li.Brand,
                    Model = li.Model,
                    SerialNo = li.SerialNo,
                    PropertyClassHint = li.PropertyClassHint,
                    Unit = li.Unit,
                    Quantity = li.Quantity,
                    UnitCost = li.UnitCost,
                    InspectionRemarks = li.InspectionRemarks,
                    StockPropertyNo = li.StockPropertyNo ?? string.Empty
                });
        }
        else
        {
            AddLine();
        }
    }

    private void AddLine() => _lines.Add(new LineModel { Quantity = 1 });

    private void RemoveLine(int index)
    {
        if (index >= 0 && index < _lines.Count) _lines.RemoveAt(index);
    }

    private async Task<IEnumerable<AssetPurchaseOrderSummaryDto>> SearchPurchaseOrdersAsync(string? value, CancellationToken ct)
    {
        try
        {
            var r = await PoClient.SearchAsync(keyword: value, page: 1, pageSize: 30, ct: ct);
            return r.Items;
        }
        catch { return []; }
    }

    private async Task<IEnumerable<EmployeeReferenceDto>> SearchEmployeesAsync(string value, CancellationToken ct)
    {
        try
        {
            var r = await LookupClient.EmployeesGetAsync(
                keyword: string.IsNullOrWhiteSpace(value) ? null : value,
                isActive: true, pageNumber: 1, pageSize: 20, cancellationToken: ct);
            return r?.Items ?? [];
        }
        catch { return []; }
    }

    private static string FormatEmployee(EmployeeReferenceDto? e) =>
        e is null ? string.Empty : $"{e.LastName}, {e.FirstName} ({e.EmployeeNumber})";

    private async Task SaveAsync()
    {
        if (_selectedPo is null) { Snackbar.Add("Select a Purchase Order.", Severity.Warning); return; }
        if (_inspectedBy is null) { Snackbar.Add("Inspection Officer is required.", Severity.Warning); return; }
        if (_receivedBy is null) { Snackbar.Add("Property Custodian is required.", Severity.Warning); return; }
        if (_lines.Count == 0) { Snackbar.Add("At least one line item is required.", Severity.Warning); return; }

        foreach (var (line, idx) in _lines.Select((l, i) => (l, i + 1)))
        {
            if (string.IsNullOrWhiteSpace(line.Description))
            { Snackbar.Add($"Line {idx}: Description is required.", Severity.Warning); return; }
            if (string.IsNullOrWhiteSpace(line.Unit))
            { Snackbar.Add($"Line {idx}: Unit is required.", Severity.Warning); return; }
            if (line.UnitCost <= 0)
            { Snackbar.Add($"Line {idx}: Unit Cost must be greater than 0.", Severity.Warning); return; }
            if (line.Quantity <= 0)
            { Snackbar.Add($"Line {idx}: Quantity must be greater than 0.", Severity.Warning); return; }
        }

        _busy = true;
        try
        {
            var requests = _lines.Select(l => new AssetIARLineItemRequest(
                l.Description!,
                l.TechnicalSpecifications,
                l.Brand,
                l.Model,
                l.SerialNo,
                l.PropertyClassHint,
                l.Unit!,
                l.Quantity,
                l.UnitCost,
                l.InspectionRemarks,
                string.IsNullOrWhiteSpace(l.StockPropertyNo) ? null : l.StockPropertyNo)).ToList();

            var deliveryDate = _deliveryDate is null ? (DateOnly?)null : DateOnly.FromDateTime(_deliveryDate.Value);

            if (Existing is null)
            {
                var cmd = new CreateAssetIARCommand(
                    _selectedPo.Id, _inspectedBy.Id, _receivedBy.Id,
                    _deliveryReceiptNo, deliveryDate, _remarks, requests);
                await IarClient.CreateAsync(cmd);
                Snackbar.Add("IAR created.", Severity.Success);
            }
            else
            {
                var cmd = new UpdateAssetIARCommand(
                    Existing.Id, _inspectedBy.Id, _receivedBy.Id,
                    _deliveryReceiptNo, deliveryDate, _remarks, requests);
                await IarClient.UpdateAsync(Existing.Id, cmd);
                Snackbar.Add("IAR updated.", Severity.Success);
            }
            Dialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex) { Snackbar.Add($"Save failed: {ex.Message}", Severity.Error); }
        finally { _busy = false; }
    }

    private void Cancel() => Dialog.Cancel();

    private sealed class LineModel
    {
        public string? Description { get; set; }
        public string? TechnicalSpecifications { get; set; }
        public string? Brand { get; set; }
        public string? Model { get; set; }
        public string? SerialNo { get; set; }
        public string? PropertyClassHint { get; set; }
        public string? Unit { get; set; }
        public decimal Quantity { get; set; } = 1;
        public decimal UnitCost { get; set; }
        public string? InspectionRemarks { get; set; }
        public string StockPropertyNo { get; set; } = string.Empty;
    }
}
