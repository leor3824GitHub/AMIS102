@page "/asset-management/property-units"
@using FSH.Playground.Blazor.ApiClient
@inject ISemiExpendablePropertyClient SEClient
@inject IPPEItemClient PPEClient
@inject IPropertyItemCatalogClient ItemClient
@inject ISnackbar Snackbar

<FshPageHeader Title="Property Units" Description="All physical property units — semi-expendable and PPE — in a single view. Register semi-expendable units here; PPE units are created via PPERR." />

<MudGrid Spacing="3">
    <!-- Register SE Form -->
    <MudItem xs="12" md="4">
        <MudCard Elevation="1">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-3">Property Register</MudText>
                <MudStack Spacing="2">
                    <MudAutocomplete T="PropertyItemCatalogSummaryDto"
                                        @bind-Value="_form.SelectedItem"
                                        SearchFunc="SearchItems"
                                        ToStringFunc="@(x => x is null ? "" : $"{x.Code} – {x.Name}")"
                                        Label="Item (from catalog)" Variant="Variant.Outlined"
                                        Required="true" Clearable="true"
                                        ResetValueOnEmptyText="true" CoerceValue="true" />
                        <PropertyNoField @bind-Value="_form.PropertyNo"
                                        Label="Property No."
                                        Required="true"
                                        MaxLength="32"
                                        Placeholder="e.g. 2026-NFA-GSD-00001" />
                    
                    <MudTextField @bind-Value="_form.SerialNo" Label="Serial No." Variant="Variant.Outlined" MaxLength="100" />
                    <MudDatePicker @bind-Date="_form.AcquisitionDateNullable" Label="Acquisition Date"
                                   Variant="Variant.Outlined" DateFormat="MM/dd/yyyy" Required="true" />
                    <MudNumericField @bind-Value="_form.UnitCost" Label="Unit Cost (₱)" Variant="Variant.Outlined"
                                     Required="true" Min="0.01m" Max="49999.99m" Format="N2" />
                    <MudTextField @bind-Value="_form.FundCluster" Label="Fund Cluster" Variant="Variant.Outlined" MaxLength="50" />
                    <MudTextField @bind-Value="_form.Remarks" Label="Remarks" Variant="Variant.Outlined" MaxLength="500" Lines="2" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                               OnClick="RegisterAsync" Disabled="_busy">Register</MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- List Panel -->
    <MudItem xs="12" md="8">
        <MudCard Elevation="1">
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
                    <MudText Typo="Typo.h6" Class="flex-grow-1">All Property Units</MudText>
                    <MudTextField @bind-Value="_keyword" Label="Search" Variant="Variant.Outlined" Size="Size.Small"
                                  Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                                  DebounceInterval="350" OnDebounceIntervalElapsed="@(() => LoadAsync())" Style="max-width:200px" />
                    <MudSelect Value="_typeFilter" Label="Type" Variant="Variant.Outlined" Size="Size.Small"
                               T="string?" Style="max-width:110px" ValueChanged="@(v => { _typeFilter = v; _ = LoadAsync(); })">
                        <MudSelectItem T="string?" Value="@((string?)null)">All</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("SE")">SE</MudSelectItem>
                        <MudSelectItem T="string?" Value="@("PPE")">PPE</MudSelectItem>
                    </MudSelect>
                    <MudSelect Value="_statusFilter" Label="Status" Variant="Variant.Outlined" Size="Size.Small"
                               T="string?" Style="max-width:140px" ValueChanged="@(v => { _statusFilter = v; _ = LoadAsync(); })">
                        <MudSelectItem T="string?" Value="@((string?)null)">All Statuses</MudSelectItem>
                        @foreach (var s in _statuses)
                        {
                            <MudSelectItem T="string?" Value="s">@s</MudSelectItem>
                        }
                    </MudSelect>
                </MudStack>

                @if (_loading)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else if (_items.Count == 0)
                {
                    <MudAlert Severity="Severity.Info">No property units found.</MudAlert>
                }
                else
                {
                    <MudSimpleTable Dense="true" Hover="true" Striped="true">
                        <thead>
                            <tr>
                                <th>Type</th>
                                <th>Property No.</th>
                                <th>Item / Description</th>
                                <th>Serial No.</th>
                                <th>Acq. Date</th>
                                <th>Unit Cost</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in _pagedItems)
                            {
                                <tr>
                                    <td>
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@(p.Type == "PPE" ? Color.Primary : Color.Tertiary)">
                                            @p.Type
                                        </MudChip>
                                    </td>
                                    <td><MudText Typo="Typo.body2"><b>@p.PropertyNo</b></MudText></td>
                                    <td>
                                        <MudText Typo="Typo.body2">@p.ItemName</MudText>
                                        @if (!string.IsNullOrWhiteSpace(p.ItemCode))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@p.ItemCode</MudText>
                                        }
                                    </td>
                                    <td>@(p.SerialNo ?? "-")</td>
                                    <td>@p.AcquisitionDate.ToString("MM/dd/yyyy")</td>
                                    <td>₱@p.UnitCost.ToString("N2")</td>
                                    <td>@StatusChip(p.Status)</td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>

                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-2" Spacing="1">
                        <MudText Typo="Typo.caption">@_items.Count total (SE: @_seCount, PPE: @_ppeCount)</MudText>
                        <MudSpacer />
                        <MudPagination Count="@TotalPages" Selected="_page" ShowFirstButton="true" ShowLastButton="true"
                                       SelectedChanged="@(p => { _page = p; StateHasChanged(); })" />
                    </MudStack>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private List<PropertyUnitRow> _items = [];
    private PropertyForm _form = new();
    private string? _keyword;
    private string? _typeFilter;
    private string? _statusFilter;
    private bool _loading;
    private bool _busy;
    private int _page = 1;
    private int _seCount;
    private int _ppeCount;
    private const int PageSize = 15;

    private static readonly string[] _statuses =
        ["OnHand", "Issued", "IssuedPAR", "Returned", "Transferred", "Disposed", "LostStolenDamaged"];

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_items.Count / (double)PageSize));
    private IEnumerable<PropertyUnitRow> _pagedItems => _items.Skip((_page - 1) * PageSize).Take(PageSize);

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _items = [];
        _seCount = 0;
        _ppeCount = 0;
        try
        {
            var merged = new List<PropertyUnitRow>();

            if (_typeFilter is null or "SE")
            {
                var seResponse = await SEClient.SearchAsync(
                    keyword: _keyword,
                    status: _statusFilter,
                    page: 1,
                    pageSize: 500);

                foreach (var p in seResponse.Items)
                    merged.Add(new PropertyUnitRow("SE", p.PropertyNo, p.ItemCode, p.ItemName,
                        p.SerialNo, p.AcquisitionDate, p.UnitCost, p.Status));

                _seCount = seResponse.TotalCount;
            }

            if (_typeFilter is null or "PPE")
            {
                var ppeResponse = await PPEClient.SearchAsync(
                    keyword: _keyword,
                    status: _statusFilter,
                    page: 1,
                    pageSize: 500);

                foreach (var p in ppeResponse.Items)
                    merged.Add(new PropertyUnitRow("PPE", p.PropertyNumber, p.PropertyCode, p.Description,
                        p.SerialNumber, p.DateAcquired, p.UnitCost, p.Status));

                _ppeCount = ppeResponse.TotalCount;
            }

            merged.Sort((a, b) => string.Compare(a.PropertyNo, b.PropertyNo, StringComparison.OrdinalIgnoreCase));
            _items = merged;
            _page = 1;
        }
        catch (Exception ex) { Snackbar.Add($"Load failed: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task<IEnumerable<PropertyItemCatalogSummaryDto>> SearchItems(string? value, CancellationToken ct)
    {
        var response = await ItemClient.SearchAsync(value, isActive: true, page: 1, pageSize: 20, ct: ct);
        return response.Items;
    }

    private async Task RegisterAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.PropertyNo) || _form.SelectedItem is null ||
            _form.AcquisitionDateNullable is null || _form.UnitCost <= 0)
        {
            Snackbar.Add("Property No., Item, Acquisition Date, and Unit Cost are required.", Severity.Warning);
            return;
        }
        _busy = true;
        try
        {
            await SEClient.RegisterAsync(new RegisterSemiExpendablePropertyCommand(
                _form.PropertyNo,
                _form.SelectedItem.Id,
                _form.SerialNo,
                DateOnly.FromDateTime(_form.AcquisitionDateNullable.Value),
                _form.UnitCost,
                _form.FundCluster,
                _form.Remarks));
            Snackbar.Add("SE property unit registered.", Severity.Success);
            _form = new();
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Register failed: {ex.Message}", Severity.Error); }
        finally { _busy = false; }
    }

    private static RenderFragment StatusChip(string status) => __builder =>
    {
        var color = status switch
        {
            "OnHand"            => Color.Success,
            "Issued"            => Color.Info,
            "IssuedPAR"         => Color.Info,
            "Returned"          => Color.Secondary,
            "Transferred"       => Color.Warning,
            "Disposed"          => Color.Default,
            "LostStolenDamaged" => Color.Error,
            _                   => Color.Default
        };
        __builder.OpenComponent<MudChip<string>>(0);
        __builder.AddAttribute(1, "Size", Size.Small);
        __builder.AddAttribute(2, "Color", color);
        __builder.AddAttribute(3, "ChildContent", (RenderFragment)(b => b.AddContent(0, status)));
        __builder.CloseComponent();
    };

    private sealed class PropertyForm
    {
        public string PropertyNo { get; set; } = string.Empty;
        public PropertyItemCatalogSummaryDto? SelectedItem { get; set; }
        public string? SerialNo { get; set; }
        public DateTime? AcquisitionDateNullable { get; set; } = DateTime.Today;
        public decimal UnitCost { get; set; }
        public string? FundCluster { get; set; }
        public string? Remarks { get; set; }
    }

    private sealed record PropertyUnitRow(
        string Type,
        string PropertyNo,
        string? ItemCode,
        string ItemName,
        string? SerialNo,
        DateOnly AcquisitionDate,
        decimal UnitCost,
        string Status);
}
