@page "/asset-management/receipts-for-returned-ppe"
@using AMIS.Playground.Blazor.ApiClient
@inject IRRPClient Client
@inject IPPEItemClient PPEItemClient
@inject ILookupClient LookupClient
@inject ISnackbar Snackbar

<AMISPageHeader Title="Receipts for Returned PPE (RRP)"
               Description="Record return of PPE items. Serviceable items revert to OnHand; Junked items are disposed." />

<MudGrid Spacing="3">
    <!-- Create Form -->
    <MudItem xs="12" md="5">
        <MudCard Elevation="1">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-3">New RRP</MudText>
                <MudStack Spacing="2">
                    <MudTextField @bind-Value="_form.RRPNo" Label="RRP No." Variant="Variant.Outlined"
                                  Required="true" MaxLength="32" Placeholder="e.g. RRP-2026-00001" />
                    <MudDatePicker @bind-Date="_form.DateNullable" Label="Date" Variant="Variant.Outlined"
                                   DateFormat="MM/dd/yyyy" Required="true" />
                    <MudSelect @bind-Value="_form.ReturnCategory" Label="Return Category" Variant="Variant.Outlined" T="PPEReturnCategory">
                        <MudSelectItem Value="PPEReturnCategory.Serviceable">Serviceable</MudSelectItem>
                        <MudSelectItem Value="PPEReturnCategory.Junked">Junked (Dispose)</MudSelectItem>
                    </MudSelect>
                    <MudAutocomplete T="EmployeeReferenceDto"
                                     @bind-Value="_form.ReturnedBy"
                                     SearchFunc="SearchEmployees" ToStringFunc="FormatEmployee"
                                     Label="Returned By" Variant="Variant.Outlined"
                                     Required="true" Clearable="true" ResetValueOnEmptyText="true" CoerceValue="true" />
                    <MudAutocomplete T="EmployeeReferenceDto"
                                     @bind-Value="_form.ApprovedBy"
                                     SearchFunc="SearchEmployees" ToStringFunc="FormatEmployee"
                                     Label="Approved By (GSD-PSMD Chief / RM / PM)" Variant="Variant.Outlined"
                                     Required="true" Clearable="true" ResetValueOnEmptyText="true" CoerceValue="true" />
                    <MudAutocomplete T="EmployeeReferenceDto"
                                     @bind-Value="_form.SignedBy"
                                     SearchFunc="SearchEmployees" ToStringFunc="FormatEmployee"
                                     Label="Signed By (Supply Officer)" Variant="Variant.Outlined"
                                     Required="true" Clearable="true" ResetValueOnEmptyText="true" CoerceValue="true" />
                    <MudCheckBox @bind-Value="_form.PropertyInspectorCertified"
                                 Label="Property Inspector Certification (required)" Color="Color.Primary" />
                    @if (!_form.PropertyInspectorCertified)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">Property Inspector must certify before this RRP can be saved.</MudAlert>
                    }

                    <MudDivider Class="my-2" />
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.subtitle2" Class="flex-grow-1">PPE Items to Return</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" Color="Color.Primary" OnClick="AddItem" />
                    </MudStack>

                    @for (var i = 0; i < _form.Items.Count; i++)
                    {
                        var idx = i;
                        var li = _form.Items[idx];
                        <MudPaper Outlined="true" Class="pa-2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Item @(idx + 1)</MudText>
                                <MudSpacer />
                                <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small" Color="Color.Error"
                                               OnClick="@(() => RemoveItem(idx))" />
                            </MudStack>
                            <MudStack Spacing="1">
                                <MudAutocomplete T="PPEItemSummaryDto"
                                                 Value="li.SelectedPPEItem"
                                                 ValueChanged="@(v => li.SelectedPPEItem = v)"
                                                 SearchFunc="SearchIssuedPPEItems"
                                                 ToStringFunc="@(x => x is null ? "" : $"{x.PropertyCode} – {x.Description[..Math.Min(40, x.Description.Length)]}")"
                                                 Label="PPE Item" Variant="Variant.Outlined" Dense="true"
                                                 Required="true" Clearable="true" CoerceValue="true" ResetValueOnEmptyText="true" />
                                @if (li.SelectedPPEItem is not null)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Status: @li.SelectedPPEItem.Status | ?@li.SelectedPPEItem.UnitCost.ToString("N2")
                                    </MudText>
                                }
                                <MudTextField @bind-Value="li.SourceDocumentRef" Label="Source Doc Ref (PAR/PTR No.)"
                                              Variant="Variant.Outlined" Dense="true" MaxLength="64" />
                                <MudNumericField @bind-Value="li.Quantity" Label="Qty" Variant="Variant.Outlined" Dense="true" Min="1" />
                            </MudStack>
                        </MudPaper>
                    }

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                               OnClick="CreateAsync" Disabled="_busy || !_form.PropertyInspectorCertified">
                        @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                        Create RRP
                    </MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- List Panel -->
    <MudItem xs="12" md="7">
        <MudCard Elevation="1">
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
                    <MudText Typo="Typo.h6" Class="flex-grow-1">Receipts for Returned PPE</MudText>
                    <MudTextField @bind-Value="_keyword" Label="Search" Variant="Variant.Outlined" Size="Size.Small"
                                  Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                                  DebounceInterval="350" OnDebounceIntervalElapsed="@(() => LoadAsync())" Style="max-width:220px" />
                </MudStack>

                @if (_loading)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else if (_list.Count == 0)
                {
                    <MudAlert Severity="Severity.Info">No RRP records yet.</MudAlert>
                }
                else
                {
                    <MudSimpleTable Dense="true" Hover="true" Striped="true">
                        <thead>
                            <tr><th>RRP No.</th><th>Date</th><th>Category</th><th>Items</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var s in _list)
                            {
                                var chip = s.ReturnCategory == "Serviceable" ? Color.Success : Color.Error;
                                <tr>
                                    <td><b>@s.RRPNo</b></td>
                                    <td>@s.Date.ToString("MM/dd/yyyy")</td>
                                    <td><MudChip T="string" Size="Size.Small" Color="@chip">@s.ReturnCategory</MudChip></td>
                                    <td><MudChip T="string" Size="Size.Small" Color="Color.Info">@s.ItemCount items</MudChip></td>
                                    <td><MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                                       Color="Color.Primary" OnClick="@(() => ViewAsync(s.Id))" /></td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-2">
                        <MudText Typo="Typo.caption">@_totalCount total</MudText>
                        <MudSpacer />
                        <MudPagination Count="@TotalPages" Selected="_page" ShowFirstButton="true" ShowLastButton="true"
                                       SelectedChanged="@(async p => { _page = p; await LoadAsync(); })" />
                    </MudStack>
                }
            </MudCardContent>
        </MudCard>

        @if (_detail is not null)
        {
            <MudCard Elevation="1" Class="mt-3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6">@_detail.RRPNo — @_detail.Date.ToString("MMMM dd, yyyy")</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@(_detail.ReturnCategory == "Serviceable" ? Color.Success : Color.Error)">
                                @_detail.ReturnCategory
                            </MudChip>
                            <MudSpacer />
                            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _detail = null)" />
                        </MudStack>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="1">
                        <MudItem xs="6"><MudText Typo="Typo.caption">Inspector Certified</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@(_detail.PropertyInspectorCertified ? Color.Success : Color.Error)">
                                @(_detail.PropertyInspectorCertified ? "Yes" : "No")
                            </MudChip>
                        </MudItem>
                        <MudItem xs="6"><MudText Typo="Typo.caption">Created</MudText><MudText Typo="Typo.caption">@_detail.CreatedOnUtc.ToLocalTime().ToString("MM/dd/yyyy HH:mm")</MudText></MudItem>
                    </MudGrid>
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle2" Class="mb-1">Line Items</MudText>
                    <MudSimpleTable Dense="true" Striped="true">
                        <thead>
                            <tr><th>#</th><th>Property Code</th><th>Description</th><th>Source Ref</th><th>Qty</th><th>Unit Cost</th><th>Total</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _detail.Items)
                            {
                                <tr>
                                    <td>@item.ItemNo</td>
                                    <td><b>@item.PropertyCode</b></td>
                                    <td>@item.Description</td>
                                    <td>@(item.SourceDocumentRef ?? "-")</td>
                                    <td>@item.Quantity</td>
                                    <td>?@item.UnitCost.ToString("N2")</td>
                                    <td><b>?@item.TotalCost.ToString("N2")</b></td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="6" style="text-align:right"><b>Total:</b></td>
                                <td><b>?@_detail.Items.Sum(x => x.TotalCost).ToString("N2")</b></td>
                            </tr>
                        </tfoot>
                    </MudSimpleTable>
                </MudCardContent>
            </MudCard>
        }
    </MudItem>
</MudGrid>

@code {
    private List<RRPSummaryDto> _list = [];
    private RRPDetailsDto? _detail;
    private RrpForm _form = new();
    private string? _keyword;
    private bool _loading, _busy;
    private int _page = 1, _totalCount;
    private const int PageSize = 15;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)PageSize));

    protected override async Task OnInitializedAsync()
    {
        _form.Items.Add(new LineItem());
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var r = await Client.SearchAsync(_keyword, page: _page, pageSize: PageSize);
            _list = [.. r.Items];
            _totalCount = r.TotalCount;
        }
        catch (Exception ex) { Snackbar.Add($"Load failed: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task ViewAsync(Guid id)
    {
        try { _detail = await Client.GetAsync(id); }
        catch (Exception ex) { Snackbar.Add($"Load failed: {ex.Message}", Severity.Error); }
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.RRPNo) || _form.DateNullable is null ||
            _form.ReturnedBy is null || _form.ApprovedBy is null || _form.SignedBy is null)
        {
            Snackbar.Add("RRP No., Date, Returned By, Approved By, and Signed By are required.", Severity.Warning);
            return;
        }
        if (!_form.PropertyInspectorCertified)
        {
            Snackbar.Add("Property Inspector certification is required.", Severity.Warning);
            return;
        }
        if (_form.Items.Any(i => i.SelectedPPEItem is null || i.Quantity <= 0))
        {
            Snackbar.Add("All items must have a PPE Item and Quantity.", Severity.Warning);
            return;
        }
        _busy = true;
        try
        {
            var items = _form.Items.Select(li => new CreateRRPItemRequest(
                li.SelectedPPEItem!.Id,
                string.IsNullOrWhiteSpace(li.SourceDocumentRef) ? null : li.SourceDocumentRef,
                li.Quantity)).ToList();

            var result = await Client.CreateAsync(new CreateRRPCommand(
                _form.RRPNo, DateOnly.FromDateTime(_form.DateNullable!.Value),
                _form.ReturnCategory, _form.ReturnedBy!.Id, _form.ApprovedBy!.Id, _form.SignedBy!.Id,
                _form.PropertyInspectorCertified, items));

            Snackbar.Add($"RRP {result.RRPNo} created with {result.ItemCount} item(s).", Severity.Success);
            _form = new RrpForm();
            _form.Items.Add(new LineItem());
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Create failed: {ex.Message}", Severity.Error); }
        finally { _busy = false; }
    }

    private void AddItem() => _form.Items.Add(new LineItem());
    private void RemoveItem(int idx) { if (_form.Items.Count > 1) _form.Items.RemoveAt(idx); }

    private async Task<IEnumerable<EmployeeReferenceDto>> SearchEmployees(string? value, CancellationToken ct)
    {
        var r = await LookupClient.EmployeesGetAsync(keyword: value, isActive: true, pageSize: 20, cancellationToken: ct);
        return r.Items;
    }

    private async Task<IEnumerable<PPEItemSummaryDto>> SearchIssuedPPEItems(string? value, CancellationToken ct)
    {
        var r = await PPEItemClient.SearchAsync(value, page: 1, pageSize: 20, ct: ct);
        return r.Items;
    }

    private static string FormatEmployee(EmployeeReferenceDto? e) =>
        e is null ? "" : $"{e.LastName}, {e.FirstName} ({e.EmployeeNumber})";

    private sealed class RrpForm
    {
        public string RRPNo { get; set; } = string.Empty;
        public DateTime? DateNullable { get; set; } = DateTime.Today;
        public PPEReturnCategory ReturnCategory { get; set; } = PPEReturnCategory.Serviceable;
        public EmployeeReferenceDto? ReturnedBy { get; set; }
        public EmployeeReferenceDto? ApprovedBy { get; set; }
        public EmployeeReferenceDto? SignedBy { get; set; }
        public bool PropertyInspectorCertified { get; set; }
        public List<LineItem> Items { get; set; } = [];
    }

    private sealed class LineItem
    {
        public PPEItemSummaryDto? SelectedPPEItem { get; set; }
        public string? SourceDocumentRef { get; set; }
        public int Quantity { get; set; } = 1;
    }
}

