@page "/asset-management/inventory-custodian-slips"
@using AMIS.Playground.Blazor.ApiClient
@using static AMIS.Playground.Blazor.ApiClient.AssetCategory
@inject IICSClient Client
@inject ITangibleInventoryItemClient PropertyLookupClient
@inject ILookupClient LookupClient
@inject ISnackbar Snackbar

<AMISPageHeader Title="Inventory Custodian Slips (ICS)"
               Description="Issue semi-expendable property to end-users per COA Circular 2022-004 Annex A.3. Issuing sets property status to Issued." />

<MudGrid Spacing="3">
    <!-- Create Form -->
    <MudItem xs="12" md="5">
        <MudCard Elevation="1">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-3">New ICS</MudText>
                <MudStack Spacing="2">
                    <MudTextField @bind-Value="_form.ICSNo" Label="ICS No." Variant="Variant.Outlined"
                                  Required="true" MaxLength="32" Placeholder="e.g. ICS-2026-00001" />
                    <MudDatePicker @bind-Date="_form.DateNullable" Label="Date" Variant="Variant.Outlined"
                                   DateFormat="MM/dd/yyyy" Required="true" />
                    <MudSelect @bind-Value="_form.Category" Label="Category" Variant="Variant.Outlined" T="AssetCategory" Required="true">
                        <MudSelectItem Value="AssetCategory.LowValuedSemi">Low-Valued Semi-Expendable (= ?5,000)</MudSelectItem>
                        <MudSelectItem Value="AssetCategory.HighValuedSemi">High-Valued Semi-Expendable (&gt; ?5,000)</MudSelectItem>
                    </MudSelect>
                    <MudTextField @bind-Value="_form.FundCluster" Label="Fund Cluster" Variant="Variant.Outlined" MaxLength="50" />

                    <MudAutocomplete T="EmployeeReferenceDto"
                                     @bind-Value="_form.IssuedFrom"
                                     SearchFunc="SearchEmployees"
                                     ToStringFunc="FormatEmployee"
                                     Label="Issued From (Supply Officer)" Variant="Variant.Outlined"
                                     Clearable="true" ResetValueOnEmptyText="true" CoerceValue="true" />

                    <MudAutocomplete T="EmployeeReferenceDto"
                                     @bind-Value="_form.ReceivedBy"
                                     SearchFunc="SearchEmployees"
                                     ToStringFunc="FormatEmployee"
                                     Label="Received By (End-User)" Variant="Variant.Outlined"
                                     Required="true" Clearable="true" ResetValueOnEmptyText="true" CoerceValue="true" />

                    <MudDivider Class="my-2" />
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.subtitle2" Class="flex-grow-1">Property Items to Issue</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" Color="Color.Primary"
                                       OnClick="AddItem" />
                    </MudStack>

                    @for (var i = 0; i < _form.Items.Count; i++)
                    {
                        var idx = i;
                        var li = _form.Items[idx];
                        <MudPaper Outlined="true" Class="pa-2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Item @(idx + 1)</MudText>
                                <MudSpacer />
                                <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small" Color="Color.Error"
                                               OnClick="@(() => RemoveItem(idx))" />
                            </MudStack>
                            <MudStack Spacing="1">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudTextField @bind-Value="li.PropertyNo" Label="Property No." Variant="Variant.Outlined"
                                                  Dense="true" MaxLength="50" Placeholder="e.g. SPLV-2026-01-0001"
                                                  Class="flex-grow-1" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Search" Size="Size.Small" Color="Color.Primary"
                                                   OnClick="@(() => LookupPropertyAsync(li))" />
                                </MudStack>
                                @if (li.LookedUpItem is not null)
                                {
                                    <MudText Typo="Typo.caption" Color="@(li.LookedUpItem.IsIssued ? Color.Error : Color.Success)">
                                        @li.LookedUpItem.ItemName | ?@li.LookedUpItem.UnitCost.ToString("N2")
                                        @(li.LookedUpItem.IsIssued ? " Ś Already Issued" : " Ś Available")
                                    </MudText>
                                }
                                else if (li.LookupFailed)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Error">Property number not found.</MudText>
                                }
                                <MudTextField @bind-Value="li.Description" Label="Description (override)" Variant="Variant.Outlined"
                                              Dense="true" MaxLength="500" />
                            </MudStack>
                        </MudPaper>
                    }

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                               OnClick="CreateAsync" Disabled="_busy">
                        @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                        Create ICS
                    </MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- List Panel -->
    <MudItem xs="12" md="7">
        <MudCard Elevation="1">
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
                    <MudText Typo="Typo.h6" Class="flex-grow-1">Custodian Slips</MudText>
                    <MudTextField @bind-Value="_keyword" Label="Search" Variant="Variant.Outlined" Size="Size.Small"
                                  Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                                  DebounceInterval="350" OnDebounceIntervalElapsed="@(() => LoadAsync())" Style="max-width:220px" />
                </MudStack>

                @if (_loading)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else if (_slips.Count == 0)
                {
                    <MudAlert Severity="Severity.Info">No ICS records yet.</MudAlert>
                }
                else
                {
                    <MudSimpleTable Dense="true" Hover="true" Striped="true">
                        <thead>
                            <tr>
                                <th>ICS No.</th>
                                <th>Date</th>
                                <th>Fund Cluster</th>
                                <th>Items</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in _slips)
                            {
                                <tr>
                                    <td><MudText Typo="Typo.body2"><b>@s.ICSNo</b></MudText></td>
                                    <td>@s.Date.ToString("MM/dd/yyyy")</td>
                                    <td><MudText Typo="Typo.caption" Color="Color.Secondary">@(s.FundCluster ?? "Ś")</MudText></td>
                                    <td><MudChip T="string" Size="Size.Small" Color="Color.Info">@s.ItemCount items</MudChip></td>
                                    <td>
                                        <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                                       Color="Color.Primary" OnClick="@(() => ViewAsync(s.Id))" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>

                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-2">
                        <MudText Typo="Typo.caption">@_totalCount total</MudText>
                        <MudSpacer />
                        <MudPagination Count="@TotalPages" Selected="_page" ShowFirstButton="true" ShowLastButton="true"
                                       SelectedChanged="@(async p => { _page = p; await LoadAsync(); })" />
                    </MudStack>
                }
            </MudCardContent>
        </MudCard>

        <!-- Detail Card -->
        @if (_detail is not null)
        {
            <MudCard Elevation="1" Class="mt-3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6">@_detail.ICSNo Ś @_detail.Date.ToString("MMMM dd, yyyy")</MudText>
                            <MudSpacer />
                            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _detail = null)" />
                        </MudStack>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="1" Class="mb-2">
                        <MudItem xs="6" sm="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Category</MudText>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(_detail.Category == "LowValuedSemi" ? Color.Info : Color.Warning)">
                                @(_detail.Category == "LowValuedSemi" ? "Low-Valued Semi" : "High-Valued Semi")
                            </MudChip>
                        </MudItem>
                        @if (_detail.FundCluster is not null)
                        {
                            <MudItem xs="6" sm="3"><MudText Typo="Typo.caption" Color="Color.Secondary">Fund Cluster</MudText><MudText Typo="Typo.body2">@_detail.FundCluster</MudText></MudItem>
                        }
                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Created By</MudText>
                            <MudText Typo="Typo.body2">@(_detail.CreatedBy ?? "Ś")</MudText>
                        </MudItem>
                        @if (_detailIssuedFrom is not null)
                        {
                            <MudItem xs="12" sm="6">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Issued From (Supply Officer)</MudText>
                                <MudText Typo="Typo.body2">@FormatEmployee(_detailIssuedFrom)</MudText>
                            </MudItem>
                        }
                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Received By (End-User)</MudText>
                            <MudText Typo="Typo.body2">@(_detailReceivedBy is not null ? FormatEmployee(_detailReceivedBy) : _detail.ReceivedByEmployeeId.ToString())</MudText>
                        </MudItem>
                    </MudGrid>
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle2" Class="mb-1">Issued Items</MudText>
                    <MudSimpleTable Dense="true" Striped="true">
                        <thead>
                            <tr><th>#</th><th>Property No.</th><th>Item</th><th>Description</th><th>Unit Cost</th><th>Useful Life</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _detail.Items.OrderBy(x => x.ItemNo))
                            {
                                <tr>
                                    <td>@item.ItemNo</td>
                                    <td><b>@item.PropertyNo</b></td>
                                    <td>
                                        <MudText Typo="Typo.body2">@item.ItemName</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@item.ItemCode</MudText>
                                    </td>
                                    <td>@(item.Description ?? "-")</td>
                                    <td>?@item.UnitCost.ToString("N2")</td>
                                    <td>@(item.EstimatedUsefulLifeYears.HasValue ? $"{item.EstimatedUsefulLifeYears} yr(s)" : "-")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="4" style="text-align:right"><b>Total Cost:</b></td>
                                <td colspan="2"><b>?@_detail.Items.Sum(x => x.UnitCost).ToString("N2")</b></td>
                            </tr>
                        </tfoot>
                    </MudSimpleTable>
                </MudCardContent>
            </MudCard>
        }
    </MudItem>
</MudGrid>

@code {
    private List<ICSSummaryDto> _slips = [];
    private ICSDetailsDto? _detail;
    private EmployeeReferenceDto? _detailReceivedBy;
    private EmployeeReferenceDto? _detailIssuedFrom;
    private IcsForm _form = new();
    private string? _keyword;
    private bool _loading;
    private bool _busy;
    private int _page = 1;
    private int _totalCount;
    private const int PageSize = 15;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)PageSize));

    protected override async Task OnInitializedAsync()
    {
        _form.Items.Add(new IcsItemRow());
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var response = await Client.SearchAsync(_keyword, page: _page, pageSize: PageSize);
            _slips = [.. response.Items];
            _totalCount = response.TotalCount;
        }
        catch (Exception ex) { Snackbar.Add($"Load failed: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task ViewAsync(Guid id)
    {
        _detailReceivedBy = null;
        _detailIssuedFrom = null;
        try
        {
            _detail = await Client.GetAsync(id);
            if (_detail is not null)
            {
                _detailReceivedBy = await LookupClient.EmployeesGetAsync(_detail.ReceivedByEmployeeId);
                if (_detail.IssuedFromEmployeeId.HasValue)
                    _detailIssuedFrom = await LookupClient.EmployeesGetAsync(_detail.IssuedFromEmployeeId.Value);
            }
        }
        catch (Exception ex) { Snackbar.Add($"Load failed: {ex.Message}", Severity.Error); }
    }

    private async Task<IEnumerable<EmployeeReferenceDto>> SearchEmployees(string? value, CancellationToken ct)
    {
        try
        {
            var result = await LookupClient.EmployeesGetAsync(
                keyword: string.IsNullOrWhiteSpace(value) ? null : value,
                isActive: true,
                pageNumber: 1,
                pageSize: 20,
                cancellationToken: ct);
            return result?.Items ?? [];
        }
        catch { return []; }
    }

    private async Task LookupPropertyAsync(IcsItemRow item)
    {
        var pno = item.PropertyNo?.Trim().ToUpperInvariant();
        if (string.IsNullOrWhiteSpace(pno)) return;
        try
        {
            item.LookedUpItem = await PropertyLookupClient.GetByPropertyNoAsync(pno);
            item.LookupFailed = item.LookedUpItem is null;
        }
        catch
        {
            item.LookedUpItem = null;
            item.LookupFailed = true;
        }
    }

    private static string FormatEmployee(EmployeeReferenceDto? e) =>
        e is null ? "" : $"{e.FirstName} {e.LastName} ({e.EmployeeNumber})";

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.ICSNo) || _form.DateNullable is null || _form.ReceivedBy is null)
        {
            Snackbar.Add("ICS No., Date, and Received By are required.", Severity.Warning);
            return;
        }
        if (_form.Items.Any(i => i.LookedUpItem is null || i.LookedUpItem.IsIssued))
        {
            Snackbar.Add("All items must be looked up and available (not already issued).", Severity.Warning);
            return;
        }
        _busy = true;
        try
        {
            var items = _form.Items.Select(i => new CreateICSItemRequest(
                i.LookedUpItem!.Id, i.Description)).ToList();

            var result = await Client.CreateAsync(new CreateICSCommand(
                _form.ICSNo,
                DateOnly.FromDateTime(_form.DateNullable!.Value),
                _form.Category,
                _form.FundCluster,
                _form.IssuedFrom?.Id,
                _form.ReceivedBy.Id,
                items));

            Snackbar.Add($"ICS created. {result.ItemCount} property unit(s) issued.", Severity.Success);
            _form = new IcsForm();
            _form.Items.Add(new IcsItemRow());
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Create failed: {ex.Message}", Severity.Error); }
        finally { _busy = false; }
    }

    private void AddItem() => _form.Items.Add(new IcsItemRow());
    private void RemoveItem(int idx) { if (_form.Items.Count > 1) _form.Items.RemoveAt(idx); }

    private sealed class IcsForm
    {
        public string ICSNo { get; set; } = string.Empty;
        public DateTime? DateNullable { get; set; } = DateTime.Today;
        public AssetCategory Category { get; set; } = AssetCategory.LowValuedSemi;
        public string? FundCluster { get; set; }
        public EmployeeReferenceDto? IssuedFrom { get; set; }
        public EmployeeReferenceDto? ReceivedBy { get; set; }
        public List<IcsItemRow> Items { get; set; } = [];
    }

    private sealed class IcsItemRow
    {
        public string? PropertyNo { get; set; }
        public TangibleInventoryItemDetailDto? LookedUpItem { get; set; }
        public bool LookupFailed { get; set; }
        public string? Description { get; set; }
    }
}

