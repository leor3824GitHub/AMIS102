@page "/asset-management/receiving-reports"
@using AMIS.Playground.Blazor.ApiClient
@inject ISMRRClient Client
@inject ITangibleItemClient TangibleClient
@inject ICapitalizationThresholdClient ThresholdClient
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<AMISPageHeader Title="Supplies and Materials Receiving Reports (SMRR)"
               Description="Link pre-registered tangible items to a receiving report. Register assets first in Tangible Items before creating an SMRR." />

<MudTabs @bind-ActivePanelIndex="_activeTab" Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">

    <!-- Tab 1: Reports List -->
    <MudTabPanel Text="List" Icon="@Icons.Material.Filled.ListAlt">

        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
            <MudText Typo="Typo.h6" Class="flex-grow-1">Receiving Reports</MudText>
            <MudTextField @bind-Value="_keyword" Label="Search" Variant="Variant.Outlined" Size="Size.Small"
                          Dense="true" Margin="Margin.Dense"
                          Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                          DebounceInterval="350" OnDebounceIntervalElapsed="@(() => LoadAsync())"
                          Style="max-width:260px" />
        </MudStack>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
        }
        else if (_smrrs.Count == 0)
        {
            <MudAlert Severity="Severity.Info">No receiving reports yet.</MudAlert>
        }
        else
        {
            <MudSimpleTable Dense="true" Hover="true" Striped="true">
                <thead>
                    <tr>
                        <th>SMRR No.</th>
                        <th>Date</th>
                        <th>Received From</th>
                        <th>Type</th>
                        <th>Items</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in _smrrs)
                    {
                        <tr>
                            <td><MudText Typo="Typo.body2"><b>@s.ReportNo</b></MudText></td>
                            <td>@s.Date.ToString("MM/dd/yyyy")</td>
                            <td>@s.ReceivedFrom</td>
                            <td>@s.ReceiptType</td>
                            <td><MudChip T="string" Size="Size.Small" Color="Color.Info">@(s.SEItemCount + s.PPEItemCount) lines</MudChip></td>
                            <td>
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                               Color="Color.Primary" OnClick="@(() => ViewAsync(s.Id))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                               Color="Color.Warning" OnClick="@(() => OpenEditAsync(s))"
                                               Title="Edit" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error" OnClick="@(() => DeleteAsync(s.Id, s.ReportNo))"
                                               Title="Delete" />
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>

            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-2">
                <MudText Typo="Typo.caption">@_totalCount total</MudText>
                <MudSpacer />
                <MudPagination Count="@TotalPages" Selected="_page" ShowFirstButton="true" ShowLastButton="true"
                               SelectedChanged="@(async p => { _page = p; await LoadAsync(); })" />
            </MudStack>
        }

        <!-- Edit Panel -->
        @if (_editId is not null)
        {
            <MudCard Elevation="0" Outlined="true" Class="mt-4" Style="border-color: var(--mud-palette-warning);">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6">Edit SMRR � @_editForm.ReportNo</MudText>
                            <MudSpacer />
                            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _editId = null)" />
                        </MudStack>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="_editForm.ReportNo" Label="SMRR No." Variant="Variant.Outlined"
                                          Dense="true" Margin="Margin.Dense" Size="Size.Small" Required="true" MaxLength="32" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudDatePicker @bind-Date="_editForm.DateNullable" Label="Date" Variant="Variant.Outlined"
                                           Dense="true" Margin="Margin.Dense" Size="Size.Small" DateFormat="MM/dd/yyyy" Required="true" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="_editForm.ReceivedFrom" Label="Received From" Variant="Variant.Outlined"
                                          Dense="true" Margin="Margin.Dense" Size="Size.Small" Required="true" MaxLength="200" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudSelect @bind-Value="_editForm.ReceiptType" Label="Receipt Type" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense" Size="Size.Small" T="ReceiptType">
                                <MudSelectItem Value="ReceiptType.Purchase">Purchase</MudSelectItem>
                                <MudSelectItem Value="ReceiptType.Transfer">Transfer</MudSelectItem>
                                <MudSelectItem Value="ReceiptType.Donation">Donation</MudSelectItem>
                                <MudSelectItem Value="ReceiptType.Others">Others</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        @if (_editForm.ReceiptType == ReceiptType.Others)
                        {
                            <MudItem xs="12" sm="4">
                                <MudTextField @bind-Value="_editForm.OtherReceiptType" Label="Specify Receipt Type"
                                              Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense" Size="Size.Small" Required="true" MaxLength="100" />
                            </MudItem>
                        }
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="_editForm.Address" Label="Address" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense" Size="Size.Small" MaxLength="500" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="_editForm.FundCluster" Label="Fund Cluster" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense" Size="Size.Small" MaxLength="50" />
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" OnClick="SaveEditAsync" Disabled="_busy"
                               StartIcon="@Icons.Material.Filled.Save">
                        @if (_busy) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                        Save Changes
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" OnClick="@(() => _editId = null)" Class="ml-2">Cancel</MudButton>
                </MudCardActions>
            </MudCard>
        }

        <!-- Detail Panel -->
        @if (_detail is not null)
        {
            <MudCard Elevation="0" Outlined="true" Class="mt-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6">@_detail.ReportNo � @_detail.Date.ToString("MMMM dd, yyyy")</MudText>
                            <MudSpacer />
                            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _detail = null)" />
                        </MudStack>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="2" Class="mb-2">
                        <MudItem xs="12" sm="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Received From</MudText>
                            <MudText Typo="Typo.body2">@_detail.ReceivedFrom</MudText>
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Receipt Type</MudText>
                            <MudText Typo="Typo.body2">@_detail.ReceiptType</MudText>
                        </MudItem>
                        @if (!string.IsNullOrWhiteSpace(_detail.FundCluster))
                        {
                            <MudItem xs="12" sm="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Fund Cluster</MudText>
                                <MudText Typo="Typo.body2">@_detail.FundCluster</MudText>
                            </MudItem>
                        }
                        @if (_detail.ReceivedByEmployeeId.HasValue)
                        {
                            <MudItem xs="12" sm="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Received By (ID)</MudText>
                                <MudText Typo="Typo.body2">@_detail.ReceivedByEmployeeId</MudText>
                            </MudItem>
                        }
                    </MudGrid>
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Property Units</MudText>
                    <MudSimpleTable Dense="true" Striped="true">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Property No.</th>
                                <th>Item</th>
                                <th>Description</th>
                                <th>Ref.</th>
                                <th>Acq. Date</th>
                                <th>Qty</th>
                                <th>Unit Cost</th>
                                <th>Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var (item, i) in _detail.Items.Select((x, i) => (x, i + 1)))
                            {
                                <tr>
                                    <td>@i</td>
                                    <td><b>@item.PropertyNo</b></td>
                                    <td>
                                        <MudText Typo="Typo.body2">@item.Description</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@item.AssetType</MudText>
                                    </td>
                                    <td>@(item.Description ?? "�")</td>
                                    <td>@(item.Reference ?? "�")</td>
                                    <td>@item.AcquisitionDate.ToString("MM/dd/yyyy")</td>
                                    <td>@item.Quantity</td>
                                    <td>?@item.UnitCost.ToString("N2")</td>
                                    <td><b>?@item.Amount.ToString("N2")</b></td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="8" style="text-align:right"><b>Total:</b></td>
                                <td><b>?@_detail.Items.Sum(x => x.Amount).ToString("N2")</b></td>
                            </tr>
                        </tfoot>
                    </MudSimpleTable>
                </MudCardContent>
            </MudCard>
        }

    </MudTabPanel>

    <!-- Tab 2: New SMRR Form -->
    <MudTabPanel Text="New SMRR" Icon="@Icons.Material.Filled.Add">

        <MudGrid Spacing="3">

            <!-- Left column: header fields -->
            <MudItem xs="12" md="4">
                <MudCard Elevation="0" Outlined="true" Style="height:100%">
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle1" Class="mb-3">Details</MudText>
                        <MudStack Spacing="2">
                            <MudTextField @bind-Value="_form.ReportNo" Label="SMRR No." Variant="Variant.Outlined"
                                          Dense="true" Margin="Margin.Dense" Size="Size.Small" Required="true" MaxLength="32" Placeholder="e.g. SMRR-2026-00001" />
                            <MudDatePicker @bind-Date="_form.DateNullable" Label="Date" Variant="Variant.Outlined"
                                           Dense="true" Margin="Margin.Dense" Size="Size.Small" DateFormat="MM/dd/yyyy" Required="true" />
                            <MudSelect @bind-Value="_form.ReceiptType" Label="Receipt Type" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense" Size="Size.Small" T="ReceiptType">
                                <MudSelectItem Value="ReceiptType.Purchase">Purchase</MudSelectItem>
                                <MudSelectItem Value="ReceiptType.Transfer">Transfer</MudSelectItem>
                                <MudSelectItem Value="ReceiptType.Donation">Donation</MudSelectItem>
                                <MudSelectItem Value="ReceiptType.Others">Others</MudSelectItem>
                            </MudSelect>
                            @if (_form.ReceiptType == ReceiptType.Others)
                            {
                                <MudTextField @bind-Value="_form.OtherReceiptType" Label="Specify Receipt Type"
                                              Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense" Size="Size.Small" Required="true" MaxLength="100" />
                            }
                            <MudTextField @bind-Value="_form.ReceivedFrom" Label="Received From" Variant="Variant.Outlined"
                                          Dense="true" Margin="Margin.Dense" Size="Size.Small" Required="true" MaxLength="200" />
                            <MudTextField @bind-Value="_form.Address" Label="Address" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense" Size="Size.Small" MaxLength="500" />


                            <MudStack Row="true" Spacing="1" Class="mt-2">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" FullWidth="true"
                                           OnClick="CreateAsync" Disabled="_busy">
                                    @if (_busy)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    }
                                    Create SMRR
                                </MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" OnClick="ClearForm">
                                    Clear
                                </MudButton>
                            </MudStack>
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Right column: tangible items -->
            <MudItem xs="12" md="8">
                <MudCard Elevation="0" Outlined="true" Style="height:100%">
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle1" Class="mb-3">Tangible Items</MudText>

                        <!-- Add item input -->
                        <MudGrid Spacing="2" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudItem xs="12" sm="10">
                                <MudAutocomplete T="TangibleItemSummaryDto"
                                                 @bind-Value="_draft.SelectedItem"
                                                 SearchFunc="SearchTangibleItems"
                                                 ToStringFunc="@(x => x is null ? "" : $"{x.PropertyNo} � {x.ItemName}")"
                                                 Label="Tangible Item" Variant="Variant.Outlined"
                                                 Dense="true" Margin="Margin.Dense" Size="Size.Small"
                                                 Clearable="true" CoerceValue="true"
                                                 ResetValueOnEmptyText="true" MinCharacters="0" />
                            </MudItem>
                            <MudItem xs="12" sm="2">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" FullWidth="true"
                                           StartIcon="@Icons.Material.Filled.Add" OnClick="AddLineItem">Add</MudButton>
                            </MudItem>
                        </MudGrid>

                        <!-- Items list -->
                        @if (_form.Items.Count > 0)
                        {
                            <MudSimpleTable Dense="true" Hover="true" Striped="true">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Property No.</th>
                                        <th>Item Name</th>
                                        <th>Qty</th>
                                        <th>Unit Cost</th>
                                        <th>Amount</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var (li, i) in _form.Items.Select((x, i) => (x, i + 1)))
                                    {
                                        <tr>
                                            <td>@i</td>
                                            <td><b>@li.SelectedItem!.PropertyNo</b></td>
                                            <td>
                                                <MudText Typo="Typo.body2">@li.SelectedItem.ItemName</MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@li.SelectedItem.ItemCode</MudText>
                                            </td>
                                            <td>@li.SelectedItem.Quantity</td>
                                            <td>?@li.SelectedItem.UnitCost.ToString("N2")</td>
                                            <td><b>?@((li.SelectedItem.Quantity * li.SelectedItem.UnitCost).ToString("N2"))</b></td>
                                            <td>
                                                <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small"
                                                               Color="Color.Error" OnClick="@(() => RemoveLineItem(i - 1))" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="5" style="text-align:right"><b>Total:</b></td>
                                        <td><b>?@(_form.Items.Sum(x => x.SelectedItem!.Quantity * x.SelectedItem.UnitCost).ToString("N2"))</b></td>
                                        <td></td>
                                    </tr>
                                </tfoot>
                            </MudSimpleTable>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">
                                Select a tangible item above and click Add.
                            </MudAlert>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>

        </MudGrid>

    </MudTabPanel>

</MudTabs>

@code {
    private List<SMRRSummaryDto> _smrrs = [];
    private SMRRDetailsDto? _detail;
    private SmrrForm _form = new();
    private SmrrForm _editForm = new();
    private Guid? _editId;
    private LineItemRow _draft = new();
    private string? _keyword;
    private bool _loading;
    private bool _busy;
    private int _page = 1;
    private int _totalCount;
    private int _activeTab;
    private const int PageSize = 15;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)PageSize));
    private decimal _capitalizationAmount = 50_000m;

    protected override async Task OnInitializedAsync()
    {
        var threshold = await ThresholdClient.GetActiveAsync();
        if (threshold is not null)
            _capitalizationAmount = threshold.CapitalizationAmount;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var response = await Client.SearchAsync(_keyword, page: _page, pageSize: PageSize);
            _smrrs = [.. response.Items];
            _totalCount = response.TotalCount;
        }
        catch (Exception ex) { Snackbar.Add($"Load failed: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task ViewAsync(Guid id)
    {
        _editId = null;
        try { _detail = await Client.GetAsync(id); }
        catch (Exception ex) { Snackbar.Add($"Load failed: {ex.Message}", Severity.Error); }
    }

    private void OpenEditAsync(SMRRSummaryDto s)
    {
        _detail = null;
        _editId = s.Id;
        Enum.TryParse<ReceiptType>(s.ReceiptType, out var receiptType);
        _editForm = new SmrrForm
        {
            ReportNo = s.ReportNo,
            DateNullable = s.Date.ToDateTime(TimeOnly.MinValue),
            ReceivedFrom = s.ReceivedFrom,
            ReceiptType = receiptType,
        };
    }

    private async Task SaveEditAsync()
    {
        if (string.IsNullOrWhiteSpace(_editForm.ReportNo) || _editForm.DateNullable is null ||
            string.IsNullOrWhiteSpace(_editForm.ReceivedFrom))
        {
            Snackbar.Add("SMRR No., Date, and Received From are required.", Severity.Warning);
            return;
        }
        _busy = true;
        try
        {
            var cmd = new UpdateSMRRCommand(
                _editId!.Value,
                _editForm.ReportNo,
                DateOnly.FromDateTime(_editForm.DateNullable!.Value),
                _editForm.ReceivedFrom,
                _editForm.Address,
                _editForm.ReceiptType,
                _editForm.OtherReceiptType,
                _editForm.FundCluster,
                null, null);
            await Client.UpdateAsync(_editId!.Value, cmd);
            Snackbar.Add("SMRR updated.", Severity.Success);
            _editId = null;
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Update failed: {ex.Message}", Severity.Error); }
        finally { _busy = false; }
    }

    private async Task DeleteAsync(Guid id, string reportNo)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Delete SMRR",
            $"Delete '{reportNo}'? This cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true) return;
        try
        {
            await Client.DeleteAsync(id);
            Snackbar.Add($"SMRR {reportNo} deleted.", Severity.Success);
            if (_detail?.Id == id) _detail = null;
            if (_editId == id) _editId = null;
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error); }
    }

    private async Task<IEnumerable<TangibleItemSummaryDto>> SearchTangibleItems(string? value, CancellationToken ct)
    {
        var response = await TangibleClient.SearchAsync(keyword: value, excludeLinked: true, page: 1, pageSize: 50, ct: ct);
        var alreadySelected = _form.Items
            .Where(x => x.SelectedItem is not null)
            .Select(x => x.SelectedItem!.Id)
            .ToHashSet();
        // Show only semi-expendable items (unit cost below the capitalization threshold)
        return response.Items
            .Where(x => !alreadySelected.Contains(x.Id) && x.UnitCost < _capitalizationAmount);
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.ReportNo) || _form.DateNullable is null ||
            string.IsNullOrWhiteSpace(_form.ReceivedFrom))
        {
            Snackbar.Add("SMRR No., Date, and Received From are required.", Severity.Warning);
            return;
        }
        if (_form.Items.Count == 0)
        {
            Snackbar.Add("Add at least one tangible item.", Severity.Warning);
            return;
        }
        _busy = true;
        try
        {
            var items = _form.Items
                .Select(li => new CreateSMRRItemRequest(li.SelectedItem!.Id, li.Reference))
                .ToList();

            var result = await Client.CreateAsync(new CreateSMRRCommand(
                _form.ReportNo,
                DateOnly.FromDateTime(_form.DateNullable!.Value),
                _form.ReceivedFrom,
                _form.Address,
                _form.ReceiptType,
                _form.OtherReceiptType,
                _form.FundCluster,
                null,
                null,
                items));

            Snackbar.Add($"SMRR {result.ReportNo} created with {result.SEItemCount + result.PPEItemCount} item(s).", Severity.Success);
            ClearForm();
            _activeTab = 0;
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Create failed: {ex.Message}", Severity.Error); }
        finally { _busy = false; }
    }

    private void AddLineItem()
    {
        if (_draft.SelectedItem is null)
        {
            Snackbar.Add("Select a tangible item first.", Severity.Warning);
            return;
        }
        _form.Items.Add(new LineItemRow { SelectedItem = _draft.SelectedItem, Reference = _draft.Reference });
        _draft = new LineItemRow();
    }

    private void RemoveLineItem(int idx) => _form.Items.RemoveAt(idx);

    private void ClearForm()
    {
        _form = new SmrrForm();
        _draft = new LineItemRow();
    }

    private sealed class SmrrForm
    {
        public string ReportNo { get; set; } = string.Empty;
        public DateTime? DateNullable { get; set; } = DateTime.Today;
        public string ReceivedFrom { get; set; } = string.Empty;
        public string? Address { get; set; }
        public ReceiptType ReceiptType { get; set; } = ReceiptType.Purchase;
        public string? OtherReceiptType { get; set; }
        public string? FundCluster { get; set; }
        public List<LineItemRow> Items { get; set; } = [];
    }

    private sealed class LineItemRow
    {
        public TangibleItemSummaryDto? SelectedItem { get; set; }
        public string? Reference { get; set; }
    }
}

