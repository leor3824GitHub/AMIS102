@page "/asset-management/receiving-reports"
@using FSH.Playground.Blazor.ApiClient
@inject ISMRRClient Client
@inject ISemiExpendableItemClient ItemClient
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<FshPageHeader Title="Supplies and Materials Receiving Reports (SMRR)"
               Description="Record inbound receipt of semi-expendable property. Creating an SMRR automatically registers individual property units." />

<MudGrid Spacing="3">
    <!-- Create Form -->
    <MudItem xs="12" md="5">
        <MudCard Elevation="1">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-3">New SMRR</MudText>
                <MudStack Spacing="2">
                    <MudTextField @bind-Value="_form.SMRRNo" Label="SMRR No." Variant="Variant.Outlined"
                                  Required="true" MaxLength="32" Placeholder="e.g. SMRR-2026-00001" />
                    <MudDatePicker @bind-Date="_form.DateNullable" Label="Date" Variant="Variant.Outlined"
                                   DateFormat="MM/dd/yyyy" Required="true" />
                    <MudTextField @bind-Value="_form.ReceivedFrom" Label="Received From" Variant="Variant.Outlined"
                                  Required="true" MaxLength="200" />
                    <MudTextField @bind-Value="_form.Address" Label="Address" Variant="Variant.Outlined" MaxLength="500" />
                    <MudSelect @bind-Value="_form.ReceiptType" Label="Receipt Type" Variant="Variant.Outlined" T="ReceiptType">
                        <MudSelectItem Value="ReceiptType.Purchase">Purchase</MudSelectItem>
                        <MudSelectItem Value="ReceiptType.Transfer">Transfer</MudSelectItem>
                        <MudSelectItem Value="ReceiptType.Donation">Donation</MudSelectItem>
                        <MudSelectItem Value="ReceiptType.Others">Others</MudSelectItem>
                    </MudSelect>
                    @if (_form.ReceiptType == ReceiptType.Others)
                    {
                        <MudTextField @bind-Value="_form.OtherReceiptType" Label="Specify Type" Variant="Variant.Outlined"
                                      Required="true" MaxLength="100" />
                    }
                    <MudTextField @bind-Value="_form.FundCluster" Label="Fund Cluster" Variant="Variant.Outlined" MaxLength="50" />
                    <MudTextField @bind-Value="_form.ReceivedBy" Label="Received By" Variant="Variant.Outlined" MaxLength="200" />
                    <MudTextField @bind-Value="_form.NotedBy" Label="Noted By" Variant="Variant.Outlined" MaxLength="200" />

                    <MudDivider Class="my-2" />
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.subtitle2" Class="flex-grow-1">Line Items</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" Color="Color.Primary"
                                       OnClick="AddLineItem" />
                    </MudStack>

                    @for (var i = 0; i < _form.Items.Count; i++)
                    {
                        var idx = i;
                        var li = _form.Items[idx];
                        <MudPaper Outlined="true" Class="pa-2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Item @(idx + 1)</MudText>
                                <MudSpacer />
                                <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small" Color="Color.Error"
                                               OnClick="@(() => RemoveLineItem(idx))" />
                            </MudStack>
                            <MudStack Spacing="1">
                                <MudAutocomplete T="SemiExpendableItemSummaryDto"
                                                 Value="li.SelectedItem"
                                                 ValueChanged="@(v => li.SelectedItem = v)"
                                                 SearchFunc="SearchItems"
                                                 ToStringFunc="@(x => x is null ? "" : $"{x.Code} – {x.Name}")"
                                                 Label="Item" Variant="Variant.Outlined" Dense="true"
                                                 Required="true" Clearable="true" CoerceValue="true" ResetValueOnEmptyText="true" />
                                <MudTextField @bind-Value="li.Reference" Label="Reference (PO/DR #)" Variant="Variant.Outlined"
                                              Dense="true" MaxLength="100" />
                                <MudTextField @bind-Value="li.Description" Label="Description / Specs" Variant="Variant.Outlined"
                                              Dense="true" MaxLength="500" />
                                <MudDatePicker @bind-Date="li.AcquisitionDateNullable" Label="Acquisition Date"
                                               Variant="Variant.Outlined" DateFormat="MM/dd/yyyy" Dense="true" />
                                <MudGrid Spacing="1">
                                    <MudItem xs="6">
                                        <MudNumericField @bind-Value="li.Quantity" Label="Qty" Variant="Variant.Outlined"
                                                         Dense="true" Min="1" />
                                    </MudItem>
                                    <MudItem xs="6">
                                        <MudNumericField @bind-Value="li.UnitCost" Label="Unit Cost (₱)"
                                                         Variant="Variant.Outlined" Dense="true" Min="0.01m" Max="49999.99m" Format="N2" />
                                    </MudItem>
                                </MudGrid>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Amount: ₱@((li.Quantity * li.UnitCost).ToString("N2"))
                                </MudText>
                            </MudStack>
                        </MudPaper>
                    }

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                               OnClick="CreateAsync" Disabled="_busy">Create SMRR</MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- List Panel -->
    <MudItem xs="12" md="7">
        <MudCard Elevation="1">
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
                    <MudText Typo="Typo.h6" Class="flex-grow-1">Receiving Reports</MudText>
                    <MudTextField @bind-Value="_keyword" Label="Search" Variant="Variant.Outlined" Size="Size.Small"
                                  Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                                  DebounceInterval="350" OnDebounceIntervalElapsed="@(() => LoadAsync())" Style="max-width:220px" />
                </MudStack>

                @if (_loading)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else if (_smrrs.Count == 0)
                {
                    <MudAlert Severity="Severity.Info">No receiving reports yet.</MudAlert>
                }
                else
                {
                    <MudSimpleTable Dense="true" Hover="true" Striped="true">
                        <thead>
                            <tr>
                                <th>SMRR No.</th>
                                <th>Date</th>
                                <th>Received From</th>
                                <th>Type</th>
                                <th>Items</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in _smrrs)
                            {
                                <tr>
                                    <td><MudText Typo="Typo.body2"><b>@s.SMRRNo</b></MudText></td>
                                    <td>@s.Date.ToString("MM/dd/yyyy")</td>
                                    <td>@s.ReceivedFrom</td>
                                    <td>@s.ReceiptType</td>
                                    <td><MudChip T="string" Size="Size.Small" Color="Color.Info">@s.ItemCount lines</MudChip></td>
                                    <td>
                                        <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                                       Color="Color.Primary" OnClick="@(() => ViewAsync(s.Id))" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>

                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-2">
                        <MudText Typo="Typo.caption">@_totalCount total</MudText>
                        <MudSpacer />
                        <MudPagination Count="@TotalPages" Selected="_page" ShowFirstButton="true" ShowLastButton="true"
                                       SelectedChanged="@(async p => { _page = p; await LoadAsync(); })" />
                    </MudStack>
                }
            </MudCardContent>
        </MudCard>

        <!-- Detail Drawer -->
        @if (_detail is not null)
        {
            <MudCard Elevation="1" Class="mt-3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6">@_detail.SMRRNo — @_detail.Date.ToString("MMMM dd, yyyy")</MudText>
                            <MudSpacer />
                            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _detail = null)" />
                        </MudStack>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="1">
                        <MudItem xs="6"><MudText Typo="Typo.caption">Received From</MudText><MudText Typo="Typo.body2">@_detail.ReceivedFrom</MudText></MudItem>
                        <MudItem xs="6"><MudText Typo="Typo.caption">Receipt Type</MudText><MudText Typo="Typo.body2">@_detail.ReceiptType</MudText></MudItem>
                        @if (!string.IsNullOrWhiteSpace(_detail.FundCluster))
                        {
                            <MudItem xs="6"><MudText Typo="Typo.caption">Fund Cluster</MudText><MudText Typo="Typo.body2">@_detail.FundCluster</MudText></MudItem>
                        }
                        @if (!string.IsNullOrWhiteSpace(_detail.ReceivedBy))
                        {
                            <MudItem xs="6"><MudText Typo="Typo.caption">Received By</MudText><MudText Typo="Typo.body2">@_detail.ReceivedBy</MudText></MudItem>
                        }
                    </MudGrid>
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle2" Class="mb-1">Line Items</MudText>
                    <MudSimpleTable Dense="true" Striped="true">
                        <thead>
                            <tr><th>#</th><th>Item</th><th>Description</th><th>Acq. Date</th><th>Qty</th><th>Unit Cost</th><th>Amount</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var (item, i) in _detail.Items.Select((x, i) => (x, i + 1)))
                            {
                                <tr>
                                    <td>@i</td>
                                    <td>
                                        <MudText Typo="Typo.body2">@item.ItemName</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@item.ItemCode</MudText>
                                    </td>
                                    <td>@(item.Description ?? "-")</td>
                                    <td>@item.AcquisitionDate.ToString("MM/dd/yyyy")</td>
                                    <td>@item.Quantity</td>
                                    <td>@item.UnitCost.ToString("N2")</td>
                                    <td><b>@item.Amount.ToString("N2")</b></td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="6" style="text-align:right"><b>Total:</b></td>
                                <td><b>@_detail.Items.Sum(x => x.Amount).ToString("N2")</b></td>
                            </tr>
                        </tfoot>
                    </MudSimpleTable>
                </MudCardContent>
            </MudCard>
        }
    </MudItem>
</MudGrid>

@code {
    private List<SMRRSummaryDto> _smrrs = [];
    private SMRRDetailsDto? _detail;
    private SmrrForm _form = new();
    private string? _keyword;
    private bool _loading;
    private bool _busy;
    private int _page = 1;
    private int _totalCount;
    private const int PageSize = 15;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)PageSize));

    protected override async Task OnInitializedAsync()
    {
        _form.Items.Add(new LineItemRow());
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var response = await Client.SearchAsync(_keyword, page: _page, pageSize: PageSize);
            _smrrs = [.. response.Items];
            _totalCount = response.TotalCount;
        }
        catch (Exception ex) { Snackbar.Add($"Load failed: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task ViewAsync(Guid id)
    {
        try { _detail = await Client.GetAsync(id); }
        catch (Exception ex) { Snackbar.Add($"Load failed: {ex.Message}", Severity.Error); }
    }

    private async Task<IEnumerable<SemiExpendableItemSummaryDto>> SearchItems(string? value, CancellationToken ct)
    {
        var response = await ItemClient.SearchAsync(value, isActive: true, page: 1, pageSize: 20, ct: ct);
        return response.Items;
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.SMRRNo) || _form.DateNullable is null ||
            string.IsNullOrWhiteSpace(_form.ReceivedFrom))
        {
            Snackbar.Add("SMRR No., Date, and Received From are required.", Severity.Warning);
            return;
        }
        if (_form.Items.Any(i => i.SelectedItem is null || i.Quantity <= 0 || i.UnitCost <= 0 || i.AcquisitionDateNullable is null))
        {
            Snackbar.Add("All line items must have an Item, Quantity, Unit Cost, and Acquisition Date.", Severity.Warning);
            return;
        }
        _busy = true;
        try
        {
            var items = _form.Items.Select(li => new CreateSMRRItemRequest(
                li.Reference,
                li.SelectedItem!.Id,
                li.Description,
                DateOnly.FromDateTime(li.AcquisitionDateNullable!.Value),
                li.Quantity,
                li.UnitCost)).ToList();

            var result = await Client.CreateAsync(new CreateSMRRCommand(
                _form.SMRRNo, DateOnly.FromDateTime(_form.DateNullable!.Value),
                _form.ReceivedFrom, _form.Address, _form.ReceiptType, _form.OtherReceiptType,
                _form.FundCluster, _form.ReceivedBy, _form.NotedBy, items));

            Snackbar.Add($"SMRR created. {result.PropertiesCreated} property unit(s) registered.", Severity.Success);
            _form = new SmrrForm();
            _form.Items.Add(new LineItemRow());
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Create failed: {ex.Message}", Severity.Error); }
        finally { _busy = false; }
    }

    private void AddLineItem() => _form.Items.Add(new LineItemRow());
    private void RemoveLineItem(int idx) { if (_form.Items.Count > 1) _form.Items.RemoveAt(idx); }

    private sealed class SmrrForm
    {
        public string SMRRNo { get; set; } = string.Empty;
        public DateTime? DateNullable { get; set; } = DateTime.Today;
        public string ReceivedFrom { get; set; } = string.Empty;
        public string? Address { get; set; }
        public ReceiptType ReceiptType { get; set; } = ReceiptType.Purchase;
        public string? OtherReceiptType { get; set; }
        public string? FundCluster { get; set; }
        public string? ReceivedBy { get; set; }
        public string? NotedBy { get; set; }
        public List<LineItemRow> Items { get; set; } = [];
    }

    private sealed class LineItemRow
    {
        public SemiExpendableItemSummaryDto? SelectedItem { get; set; }
        public string? Reference { get; set; }
        public string? Description { get; set; }
        public DateTime? AcquisitionDateNullable { get; set; } = DateTime.Today;
        public int Quantity { get; set; } = 1;
        public decimal UnitCost { get; set; }
    }
}
