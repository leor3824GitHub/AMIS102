@page "/asset-management/returned-properties"
@using AMIS.Playground.Blazor.ApiClient
@inject IRRSPClient Client
@inject IICSClient ICSClient
@inject ILookupClient LookupClient
@inject ISnackbar Snackbar

<AMISPageHeader Title="Receipt for Returned Semi-Expendable Properties (RRSP)"
               Description="Record full return of issued property by an end-user. Cancels the referenced ICS and sets all items back to Returned status." />

<MudGrid Spacing="3">
    <!-- Create Form -->
    <MudItem xs="12" md="5">
        <MudCard Elevation="1">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-3">New RRSP</MudText>
                <MudStack Spacing="2">
                    <MudTextField @bind-Value="_form.RRSPNo" Label="RRSP No." Variant="Variant.Outlined"
                                  Required="true" MaxLength="32" Placeholder="e.g. RRSP-2026-00001" />
                    <MudDatePicker @bind-Date="_form.DateNullable" Label="Date" Variant="Variant.Outlined"
                                   DateFormat="MM/dd/yyyy" Required="true" />

                    <MudAutocomplete T="ICSSummaryDto"
                                     @bind-Value="_form.SelectedICS"
                                     SearchFunc="SearchICS"
                                     ToStringFunc="@(x => x is null ? "" : x.ICSNo)"
                                     Label="ICS to Cancel" Variant="Variant.Outlined"
                                     Required="true" Clearable="true" ResetValueOnEmptyText="true" CoerceValue="true" />
                    @if (_form.SelectedICS is not null)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">
                            All @_form.SelectedICS.ItemCount item(s) on ICS <b>@_form.SelectedICS.ICSNo</b> will be returned.
                        </MudAlert>
                    }

                    <MudTextField @bind-Value="_form.FundCluster" Label="Fund Cluster" Variant="Variant.Outlined" MaxLength="50" />

                    <MudAutocomplete T="EmployeeReferenceDto"
                                     @bind-Value="_form.ReturnedBy"
                                     SearchFunc="SearchEmployees"
                                     ToStringFunc="FormatEmployee"
                                     Label="Returned By (End-User)" Variant="Variant.Outlined"
                                     Required="true" Clearable="true" ResetValueOnEmptyText="true" CoerceValue="true" />

                    <MudAutocomplete T="EmployeeReferenceDto"
                                     @bind-Value="_form.ReceivedBy"
                                     SearchFunc="SearchEmployees"
                                     ToStringFunc="FormatEmployee"
                                     Label="Received By (Supply Officer)" Variant="Variant.Outlined"
                                     Clearable="true" ResetValueOnEmptyText="true" CoerceValue="true" />

                    <MudTextField @bind-Value="_form.Remarks" Label="Remarks" Variant="Variant.Outlined"
                                  Lines="2" MaxLength="500" />

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                               OnClick="CreateAsync" Disabled="_busy">Create RRSP</MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- List Panel -->
    <MudItem xs="12" md="7">
        <MudCard Elevation="1">
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
                    <MudText Typo="Typo.h6" Class="flex-grow-1">Return Receipts</MudText>
                    <MudTextField @bind-Value="_keyword" Label="Search" Variant="Variant.Outlined" Size="Size.Small"
                                  Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                                  DebounceInterval="350" OnDebounceIntervalElapsed="@(() => LoadAsync())" Style="max-width:220px" />
                </MudStack>

                @if (_loading)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else if (_records.Count == 0)
                {
                    <MudAlert Severity="Severity.Info">No return receipts yet.</MudAlert>
                }
                else
                {
                    <MudSimpleTable Dense="true" Hover="true" Striped="true">
                        <thead>
                            <tr>
                                <th>RRSP No.</th>
                                <th>Date</th>
                                <th>ICS No.</th>
                                <th>Items</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in _records)
                            {
                                <tr>
                                    <td><MudText Typo="Typo.body2"><b>@s.RRSPNo</b></MudText></td>
                                    <td>@s.Date.ToString("MM/dd/yyyy")</td>
                                    <td><MudText Typo="Typo.caption">@s.ICSNo</MudText></td>
                                    <td><MudChip T="string" Size="Size.Small" Color="Color.Info">@s.ItemCount items</MudChip></td>
                                    <td>
                                        <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                                       Color="Color.Primary" OnClick="@(() => ViewAsync(s.Id))" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>

                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-2">
                        <MudText Typo="Typo.caption">@_totalCount total</MudText>
                        <MudSpacer />
                        <MudPagination Count="@TotalPages" Selected="_page" ShowFirstButton="true" ShowLastButton="true"
                                       SelectedChanged="@(async p => { _page = p; await LoadAsync(); })" />
                    </MudStack>
                }
            </MudCardContent>
        </MudCard>

        <!-- Detail Card -->
        @if (_detail is not null)
        {
            <MudCard Elevation="1" Class="mt-3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6">@_detail.RRSPNo — @_detail.Date.ToString("MMMM dd, yyyy")</MudText>
                            <MudSpacer />
                            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _detail = null)" />
                        </MudStack>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="1" Class="mb-2">
                        <MudItem xs="6"><MudText Typo="Typo.caption">Cancelled ICS</MudText><MudText Typo="Typo.body2"><b>@_detail.ICSNo</b></MudText></MudItem>
                        <MudItem xs="6"><MudText Typo="Typo.caption">Returned By (Employee ID)</MudText><MudText Typo="Typo.body2" Style="font-family:monospace;font-size:0.85em">@ShortGuid(_detail.ReturnedByEmployeeId)</MudText></MudItem>
                        @if (_detail.ReceivedByEmployeeId.HasValue)
                        {
                            <MudItem xs="6"><MudText Typo="Typo.caption">Received By (Employee ID)</MudText><MudText Typo="Typo.body2" Style="font-family:monospace;font-size:0.85em">@ShortGuid(_detail.ReceivedByEmployeeId.Value)</MudText></MudItem>
                        }
                        @if (!string.IsNullOrWhiteSpace(_detail.FundCluster))
                        {
                            <MudItem xs="6"><MudText Typo="Typo.caption">Fund Cluster</MudText><MudText Typo="Typo.body2">@_detail.FundCluster</MudText></MudItem>
                        }
                        @if (!string.IsNullOrWhiteSpace(_detail.Remarks))
                        {
                            <MudItem xs="12"><MudText Typo="Typo.caption">Remarks</MudText><MudText Typo="Typo.body2">@_detail.Remarks</MudText></MudItem>
                        }
                    </MudGrid>
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle2" Class="mb-1">Returned Items</MudText>
                    <MudSimpleTable Dense="true" Striped="true">
                        <thead>
                            <tr><th>#</th><th>Property No.</th><th>Description</th><th>Category</th><th>Unit Cost</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _detail.Items.OrderBy(x => x.ItemNo))
                            {
                                <tr>
                                    <td>@item.ItemNo</td>
                                    <td><b>@item.PropertyNo</b></td>
                                    <td>@(item.Description ?? "-")</td>
                                    <td><MudChip T="string" Size="Size.Small" Color="Color.Default">@item.CategoryAtTimeOfReturn</MudChip></td>
                                    <td>?@item.UnitCost.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="4" style="text-align:right"><b>Total:</b></td>
                                <td><b>?@_detail.Items.Sum(x => x.UnitCost).ToString("N2")</b></td>
                            </tr>
                        </tfoot>
                    </MudSimpleTable>
                </MudCardContent>
            </MudCard>
        }
    </MudItem>
</MudGrid>

@code {
    private List<RRSPSummaryDto> _records = [];
    private RRSPDetailsDto? _detail;
    private RrspForm _form = new();
    private string? _keyword;
    private bool _loading;
    private bool _busy;
    private int _page = 1;
    private int _totalCount;
    private const int PageSize = 15;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)PageSize));

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var response = await Client.SearchAsync(_keyword, page: _page, pageSize: PageSize);
            _records = [.. response.Items];
            _totalCount = response.TotalCount;
        }
        catch (Exception ex) { Snackbar.Add($"Load failed: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task ViewAsync(Guid id)
    {
        try { _detail = await Client.GetAsync(id); }
        catch (Exception ex) { Snackbar.Add($"Load failed: {ex.Message}", Severity.Error); }
    }

    private async Task<IEnumerable<ICSSummaryDto>> SearchICS(string? value, CancellationToken ct)
    {
        var response = await ICSClient.SearchAsync(value, page: 1, pageSize: 20, ct: ct);
        return response.Items;
    }

    private async Task<IEnumerable<EmployeeReferenceDto>> SearchEmployees(string? value, CancellationToken ct)
    {
        try
        {
            var result = await LookupClient.EmployeesGetAsync(
                keyword: string.IsNullOrWhiteSpace(value) ? null : value,
                isActive: true, pageNumber: 1, pageSize: 20, cancellationToken: ct);
            return result?.Items ?? [];
        }
        catch { return []; }
    }

    private static string FormatEmployee(EmployeeReferenceDto? e) =>
        e is null ? "" : $"{e.FirstName} {e.LastName} ({e.EmployeeNumber})";

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.RRSPNo) || _form.DateNullable is null ||
            _form.SelectedICS is null || _form.ReturnedBy is null)
        {
            Snackbar.Add("RRSP No., Date, ICS, and Returned By are required.", Severity.Warning);
            return;
        }
        _busy = true;
        try
        {
            var result = await Client.CreateAsync(new CreateRRSPCommand(
                _form.RRSPNo,
                DateOnly.FromDateTime(_form.DateNullable!.Value),
                _form.SelectedICS.Id,
                _form.FundCluster,
                _form.ReceivedBy?.Id,
                _form.ReturnedBy.Id,
                _form.Remarks));

            Snackbar.Add($"RRSP created. {result.ItemCount} item(s) returned and ICS cancelled.", Severity.Success);
            _form = new RrspForm();
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Create failed: {ex.Message}", Severity.Error); }
        finally { _busy = false; }
    }

    private static string ShortGuid(Guid id) => $"{id:D}"[..8] + "…";

    private sealed class RrspForm
    {
        public string RRSPNo { get; set; } = string.Empty;
        public DateTime? DateNullable { get; set; } = DateTime.Today;
        public ICSSummaryDto? SelectedICS { get; set; }
        public string? FundCluster { get; set; }
        public EmployeeReferenceDto? ReturnedBy { get; set; }
        public EmployeeReferenceDto? ReceivedBy { get; set; }
        public string? Remarks { get; set; }
    }
}

