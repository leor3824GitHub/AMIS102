@page "/asset-management/ppe-receiving-reports"
@using FSH.Playground.Blazor.ApiClient
@inject IPPERRClient Client
@inject ILookupClient LookupClient
@inject ITangibleItemClient TangibleClient
@inject ISnackbar Snackbar

<FshPageHeader Title="PPE Receiving Reports (PPERR)"
               Description="Record receipt of Property, Plant & Equipment above the capitalization threshold. Each PPERR creates individual PPE Item records." />

<MudTabs @bind-ActivePanelIndex="_activeTab" Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">

    <!-- Tab 1: List -->
    <MudTabPanel Text="List" Icon="@Icons.Material.Filled.ListAlt">

        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
            <MudText Typo="Typo.h6" Class="flex-grow-1">PPE Receiving Reports</MudText>
            <MudTextField @bind-Value="_keyword" Label="Search" Variant="Variant.Outlined" Size="Size.Small"
                          Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                          DebounceInterval="350" OnDebounceIntervalElapsed="@(() => LoadAsync())"
                          Style="max-width:260px" />
        </MudStack>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
        }
        else if (_list.Count == 0)
        {
            <MudAlert Severity="Severity.Info">No PPE receiving reports yet.</MudAlert>
        }
        else
        {
            <MudSimpleTable Dense="true" Hover="true" Striped="true">
                <thead>
                    <tr>
                        <th>PPERR No.</th>
                        <th>Date</th>
                        <th>Received From</th>
                        <th>Nature</th>
                        <th>Items</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in _list)
                    {
                        <tr>
                            <td><b>@s.PPERRNo</b></td>
                            <td>@s.Date.ToString("MM/dd/yyyy")</td>
                            <td>@s.ReceivedFrom</td>
                            <td>@s.ReceiptNature</td>
                            <td><MudChip T="string" Size="Size.Small" Color="Color.Info">@s.ItemCount lines</MudChip></td>
                            <td>
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                               Color="Color.Primary" OnClick="@(() => ViewAsync(s.Id))" />
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-2">
                <MudText Typo="Typo.caption">@_totalCount total</MudText>
                <MudSpacer />
                <MudPagination Count="@TotalPages" Selected="_page" ShowFirstButton="true" ShowLastButton="true"
                               SelectedChanged="@(async p => { _page = p; await LoadAsync(); })" />
            </MudStack>
        }

        <!-- Detail panel -->
        @if (_detail is not null)
        {
            <MudCard Elevation="0" Outlined="true" Class="mt-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6">@_detail.PPERRNo — @_detail.Date.ToString("MMMM dd, yyyy")</MudText>
                            <MudSpacer />
                            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _detail = null)" />
                        </MudStack>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="2" Class="mb-2">
                        <MudItem xs="12" sm="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Received From</MudText>
                            <MudText Typo="Typo.body2">@_detail.ReceivedFrom</MudText>
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Address</MudText>
                            <MudText Typo="Typo.body2">@_detail.Address</MudText>
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Nature</MudText>
                            <MudText Typo="Typo.body2">@_detail.ReceiptNature</MudText>
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Created</MudText>
                            <MudText Typo="Typo.body2">@_detail.CreatedOnUtc.ToLocalTime().ToString("MM/dd/yyyy HH:mm")</MudText>
                        </MudItem>
                    </MudGrid>
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Line Items</MudText>
                    <MudSimpleTable Dense="true" Striped="true">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Property Code</th>
                                <th>Description</th>
                                <th>Acq. Date</th>
                                <th>Qty</th>
                                <th>Unit Cost</th>
                                <th>Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _detail.Items)
                            {
                                <tr>
                                    <td>@item.ItemNo</td>
                                    <td><b>@item.PropertyCode</b></td>
                                    <td>@item.Description</td>
                                    <td>@item.DateAcquired.ToString("MM/dd/yyyy")</td>
                                    <td>@item.Quantity</td>
                                    <td>₱@item.UnitCost.ToString("N2")</td>
                                    <td><b>₱@item.Amount.ToString("N2")</b></td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="6" style="text-align:right"><b>Total:</b></td>
                                <td><b>₱@_detail.Items.Sum(x => x.Amount).ToString("N2")</b></td>
                            </tr>
                        </tfoot>
                    </MudSimpleTable>
                </MudCardContent>
            </MudCard>
        }

    </MudTabPanel>

    <!-- Tab 2: New PPERR -->
    <MudTabPanel Text="New PPERR" Icon="@Icons.Material.Filled.Add">

        <MudGrid Spacing="3">

            <!-- Left: header fields -->
            <MudItem xs="12" md="4">
                <MudCard Elevation="0" Outlined="true" Style="height:100%">
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle1" Class="mb-3">Details</MudText>
                        <MudStack Spacing="2">
                            <MudTextField @bind-Value="_form.PPERRNo" Label="PPERR No." Variant="Variant.Outlined"
                                          Required="true" MaxLength="32" Placeholder="e.g. PPERR-2026-00001" />
                            <MudDatePicker @bind-Date="_form.DateNullable" Label="Date" Variant="Variant.Outlined"
                                           DateFormat="MM/dd/yyyy" Required="true" />
                            <MudTextField @bind-Value="_form.ReceivedFrom" Label="Received From" Variant="Variant.Outlined"
                                          Required="true" MaxLength="200" />
                            <MudTextField @bind-Value="_form.Address" Label="Address" Variant="Variant.Outlined" MaxLength="500" />
                            <MudSelect @bind-Value="_form.ReceiptNature" Label="Receipt Nature" Variant="Variant.Outlined" T="PPEReceiptNature">
                                <MudSelectItem Value="PPEReceiptNature.Purchase">Purchase</MudSelectItem>
                                <MudSelectItem Value="PPEReceiptNature.Transfer">Transfer</MudSelectItem>
                                <MudSelectItem Value="PPEReceiptNature.Donation">Donation</MudSelectItem>
                                <MudSelectItem Value="PPEReceiptNature.Others">Others</MudSelectItem>
                            </MudSelect>
                            <MudAutocomplete T="EmployeeReferenceDto"
                                             @bind-Value="_form.ReceivedBy"
                                             SearchFunc="SearchEmployees"
                                             ToStringFunc="FormatEmployee"
                                             Label="Received By" Variant="Variant.Outlined"
                                             Required="true" Clearable="true" ResetValueOnEmptyText="true" CoerceValue="true" />
                            <MudAutocomplete T="EmployeeReferenceDto"
                                             @bind-Value="_form.NotedBy"
                                             SearchFunc="SearchEmployees"
                                             ToStringFunc="FormatEmployee"
                                             Label="Noted By (Division Chief)" Variant="Variant.Outlined"
                                             Required="true" Clearable="true" ResetValueOnEmptyText="true" CoerceValue="true" />

                            <MudStack Row="true" Spacing="1" Class="mt-2">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                           OnClick="CreateAsync" Disabled="_busy">
                                    @if (_busy)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    }
                                    Create PPERR
                                </MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ClearForm">
                                    Clear
                                </MudButton>
                            </MudStack>
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Right: PPE items -->
            <MudItem xs="12" md="8">
                <MudCard Elevation="0" Outlined="true" Style="height:100%">
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle1" Class="mb-3">PPE Line Items</MudText>

                        <!-- Add item input -->
                        <MudGrid Spacing="2" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudItem xs="12" sm="9">
                                <MudAutocomplete T="TangibleItemSummaryDto"
                                                 @bind-Value="_draft.SelectedItem"
                                                 SearchFunc="SearchTangibleItemsAsync"
                                                 ToStringFunc="@(x => x is null ? "" : $"{x.PropertyNo} — {x.ItemName}")"
                                                 Label="Tangible Item" Variant="Variant.Outlined"
                                                 Clearable="true" CoerceValue="true"
                                                 ResetValueOnEmptyText="true" MinCharacters="0" />
                            </MudItem>
                            <MudItem xs="12" sm="3">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                           StartIcon="@Icons.Material.Filled.Add" OnClick="AddItem">Add</MudButton>
                            </MudItem>
                        </MudGrid>

                        <!-- Confirmed items table -->
                        @if (_form.Items.Count > 0)
                        {
                            <MudSimpleTable Dense="true" Hover="true" Striped="true">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Property No.</th>
                                        <th>Item Name</th>
                                        <th>Qty</th>
                                        <th>Unit Cost</th>
                                        <th>Amount</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var (li, i) in _form.Items.Select((x, i) => (x, i + 1)))
                                    {
                                        <tr>
                                            <td>@i</td>
                                            <td><b>@li.SelectedItem!.PropertyNo</b></td>
                                            <td>
                                                <MudText Typo="Typo.body2">@li.SelectedItem.ItemName</MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@li.SelectedItem.PropertyClass / @li.SelectedItem.CategoryCode</MudText>
                                            </td>
                                            <td>@li.SelectedItem.Quantity</td>
                                            <td>₱@li.SelectedItem.UnitCost.ToString("N2")</td>
                                            <td><b>₱@((li.SelectedItem.Quantity * li.SelectedItem.UnitCost).ToString("N2"))</b></td>
                                            <td>
                                                <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small"
                                                               Color="Color.Error" OnClick="@(() => RemoveItem(i - 1))" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="4" style="text-align:right"><b>Total:</b></td>
                                        <td><b>₱@(_form.Items.Sum(x => x.SelectedItem!.Quantity * x.SelectedItem.UnitCost).ToString("N2"))</b></td>
                                        <td colspan="2"></td>
                                    </tr>
                                </tfoot>
                            </MudSimpleTable>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">
                                Select a tangible item above and click Add.
                            </MudAlert>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>

        </MudGrid>

    </MudTabPanel>

</MudTabs>

@code {
    private List<PPERRSummaryDto> _list = [];
    private PPERRDetailsDto? _detail;
    private PpErrForm _form = new();
    private LineItem _draft = new();
    private string? _keyword;
    private bool _loading, _busy;
    private int _page = 1, _totalCount, _activeTab;
    private const int PageSize = 15;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)PageSize));

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task<IEnumerable<TangibleItemSummaryDto>> SearchTangibleItemsAsync(string? value, CancellationToken ct)
    {
        var response = await TangibleClient.SearchAsync(keyword: value, page: 1, pageSize: 50, ct: ct);
        var alreadySelected = _form.Items
            .Where(x => x.SelectedItem is not null)
            .Select(x => x.SelectedItem!.Id)
            .ToHashSet();
        return response.Items.Where(x => !alreadySelected.Contains(x.Id));
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var r = await Client.SearchAsync(_keyword, page: _page, pageSize: PageSize);
            _list = [.. r.Items];
            _totalCount = r.TotalCount;
        }
        catch (Exception ex) { Snackbar.Add($"Load failed: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task ViewAsync(Guid id)
    {
        try { _detail = await Client.GetAsync(id); }
        catch (Exception ex) { Snackbar.Add($"Load failed: {ex.Message}", Severity.Error); }
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.PPERRNo) || _form.DateNullable is null ||
            string.IsNullOrWhiteSpace(_form.ReceivedFrom) || _form.ReceivedBy is null || _form.NotedBy is null)
        {
            Snackbar.Add("PPERR No., Date, Received From, Received By, and Noted By are required.", Severity.Warning);
            return;
        }
        if (_form.Items.Count == 0)
        {
            Snackbar.Add("Add at least one PPE line item.", Severity.Warning);
            return;
        }
        _busy = true;
        try
        {
            var items = _form.Items.Select(li => new CreatePPERRItemRequest(
                li.SelectedItem!.PropertyClass,
                li.SelectedItem!.CategoryCode,
                li.SelectedItem!.PropertyNo,
                li.SelectedItem!.ItemName,
                null,
                li.SelectedItem!.AcquisitionDate,
                li.SelectedItem!.Quantity,
                li.SelectedItem!.UnitCost,
                0)).ToList();

            var result = await Client.CreateAsync(new CreatePPERRCommand(
                _form.PPERRNo, DateOnly.FromDateTime(_form.DateNullable!.Value),
                _form.ReceivedFrom, _form.Address ?? string.Empty, _form.ReceiptNature,
                _form.ReceivedBy!.Id, _form.NotedBy!.Id, items));

            Snackbar.Add($"PPERR created. {result.PPEItemsCreated} PPE item(s) registered.", Severity.Success);
            ClearForm();
            _activeTab = 0;
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Create failed: {ex.Message}", Severity.Error); }
        finally { _busy = false; }
    }

    private void AddItem()
    {
        if (_draft.SelectedItem is null)
        {
            Snackbar.Add("Select a tangible item first.", Severity.Warning);
            return;
        }
        _form.Items.Add(new LineItem { SelectedItem = _draft.SelectedItem });
        _draft = new LineItem();
    }

    private void RemoveItem(int idx) => _form.Items.RemoveAt(idx);

    private void ClearForm()
    {
        _form = new PpErrForm();
        _draft = new LineItem();
    }

    private async Task<IEnumerable<EmployeeReferenceDto>> SearchEmployees(string? value, CancellationToken ct)
    {
        var r = await LookupClient.EmployeesGetAsync(keyword: value, isActive: true, pageSize: 20, cancellationToken: ct);
        return r.Items;
    }

    private static string FormatEmployee(EmployeeReferenceDto? e) =>
        e is null ? "" : $"{e.LastName}, {e.FirstName} ({e.EmployeeNumber})";

    private sealed class PpErrForm
    {
        public string PPERRNo { get; set; } = string.Empty;
        public DateTime? DateNullable { get; set; } = DateTime.Today;
        public string ReceivedFrom { get; set; } = string.Empty;
        public string? Address { get; set; }
        public PPEReceiptNature ReceiptNature { get; set; } = PPEReceiptNature.Purchase;
        public EmployeeReferenceDto? ReceivedBy { get; set; }
        public EmployeeReferenceDto? NotedBy { get; set; }
        public List<LineItem> Items { get; set; } = [];
    }

    private sealed class LineItem
    {
        public TangibleItemSummaryDto? SelectedItem { get; set; }
    }
}
