@page "/asset-management/unserviceable-reports"
@using FSH.Playground.Blazor.ApiClient
@inject IUnserviceablePropertyReportClient Client
@inject ISemiExpendablePropertyClient PropertyClient
@inject ILookupClient LookupClient
@inject ISnackbar Snackbar

<FshPageHeader Title="Unserviceable Property Reports (IIRUSP)"
               Description="Inspection and Inventory Report of Unserviceable Semi-Expendable Property. Records disposal of property that is no longer serviceable." />

<MudGrid Spacing="3">
    <!-- Create Form -->
    <MudItem xs="12" md="5">
        <MudCard Elevation="1">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-3">New IIRUSP</MudText>
                <MudStack Spacing="2">
                    <MudTextField @bind-Value="_form.ReportNo" Label="Report No." Variant="Variant.Outlined"
                                  Required="true" MaxLength="32" Placeholder="e.g. IUR-2026-04-0001" />
                    <MudDatePicker @bind-Date="_form.DateNullable" Label="Date" Variant="Variant.Outlined"
                                   DateFormat="MM/dd/yyyy" Required="true" />
                    <MudSelect @bind-Value="_form.DisposalMethod" Label="Disposal Method" Variant="Variant.Outlined" T="DisposalMethod">
                        <MudSelectItem Value="DisposalMethod.Sale">Sale</MudSelectItem>
                        <MudSelectItem Value="DisposalMethod.Destruction">Destruction</MudSelectItem>
                        <MudSelectItem Value="DisposalMethod.Donation">Donation</MudSelectItem>
                        <MudSelectItem Value="DisposalMethod.Transfer">Transfer</MudSelectItem>
                        <MudSelectItem Value="DisposalMethod.Others">Others</MudSelectItem>
                    </MudSelect>
                    <MudTextField @bind-Value="_form.FundCluster" Label="Fund Cluster" Variant="Variant.Outlined" MaxLength="50" />

                    <MudAutocomplete T="EmployeeReferenceDto"
                                     @bind-Value="_form.InspectedBy"
                                     SearchFunc="SearchEmployees"
                                     ToStringFunc="FormatEmployee"
                                     Label="Inspected By" Variant="Variant.Outlined"
                                     Clearable="true" ResetValueOnEmptyText="true" CoerceValue="true" />

                    <MudAutocomplete T="EmployeeReferenceDto"
                                     @bind-Value="_form.ApprovedBy"
                                     SearchFunc="SearchEmployees"
                                     ToStringFunc="FormatEmployee"
                                     Label="Approved By" Variant="Variant.Outlined"
                                     Clearable="true" ResetValueOnEmptyText="true" CoerceValue="true" />

                    <MudTextField @bind-Value="_form.Remarks" Label="Remarks" Variant="Variant.Outlined"
                                  Lines="2" MaxLength="500" />

                    <MudDivider Class="my-2" />
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.subtitle2" Class="flex-grow-1">Properties for Disposal</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" Color="Color.Primary"
                                       OnClick="AddItem" />
                    </MudStack>

                    @for (var i = 0; i < _form.Items.Count; i++)
                    {
                        var idx = i;
                        var li = _form.Items[idx];
                        <MudPaper Outlined="true" Class="pa-2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Item @(idx + 1)</MudText>
                                <MudSpacer />
                                <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small" Color="Color.Error"
                                               OnClick="@(() => RemoveItem(idx))" />
                            </MudStack>
                            <MudStack Spacing="1">
                                <MudAutocomplete T="SemiExpendablePropertySummaryDto"
                                                 Value="li.SelectedProperty"
                                                 ValueChanged="@(v => li.SelectedProperty = v)"
                                                 SearchFunc="SearchEligibleProperties"
                                                 ToStringFunc="@(x => x is null ? "" : $"{x.PropertyNo} – {x.ItemName} ({x.Status})")"
                                                 Label="Property (OnHand/Returned/LostStolenDamaged)" Variant="Variant.Outlined" Dense="true"
                                                 Required="true" Clearable="true" CoerceValue="true" ResetValueOnEmptyText="true" />
                                @if (li.SelectedProperty is not null)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        ₱@li.SelectedProperty.UnitCost.ToString("N2") | @li.SelectedProperty.Status
                                    </MudText>
                                }
                                <MudTextField @bind-Value="li.ConditionRemarks" Label="Condition Remarks" Variant="Variant.Outlined"
                                              Dense="true" MaxLength="500"
                                              Placeholder="Inspector notes on condition..." />
                            </MudStack>
                        </MudPaper>
                    }

                    <MudButton Variant="Variant.Filled" Color="Color.Error" FullWidth="true"
                               OnClick="CreateAsync" Disabled="_busy">Create IIRUSP</MudButton>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <!-- List Panel -->
    <MudItem xs="12" md="7">
        <MudCard Elevation="1">
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3" Spacing="2">
                    <MudText Typo="Typo.h6" Class="flex-grow-1">Unserviceable Reports</MudText>
                    <MudTextField @bind-Value="_keyword" Label="Search" Variant="Variant.Outlined" Size="Size.Small"
                                  Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                                  DebounceInterval="350" OnDebounceIntervalElapsed="@(() => LoadAsync())" Style="max-width:180px" />
                    <MudSelect Value="_methodFilter" Label="Method" Variant="Variant.Outlined" Size="Size.Small"
                               T="DisposalMethod?" Style="max-width:130px"
                               ValueChanged="@(v => { _methodFilter = v; _ = LoadAsync(); })">
                        <MudSelectItem T="DisposalMethod?" Value="null">All</MudSelectItem>
                        <MudSelectItem T="DisposalMethod?" Value="DisposalMethod.Sale">Sale</MudSelectItem>
                        <MudSelectItem T="DisposalMethod?" Value="DisposalMethod.Destruction">Destruction</MudSelectItem>
                        <MudSelectItem T="DisposalMethod?" Value="DisposalMethod.Donation">Donation</MudSelectItem>
                        <MudSelectItem T="DisposalMethod?" Value="DisposalMethod.Transfer">Transfer</MudSelectItem>
                        <MudSelectItem T="DisposalMethod?" Value="DisposalMethod.Others">Others</MudSelectItem>
                    </MudSelect>
                </MudStack>

                @if (_loading)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                }
                else if (_records.Count == 0)
                {
                    <MudAlert Severity="Severity.Info">No unserviceable property reports yet.</MudAlert>
                }
                else
                {
                    <MudSimpleTable Dense="true" Hover="true" Striped="true">
                        <thead>
                            <tr>
                                <th>Report No.</th>
                                <th>Date</th>
                                <th>Disposal</th>
                                <th>Items</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in _records)
                            {
                                <tr>
                                    <td><MudText Typo="Typo.body2"><b>@s.ReportNo</b></MudText></td>
                                    <td>@s.Date.ToString("MM/dd/yyyy")</td>
                                    <td>
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error">@s.DisposalMethod</MudChip>
                                    </td>
                                    <td><MudChip T="string" Size="Size.Small" Color="Color.Info">@s.ItemCount items</MudChip></td>
                                    <td>
                                        <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                                       Color="Color.Primary" OnClick="@(() => ViewAsync(s.Id))" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>

                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-2">
                        <MudText Typo="Typo.caption">@_totalCount total</MudText>
                        <MudSpacer />
                        <MudPagination Count="@TotalPages" Selected="_page" ShowFirstButton="true" ShowLastButton="true"
                                       SelectedChanged="@(async p => { _page = p; await LoadAsync(); })" />
                    </MudStack>
                }
            </MudCardContent>
        </MudCard>

        <!-- Detail Card -->
        @if (_detail is not null)
        {
            <MudCard Elevation="1" Class="mt-3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6">@_detail.ReportNo — @_detail.Date.ToString("MMMM dd, yyyy")</MudText>
                            <MudSpacer />
                            <MudChip T="string" Size="Size.Small" Color="Color.Error">@_detail.DisposalMethod</MudChip>
                            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _detail = null)" />
                        </MudStack>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="1" Class="mb-2">
                        @if (!string.IsNullOrWhiteSpace(_detail.FundCluster))
                        {
                            <MudItem xs="6"><MudText Typo="Typo.caption">Fund Cluster</MudText><MudText Typo="Typo.body2">@_detail.FundCluster</MudText></MudItem>
                        }
                        @if (_detail.InspectedByEmployeeId.HasValue)
                        {
                            <MudItem xs="6"><MudText Typo="Typo.caption">Inspected By (Employee ID)</MudText><MudText Typo="Typo.body2" Style="font-family:monospace;font-size:0.85em">@ShortGuid(_detail.InspectedByEmployeeId.Value)</MudText></MudItem>
                        }
                        @if (_detail.ApprovedByEmployeeId.HasValue)
                        {
                            <MudItem xs="6"><MudText Typo="Typo.caption">Approved By (Employee ID)</MudText><MudText Typo="Typo.body2" Style="font-family:monospace;font-size:0.85em">@ShortGuid(_detail.ApprovedByEmployeeId.Value)</MudText></MudItem>
                        }
                        @if (!string.IsNullOrWhiteSpace(_detail.Remarks))
                        {
                            <MudItem xs="12"><MudText Typo="Typo.caption">Remarks</MudText><MudText Typo="Typo.body2">@_detail.Remarks</MudText></MudItem>
                        }
                    </MudGrid>
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle2" Class="mb-1">Disposed Items</MudText>
                    <MudSimpleTable Dense="true" Striped="true">
                        <thead>
                            <tr><th>#</th><th>Property No.</th><th>Description</th><th>Category</th><th>Unit Cost</th><th>Condition</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _detail.Items.OrderBy(x => x.ItemNo))
                            {
                                <tr>
                                    <td>@item.ItemNo</td>
                                    <td><b>@item.PropertyNo</b></td>
                                    <td>@(item.Description ?? "-")</td>
                                    <td><MudChip T="string" Size="Size.Small" Color="Color.Default">@item.CategoryAtTimeOfReport</MudChip></td>
                                    <td>₱@item.UnitCost.ToString("N2")</td>
                                    <td><MudText Typo="Typo.caption">@(item.ConditionRemarks ?? "-")</MudText></td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="4" style="text-align:right"><b>Total:</b></td>
                                <td><b>₱@_detail.Items.Sum(x => x.UnitCost).ToString("N2")</b></td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </MudSimpleTable>
                </MudCardContent>
            </MudCard>
        }
    </MudItem>
</MudGrid>

@code {
    private List<UnserviceablePropertyReportSummaryDto> _records = [];
    private UnserviceablePropertyReportDetailsDto? _detail;
    private IirusForm _form = new();
    private string? _keyword;
    private DisposalMethod? _methodFilter;
    private bool _loading;
    private bool _busy;
    private int _page = 1;
    private int _totalCount;
    private const int PageSize = 15;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_totalCount / (double)PageSize));

    protected override async Task OnInitializedAsync()
    {
        _form.Items.Add(new IirusItemRow());
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var response = await Client.SearchAsync(_keyword, disposalMethod: _methodFilter, page: _page, pageSize: PageSize);
            _records = [.. response.Items];
            _totalCount = response.TotalCount;
        }
        catch (Exception ex) { Snackbar.Add($"Load failed: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task ViewAsync(Guid id)
    {
        try { _detail = await Client.GetAsync(id); }
        catch (Exception ex) { Snackbar.Add($"Load failed: {ex.Message}", Severity.Error); }
    }

    private async Task<IEnumerable<EmployeeReferenceDto>> SearchEmployees(string? value, CancellationToken ct)
    {
        try
        {
            var result = await LookupClient.EmployeesGetAsync(
                keyword: string.IsNullOrWhiteSpace(value) ? null : value,
                isActive: true, pageNumber: 1, pageSize: 20, cancellationToken: ct);
            return result?.Items ?? [];
        }
        catch { return []; }
    }

    private async Task<IEnumerable<SemiExpendablePropertySummaryDto>> SearchEligibleProperties(string? value, CancellationToken ct)
    {
        // Search OnHand, Returned, and LostStolenDamaged in three calls merged.
        // Guard against cancellation between calls (user typed another character).
        var results = new List<SemiExpendablePropertySummaryDto>();
        try
        {
            foreach (var status in new[] { "OnHand", "Returned", "LostStolenDamaged" })
            {
                ct.ThrowIfCancellationRequested();
                var response = await PropertyClient.SearchAsync(value, status: status, page: 1, pageSize: 10, ct: ct);
                results.AddRange(response.Items);
            }
        }
        catch (OperationCanceledException) { return []; }
        return results.Take(20);
    }

    private static string ShortGuid(Guid id) => $"{id:D}"[..8] + "…";

    private static string FormatEmployee(EmployeeReferenceDto? e) =>
        e is null ? "" : $"{e.FirstName} {e.LastName} ({e.EmployeeNumber})";

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.ReportNo) || _form.DateNullable is null)
        {
            Snackbar.Add("Report No. and Date are required.", Severity.Warning);
            return;
        }
        if (_form.Items.Any(i => i.SelectedProperty is null))
        {
            Snackbar.Add("All items must have a selected property.", Severity.Warning);
            return;
        }
        _busy = true;
        try
        {
            var items = _form.Items.Select(i => new CreateUnserviceablePropertyItemRequest(
                i.SelectedProperty!.Id, i.ConditionRemarks)).ToList();

            var result = await Client.CreateAsync(new CreateUnserviceablePropertyReportCommand(
                _form.ReportNo,
                DateOnly.FromDateTime(_form.DateNullable!.Value),
                _form.DisposalMethod,
                _form.FundCluster,
                _form.InspectedBy?.Id,
                _form.ApprovedBy?.Id,
                _form.Remarks,
                items));

            Snackbar.Add($"IIRUSP created. {result.ItemCount} property unit(s) marked as Disposed.", Severity.Success);
            _form = new IirusForm();
            _form.Items.Add(new IirusItemRow());
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Create failed: {ex.Message}", Severity.Error); }
        finally { _busy = false; }
    }

    private void AddItem() => _form.Items.Add(new IirusItemRow());
    private void RemoveItem(int idx) { if (_form.Items.Count > 1) _form.Items.RemoveAt(idx); }

    private sealed class IirusForm
    {
        public string ReportNo { get; set; } = string.Empty;
        public DateTime? DateNullable { get; set; } = DateTime.Today;
        public DisposalMethod DisposalMethod { get; set; } = DisposalMethod.Destruction;
        public string? FundCluster { get; set; }
        public EmployeeReferenceDto? InspectedBy { get; set; }
        public EmployeeReferenceDto? ApprovedBy { get; set; }
        public string? Remarks { get; set; }
        public List<IirusItemRow> Items { get; set; } = [];
    }

    private sealed class IirusItemRow
    {
        public SemiExpendablePropertySummaryDto? SelectedProperty { get; set; }
        public string? ConditionRemarks { get; set; }
    }
}
