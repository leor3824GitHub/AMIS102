@page "/masterdata/suppliers"
@using FSH.Framework.Blazor.UI.Components.Cards
@using FSH.Playground.Blazor.ApiClient
@using FSH.Playground.Blazor.Services
@inherits ComponentBase
@inject ISnackbar Snackbar
@inject MasterDataService MasterDataService
@inject ILookupClient LookupClient
@inject IOrganizationProfileClient OrgProfileClient

<FshPageHeader Title="Suppliers" Description="Manage supplier information">
    <ActionContent>
        <MudStack Row="true" Spacing="2" Style="width: 100%; max-width: 400px;">
            <MudTextField @bind-Value="_searchKeyword" Label="Search" Placeholder="Search suppliers..."
                          DebounceInterval="300" OnDebounceIntervalElapsed="@(async () => await SearchSuppliers())"
                          Variant="Variant.Outlined" Size="Size.Small" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SearchSuppliers">
                Search
            </MudButton>
        </MudStack>
    </ActionContent>
</FshPageHeader>

<div class="mt-4">
    <MudGrid Spacing="2">
        <!-- Create/Edit Form -->
        <MudItem xs="12" md="4">
            <MudCard Class="fsh-card">
                <MudCardContent>
                    <MudText Typo="Typo.h6" Class="mb-3">@(EditingSupplier != null ? "Edit Supplier" : "Add Supplier")</MudText>
                    <MudStack Spacing="3">
                        <MudTextField @bind-Value="_form.Code" Label="Supplier Code" Placeholder="Unique code" Required="true" />
                        <MudTextField @bind-Value="_form.Name" Label="Supplier Name" Placeholder="Company name" Required="true" />
                        <MudTextField @bind-Value="_form.TinNo" Label="TIN No." Placeholder="Tax identification number" />
                        <MudSelect @bind-Value="_form.BusinessTaxType" Label="Business Tax Type" Required="true">
                            <MudSelectItem Value='@("VAT")'>VAT</MudSelectItem>
                            <MudSelectItem Value='@("NON-VAT")'>NON-VAT</MudSelectItem>
                        </MudSelect>
                        <MudTextField @bind-Value="_form.Description" Label="Description" Placeholder="Supplier description" Lines="2" />
                        <MudTextField @bind-Value="_form.ContactPerson" Label="Contact Person" Placeholder="Name of contact" />
                        <MudTextField @bind-Value="_form.Email" Label="Email" Placeholder="contact@example.com" />
                        <MudTextField @bind-Value="_form.Phone" Label="Phone" Placeholder="+1234567890" />
                        <MudTextField @bind-Value="_form.Address" Label="Address" Placeholder="Street address" Lines="2" />
                        <MudTextField @bind-Value="_form.OfficeCode" Label="Owner Office Code"
                                      Placeholder="e.g. 100, NDO (leave blank for shared)" MaxLength="8"
                                      Disabled="@(EditingSupplier != null)"
                                      HelperText="@(EditingSupplier != null ? "Cannot be changed after creation" : string.Empty)" />
                        <MudCheckBox @bind-Value="_form.IsActive" Label="Active" T="bool" />

                        <MudStack Row="true" Spacing="2" Class="mt-4">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                       OnClick="SaveSupplier" Disabled="_isLoading">
                                @(EditingSupplier != null ? "Update" : "Create")
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true"
                                       OnClick="ResetForm">
                                Clear
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Suppliers List -->
        <MudItem xs="12" md="8">
            <MudCard Class="fsh-card">
                <MudCardContent>
                    <MudStack Row="true" Spacing="1" Class="mb-3" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6" Class="flex-grow-1">Suppliers List</MudText>
                        <MasterDataStatusFilterChips Value="_statusFilter" ValueChanged="OnStatusFilterChanged" />
                    </MudStack>

                    @if (_suppliers.Any())
                    {
                        <MudSimpleTable Dense="true" Hover="true" Striped="true">
                            <thead>
                                <tr>
                                    <th style="cursor:pointer" @onclick='() => SetSort("Code")'>Code @SortIcon("Code")</th>
                                    <th style="cursor:pointer" @onclick='() => SetSort("Name")'>Name @SortIcon("Name")</th>
                                    <th>TIN No.</th>
                                    <th>Tax Type</th>
                                    <th>Contact</th>
                                    <th>Email</th>
                                    <th>Phone</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var supplier in _suppliers.Skip((_pageIndex - 1) * PageSize).Take(PageSize))
                                {
                                    <tr>
                                        <td>@supplier.Code</td>
                                        <td>@supplier.Name</td>
                                        <td>@(supplier.TinNo ?? "-")</td>
                                        <td>@supplier.BusinessTaxType</td>
                                        <td>@(supplier.ContactPerson ?? "-")</td>
                                        <td>@(supplier.Email ?? "-")</td>
                                        <td>@(supplier.Phone ?? "-")</td>
                                        <td><MudChip T="string" Size="Size.Small" Color="@(supplier.IsActive ? Color.Success : Color.Error)">@(supplier.IsActive ? "Active" : "Inactive")</MudChip></td>
                                        <td>
                                            @if (IsOwnedByMe(supplier.OfficeCode))
                                            {
                                                <MudStack Row="true" Spacing="1">
                                                    <MudTooltip Text="Edit supplier">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                                       Color="Color.Primary" OnClick="@(() => EditSupplier(supplier))" />
                                                    </MudTooltip>
                                                    <MudTooltip Text="Delete supplier">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                       Color="Color.Error" OnClick="@(() => DeleteSupplier(supplier.Id))" />
                                                    </MudTooltip>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudTooltip Text="@(string.IsNullOrWhiteSpace(supplier.OfficeCode) ? "Shared record — read only" : "Owned by another office — read only")">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Default" Disabled="true" />
                                                </MudTooltip>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                        @if (_suppliers.Count > PageSize)
                        {
                            <MudPagination Class="mt-2" Count="@((int)Math.Ceiling(_suppliers.Count / (double)PageSize))"
                                           @bind-Selected="_pageIndex" Color="Color.Primary" ShowFirstButton="true" ShowLastButton="true" />
                        }
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info">No suppliers yet. Add one to get started.</MudAlert>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</div>

@code {
    private SupplierForm _form = new();
    private SupplierDto? EditingSupplier;
    private List<SupplierDto> _suppliers = new();
    private List<SupplierDto> _allSuppliers = new();
    private bool _initialized = false;
    private bool _isLoading = false;
    private string _searchKeyword = string.Empty;
    private string _statusFilter = "All";
    private string _officeCodeFilter = string.Empty;
    private string _sortField = "Name";
    private bool _sortAscending = true;
    private string? _myOfficeCode;
    private int _pageIndex = 1;
    private const int PageSize = 10;

    public class SupplierForm
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? TinNo { get; set; }
        public string BusinessTaxType { get; set; } = "NON-VAT";
        public string? Description { get; set; }
        public string? ContactPerson { get; set; }
        public string? Email { get; set; }
        public string? Phone { get; set; }
        public string? Address { get; set; }
        public bool IsActive { get; set; } = true;
        public string? OfficeCode { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        if (_initialized) return;
        _initialized = true;
        var profile = await OrgProfileClient.GetAsync();
        _myOfficeCode = profile?.AnnexECode;
        await LoadSuppliers();
    }

    private async Task LoadSuppliers()
    {
        try
        {
            _isLoading = true;
            var response = await MasterDataService.GetSuppliersAsync(pageSize: 100);
            _allSuppliers = response?.Items?.ToList() ?? new();
            ApplyLocalFilters();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load suppliers: {ex.Message}", Severity.Error);
            _suppliers = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SearchSuppliers()
    {
        try
        {
            _isLoading = true;
            var response = await MasterDataService.GetSuppliersAsync(keyword: _searchKeyword, pageSize: 100);
            _allSuppliers = response?.Items?.ToList() ?? new();
            ApplyLocalFilters();

            if (_suppliers.Count == 0 && !string.IsNullOrWhiteSpace(_searchKeyword))
            {
                Snackbar.Add("No suppliers found matching your search", Severity.Info);
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Search failed: {ex.Message}", Severity.Error);
            _suppliers = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SaveSupplier()
    {
        if (string.IsNullOrWhiteSpace(_form.Code) || string.IsNullOrWhiteSpace(_form.Name))
        {
            Snackbar.Add("Code and Name are required", Severity.Warning);
            return;
        }

        try
        {
            if (EditingSupplier != null)
            {
                var updateCmd = new UpdateSupplierCommand
                {
                    Id = EditingSupplier.Id,
                    Code = _form.Code,
                    Name = _form.Name,
                    TinNo = _form.TinNo,
                    BusinessTaxType = _form.BusinessTaxType,
                    Description = _form.Description,
                    ContactPerson = _form.ContactPerson,
                    Email = _form.Email,
                    Phone = _form.Phone,
                    Address = _form.Address,
                    IsActive = _form.IsActive
                };

                await MasterDataService.UpdateSupplierAsync(EditingSupplier.Id, updateCmd);
                Snackbar.Add("Supplier updated successfully", Severity.Success);
            }
            else
            {
                var createCmd = new CreateSupplierCommand
                {
                    Code = _form.Code,
                    Name = _form.Name,
                    TinNo = _form.TinNo,
                    BusinessTaxType = _form.BusinessTaxType,
                    Description = _form.Description,
                    ContactPerson = _form.ContactPerson,
                    Email = _form.Email,
                    Phone = _form.Phone,
                    Address = _form.Address,
                    OfficeCode = string.IsNullOrWhiteSpace(_form.OfficeCode) ? null : _form.OfficeCode.Trim()
                };

                await MasterDataService.CreateSupplierAsync(createCmd);
                Snackbar.Add("Supplier created successfully", Severity.Success);
            }

            await LoadSuppliers();
            ResetForm();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save supplier: {ex.Message}", Severity.Error);
        }
    }

    private void EditSupplier(SupplierDto supplier)
    {
        EditingSupplier = supplier;
        _form = new SupplierForm
        {
            Code = supplier.Code,
            Name = supplier.Name,
            TinNo = supplier.TinNo,
            BusinessTaxType = supplier.BusinessTaxType,
            Description = supplier.Description,
            ContactPerson = supplier.ContactPerson,
            Email = supplier.Email,
            Phone = supplier.Phone,
            Address = supplier.Address,
            IsActive = supplier.IsActive,
            OfficeCode = supplier.OfficeCode
        };
    }

    private void ResetForm()
    {
        _form = new();
        EditingSupplier = null;
    }

    private async Task DeleteSupplier(Guid id)
    {
        try
        {
            await MasterDataService.DeleteSupplierAsync(id);
            await LoadSuppliers();
            Snackbar.Add("Supplier deleted", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to delete supplier: {ex.Message}", Severity.Error);
        }
    }

    private void OnOfficeCodeFilterChanged(string value)
    {
        _officeCodeFilter = value ?? string.Empty;
        ApplyLocalFilters();
        StateHasChanged();
    }

    private Task OnStatusFilterChanged(string status)
    {
        _statusFilter = string.IsNullOrWhiteSpace(status) ? "All" : status;
        ApplyLocalFilters();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private bool IsOwnedByMe(string? officeCode) =>
        !string.IsNullOrWhiteSpace(_myOfficeCode) &&
        string.Equals(officeCode, _myOfficeCode, StringComparison.OrdinalIgnoreCase);

    private void ApplyLocalFilters()
    {
        var filtered = _statusFilter switch
        {
            "Active" => _allSuppliers.Where(x => x.IsActive),
            "Inactive" => _allSuppliers.Where(x => !x.IsActive),
            "Own" => _allSuppliers.Where(x => IsOwnedByMe(x.OfficeCode)),
            _ => _allSuppliers.AsEnumerable()
        };

        if (!string.IsNullOrWhiteSpace(_officeCodeFilter))
            filtered = filtered.Where(x => x.OfficeCode != null &&
                x.OfficeCode.Contains(_officeCodeFilter, StringComparison.OrdinalIgnoreCase));

        _pageIndex = 1;
        _suppliers = (_sortField, _sortAscending) switch
        {
            ("Code", true)  => filtered.OrderBy(x => x.Code).ToList(),
            ("Code", false) => filtered.OrderByDescending(x => x.Code).ToList(),
            ("Name", false) => filtered.OrderByDescending(x => x.Name).ThenBy(x => x.Code).ToList(),
            _               => filtered.OrderBy(x => x.Name).ThenBy(x => x.Code).ToList()
        };
    }

    private void SetSort(string field)
    {
        if (_sortField == field) _sortAscending = !_sortAscending;
        else { _sortField = field; _sortAscending = true; }
        ApplyLocalFilters();
    }

    private string SortIcon(string field)
    {
        if (_sortField != field) return string.Empty;
        return _sortAscending ? "▲" : "▼";
    }
}
