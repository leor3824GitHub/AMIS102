@page "/master-data/departments"
@using FSH.Framework.Blazor.UI.Components.Cards
@using FSH.Playground.Blazor.ApiClient
@inherits ComponentBase
@inject ISnackbar Snackbar
@inject IMaster_dataClient MasterDataClient
@inject ILookupClient LookupClient
@inject IOrganizationProfileClient OrgProfileClient

<FshPageHeader Title="Departments" Description="Manage departments">
    <ActionContent>
        <MudStack Row="true" Spacing="2" Style="width: 100%; max-width: 400px;">
            <MudTextField @bind-Value="_searchKeyword" Label="Search" Placeholder="Search departments..."
                          DebounceInterval="300" OnDebounceIntervalElapsed="@(async () => await SearchDepartments())"
                          Variant="Variant.Outlined" Size="Size.Small" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SearchDepartments">
                Search
            </MudButton>
        </MudStack>
    </ActionContent>
</FshPageHeader>

<div class="mt-4">
    <MudGrid Spacing="2">
        <!-- Create/Edit Form -->
        <MudItem xs="12" sm="6" md="4" Style="min-height: 100%;">
            <MudCard Class="fsh-card">
                <MudCardContent>
                    <MudText Typo="Typo.h6" Class="mb-3">@(EditingDepartment != null ? "Edit Department" : "Create Department")</MudText>
                    <MudStack Spacing="3">
                        <MudTextField @bind-Value="_form.Code" Label="Code" Placeholder="Department code"
                                      Required="true" />
                        <MudTextField @bind-Value="_form.Name" Label="Name" Placeholder="Department name"
                                      Required="true" />
                        <MudTextField @bind-Value="_form.Description" Label="Description"
                                      Placeholder="Department description" Lines="2" />
                        <MudTextField @bind-Value="_form.FundCluster" Label="Fund Cluster"
                                      Placeholder="e.g. GENERAL OPERATING FUND" MaxLength="100" />
                        <MudTextField @bind-Value="_form.OfficeCode" Label="Owner Office Code"
                                      Placeholder="e.g. 100, NDO (leave blank for shared)" MaxLength="8"
                                      Disabled="@(EditingDepartment != null)"
                                      HelperText="@(EditingDepartment != null ? "Cannot be changed after creation" : string.Empty)" />
                        <MudCheckBox @bind-Value="_form.IsActive"
                                     Label="Active" />

                        <MudStack Row="true" Spacing="2" Class="mt-4">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                       OnClick="SaveDepartment" Disabled="_isLoading">
                                @(EditingDepartment != null ? "Update" : "Create")
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true"
                                       OnClick="ResetForm">
                                Clear
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Departments List -->
        <MudItem xs="12" sm="6" md="8">
            <MudCard Class="fsh-card">
                <MudCardContent>
                    <MudStack Row="true" Spacing="1" Class="mb-3" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6" Class="flex-grow-1">Departments List</MudText>
                        <MasterDataStatusFilterChips Value="_statusFilter" ValueChanged="OnStatusFilterChanged" />
                    </MudStack>

                    @if (_departments.Any())
                    {
                        <MudSimpleTable Dense="true" Hover="true" Striped="true">
                            <thead>
                                <tr>
                                    <th style="cursor:pointer" @onclick='() => SetSort("Code")'>Code @SortIcon("Code")</th>
                                    <th style="cursor:pointer" @onclick='() => SetSort("Name")'>Name @SortIcon("Name")</th>
                                    <th>Owner</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var department in _departments.Skip((_pageIndex - 1) * PageSize).Take(PageSize))
                                {
                                    <tr>
                                        <td>@department.Code</td>
                                        <td>@department.Name</td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(department.OfficeCode))
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Label="true"
                                                         Style="font-family:monospace">@department.OfficeCode</MudChip>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Default">—</MudText>
                                            }
                                        </td>
                                        <td><MudChip T="string" Size="Size.Small" Color="@(department.IsActive ? Color.Success : Color.Default)">@(department.IsActive ? "Active" : "Inactive")</MudChip></td>
                                        <td>
                                            @if (IsOwnedByMe(department.OfficeCode))
                                            {
                                                <MudStack Row="true" Spacing="1">
                                                    <MudTooltip Text="Edit department">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                                       Color="Color.Primary" OnClick="@(() => EditDepartment(department))" />
                                                    </MudTooltip>
                                                    <MudTooltip Text="Delete department">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                       Color="Color.Error" OnClick="@(() => DeleteDepartment(department.Id))" />
                                                    </MudTooltip>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudTooltip Text="@(string.IsNullOrWhiteSpace(department.OfficeCode) ? "Shared record — read only" : "Owned by another office — read only")">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Default" Disabled="true" />
                                                </MudTooltip>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                        @if (_departments.Count > PageSize)
                        {
                            <MudPagination Class="mt-2" Count="@((int)Math.Ceiling(_departments.Count / (double)PageSize))"
                                           @bind-Selected="_pageIndex" Color="Color.Primary" ShowFirstButton="true" ShowLastButton="true" />
                        }
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info">No departments yet. Create one to get started.</MudAlert>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</div>

@code {
    private DepartmentForm _form = new();
    private FSH.Playground.Blazor.ApiClient.DepartmentReferenceDto? EditingDepartment { get; set; }
    private List<FSH.Playground.Blazor.ApiClient.DepartmentReferenceDto> _departments = new();
    private List<FSH.Playground.Blazor.ApiClient.DepartmentReferenceDto> _allDepartments = new();
    private bool _initialized = false;
    private bool _isLoading = false;
    private string _searchKeyword = string.Empty;
    private string _statusFilter = "All";
    private string _officeCodeFilter = string.Empty;
    private string _sortField = "Name";
    private bool _sortAscending = true;
    private string? _myOfficeCode;
    private int _pageIndex = 1;
    private const int PageSize = 10;

    public class DepartmentForm
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string? FundCluster { get; set; }
        public bool IsActive { get; set; } = true;
        public string? OfficeCode { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        if (_initialized) return;
        _initialized = true;
        var profile = await OrgProfileClient.GetAsync();
        _myOfficeCode = profile?.AnnexECode;
        await LoadDepartments();
    }

    private async Task LoadDepartments()
    {
        try
        {
            _isLoading = true;
            var response = await LookupClient.DepartmentsAsync(pageSize: 100);
            _allDepartments = response?.Items?.ToList() ?? new();
            ApplyLocalFilters();
            StateHasChanged();
        }
        catch (HttpRequestException ex) when (
            ex.Message.Contains("StatusCode=401", StringComparison.OrdinalIgnoreCase) ||
            ex.Message.Contains("401 (Unauthorized)", StringComparison.OrdinalIgnoreCase) ||
            (ex.InnerException?.Message?.Contains("401", StringComparison.OrdinalIgnoreCase) ?? false))
        {
            Snackbar.Add("Authenticating...", Severity.Info);
            await Task.Delay(500);
            await LoadDepartmentsInternal(retryCount: 1);
            return;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load departments: {ex.Message}", Severity.Error);
            _departments = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadDepartmentsInternal(int retryCount = 0, int maxRetries = 3)
    {
        try
        {
            var response = await LookupClient.DepartmentsAsync(pageSize: 100);
            _allDepartments = response?.Items?.ToList() ?? new();
            ApplyLocalFilters();
            StateHasChanged();
        }
        catch (HttpRequestException ex) when (
            (ex.Message.Contains("StatusCode=401", StringComparison.OrdinalIgnoreCase) ||
             ex.Message.Contains("401 (Unauthorized)", StringComparison.OrdinalIgnoreCase) ||
             (ex.InnerException?.Message?.Contains("401", StringComparison.OrdinalIgnoreCase) ?? false)) &&
            retryCount < maxRetries)
        {
            await Task.Delay(300 * (retryCount + 1));
            await LoadDepartmentsInternal(retryCount + 1, maxRetries);
        }
        catch (Exception ex)
        {
            if (retryCount == 0)
            {
                Snackbar.Add($"Failed to load departments: {ex.Message}", Severity.Error);
            }
            _departments = new();
            StateHasChanged();
        }
    }

    private async Task SearchDepartments()
    {
        try
        {
            _isLoading = true;
            var response = await LookupClient.DepartmentsAsync(keyword: _searchKeyword, pageSize: 100);
            _allDepartments = response?.Items?.ToList() ?? new();
            ApplyLocalFilters();
            
            if (_departments.Count == 0 && !string.IsNullOrWhiteSpace(_searchKeyword))
            {
                Snackbar.Add("No departments found matching your search", Severity.Info);
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Search failed: {ex.Message}", Severity.Error);
            _departments = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SaveDepartment()
    {
        if (string.IsNullOrWhiteSpace(_form.Code) || string.IsNullOrWhiteSpace(_form.Name))
        {
            Snackbar.Add("Code and Name are required", Severity.Warning);
            return;
        }

        try
        {
            if (EditingDepartment != null)
            {
                var updateCmd = new UpdateDepartmentCommand
                {
                    Id = EditingDepartment.Id,
                    Code = _form.Code,
                    Name = _form.Name,
                    Description = _form.Description,
                    FundCluster = _form.FundCluster,
                    IsActive = _form.IsActive
                };

                var updatedDepartment = await MasterDataClient.DepartmentsPutAsync(EditingDepartment.Id, updateCmd);
                
                // Update the local department with new values
                if (updatedDepartment != null)
                {
                    EditingDepartment = updatedDepartment;
                    var departmentIndex = _departments.FindIndex(d => d.Id == updatedDepartment.Id);
                    if (departmentIndex >= 0)
                    {
                        _departments[departmentIndex] = updatedDepartment;
                    }
                    StateHasChanged();
                }
                
                Snackbar.Add("Department updated successfully", Severity.Success);
            }
            else
            {
                var createCmd = new CreateDepartmentCommand
                {
                    Code = _form.Code,
                    Name = _form.Name,
                    Description = _form.Description,
                    FundCluster = _form.FundCluster,
                    IsActive = _form.IsActive,
                    OfficeCode = string.IsNullOrWhiteSpace(_form.OfficeCode) ? null : _form.OfficeCode.Trim()
                };
                await MasterDataClient.DepartmentsPostAsync(createCmd);
                Snackbar.Add("Department created successfully", Severity.Success);
            }

            await LoadDepartments();
            ResetForm();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save department: {ex.Message}", Severity.Error);
        }
    }

    private async Task EditDepartment(FSH.Playground.Blazor.ApiClient.DepartmentReferenceDto department)
    {
        EditingDepartment = department;
        _form = new DepartmentForm
        {
            Code = department.Code,
            Name = department.Name,
            Description = department.Description,
            FundCluster = department.FundCluster ?? string.Empty,
            IsActive = department.IsActive,
            OfficeCode = department.OfficeCode
        };
        await InvokeAsync(StateHasChanged);
    }

    private void ResetForm()
    {
        _form = new();
        EditingDepartment = null;
    }

    private async Task DeleteDepartment(Guid id)
    {
        try
        {
            await MasterDataClient.DepartmentsDeleteAsync(id);
            await LoadDepartments();
            Snackbar.Add("Department deleted", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to delete department: {ex.Message}", Severity.Error);
        }
    }

    private void OnOfficeCodeFilterChanged(string value)
    {
        _officeCodeFilter = value ?? string.Empty;
        ApplyLocalFilters();
        StateHasChanged();
    }

    private Task OnStatusFilterChanged(string status)
    {
        _statusFilter = string.IsNullOrWhiteSpace(status) ? "All" : status;
        ApplyLocalFilters();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private bool IsOwnedByMe(string? officeCode) =>
        !string.IsNullOrWhiteSpace(_myOfficeCode) &&
        string.Equals(officeCode, _myOfficeCode, StringComparison.OrdinalIgnoreCase);

    private void ApplyLocalFilters()
    {
        var filtered = _statusFilter switch
        {
            "Active" => _allDepartments.Where(x => x.IsActive),
            "Inactive" => _allDepartments.Where(x => !x.IsActive),
            "Own" => _allDepartments.Where(x => IsOwnedByMe(x.OfficeCode)),
            _ => _allDepartments.AsEnumerable()
        };

        if (!string.IsNullOrWhiteSpace(_officeCodeFilter))
            filtered = filtered.Where(x => x.OfficeCode != null &&
                x.OfficeCode.Contains(_officeCodeFilter, StringComparison.OrdinalIgnoreCase));

        _pageIndex = 1;
        _departments = (_sortField, _sortAscending) switch
        {
            ("Code", true)  => filtered.OrderBy(x => x.Code).ToList(),
            ("Code", false) => filtered.OrderByDescending(x => x.Code).ToList(),
            ("Name", false) => filtered.OrderByDescending(x => x.Name).ThenBy(x => x.Code).ToList(),
            _               => filtered.OrderBy(x => x.Name).ThenBy(x => x.Code).ToList()
        };
    }

    private void SetSort(string field)
    {
        if (_sortField == field) _sortAscending = !_sortAscending;
        else { _sortField = field; _sortAscending = true; }
        ApplyLocalFilters();
    }

    private string SortIcon(string field)
    {
        if (_sortField != field) return string.Empty;
        return _sortAscending ? "▲" : "▼";
    }
}
