@page "/master-data/offices"
@using FSH.Framework.Blazor.UI.Components.Cards
@using FSH.Playground.Blazor.ApiClient
@inherits ComponentBase
@inject ISnackbar Snackbar
@inject IMaster_dataClient MasterDataClient
@inject ILookupClient LookupClient
@inject IOrganizationProfileClient OrgProfileClient

<FshPageHeader Title="Offices" Description="Manage offices">
    <ActionContent>
        <MudStack Row="true" Spacing="2" Style="width: 100%; max-width: 400px;">
            <MudTextField @bind-Value="_searchKeyword" Label="Search" Placeholder="Search offices..."
                          DebounceInterval="300" OnDebounceIntervalElapsed="@(async () => await SearchOffices())"
                          Variant="Variant.Outlined" Size="Size.Small" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SearchOffices">
                Search
            </MudButton>
        </MudStack>
    </ActionContent>
</FshPageHeader>

<div class="mt-4">
    <MudGrid Spacing="2">
        <!-- Create/Edit Form -->
        <MudItem xs="12" sm="6" md="4" Style="min-height: 100%;">
            <MudCard Class="fsh-card">
                <MudCardContent>
                    <MudText Typo="Typo.h6" Class="mb-3">@(EditingOffice != null ? "Edit Office" : "Create Office")</MudText>
                    <MudStack Spacing="3">
                        <MudTextField @bind-Value="_form.Code" Label="Code" Placeholder="e.g. GSD, 100, NDO"
                                      Required="true" />
                        <MudTextField @bind-Value="_form.Name" Label="Name" Placeholder="Office name"
                                      Required="true" />
                        <MudTextField @bind-Value="_form.Address" Label="Address"
                                      Placeholder="Office address" Lines="2" />
                        <MudTextField @bind-Value="_form.LocationCode" Label="Location Code"
                                      Placeholder="e.g. 8600, 0100, 1301" />
                        <MudTextField @bind-Value="_form.RegProvCode" Label="Reg./Prov. Code"
                                      Placeholder="e.g. 100, NDO, 00B (leave blank for Central Office)" />
                        <MudTextField @bind-Value="_form.Description" Label="Description"
                                      Placeholder="Office description" Lines="2" />
                        <MudTextField @bind-Value="_form.OfficeCode" Label="Owner Office Code"
                                      Placeholder="e.g. 100, NDO (leave blank for shared)" MaxLength="8"
                                      Disabled="@(EditingOffice != null)"
                                      HelperText="@(EditingOffice != null ? "Cannot be changed after creation" : string.Empty)" />
                        <MudCheckBox @bind-Value="_form.IsActive"
                                     Label="Active" />

                        <MudStack Row="true" Spacing="2" Class="mt-4">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                       OnClick="SaveOffice" Disabled="_isLoading">
                                @(EditingOffice != null ? "Update" : "Create")
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true"
                                       OnClick="ResetForm">
                                Clear
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Offices List -->
        <MudItem xs="12" sm="6" md="8">
            <MudCard Class="fsh-card">
                <MudCardContent>
                    <MudStack Row="true" Spacing="1" Class="mb-3" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6" Class="flex-grow-1">Offices List</MudText>
                        <MasterDataStatusFilterChips Value="_statusFilter" ValueChanged="OnStatusFilterChanged" />
                    </MudStack>

                    @if (_offices.Any())
                    {
                        <MudSimpleTable Dense="true" Hover="true" Striped="true">
                            <thead>
                                <tr>
                                    <th style="cursor:pointer" @onclick='() => SetSort("LocationCode")'>
                                        Loc. Code @SortIcon("LocationCode")
                                    </th>
                                    <th style="cursor:pointer" @onclick='() => SetSort("Name")'>
                                        Name @SortIcon("Name")
                                    </th>
                                    <th style="cursor:pointer" @onclick='() => SetSort("RegProvCode")'>
                                        Reg./Prov. @SortIcon("RegProvCode")
                                    </th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var office in _offices.Skip((_pageIndex - 1) * PageSize).Take(PageSize))
                                {
                                    <tr>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(office.LocationCode))
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Label="true"
                                                         Style="font-family: monospace;">@office.LocationCode</MudChip>
                                            }
                                        </td>
                                        <td>@office.Name</td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(office.RegProvCode))
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Label="true"
                                                         Style="font-family: monospace;">@office.RegProvCode</MudChip>
                                            }
                                        </td>
                                        <td><MudChip T="string" Size="Size.Small" Color="@(office.IsActive ? Color.Success : Color.Default)">@(office.IsActive ? "Active" : "Inactive")</MudChip></td>
                                        <td>
                                            @if (IsOwnedByMe(office.OfficeCode))
                                            {
                                                <MudStack Row="true" Spacing="1">
                                                    <MudTooltip Text="Edit office">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                                       Color="Color.Primary" OnClick="@(() => EditOffice(office))" />
                                                    </MudTooltip>
                                                    <MudTooltip Text="Delete office">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                       Color="Color.Error" OnClick="@(() => DeleteOffice(office.Id))" />
                                                    </MudTooltip>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudTooltip Text="@(string.IsNullOrWhiteSpace(office.OfficeCode) ? "Shared record — read only" : "Owned by another office — read only")">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Default" Disabled="true" />
                                                </MudTooltip>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                        @if (_offices.Count > PageSize)
                        {
                            <MudPagination Class="mt-2" Count="@((int)Math.Ceiling(_offices.Count / (double)PageSize))"
                                           @bind-Selected="_pageIndex" Color="Color.Primary" ShowFirstButton="true" ShowLastButton="true" />
                        }
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info">No offices yet. Create one to get started.</MudAlert>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</div>

@code {
    private OfficeForm _form = new();
    private FSH.Playground.Blazor.ApiClient.OfficeReferenceDto? EditingOffice { get; set; }
    private List<FSH.Playground.Blazor.ApiClient.OfficeReferenceDto> _offices = new();
    private List<FSH.Playground.Blazor.ApiClient.OfficeReferenceDto> _allOffices = new();
    private bool _initialized = false;
    private bool _isLoading = false;
    private string _searchKeyword = string.Empty;
    private string _statusFilter = "All";
    private string _sortField = "Name";
    private bool _sortAscending = true;
    private string _officeCodeFilter = string.Empty;
    private string? _myOfficeCode;
    private int _pageIndex = 1;
    private const int PageSize = 10;

    public class OfficeForm
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Address { get; set; }
        public string? LocationCode { get; set; }
        public string? RegProvCode { get; set; }
        public string? Description { get; set; }
        public bool IsActive { get; set; } = true;
        public string? OfficeCode { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        if (_initialized) return;
        _initialized = true;
        var profile = await OrgProfileClient.GetAsync();
        _myOfficeCode = profile?.AnnexECode;
        await LoadOffices();
    }

    private async Task LoadOffices()
    {
        try
        {
            _isLoading = true;
            var response = await LookupClient.OfficesAsync(pageSize: 100);
            _allOffices = response?.Items?.ToList() ?? new();
            ApplyLocalFilters();
            StateHasChanged();
        }
        catch (HttpRequestException ex) when (
            ex.Message.Contains("StatusCode=401", StringComparison.OrdinalIgnoreCase) ||
            ex.Message.Contains("401 (Unauthorized)", StringComparison.OrdinalIgnoreCase) ||
            (ex.InnerException?.Message?.Contains("401", StringComparison.OrdinalIgnoreCase) ?? false))
        {
            Snackbar.Add("Authenticating...", Severity.Info);
            await Task.Delay(500);
            await LoadOfficesInternal(retryCount: 1);
            return;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load offices: {ex.Message}", Severity.Error);
            _offices = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadOfficesInternal(int retryCount = 0, int maxRetries = 3)
    {
        try
        {
            var response = await LookupClient.OfficesAsync(pageSize: 100);
            _allOffices = response?.Items?.ToList() ?? new();
            ApplyLocalFilters();
            StateHasChanged();
        }
        catch (HttpRequestException ex) when (
            (ex.Message.Contains("StatusCode=401", StringComparison.OrdinalIgnoreCase) ||
             ex.Message.Contains("401 (Unauthorized)", StringComparison.OrdinalIgnoreCase) ||
             (ex.InnerException?.Message?.Contains("401", StringComparison.OrdinalIgnoreCase) ?? false)) &&
            retryCount < maxRetries)
        {
            await Task.Delay(300 * (retryCount + 1));
            await LoadOfficesInternal(retryCount + 1, maxRetries);
        }
        catch (Exception ex)
        {
            if (retryCount == 0)
            {
                Snackbar.Add($"Failed to load offices: {ex.Message}", Severity.Error);
            }
            _offices = new();
            StateHasChanged();
        }
    }

    private async Task SearchOffices()
    {
        try
        {
            _isLoading = true;
            var response = await LookupClient.OfficesAsync(keyword: _searchKeyword, pageSize: 100);
            _allOffices = response?.Items?.ToList() ?? new();
            ApplyLocalFilters();
            
            if (_offices.Count == 0 && !string.IsNullOrWhiteSpace(_searchKeyword))
            {
                Snackbar.Add("No offices found matching your search", Severity.Info);
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Search failed: {ex.Message}", Severity.Error);
            _offices = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SaveOffice()
    {
        if (string.IsNullOrWhiteSpace(_form.Code) || string.IsNullOrWhiteSpace(_form.Name))
        {
            Snackbar.Add("Code and Name are required", Severity.Warning);
            return;
        }

        try
        {
            if (EditingOffice != null)
            {

                var updateCmd = new UpdateOfficeCommand
                {
                    Id = EditingOffice.Id,
                    Code = _form.Code,
                    Name = _form.Name,
                    Address = _form.Address,
                    LocationCode = _form.LocationCode,
                    RegProvCode = _form.RegProvCode,
                    Description = _form.Description,
                    IsActive = _form.IsActive
                };

                var updatedOffice = await MasterDataClient.OfficesPutAsync(EditingOffice.Id, updateCmd);
                
                // Update the local office with new values
                if (updatedOffice != null)
                {
                    EditingOffice = updatedOffice;
                    var officeIndex = _offices.FindIndex(o => o.Id == updatedOffice.Id);
                    if (officeIndex >= 0)
                    {
                        _offices[officeIndex] = updatedOffice;
                    }
                    StateHasChanged();
                }
                
                Snackbar.Add("Office updated successfully", Severity.Success);
            }
            else
            {
                var createCmd = new CreateOfficeCommand
                {
                    Code = _form.Code,
                    Name = _form.Name,
                    Address = _form.Address,
                    LocationCode = _form.LocationCode,
                    RegProvCode = _form.RegProvCode,
                    Description = _form.Description,
                    IsActive = _form.IsActive,
                    OfficeCode = string.IsNullOrWhiteSpace(_form.OfficeCode) ? null : _form.OfficeCode.Trim()
                };
                await MasterDataClient.OfficesPostAsync(createCmd);
                Snackbar.Add("Office created successfully", Severity.Success);
            }

            await LoadOffices();
            ResetForm();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save office: {ex.Message}", Severity.Error);
        }
    }

    private async Task EditOffice(FSH.Playground.Blazor.ApiClient.OfficeReferenceDto office)
    {
        EditingOffice = office;
        _form = new OfficeForm
        {
            Code = office.Code,
            Name = office.Name,
            Address = office.Address,
            LocationCode = office.LocationCode,
            RegProvCode = office.RegProvCode,
            Description = office.Description,
            IsActive = office.IsActive,
            OfficeCode = office.OfficeCode
        };
        await InvokeAsync(StateHasChanged);
    }

    private void ResetForm()
    {
        _form = new();
        EditingOffice = null;
    }

    private async Task DeleteOffice(Guid id)
    {
        try
        {
            await MasterDataClient.OfficesDeleteAsync(id);
            await LoadOffices();
            Snackbar.Add("Office deleted", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to delete office: {ex.Message}", Severity.Error);
        }
    }

    private void OnOfficeCodeFilterChanged(string value)
    {
        _officeCodeFilter = value ?? string.Empty;
        ApplyLocalFilters();
        StateHasChanged();
    }

    private Task OnStatusFilterChanged(string status)
    {
        _statusFilter = string.IsNullOrWhiteSpace(status) ? "All" : status;
        ApplyLocalFilters();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private bool IsOwnedByMe(string? officeCode) =>
        !string.IsNullOrWhiteSpace(_myOfficeCode) &&
        string.Equals(officeCode, _myOfficeCode, StringComparison.OrdinalIgnoreCase);

    private void ApplyLocalFilters()
    {
        var filtered = _statusFilter switch
        {
            "Active" => _allOffices.Where(x => x.IsActive),
            "Inactive" => _allOffices.Where(x => !x.IsActive),
            "Own" => _allOffices.Where(x => IsOwnedByMe(x.OfficeCode)),
            _ => _allOffices.AsEnumerable()
        };

        if (!string.IsNullOrWhiteSpace(_officeCodeFilter))
            filtered = filtered.Where(x => x.OfficeCode != null &&
                x.OfficeCode.Contains(_officeCodeFilter, StringComparison.OrdinalIgnoreCase));

        _pageIndex = 1;
        _offices = (_sortField, _sortAscending) switch
        {
            ("Name", true)         => filtered.OrderBy(x => x.Name).ThenBy(x => x.Code).ToList(),
            ("Name", false)        => filtered.OrderByDescending(x => x.Name).ThenBy(x => x.Code).ToList(),
            ("LocationCode", true) => filtered.OrderBy(x => x.LocationCode).ThenBy(x => x.Name).ToList(),
            ("LocationCode", false)=> filtered.OrderByDescending(x => x.LocationCode).ThenBy(x => x.Name).ToList(),
            ("RegProvCode", true)  => filtered.OrderBy(x => x.RegProvCode).ThenBy(x => x.Name).ToList(),
            ("RegProvCode", false) => filtered.OrderByDescending(x => x.RegProvCode).ThenBy(x => x.Name).ToList(),
            _                     => filtered.OrderBy(x => x.Name).ToList()
        };
    }

    private void SetSort(string field)
    {
        if (_sortField == field)
            _sortAscending = !_sortAscending;
        else
        {
            _sortField = field;
            _sortAscending = true;
        }
        ApplyLocalFilters();
    }

    private string SortIcon(string field)
    {
        if (_sortField != field) return string.Empty;
        return _sortAscending ? "▲" : "▼";
    }
}
