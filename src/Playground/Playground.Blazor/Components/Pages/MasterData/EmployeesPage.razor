@page "/master-data/employees"
@using FSH.Framework.Blazor.UI.Components.Cards
@using FSH.Playground.Blazor.ApiClient
@inherits ComponentBase
@inject ISnackbar Snackbar
@inject IMaster_dataClient MasterDataClient
@inject ILookupClient LookupClient
@inject IIdentityClient IdentityClient
@inject IUsersClient UsersClient
@inject IOrganizationProfileClient OrgProfileClient

<FshPageHeader Title="Employees" Description="Manage employee profiles">
    <ActionContent>
        <MudStack Row="true" Spacing="2" Style="width: 100%; max-width: 400px;">
            <MudTextField @bind-Value="_searchKeyword" Label="Search" Placeholder="Search employees..."
                          DebounceInterval="300" OnDebounceIntervalElapsed="@(async () => await SearchEmployees())"
                          Variant="Variant.Outlined" Size="Size.Small" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SearchEmployees">
                Search
            </MudButton>
        </MudStack>
    </ActionContent>
</FshPageHeader>

<div class="mt-4">
    <MudGrid Spacing="2">
        <!-- Create/Edit Form -->
        <MudItem xs="12" sm="6" md="4" Style="min-height: 100%;">
            <MudCard Class="fsh-card">
                <MudCardContent>
                    <MudText Typo="Typo.h6" Class="mb-3">@(EditingEmployee != null ? "Edit Employee" : "Create Employee")</MudText>
                    <MudStack Spacing="3">
                        <MudTextField @bind-Value="_form.EmployeeNumber" Label="Employee Number"
                                      Placeholder="Employee ID" Required="true" />
                        <MudTextField @bind-Value="_form.FirstName" Label="First Name" Placeholder="First name"
                                      Required="true" />
                        <MudTextField @bind-Value="_form.LastName" Label="Last Name" Placeholder="Last name"
                                      Required="true" />
                        <MudTextField @bind-Value="_form.WorkEmail" Label="Work Email" InputType="InputType.Email"
                                      Placeholder="work@example.com" />
                        
                        <!-- Office Autocomplete -->
                        <MudAutocomplete T="OfficeReferenceDto" Label="Office" @bind-Value="_form.Office"
                                         SearchFunc="@SearchOffices" ToStringFunc="@(o => o?.Name)" ResetValueOnEmptyText="true"
                                         CoerceText="true" CoerceValue="true" Required="true" Placeholder="Search office..."
                                         Clearable="true" />

                        <!-- Department Autocomplete -->
                        <MudAutocomplete T="DepartmentReferenceDto" Label="Department" @bind-Value="_form.Department"
                                         SearchFunc="@SearchDepartments" ToStringFunc="@(d => d?.Name)" ResetValueOnEmptyText="true"
                                         CoerceText="true" CoerceValue="true" Required="true" Placeholder="Search department..."
                                         Clearable="true" />

                        <!-- Position Autocomplete -->
                        <MudAutocomplete T="PositionReferenceDto" Label="Position" @bind-Value="_form.Position"
                                         SearchFunc="@SearchPositions" ToStringFunc="@(p => p?.Name)" ResetValueOnEmptyText="true"
                                         CoerceText="true" CoerceValue="true" Required="true" Placeholder="Search position..."
                                         Clearable="true" />

                        <MudAutocomplete T="UserDto" Label="Linked Login Account" @bind-Value="_form.IdentityUser"
                                         SearchFunc="@SearchIdentityUsers"
                                         ToStringFunc="@(u => u == null ? string.Empty : $"{u.FirstName} {u.LastName} ({u.Email})")"
                                         CoerceValue="true" Clearable="true" Placeholder="Search by name or email..."
                                         HelperText="@(_form.IdentityUser != null ? $"Linked: {_form.IdentityUser.FirstName} {_form.IdentityUser.LastName}" : "No account linked")" />
                        
                        <MudCheckBox @bind-Value="_form.IsActive" Label="Active" />

                        <MudStack Row="true" Spacing="2" Class="mt-4">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                       OnClick="SaveEmployee" Disabled="_isLoading">
                                @(EditingEmployee != null ? "Update" : "Create")
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true"
                                       OnClick="ResetForm">
                                Clear
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Employees List -->
        <MudItem xs="12" sm="6" md="8">
            <MudCard Class="fsh-card">
                <MudCardContent>
                    <MudStack Row="true" Spacing="1" Class="mb-3" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6" Class="flex-grow-1">Employees List</MudText>
                        <MasterDataStatusFilterChips Value="_statusFilter" ValueChanged="OnStatusFilterChanged" />
                    </MudStack>

                    @if (_employees.Any())
                    {
                        <MudSimpleTable Dense="true" Hover="true" Striped="true">
                            <thead>
                                <tr>
                                    <th style="cursor:pointer" @onclick='() => SetSort("EmployeeNumber")'>Employee # @SortIcon("EmployeeNumber")</th>
                                    <th style="cursor:pointer" @onclick='() => SetSort("Name")'>Name @SortIcon("Name")</th>
                                    <th>Email</th>
                                    <th style="cursor:pointer" @onclick='() => SetSort("Office")'>Office @SortIcon("Office")</th>
                                    <th>Department</th>
                                    <th>Position</th>
                                    <th>Linked Account</th>
                                    <th>Owner</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var employee in _employees.Skip((_pageIndex - 1) * PageSize).Take(PageSize))
                                {
                                    <tr>
                                        <td>@employee.EmployeeNumber</td>
                                        <td>@($"{employee.FirstName} {employee.LastName}")</td>
                                        <td>@(employee.WorkEmail ?? "-")</td>
                                        <td>@(GetOfficeName(employee.OfficeId))</td>
                                        <td>@(GetDepartmentName(employee.DepartmentId))</td>
                                        <td>@(GetPositionName(employee.PositionId))</td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(employee.IdentityUserId))
                                            {
                                                <MudTooltip Text="@GetLinkedAccountDisplay(employee.IdentityUserId)">
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Success"
                                                             Icon="@Icons.Material.Filled.Link" Variant="Variant.Outlined">
                                                        @GetLinkedAccountDisplay(employee.IdentityUserId)
                                                    </MudChip>
                                                </MudTooltip>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.body2" Color="Color.Default">—</MudText>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(employee.OfficeCode))
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Label="true"
                                                         Style="font-family:monospace">@employee.OfficeCode</MudChip>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Default">—</MudText>
                                            }
                                        </td>
                                        <td>
                                            <MudChip T="string" Size="Size.Small"
                                                     Color="@(employee.IsActive ? Color.Success : Color.Default)">@(employee.IsActive
                                                                                        ? "Active" : "Inactive")</MudChip>
                                            </td>
                                            <td>
                                                @if (IsOwnedByMe(employee.OfficeCode))
                                                {
                                                    <MudStack Row="true" Spacing="1">
                                                        <MudTooltip Text="Edit employee">
                                                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                                           Color="Color.Primary" OnClick="@(() => EditEmployee(employee))" />
                                                        </MudTooltip>
                                                        <MudTooltip Text="Delete employee">
                                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                           Color="Color.Error" OnClick="@(() => DeleteEmployee(employee.Id))" />
                                                        </MudTooltip>
                                                    </MudStack>
                                                }
                                                else
                                                {
                                                    <MudTooltip Text="Owned by another office — read only">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Default" Disabled="true" />
                                                    </MudTooltip>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        @if (_employees.Count > PageSize)
                        {
                            <MudPagination Class="mt-2" Count="@((int)Math.Ceiling(_employees.Count / (double)PageSize))"
                                           @bind-Selected="_pageIndex" Color="Color.Primary" ShowFirstButton="true" ShowLastButton="true" />
                        }
                        }
                    else
                        {
                            <MudAlert Severity="Severity.Info">No employees yet. Create one to get started.</MudAlert>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    </div>

@code {
    private EmployeeForm _form = new();
    private EmployeeReferenceDto? EditingEmployee { get; set; }
    private List<EmployeeReferenceDto> _employees = new();
    private List<EmployeeReferenceDto> _allEmployees = new();
    private readonly Dictionary<string, string> _linkedAccountDisplays = [];
    private List<OfficeReferenceDto> _offices = new();
    private List<DepartmentReferenceDto> _departments = new();
    private List<PositionReferenceDto> _positions = new();
    private bool _initialized = false;
    private bool _isLoading = false;
    private string _searchKeyword = string.Empty;
    private string _statusFilter = "All";
    private string _officeCodeFilter = string.Empty;
    private string _sortField = "Name";
    private bool _sortAscending = true;
    private string? _myOfficeCode;
    private int _pageIndex = 1;
    private const int PageSize = 10;

    public class EmployeeForm
    {
        public string EmployeeNumber { get; set; } = string.Empty;
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string? WorkEmail { get; set; }
        public UserDto? IdentityUser { get; set; }
        
        // Derived from IdentityUser for API submission
        public string? IdentityUserId => IdentityUser?.Id.ToString();
        
        // These hold the object references for the Autocomplete
        public OfficeReferenceDto? Office { get; set; }
        public DepartmentReferenceDto? Department { get; set; }
        public PositionReferenceDto? Position { get; set; }
        
        public bool IsActive { get; set; } = true;
    }

    private async Task<IEnumerable<UserDto>> SearchIdentityUsers(string value, CancellationToken token)
    {
        try
        {
            var result = await UsersClient.SearchAsync(
                search: string.IsNullOrWhiteSpace(value) ? null : value,
                pageSize: 20,
                cancellationToken: token);

            var items = result?.Items ?? Enumerable.Empty<UserDto>();

            // Build the set of user IDs already linked to another employee.
            // Exclude the current employee's own linked ID so it stays selectable while editing.
            var currentLinkedId = EditingEmployee?.IdentityUserId;
            var alreadyLinked = _allEmployees
                .Where(e => !string.IsNullOrWhiteSpace(e.IdentityUserId)
                            && e.IdentityUserId != currentLinkedId)
                .Select(e => e.IdentityUserId!)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            return items.Where(u => !alreadyLinked.Contains(u.Id.ToString()));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"User search failed: {ex.Message}", Severity.Warning);
            return Enumerable.Empty<UserDto>();
        }
    }

    // Search Functions for Autocompletes
    private async Task<IEnumerable<OfficeReferenceDto>> SearchOffices(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value)) return _offices;
        return _offices.Where(x => x.Name.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }

    private async Task<IEnumerable<DepartmentReferenceDto>> SearchDepartments(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value)) return _departments;
        return _departments.Where(x => x.Name.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }

    private async Task<IEnumerable<PositionReferenceDto>> SearchPositions(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value)) return _positions;
        return _positions.Where(x => x.Name.Contains(value, StringComparison.InvariantCultureIgnoreCase));
    }

    protected override async Task OnInitializedAsync()
    {
        if (_initialized) return;
        _initialized = true;

        var profileTask = OrgProfileClient.GetAsync();
        await Task.WhenAll(
            LoadOffices(),
            LoadDepartments(),
            LoadPositions()
        );
        _myOfficeCode = (await profileTask)?.AnnexECode;

        await LoadEmployees();
    }

    private async Task LoadEmployees()
    {
        try
        {
            _isLoading = true;
            var response = await LookupClient.EmployeesGetAsync(pageSize: 100);
            _allEmployees = response?.Items?.ToList() ?? new();
            ApplyLocalFilters();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load employees: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }

        await LoadLinkedAccountDisplaysAsync();
    }

    private async Task LoadLinkedAccountDisplaysAsync()
    {
        var linkedIds = _allEmployees
            .Where(e => !string.IsNullOrWhiteSpace(e.IdentityUserId))
            .Select(e => e.IdentityUserId!)
            .Distinct()
            .Where(id => !_linkedAccountDisplays.ContainsKey(id))
            .ToList();

        foreach (var identityUserId in linkedIds)
        {
            if (!Guid.TryParse(identityUserId, out var identityGuid)) continue;
            try
            {
                var user = await IdentityClient.UsersGetAsync(identityGuid);
                _linkedAccountDisplays[identityUserId] = $"{user.FirstName} {user.LastName} ({user.Email})".Trim();
            }
            catch
            {
                _linkedAccountDisplays[identityUserId] = identityUserId[..8] + "…";
            }
        }

        StateHasChanged();
    }

    private string GetLinkedAccountDisplay(string identityUserId) =>
        _linkedAccountDisplays.TryGetValue(identityUserId, out var display) ? display : "Linked";

    private async Task LoadOffices()
    {
        try
        {
            var response = await LookupClient.OfficesAsync(pageSize: 1000, isActive: true);
            _offices = response?.Items?.ToList() ?? new();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private async Task LoadDepartments()
    {
        try
        {
            var response = await LookupClient.DepartmentsAsync(pageSize: 1000, isActive: true);
            _departments = response?.Items?.ToList() ?? new();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private async Task LoadPositions()
    {
        try
        {
            var response = await LookupClient.PositionsAsync(pageSize: 1000, isActive: true);
            _positions = response?.Items?.ToList() ?? new();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private async Task SearchEmployees()
    {
        try
        {
            _isLoading = true;
            var keyword = string.IsNullOrWhiteSpace(_searchKeyword) ? null : _searchKeyword;
            var response = await LookupClient.EmployeesGetAsync(keyword: keyword, pageSize: 100);
            _allEmployees = response?.Items?.ToList() ?? new();
            ApplyLocalFilters();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Search failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void OnOfficeCodeFilterChanged(string value)
    {
        _officeCodeFilter = value ?? string.Empty;
        ApplyLocalFilters();
        StateHasChanged();
    }

    private Task OnStatusFilterChanged(string status)
    {
        _statusFilter = string.IsNullOrWhiteSpace(status) ? "All" : status;
        ApplyLocalFilters();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private bool IsOwnedByMe(string? officeCode) =>
        !string.IsNullOrWhiteSpace(_myOfficeCode) &&
        string.Equals(officeCode, _myOfficeCode, StringComparison.OrdinalIgnoreCase);

    private void ApplyLocalFilters()
    {
        var filtered = _statusFilter switch
        {
            "Active" => _allEmployees.Where(x => x.IsActive),
            "Inactive" => _allEmployees.Where(x => !x.IsActive),
            "Own" => _allEmployees.Where(x => IsOwnedByMe(x.OwnerOfficeCode)),
            _ => _allEmployees.AsEnumerable()
        };

        if (!string.IsNullOrWhiteSpace(_officeCodeFilter))
            filtered = filtered.Where(x => x.OwnerOfficeCode != null &&
                x.OwnerOfficeCode.Contains(_officeCodeFilter, StringComparison.OrdinalIgnoreCase));

        _pageIndex = 1;
        _employees = (_sortField, _sortAscending) switch
        {
            ("EmployeeNumber", true)  => filtered.OrderBy(x => x.EmployeeNumber).ToList(),
            ("EmployeeNumber", false) => filtered.OrderByDescending(x => x.EmployeeNumber).ToList(),
            ("Name", false)           => filtered.OrderByDescending(x => x.LastName).ThenByDescending(x => x.FirstName).ToList(),
            ("Office", true)          => filtered.OrderBy(x => x.OfficeName).ThenBy(x => x.LastName).ToList(),
            ("Office", false)         => filtered.OrderByDescending(x => x.OfficeName).ThenBy(x => x.LastName).ToList(),
            _                         => filtered.OrderBy(x => x.LastName).ThenBy(x => x.FirstName).ToList()
        };
    }

    private void SetSort(string field)
    {
        if (_sortField == field) _sortAscending = !_sortAscending;
        else { _sortField = field; _sortAscending = true; }
        ApplyLocalFilters();
    }

    private string SortIcon(string field)
    {
        if (_sortField != field) return string.Empty;
        return _sortAscending ? "▲" : "▼";
    }

    private async Task SaveEmployee()
    {
        if (string.IsNullOrWhiteSpace(_form.EmployeeNumber) ||
            _form.Office == null ||
            _form.Department == null ||
            _form.Position == null)
        {
            Snackbar.Add("Please fill in all required fields", Severity.Warning);
            return;
        }

        try
        {
            if (EditingEmployee != null)
            {
                var updateCmd = new UpdateEmployeeCommand
                {
                    Id = EditingEmployee.Id,
                    EmployeeNumber = _form.EmployeeNumber,
                    FirstName = _form.FirstName,
                    LastName = _form.LastName,
                    WorkEmail = _form.WorkEmail,
                    IdentityUserId = string.IsNullOrWhiteSpace(_form.IdentityUserId) ? null : _form.IdentityUserId.Trim(),
                    OfficeId = _form.Office.Id,
                    DepartmentId = _form.Department.Id,
                    PositionId = _form.Position.Id,
                    IsActive = _form.IsActive
                };
                await MasterDataClient.EmployeesPutAsync(EditingEmployee.Id, updateCmd);
                Snackbar.Add("Employee updated", Severity.Success);
            }
            else
            {
                var createCmd = new CreateEmployeeCommand
                {
                    EmployeeNumber = _form.EmployeeNumber,
                    FirstName = _form.FirstName,
                    LastName = _form.LastName,
                    WorkEmail = _form.WorkEmail,
                    IdentityUserId = string.IsNullOrWhiteSpace(_form.IdentityUserId) ? null : _form.IdentityUserId.Trim(),
                    OfficeId = _form.Office.Id,
                    DepartmentId = _form.Department.Id,
                    PositionId = _form.Position.Id,
                    IsActive = _form.IsActive
                };
                await MasterDataClient.EmployeesPostAsync(createCmd);
                Snackbar.Add("Employee created", Severity.Success);
            }

            await LoadEmployees();
            ResetForm();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private async Task EditEmployee(EmployeeReferenceDto employee)
    {
        EditingEmployee = employee;
        UserDto? linkedUser = null;
        if (!string.IsNullOrWhiteSpace(employee.IdentityUserId) && Guid.TryParse(employee.IdentityUserId, out var identityGuid))
        {
            try { linkedUser = await IdentityClient.UsersGetAsync(identityGuid); }
            catch (Exception ex) { Snackbar.Add($"Could not load linked account: {ex.Message}", Severity.Warning); }
        }
        _form = new EmployeeForm
        {
            EmployeeNumber = employee.EmployeeNumber,
            FirstName = employee.FirstName,
            LastName = employee.LastName,
            WorkEmail = employee.WorkEmail,
            IdentityUser = linkedUser,
            IsActive = employee.IsActive,
            // Find the object in the list so the autocomplete shows the name
            Office = _offices.FirstOrDefault(o => o.Id == employee.OfficeId),
            Department = _departments.FirstOrDefault(d => d.Id == employee.DepartmentId),
            Position = _positions.FirstOrDefault(p => p.Id == employee.PositionId)
        };
        StateHasChanged();
    }

    private void ResetForm()
    {
        _form = new EmployeeForm();
        EditingEmployee = null;
        StateHasChanged();
    }

    private async Task DeleteEmployee(Guid id)
    {
        try
        {
            await MasterDataClient.EmployeesDeleteAsync(id);
            await LoadEmployees();
            Snackbar.Add("Employee deleted", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    // Helper methods for the Table display
    private string GetOfficeName(Guid id) => _offices.FirstOrDefault(o => o.Id == id)?.Name ?? "Unknown";
    private string GetDepartmentName(Guid id) => _departments.FirstOrDefault(d => d.Id == id)?.Name ?? "Unknown";
    private string GetPositionName(Guid id) => _positions.FirstOrDefault(p => p.Id == id)?.Name ?? "Unknown";
}