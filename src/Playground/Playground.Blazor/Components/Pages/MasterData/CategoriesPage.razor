@page "/masterdata/categories"
@using AMIS.Framework.Blazor.UI.Components.Cards
@using AMIS.Playground.Blazor.ApiClient
@using AMIS.Playground.Blazor.Services
@inherits ComponentBase
@inject ISnackbar Snackbar
@inject MasterDataService MasterDataService
@inject IOrganizationProfileClient OrgProfileClient

<AMISPageHeader Title="Categories" Description="Manage product categories">
    <ActionContent>
        <MudStack Row="true" Spacing="2" Style="width: 100%; max-width: 400px;">
            <MudTextField @bind-Value="_searchKeyword" Label="Search" Placeholder="Search categories..."
                          DebounceInterval="300" OnDebounceIntervalElapsed="@(async () => await SearchCategories())"
                          Variant="Variant.Outlined" Size="Size.Small" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SearchCategories">
                Search
            </MudButton>
        </MudStack>
    </ActionContent>
</AMISPageHeader>

<div class="mt-4">
    <MudGrid Spacing="2">
        <!-- Create/Edit Form -->
        <MudItem xs="12" md="4">
            <MudCard Class="AMIS-card">
                <MudCardContent>
                    <MudText Typo="Typo.h6" Class="mb-3">@(EditingCategory != null ? "Edit Category" : "Add Category")</MudText>
                    <MudStack Spacing="3">
                        <MudTextField @bind-Value="_form.Code" Label="Category Code" Placeholder="Unique code" Required="true" />
                        <MudTextField @bind-Value="_form.Name" Label="Category Name" Placeholder="Category name" Required="true" />
                        <MudTextField @bind-Value="_form.Description" Label="Description" Placeholder="Category description" Lines="3" />
                        <MudTextField @bind-Value="_form.OfficeCode" Label="Owner Office Code"
                                      Placeholder="e.g. 100, NDO (leave blank for shared)" MaxLength="8"
                                      Disabled="@(EditingCategory != null)"
                                      HelperText="@(EditingCategory != null ? "Cannot be changed after creation" : string.Empty)" />
                        <MudCheckBox @bind-Value="_form.IsActive" Label="Active" T="bool" />

                        <MudStack Row="true" Spacing="2" Class="mt-4">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                       OnClick="SaveCategory" Disabled="_isLoading">
                                @(EditingCategory != null ? "Update" : "Create")
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true"
                                       OnClick="ResetForm">
                                Clear
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Categories List -->
        <MudItem xs="12" md="8">
            <MudCard Class="AMIS-card">
                <MudCardContent>
                    <MudStack Row="true" Spacing="1" Class="mb-3" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6" Class="flex-grow-1">Categories List</MudText>
                        <MasterDataStatusFilterChips Value="_statusFilter" ValueChanged="OnStatusFilterChanged" />
                    </MudStack>

                    @if (_categories.Any())
                    {
                        <MudSimpleTable Dense="true" Hover="true" Striped="true">
                            <thead>
                                <tr>
                                    <th style="cursor:pointer" @onclick='() => SetSort("Code")'>Code @SortIcon("Code")</th>
                                    <th style="cursor:pointer" @onclick='() => SetSort("Name")'>Name @SortIcon("Name")</th>
                                    <th>Description</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var category in _categories.Skip((_pageIndex - 1) * PageSize).Take(PageSize))
                                {
                                    <tr>
                                        <td>@category.Code</td>
                                        <td>@category.Name</td>
                                        <td>@(category.Description ?? "-")</td>
                                        <td><MudChip T="string" Size="Size.Small" Color="@(category.IsActive ? Color.Success : Color.Error)">@(category.IsActive ? "Active" : "Inactive")</MudChip></td>
                                        <td>
                                            @if (IsOwnedByMe(category.OfficeCode))
                                            {
                                                <MudStack Row="true" Spacing="1">
                                                    <MudTooltip Text="Edit category">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                                       Color="Color.Primary" OnClick="@(() => EditCategory(category))" />
                                                    </MudTooltip>
                                                    <MudTooltip Text="Delete category">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                       Color="Color.Error" OnClick="@(() => DeleteCategory(category.Id))" />
                                                    </MudTooltip>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudTooltip Text="@(string.IsNullOrWhiteSpace(category.OfficeCode) ? "Shared record — read only" : "Owned by another office — read only")">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Default" Disabled="true" />
                                                </MudTooltip>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                        @if (_categories.Count > PageSize)
                        {
                            <MudPagination Class="mt-2" Count="@((int)Math.Ceiling(_categories.Count / (double)PageSize))"
                                           @bind-Selected="_pageIndex" Color="Color.Primary" ShowFirstButton="true" ShowLastButton="true" />
                        }
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info">No categories yet. Create one to get started.</MudAlert>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</div>

@code {
    private CategoryForm _form = new();
    private CategoryDto? EditingCategory;
    private List<CategoryDto> _categories = new();
    private List<CategoryDto> _allCategories = new();
    private bool _initialized = false;
    private bool _isLoading = false;
    private string _searchKeyword = string.Empty;
    private string _statusFilter = "All";
    private string _officeCodeFilter = string.Empty;
    private string _sortField = "Name";
    private bool _sortAscending = true;
    private string? _myOfficeCode;
    private int _pageIndex = 1;
    private const int PageSize = 10;

    public class CategoryForm
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public bool IsActive { get; set; } = true;
        public string? OfficeCode { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        if (_initialized) return;
        _initialized = true;
        var profile = await OrgProfileClient.GetAsync();
        _myOfficeCode = profile?.AnnexECode;
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        try
        {
            _isLoading = true;
            var response = await MasterDataService.GetCategoriesAsync(pageSize: 100);
            _allCategories = response?.Items?.ToList() ?? new();
            ApplyLocalFilters();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load categories: {ex.Message}", Severity.Error);
            _categories = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SearchCategories()
    {
        try
        {
            _isLoading = true;
            var response = await MasterDataService.GetCategoriesAsync(keyword: _searchKeyword, pageSize: 100);
            _allCategories = response?.Items?.ToList() ?? new();
            ApplyLocalFilters();

            if (_categories.Count == 0 && !string.IsNullOrWhiteSpace(_searchKeyword))
            {
                Snackbar.Add("No categories found matching your search", Severity.Info);
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Search failed: {ex.Message}", Severity.Error);
            _categories = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SaveCategory()
    {
        var normalizedCode = _form.Code?.Trim() ?? string.Empty;
        var normalizedName = _form.Name?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(normalizedCode) || string.IsNullOrWhiteSpace(normalizedName))
        {
            Snackbar.Add("Code and Name are required", Severity.Warning);
            return;
        }

        var duplicateCodeExists = _categories.Any(c =>
            !string.IsNullOrWhiteSpace(c.Code) &&
            string.Equals(c.Code.Trim(), normalizedCode, StringComparison.OrdinalIgnoreCase) &&
            (EditingCategory is null || c.Id != EditingCategory.Id));

        if (duplicateCodeExists)
        {
            Snackbar.Add("A category with this code already exists.", Severity.Warning);
            return;
        }

        try
        {
            if (EditingCategory != null)
            {
                var updateCmd = new UpdateCategoryCommand
                {
                    Id = EditingCategory.Id,
                    Code = normalizedCode,
                    Name = normalizedName,
                    Description = _form.Description,
                    IsActive = _form.IsActive
                };

                await MasterDataService.UpdateCategoryAsync(EditingCategory.Id, updateCmd);
                Snackbar.Add("Category updated successfully", Severity.Success);
            }
            else
            {
                var createCmd = new CreateCategoryCommand
                {
                    Code = normalizedCode,
                    Name = normalizedName,
                    Description = _form.Description,
                    OfficeCode = string.IsNullOrWhiteSpace(_form.OfficeCode) ? null : _form.OfficeCode.Trim()
                };

                await MasterDataService.CreateCategoryAsync(createCmd);
                Snackbar.Add("Category created successfully", Severity.Success);
            }

            await LoadCategories();
            ResetForm();
        }
        catch (ApiException apiEx) when (apiEx.StatusCode == StatusCodes.Status400BadRequest)
        {
            var validationMessages = ExtractValidationMessages(apiEx.Response);
            if (validationMessages.Count > 0)
            {
                foreach (var message in validationMessages)
                {
                    Snackbar.Add(message, Severity.Warning);
                }
            }
            else
            {
                Snackbar.Add("Validation failed. Please check your inputs and try again.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save category: {ex.Message}", Severity.Error);
        }
    }

    private static List<string> ExtractValidationMessages(string? response)
    {
        if (string.IsNullOrWhiteSpace(response))
        {
            return new List<string>();
        }

        try
        {
            using var json = System.Text.Json.JsonDocument.Parse(response);
            if (!json.RootElement.TryGetProperty("errors", out var errorsElement) ||
                errorsElement.ValueKind != System.Text.Json.JsonValueKind.Object)
            {
                return new List<string>();
            }

            var messages = new List<string>();
            foreach (var property in errorsElement.EnumerateObject())
            {
                if (property.Value.ValueKind != System.Text.Json.JsonValueKind.Array)
                {
                    continue;
                }

                foreach (var errorItem in property.Value.EnumerateArray())
                {
                    var message = errorItem.GetString();
                    if (!string.IsNullOrWhiteSpace(message))
                    {
                        messages.Add(message);
                    }
                }
            }

            return messages;
        }
        catch
        {
            return new List<string>();
        }
    }

    private void EditCategory(CategoryDto category)
    {
        EditingCategory = category;
        _form = new CategoryForm
        {
            Code = category.Code,
            Name = category.Name,
            Description = category.Description,
            IsActive = category.IsActive,
            OfficeCode = category.OfficeCode
        };
    }

    private void ResetForm()
    {
        _form = new();
        EditingCategory = null;
    }

    private async Task DeleteCategory(Guid id)
    {
        try
        {
            await MasterDataService.DeleteCategoryAsync(id);
            await LoadCategories();
            Snackbar.Add("Category deleted", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to delete category: {ex.Message}", Severity.Error);
        }
    }

    private void OnOfficeCodeFilterChanged(string value)
    {
        _officeCodeFilter = value ?? string.Empty;
        ApplyLocalFilters();
        StateHasChanged();
    }

    private Task OnStatusFilterChanged(string status)
    {
        _statusFilter = string.IsNullOrWhiteSpace(status) ? "All" : status;
        ApplyLocalFilters();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private bool IsOwnedByMe(string? officeCode) =>
        !string.IsNullOrWhiteSpace(_myOfficeCode) &&
        string.Equals(officeCode, _myOfficeCode, StringComparison.OrdinalIgnoreCase);

    private void ApplyLocalFilters()
    {
        var filtered = _statusFilter switch
        {
            "Active" => _allCategories.Where(x => x.IsActive),
            "Inactive" => _allCategories.Where(x => !x.IsActive),
            "Own" => _allCategories.Where(x => IsOwnedByMe(x.OfficeCode)),
            _ => _allCategories.AsEnumerable()
        };

        if (!string.IsNullOrWhiteSpace(_officeCodeFilter))
            filtered = filtered.Where(x => x.OfficeCode != null &&
                x.OfficeCode.Contains(_officeCodeFilter, StringComparison.OrdinalIgnoreCase));

        _pageIndex = 1;
        _categories = (_sortField, _sortAscending) switch
        {
            ("Code", true)  => filtered.OrderBy(x => x.Code).ToList(),
            ("Code", false) => filtered.OrderByDescending(x => x.Code).ToList(),
            ("Name", false) => filtered.OrderByDescending(x => x.Name).ThenBy(x => x.Code).ToList(),
            _               => filtered.OrderBy(x => x.Name).ThenBy(x => x.Code).ToList()
        };
    }

    private void SetSort(string field)
    {
        if (_sortField == field) _sortAscending = !_sortAscending;
        else { _sortField = field; _sortAscending = true; }
        ApplyLocalFilters();
    }

    private string SortIcon(string field)
    {
        if (_sortField != field) return string.Empty;
        return _sortAscending ? "?" : "?";
    }
}

