@page "/master-data/unit-of-measures"
@using FSH.Framework.Blazor.UI.Components.Cards
@using FSH.Playground.Blazor.ApiClient
@inherits ComponentBase
@inject ISnackbar Snackbar
@inject IMaster_dataClient MasterDataClient
@inject ILookupClient LookupClient
@inject IOrganizationProfileClient OrgProfileClient

<FshPageHeader Title="Units of Measure" Description="Manage units of measure">
    <ActionContent>
        <MudStack Row="true" Spacing="2" Style="width: 100%; max-width: 400px;">
            <MudTextField @bind-Value="_searchKeyword" Label="Search" Placeholder="Search units..."
                          DebounceInterval="300" OnDebounceIntervalElapsed="@(async () => await SearchUnitOfMeasures())"
                          Variant="Variant.Outlined" Size="Size.Small" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SearchUnitOfMeasures">
                Search
            </MudButton>
        </MudStack>
    </ActionContent>
</FshPageHeader>

<div class="mt-4">
    <MudGrid Spacing="2">
        <!-- Create/Edit Form -->
        <MudItem xs="12" sm="6" md="4" Style="min-height: 100%;">
            <MudCard Class="fsh-card">
                <MudCardContent>
                    <MudText Typo="Typo.h6" Class="mb-3">@(EditingUnitOfMeasure != null ? "Edit Unit of Measure" : "Create Unit of Measure")</MudText>
                    <MudStack Spacing="3">
                        <MudTextField @bind-Value="_form.Code" Label="Code" Placeholder="Unit code (e.g., PCS, BOX)"
                                      Required="true" />
                        <MudTextField @bind-Value="_form.Name" Label="Name" Placeholder="Unit name"
                                      Required="true" />
                        <MudTextField @bind-Value="_form.Description" Label="Description"
                                      Placeholder="Unit description" Lines="2" />
                        <MudTextField @bind-Value="_form.OfficeCode" Label="Owner Office Code"
                                      Placeholder="e.g. 100, NDO (leave blank for shared)" MaxLength="8"
                                      Disabled="@(EditingUnitOfMeasure != null)"
                                      HelperText="@(EditingUnitOfMeasure != null ? "Cannot be changed after creation" : string.Empty)" />
                        <MudCheckBox @bind-Value="_form.IsActive"
                                     Label="Active" />

                        <MudStack Row="true" Spacing="2" Class="mt-4">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                       OnClick="SaveUnitOfMeasure" Disabled="_isLoading">
                                @(EditingUnitOfMeasure != null ? "Update" : "Create")
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true"
                                       OnClick="ResetForm">
                                Clear
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Units of Measure List -->
        <MudItem xs="12" sm="6" md="8">
            <MudCard Class="fsh-card">
                <MudCardContent>
                    <MudStack Row="true" Spacing="1" Class="mb-3" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6" Class="flex-grow-1">Units of Measure List</MudText>
                        <MasterDataStatusFilterChips Value="_statusFilter" ValueChanged="OnStatusFilterChanged" />
                    </MudStack>

                    @if (_unitOfMeasures.Any())
                    {
                        <MudSimpleTable Dense="true" Hover="true" Striped="true">
                            <thead>
                                <tr>
                                    <th style="cursor:pointer" @onclick='() => SetSort("Code")'>Code @SortIcon("Code")</th>
                                    <th style="cursor:pointer" @onclick='() => SetSort("Name")'>Name @SortIcon("Name")</th>
                                    <th>Owner</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var unit in _unitOfMeasures.Skip((_pageIndex - 1) * PageSize).Take(PageSize))
                                {
                                    <tr>
                                        <td>@unit.Code</td>
                                        <td>@unit.Name</td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(unit.OfficeCode))
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Label="true"
                                                         Style="font-family:monospace">@unit.OfficeCode</MudChip>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Default">—</MudText>
                                            }
                                        </td>
                                        <td><MudChip T="string" Size="Size.Small" Color="@(unit.IsActive ? Color.Success : Color.Default)">@(unit.IsActive ? "Active" : "Inactive")</MudChip></td>
                                        <td>
                                            @if (IsOwnedByMe(unit.OfficeCode))
                                            {
                                                <MudStack Row="true" Spacing="1">
                                                    <MudTooltip Text="Edit unit of measure">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                                       Color="Color.Primary" OnClick="@(() => EditUnitOfMeasure(unit))" />
                                                    </MudTooltip>
                                                    <MudTooltip Text="Delete unit of measure">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                       Color="Color.Error" OnClick="@(() => DeleteUnitOfMeasure(unit.Id))" />
                                                    </MudTooltip>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudTooltip Text="@(string.IsNullOrWhiteSpace(unit.OfficeCode) ? "Shared record — read only" : "Owned by another office — read only")">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Default" Disabled="true" />
                                                </MudTooltip>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                        @if (_unitOfMeasures.Count > PageSize)
                        {
                            <MudPagination Class="mt-2" Count="@((int)Math.Ceiling(_unitOfMeasures.Count / (double)PageSize))"
                                           @bind-Selected="_pageIndex" Color="Color.Primary" ShowFirstButton="true" ShowLastButton="true" />
                        }
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info">No units of measure yet. Create one to get started.</MudAlert>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</div>

@code {
    private UnitOfMeasureForm _form = new();
    private FSH.Playground.Blazor.ApiClient.UnitOfMeasureReferenceDto? EditingUnitOfMeasure { get; set; }
    private List<FSH.Playground.Blazor.ApiClient.UnitOfMeasureReferenceDto> _unitOfMeasures = new();
    private List<FSH.Playground.Blazor.ApiClient.UnitOfMeasureReferenceDto> _allUnitOfMeasures = new();
    private bool _initialized = false;
    private bool _isLoading = false;
    private string _searchKeyword = string.Empty;
    private string _statusFilter = "All";
    private string _officeCodeFilter = string.Empty;
    private string _sortField = "Name";
    private bool _sortAscending = true;
    private string? _myOfficeCode;
    private int _pageIndex = 1;
    private const int PageSize = 10;

    public class UnitOfMeasureForm
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public bool IsActive { get; set; } = true;
        public string? OfficeCode { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        if (_initialized) return;
        _initialized = true;
        var profile = await OrgProfileClient.GetAsync();
        _myOfficeCode = profile?.AnnexECode;
        await LoadUnitOfMeasures();
    }

    private async Task LoadUnitOfMeasures()
    {
        try
        {
            _isLoading = true;
            var response = await LookupClient.UnitOfMeasuresAsync(pageSize: 100);
            _allUnitOfMeasures = response?.Items?.ToList() ?? new();
            ApplyLocalFilters();
            StateHasChanged();
        }
        catch (HttpRequestException ex) when (
            ex.Message.Contains("StatusCode=401", StringComparison.OrdinalIgnoreCase) ||
            ex.Message.Contains("401 (Unauthorized)", StringComparison.OrdinalIgnoreCase) ||
            (ex.InnerException?.Message?.Contains("401", StringComparison.OrdinalIgnoreCase) ?? false))
        {
            Snackbar.Add("Authenticating...", Severity.Info);
            await Task.Delay(500);
            await LoadUnitOfMeasuresInternal(retryCount: 1);
            return;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load units of measure: {ex.Message}", Severity.Error);
            _unitOfMeasures = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadUnitOfMeasuresInternal(int retryCount = 0, int maxRetries = 3)
    {
        try
        {
            var response = await LookupClient.UnitOfMeasuresAsync(pageSize: 100);
            _allUnitOfMeasures = response?.Items?.ToList() ?? new();
            ApplyLocalFilters();
            StateHasChanged();
        }
        catch (HttpRequestException ex) when (
            (ex.Message.Contains("StatusCode=401", StringComparison.OrdinalIgnoreCase) ||
             ex.Message.Contains("401 (Unauthorized)", StringComparison.OrdinalIgnoreCase) ||
             (ex.InnerException?.Message?.Contains("401", StringComparison.OrdinalIgnoreCase) ?? false)) &&
            retryCount < maxRetries)
        {
            await Task.Delay(300 * (retryCount + 1));
            await LoadUnitOfMeasuresInternal(retryCount + 1, maxRetries);
        }
        catch (Exception ex)
        {
            if (retryCount == 0)
            {
                Snackbar.Add($"Failed to load units of measure: {ex.Message}", Severity.Error);
            }
            _unitOfMeasures = new();
            StateHasChanged();
        }
    }

    private async Task SearchUnitOfMeasures()
    {
        try
        {
            _isLoading = true;
            var response = await LookupClient.UnitOfMeasuresAsync(keyword: _searchKeyword, pageSize: 100);
            _allUnitOfMeasures = response?.Items?.ToList() ?? new();
            ApplyLocalFilters();
            
            if (_unitOfMeasures.Count == 0 && !string.IsNullOrWhiteSpace(_searchKeyword))
            {
                Snackbar.Add("No units of measure found matching your search", Severity.Info);
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Search failed: {ex.Message}", Severity.Error);
            _unitOfMeasures = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SaveUnitOfMeasure()
    {
        if (string.IsNullOrWhiteSpace(_form.Code) || string.IsNullOrWhiteSpace(_form.Name))
        {
            Snackbar.Add("Code and Name are required", Severity.Warning);
            return;
        }

        try
        {
            if (EditingUnitOfMeasure != null)
            {

                var updateCmd = new UpdateUnitOfMeasureCommand
                {
                    Id = EditingUnitOfMeasure.Id,
                    Code = _form.Code,
                    Name = _form.Name,
                    Description = _form.Description,
                    IsActive = _form.IsActive
                };

                var updatedUnitOfMeasure = await MasterDataClient.UnitOfMeasuresPutAsync(EditingUnitOfMeasure.Id, updateCmd);
                
                // Update the local unit of measure with new values
                if (updatedUnitOfMeasure != null)
                {
                    EditingUnitOfMeasure = updatedUnitOfMeasure;
                    var unitIndex = _unitOfMeasures.FindIndex(u => u.Id == updatedUnitOfMeasure.Id);
                    if (unitIndex >= 0)
                    {
                        _unitOfMeasures[unitIndex] = updatedUnitOfMeasure;
                    }
                    StateHasChanged();
                }
                
                Snackbar.Add("Unit of measure updated successfully", Severity.Success);
            }
            else
            {
                var createCmd = new CreateUnitOfMeasureCommand
                {
                    Code = _form.Code,
                    Name = _form.Name,
                    Description = _form.Description,
                    IsActive = _form.IsActive,
                    OfficeCode = string.IsNullOrWhiteSpace(_form.OfficeCode) ? null : _form.OfficeCode.Trim()
                };
                await MasterDataClient.UnitOfMeasuresPostAsync(createCmd);
                Snackbar.Add("Unit of measure created successfully", Severity.Success);
            }

            await LoadUnitOfMeasures();
            ResetForm();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save unit of measure: {ex.Message}", Severity.Error);
        }
    }

    private async Task EditUnitOfMeasure(FSH.Playground.Blazor.ApiClient.UnitOfMeasureReferenceDto unit)
    {
        EditingUnitOfMeasure = unit;
        _form = new UnitOfMeasureForm
        {
            Code = unit.Code,
            Name = unit.Name,
            Description = unit.Description,
            IsActive = unit.IsActive,
            OfficeCode = unit.OfficeCode
        };
        await InvokeAsync(StateHasChanged);
    }

    private void ResetForm()
    {
        _form = new();
        EditingUnitOfMeasure = null;
    }

    private async Task DeleteUnitOfMeasure(Guid id)
    {
        try
        {
            await MasterDataClient.UnitOfMeasuresDeleteAsync(id);
            await LoadUnitOfMeasures();
            Snackbar.Add("Unit of measure deleted", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to delete unit of measure: {ex.Message}", Severity.Error);
        }
    }

    private void OnOfficeCodeFilterChanged(string value)
    {
        _officeCodeFilter = value ?? string.Empty;
        ApplyLocalFilters();
        StateHasChanged();
    }

    private Task OnStatusFilterChanged(string status)
    {
        _statusFilter = string.IsNullOrWhiteSpace(status) ? "All" : status;
        ApplyLocalFilters();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private bool IsOwnedByMe(string? officeCode) =>
        !string.IsNullOrWhiteSpace(_myOfficeCode) &&
        string.Equals(officeCode, _myOfficeCode, StringComparison.OrdinalIgnoreCase);

    private void ApplyLocalFilters()
    {
        var filtered = _statusFilter switch
        {
            "Active" => _allUnitOfMeasures.Where(x => x.IsActive),
            "Inactive" => _allUnitOfMeasures.Where(x => !x.IsActive),
            "Own" => _allUnitOfMeasures.Where(x => IsOwnedByMe(x.OfficeCode)),
            _ => _allUnitOfMeasures.AsEnumerable()
        };

        if (!string.IsNullOrWhiteSpace(_officeCodeFilter))
            filtered = filtered.Where(x => x.OfficeCode != null &&
                x.OfficeCode.Contains(_officeCodeFilter, StringComparison.OrdinalIgnoreCase));

        _pageIndex = 1;
        _unitOfMeasures = (_sortField, _sortAscending) switch
        {
            ("Code", true)  => filtered.OrderBy(x => x.Code).ToList(),
            ("Code", false) => filtered.OrderByDescending(x => x.Code).ToList(),
            ("Name", false) => filtered.OrderByDescending(x => x.Name).ThenBy(x => x.Code).ToList(),
            _               => filtered.OrderBy(x => x.Name).ThenBy(x => x.Code).ToList()
        };
    }

    private void SetSort(string field)
    {
        if (_sortField == field) _sortAscending = !_sortAscending;
        else { _sortField = field; _sortAscending = true; }
        ApplyLocalFilters();
    }

    private string SortIcon(string field)
    {
        if (_sortField != field) return string.Empty;
        return _sortAscending ? "▲" : "▼";
    }
}
