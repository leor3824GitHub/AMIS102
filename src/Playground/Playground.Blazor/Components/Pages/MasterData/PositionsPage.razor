@page "/master-data/positions"
@using FSH.Framework.Blazor.UI.Components.Cards
@using FSH.Playground.Blazor.ApiClient
@inherits ComponentBase
@inject ISnackbar Snackbar
@inject IMaster_dataClient MasterDataClient
@inject ILookupClient LookupClient

<FshPageHeader Title="Positions" Description="Manage positions">
    <ActionContent>
        <MudStack Row="true" Spacing="2" Style="width: 100%; max-width: 400px;">
            <MudTextField @bind-Value="_searchKeyword" Label="Search" Placeholder="Search positions..."
                          DebounceInterval="300" OnDebounceIntervalElapsed="@(async () => await SearchPositions())"
                          Variant="Variant.Outlined" Size="Size.Small" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SearchPositions">
                Search
            </MudButton>
        </MudStack>
    </ActionContent>
</FshPageHeader>

<div class="mt-4">
    <MudGrid Spacing="2">
        <!-- Create/Edit Form -->
        <MudItem xs="12" sm="6" md="4" Style="min-height: 100%;">
            <MudCard Class="fsh-card">
                <MudCardContent>
                    <MudText Typo="Typo.h6" Class="mb-3">@(EditingPosition != null ? "Edit Position" : "Create Position")</MudText>
                    <MudStack Spacing="3">
                        <MudTextField @bind-Value="_form.Code" Label="Code" Placeholder="Position code"
                                      Required="true" />
                        <MudTextField @bind-Value="_form.Name" Label="Name" Placeholder="Position name"
                                      Required="true" />
                        <MudTextField @bind-Value="_form.Description" Label="Description"
                                      Placeholder="Position description" Lines="2" />
                        <MudCheckBox @bind-Value="_form.IsActive"
                                     Label="Active" />

                        <MudStack Row="true" Spacing="2" Class="mt-4">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                       OnClick="SavePosition" Disabled="_isLoading">
                                @(EditingPosition != null ? "Update" : "Create")
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true"
                                       OnClick="ResetForm">
                                Clear
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Positions List -->
        <MudItem xs="12" sm="6" md="8">
            <MudCard Class="fsh-card">
                <MudCardContent>
                    <MudStack Row="true" Spacing="1" Class="mb-3" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6" Class="flex-grow-1">Positions List</MudText>
                        <MasterDataStatusFilterChips Value="_statusFilter" ValueChanged="OnStatusFilterChanged" />
                    </MudStack>

                    @if (_positions.Any())
                    {
                        <MudSimpleTable Dense="true" Hover="true" Striped="true">
                            <thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Name</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var position in _positions)
                                {
                                    <tr>
                                        <td>@position.Code</td>
                                        <td>@position.Name</td>
                                        <td><MudChip T="string" Size="Size.Small" Color="@(position.IsActive ? Color.Success : Color.Default)">@(position.IsActive ? "Active" : "Inactive")</MudChip></td>
                                        <td>
                                            <MudStack Row="true" Spacing="1">
                                                <MudTooltip Text="Edit position">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                                   Color="Color.Primary" OnClick="@(() => EditPosition(position))" />
                                                </MudTooltip>
                                                <MudTooltip Text="Delete position">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                   Color="Color.Error" OnClick="@(() => DeletePosition(position.Id))" />
                                                </MudTooltip>
                                            </MudStack>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info">No positions yet. Create one to get started.</MudAlert>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</div>

@code {
    private PositionForm _form = new();
    private FSH.Playground.Blazor.ApiClient.PositionReferenceDto? EditingPosition { get; set; }
    private List<FSH.Playground.Blazor.ApiClient.PositionReferenceDto> _positions = new();
    private List<FSH.Playground.Blazor.ApiClient.PositionReferenceDto> _allPositions = new();
    private bool _initialized = false;
    private bool _isLoading = false;
    private string _searchKeyword = string.Empty;
    private string _statusFilter = "All";

    public class PositionForm
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public bool IsActive { get; set; } = true;
    }

    protected override async Task OnInitializedAsync()
    {
        if (_initialized) return;
        _initialized = true;
        await LoadPositions();
    }

    private async Task LoadPositions()
    {
        try
        {
            _isLoading = true;
            var response = await LookupClient.PositionsAsync(pageSize: 100);
            _allPositions = response?.Items?.ToList() ?? new();
            ApplyLocalFilters();
            StateHasChanged();
        }
        catch (HttpRequestException ex) when (
            ex.Message.Contains("StatusCode=401", StringComparison.OrdinalIgnoreCase) ||
            ex.Message.Contains("401 (Unauthorized)", StringComparison.OrdinalIgnoreCase) ||
            (ex.InnerException?.Message?.Contains("401", StringComparison.OrdinalIgnoreCase) ?? false))
        {
            Snackbar.Add("Authenticating...", Severity.Info);
            await Task.Delay(500);
            await LoadPositionsInternal(retryCount: 1);
            return;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load positions: {ex.Message}", Severity.Error);
            _positions = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadPositionsInternal(int retryCount = 0, int maxRetries = 3)
    {
        try
        {
            var response = await LookupClient.PositionsAsync(pageSize: 100);
            _allPositions = response?.Items?.ToList() ?? new();
            ApplyLocalFilters();
            StateHasChanged();
        }
        catch (HttpRequestException ex) when (
            (ex.Message.Contains("StatusCode=401", StringComparison.OrdinalIgnoreCase) ||
             ex.Message.Contains("401 (Unauthorized)", StringComparison.OrdinalIgnoreCase) ||
             (ex.InnerException?.Message?.Contains("401", StringComparison.OrdinalIgnoreCase) ?? false)) &&
            retryCount < maxRetries)
        {
            await Task.Delay(300 * (retryCount + 1));
            await LoadPositionsInternal(retryCount + 1, maxRetries);
        }
        catch (Exception ex)
        {
            if (retryCount == 0)
            {
                Snackbar.Add($"Failed to load positions: {ex.Message}", Severity.Error);
            }
            _positions = new();
            StateHasChanged();
        }
    }

    private async Task SearchPositions()
    {
        try
        {
            _isLoading = true;
            var response = await LookupClient.PositionsAsync(keyword: _searchKeyword, pageSize: 100);
            _allPositions = response?.Items?.ToList() ?? new();
            ApplyLocalFilters();
            
            if (_positions.Count == 0 && !string.IsNullOrWhiteSpace(_searchKeyword))
            {
                Snackbar.Add("No positions found matching your search", Severity.Info);
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Search failed: {ex.Message}", Severity.Error);
            _positions = new();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SavePosition()
    {
        if (string.IsNullOrWhiteSpace(_form.Code) || string.IsNullOrWhiteSpace(_form.Name))
        {
            Snackbar.Add("Code and Name are required", Severity.Warning);
            return;
        }

        try
        {
            if (EditingPosition != null)
            {

                var updateCmd = new UpdatePositionCommand
                {
                    Id = EditingPosition.Id,
                    Code = _form.Code,
                    Name = _form.Name,
                    Description = _form.Description,
                    IsActive = _form.IsActive
                };

                var updatedPosition = await MasterDataClient.PositionsPutAsync(EditingPosition.Id, updateCmd);
                
                // Update the local position with new values
                if (updatedPosition != null)
                {
                    EditingPosition = updatedPosition;
                    var positionIndex = _positions.FindIndex(p => p.Id == updatedPosition.Id);
                    if (positionIndex >= 0)
                    {
                        _positions[positionIndex] = updatedPosition;
                    }
                    StateHasChanged();
                }
                
                Snackbar.Add("Position updated successfully", Severity.Success);
            }
            else
            {
                var createCmd = new CreatePositionCommand
                {
                    Code = _form.Code,
                    Name = _form.Name,
                    Description = _form.Description,
                    IsActive = _form.IsActive
                };
                await MasterDataClient.PositionsPostAsync(createCmd);
                Snackbar.Add("Position created successfully", Severity.Success);
            }

            await LoadPositions();
            ResetForm();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save position: {ex.Message}", Severity.Error);
        }
    }

    private async Task EditPosition(FSH.Playground.Blazor.ApiClient.PositionReferenceDto position)
    {
        EditingPosition = position;
        _form = new PositionForm
        {
            Code = position.Code,
            Name = position.Name,
            Description = position.Description,
            IsActive = position.IsActive
        };
        await InvokeAsync(StateHasChanged);
    }

    private void ResetForm()
    {
        _form = new();
        EditingPosition = null;
    }

    private async Task DeletePosition(Guid id)
    {
        try
        {
            await MasterDataClient.PositionsDeleteAsync(id);
            await LoadPositions();
            Snackbar.Add("Position deleted", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to delete position: {ex.Message}", Severity.Error);
        }
    }

    private Task OnStatusFilterChanged(string status)
    {
        _statusFilter = string.IsNullOrWhiteSpace(status) ? "All" : status;
        ApplyLocalFilters();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void ApplyLocalFilters()
    {
        _positions = _statusFilter switch
        {
            "Active" => _allPositions.Where(x => x.IsActive).ToList(),
            "Inactive" => _allPositions.Where(x => !x.IsActive).ToList(),
            _ => _allPositions.ToList()
        };
    }
}
