@page "/master-data/property-code-generator"
@using FSH.Modules.MasterData.Contracts.v1.PropertyClasses
@using FSH.Playground.Blazor.ApiClient
@inject IPropertyClassClient PropertyClassClient
@inject IOrganizationProfileClient OrgProfileClient
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<FshPageHeader Title="Property Code Generator"
               Description="Preview and plan PPE property codes before recording receipts. Format: {Year}-NFA-{Office}-{Class}-{Item}-{Seq}." />

<MudGrid Spacing="3" Class="mt-3">
            <!-- Controls -->
            <MudItem xs="12" md="4">
                <MudCard Elevation="1">
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle1" Class="mb-3">Code Parameters</MudText>
                        <MudStack Spacing="2">

                            <MudTextField Value="@_officeCode" Label="Office Code (Annex E)"
                                          Variant="Variant.Outlined" ReadOnly="true"
                                          HelperText="Master Data → Organization Profile"
                                          Adornment="@(_officeCode == "???" ? Adornment.End : Adornment.None)"
                                          AdornmentIcon="@Icons.Material.Outlined.Warning"
                                          AdornmentColor="Color.Warning" />

                            <MudButtonGroup Size="Size.Small" OverrideStyles="false" Style="width:100%">
                                <MudButton OnClick="@(() => SetMode(false))"
                                           Variant="@(!_categoryFirst ? Variant.Filled : Variant.Outlined)"
                                           Color="@(!_categoryFirst ? Color.Primary : Color.Default)"
                                           FullWidth="true">
                                    Class &#8594; Category
                                </MudButton>
                                <MudButton OnClick="@(() => SetMode(true))"
                                           Variant="@(_categoryFirst ? Variant.Filled : Variant.Outlined)"
                                           Color="@(_categoryFirst ? Color.Primary : Color.Default)"
                                           FullWidth="true">
                                    Category &#8594; Class
                                </MudButton>
                            </MudButtonGroup>

                            @if (!_categoryFirst)
                            {
                                <MudAutocomplete T="PropertyClassDto"
                                                 Value="_selectedClass"
                                                 ValueChanged="OnClassSelectedAsync"
                                                 SearchFunc="SearchClassesAsync"
                                                 ToStringFunc="@(c => c is null ? string.Empty : $"{c.Code} — {c.Name}")"
                                                 Label="Property Class"
                                                 Variant="Variant.Outlined"
                                                 Placeholder="Type class code or name..."
                                                 ResetValueOnEmptyText="true"
                                                 CoerceValue="false"
                                                 MinCharacters="0"
                                                 AnchorOrigin="Origin.BottomLeft" />

                                <MudAutocomplete T="PropertyClassItemDto"
                                                 Value="_selectedItem"
                                                 ValueChanged="OnItemSelectedAsync"
                                                 SearchFunc="SearchItemsInClassAsync"
                                                 ToStringFunc="@(i => i is null ? string.Empty : $"{i.ItemCode} — {i.Name}")"
                                                 Label="Category Code"
                                                 Variant="Variant.Outlined"
                                                 Placeholder="Type category code or name..."
                                                 Disabled="@(string.IsNullOrWhiteSpace(_ppeClassCode))"
                                                 ResetValueOnEmptyText="true"
                                                 CoerceValue="false"
                                                 MinCharacters="0"
                                                 AnchorOrigin="Origin.BottomLeft" />
                            }
                            else
                            {
                                <MudAutocomplete T="PropertyClassItemDto"
                                                 Value="_selectedItem"
                                                 ValueChanged="OnItemSelectedAsync"
                                                 SearchFunc="SearchAllItemsAsync"
                                                 ToStringFunc="@(i => i is null ? string.Empty : $"{i.ItemCode} — {i.Name}")"
                                                 Label="Category Code"
                                                 Variant="Variant.Outlined"
                                                 Placeholder="Type category code or name..."
                                                 ResetValueOnEmptyText="true"
                                                 CoerceValue="false"
                                                 MinCharacters="0"
                                                 AnchorOrigin="Origin.BottomLeft" />

                                <MudTextField Value="@FormatClass(_ppeClassCode)"
                                              Label="Property Class"
                                              Variant="Variant.Outlined"
                                              ReadOnly="true"
                                              Placeholder="Auto-filled when category is selected"
                                              Adornment="@(string.IsNullOrWhiteSpace(_ppeClassCode) ? Adornment.End : Adornment.None)"
                                              AdornmentIcon="@Icons.Material.Outlined.Info"
                                              AdornmentColor="Color.Secondary" />
                            }

                            <MudNumericField @bind-Value="_ppeYear" Label="Year" Variant="Variant.Outlined"
                                             Min="2000" Max="2099" />

                            <MudStack Row="true" Spacing="2">
                                <MudNumericField @bind-Value="_ppeSeqFrom" Label="From Seq."
                                                 Variant="Variant.Outlined" Min="1" Max="999" />
                                <MudNumericField @bind-Value="_ppeSeqTo" Label="To Seq."
                                                 Variant="Variant.Outlined" Min="1" Max="999" />
                            </MudStack>
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Preview -->
            <MudItem xs="12" md="8">
                <MudCard Elevation="1">
                    <MudCardContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudText Typo="Typo.subtitle1" Class="flex-grow-1">Code Preview</MudText>
                            @if (PpeReady)
                            {
                                <MudTooltip Text="Copy format string">
                                    <MudIconButton Icon="@Icons.Material.Outlined.ContentCopy" Size="Size.Small"
                                                   OnClick="@(() => CopyToClipboard(PpeFormatString))" />
                                </MudTooltip>
                            }
                        </MudStack>

                        @if (!PpeReady)
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">
                                Select a Property Class and Category Code to preview codes.
                            </MudAlert>
                        }
                        else
                        {
                            <!-- Format banner -->
                            <MudPaper Elevation="0" Style="background: var(--mud-palette-background-grey); border-radius: 8px;"
                                      Class="pa-3 mb-3">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Outlined.Tag" Size="Size.Small" Color="Color.Primary" />
                                    <MudText Typo="Typo.body2" Style="font-family: monospace; font-weight: 700; font-size: 1rem;">
                                        @PpeFormatString
                                    </MudText>
                                </MudStack>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                    @SelectedClassName — @SelectedItemName
                                </MudText>
                            </MudPaper>

                            <!-- Sequence table -->
                            <MudSimpleTable Dense="true" Hover="true" Striped="true">
                                <thead>
                                    <tr>
                                        <th style="width: 60px">Seq</th>
                                        <th>Property Code</th>
                                        <th style="width: 48px"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var seq in PpeSequenceRange)
                                    {
                                        var propertyCode = BuildPpeCode(seq);
                                        <tr>
                                            <td>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@seq.ToString("D3")</MudText>
                                            </td>
                                            <td>
                                                <MudText Style="font-family: monospace; font-weight: 600;">@propertyCode</MudText>
                                            </td>
                                            <td>
                                                <MudIconButton Icon="@Icons.Material.Outlined.ContentCopy"
                                                               Size="Size.Small" Color="Color.Default"
                                                               OnClick="@(() => CopyToClipboard(propertyCode))" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>

</MudGrid>

@code {
    private List<PropertyClassDto> _activeClasses = [];
    private string _officeCode = "???";
    private string? _ppeClassCode;
    private string? _ppeItemCode;
    private int _ppeYear = DateTime.Now.Year;
    private int _ppeSeqFrom = 1;
    private int _ppeSeqTo = 10;
    private bool _categoryFirst;
    private PropertyClassDto? _selectedClass;
    private PropertyClassItemDto? _selectedItem;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadClassesAsync(), LoadOfficeCodeAsync());
    }

    private async Task LoadClassesAsync()
    {
        try
        {
            var all = await PropertyClassClient.GetTreeAsync();
            _activeClasses = all?.Where(c => c.IsActive).OrderBy(c => c.Code).ToList() ?? [];
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not load property classes: {ex.Message}", Severity.Warning);
        }
    }

    private async Task LoadOfficeCodeAsync()
    {
        try
        {
            var profile = await OrgProfileClient.GetAsync();
            _officeCode = string.IsNullOrWhiteSpace(profile?.AnnexECode) ? "???" : profile.AnnexECode.ToUpperInvariant();
        }
        catch
        {
            _officeCode = "???";
        }
    }

    // PPE helpers
    private IEnumerable<PropertyClassItemDto> PpeActiveItems =>
        (_activeClasses.FirstOrDefault(c => c.Code == _ppeClassCode)?.Items ?? [])
        .Where(i => i.IsActive)
        .OrderBy(i => i.ItemCode);

    private IEnumerable<PropertyClassItemDto> PpeAllActiveItems =>
        _activeClasses
            .Where(c => c.IsActive)
            .SelectMany(c => c.Items.Where(i => i.IsActive))
            .OrderBy(i => i.ItemCode);

    private PropertyClassItemDto? SelectedItem =>
        PpeAllActiveItems.FirstOrDefault(i =>
            i.ItemCode == _ppeItemCode &&
            (string.IsNullOrWhiteSpace(_ppeClassCode) || i.ClassCode == _ppeClassCode));

    private bool PpeReady =>
        !string.IsNullOrWhiteSpace(_ppeClassCode) && !string.IsNullOrWhiteSpace(_ppeItemCode);

    private string PpeFormatString =>
        $"{_ppeYear}-NFA-{_officeCode}-{_ppeClassCode}-{_ppeItemCode}-{{Seq:D3}}";

    private string SelectedClassName =>
        _activeClasses.FirstOrDefault(c => c.Code == _ppeClassCode)?.Name ?? string.Empty;

    private string SelectedItemName =>
        SelectedItem?.Name ?? string.Empty;

    private IEnumerable<int> PpeSequenceRange =>
        Enumerable.Range(_ppeSeqFrom, Math.Max(1, Math.Min(_ppeSeqTo - _ppeSeqFrom + 1, 50)));

    private string BuildPpeCode(int seq) =>
        $"{_ppeYear}-NFA-{_officeCode}-{_ppeClassCode}-{_ppeItemCode}-{seq:D3}";

    private string FormatClass(string? code)
    {
        if (string.IsNullOrWhiteSpace(code)) return string.Empty;
        var cls = _activeClasses.FirstOrDefault(c => c.Code == code);
        return cls is null ? code : $"{cls.Code} — {cls.Name}";
    }

    private void SetMode(bool categoryFirst)
    {
        if (_categoryFirst == categoryFirst) return;
        _categoryFirst = categoryFirst;
        _selectedClass = null;
        _selectedItem = null;
        _ppeClassCode = null;
        _ppeItemCode = null;
    }

    private Task<IEnumerable<PropertyClassDto>> SearchClassesAsync(string? value, CancellationToken ct)
    {
        IEnumerable<PropertyClassDto> results = string.IsNullOrWhiteSpace(value)
            ? _activeClasses
            : _activeClasses.Where(c =>
                c.Code.Contains(value, StringComparison.OrdinalIgnoreCase) ||
                c.Name.Contains(value, StringComparison.OrdinalIgnoreCase));

        return Task.FromResult(results);
    }

    private Task<IEnumerable<PropertyClassItemDto>> SearchItemsInClassAsync(string? value, CancellationToken ct)
    {
        IEnumerable<PropertyClassItemDto> items = _selectedClass is null
            ? []
            : _selectedClass.Items.Where(i => i.IsActive);
        if (!string.IsNullOrWhiteSpace(value))
            items = items.Where(i =>
                i.ItemCode.Contains(value, StringComparison.OrdinalIgnoreCase) ||
                i.Name.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(items.OrderBy(i => i.ItemCode).AsEnumerable());
    }

    private Task<IEnumerable<PropertyClassItemDto>> SearchAllItemsAsync(string? value, CancellationToken ct)
    {
        IEnumerable<PropertyClassItemDto> items = PpeAllActiveItems;
        if (!string.IsNullOrWhiteSpace(value))
            items = items.Where(i =>
                i.ItemCode.Contains(value, StringComparison.OrdinalIgnoreCase) ||
                i.Name.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(items.AsEnumerable());
    }

    private Task OnClassSelectedAsync(PropertyClassDto? selectedClass)
    {
        _selectedClass = selectedClass;
        _ppeClassCode = selectedClass?.Code;
        _selectedItem = null;
        _ppeItemCode = null;
        return Task.CompletedTask;
    }

    private Task OnItemSelectedAsync(PropertyClassItemDto? item)
    {
        _selectedItem = item;
        _ppeItemCode = item?.ItemCode;
        if (_categoryFirst)
        {
            _ppeClassCode = item?.ClassCode;
            _selectedClass = _activeClasses.FirstOrDefault(c => c.Code == _ppeClassCode);
        }

        return Task.CompletedTask;
    }

    // Utility
    private async Task CopyToClipboard(string text)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
            Snackbar.Add($"Copied: {text}", Severity.Success, cfg => cfg.VisibleStateDuration = 1500);
        }
        catch
        {
            Snackbar.Add("Copy failed — use Ctrl+C on the text instead.", Severity.Warning);
        }
    }
}
