@code {
    private bool _isRootTenantAdmin;
    private bool _expendableExpanded;
    private bool _vehicleExpanded;
    private bool _masterDataExpanded;
    private bool _procurementPlanningExpanded;
    private bool _procurementExpanded;
    private bool _financeExpanded;
    private bool _assetManagementExpanded;
    private bool _seExpanded;
    private bool _ppeExpanded;

    protected override async Task OnInitializedAsync()
    {
        var uri = Navigation.Uri;
        _expendableExpanded = uri.Contains("/expendable", StringComparison.OrdinalIgnoreCase);
        _vehicleExpanded = uri.Contains("/vehicle", StringComparison.OrdinalIgnoreCase);
        _procurementPlanningExpanded = uri.Contains("/procurement-planning", StringComparison.OrdinalIgnoreCase);
        _procurementExpanded = uri.Contains("/procurement/", StringComparison.OrdinalIgnoreCase);
        _financeExpanded = uri.Contains("/finance", StringComparison.OrdinalIgnoreCase);
        _masterDataExpanded = uri.Contains("/master-data", StringComparison.OrdinalIgnoreCase)
                           || uri.Contains("/masterdata", StringComparison.OrdinalIgnoreCase);
        _assetManagementExpanded = uri.Contains("/asset-management", StringComparison.OrdinalIgnoreCase);
        _seExpanded = uri.Contains("/asset-management/receiving-reports", StringComparison.OrdinalIgnoreCase)
                   || uri.Contains("/asset-management/inventory-custodian-slips", StringComparison.OrdinalIgnoreCase)
                   || uri.Contains("/asset-management/issuance-records", StringComparison.OrdinalIgnoreCase)
                   || uri.Contains("/asset-management/returned-properties", StringComparison.OrdinalIgnoreCase)
                   || uri.Contains("/asset-management/incident-reports", StringComparison.OrdinalIgnoreCase)
                   || uri.Contains("/asset-management/unserviceable-reports", StringComparison.OrdinalIgnoreCase)
                   || uri.Contains("/asset-management/reports", StringComparison.OrdinalIgnoreCase);
        _ppeExpanded = uri.Contains("/asset-management/ppe-receiving-reports", StringComparison.OrdinalIgnoreCase)
                    || uri.Contains("/asset-management/property-acknowledgement-receipts", StringComparison.OrdinalIgnoreCase)
                    || uri.Contains("/asset-management/ppe-issuance-reports", StringComparison.OrdinalIgnoreCase)
                    || uri.Contains("/asset-management/ppe-transfer-reports", StringComparison.OrdinalIgnoreCase)
                    || uri.Contains("/asset-management/receipts-for-returned-ppe", StringComparison.OrdinalIgnoreCase);
        await CheckRootTenantAdmin();
    }

    private async Task CheckRootTenantAdmin()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated != true)
            {
                _isRootTenantAdmin = false;
                return;
            }

            var tenant = user.FindFirst(CustomClaims.Tenant)?.Value;
            var isRootTenant = string.Equals(tenant, MultitenancyConstants.Root.Id, StringComparison.OrdinalIgnoreCase);

            var roles = user.FindAll(System.Security.Claims.ClaimTypes.Role).Select(c => c.Value).ToList();
            var isAdmin = roles.Any(r => string.Equals(r, RoleConstants.Admin, StringComparison.OrdinalIgnoreCase));

            _isRootTenantAdmin = isRootTenant && isAdmin;
        }
        catch
        {
            _isRootTenantAdmin = false;
        }
    }
}
