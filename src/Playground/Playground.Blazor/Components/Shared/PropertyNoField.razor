@inject IDialogService DialogService

<MudTextField Value="@Value"
              ValueChanged="@((string v) => ValueChanged.InvokeAsync(v))"
              Label="@Label"
              Variant="Variant.Outlined"
              Required="@(Required && !Disabled)"
              MaxLength="@MaxLength"
              Placeholder="@Placeholder"
              Disabled="@Disabled"
              Adornment="Adornment.End"
              AdornmentIcon="@Icons.Material.Outlined.AutoAwesome"
              AdornmentColor="Color.Default"
              OnAdornmentClick="OpenGeneratorDialogAsync" />

@code {
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Label { get; set; } = "Property No.";
    [Parameter] public bool Required { get; set; }
    [Parameter] public int MaxLength { get; set; } = 32;
    [Parameter] public string Placeholder { get; set; } = string.Empty;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback<(string ClassCode, string ItemCode)> OnCodeSelected { get; set; }
    [Parameter] public int InitialYear { get; set; } = DateTime.Now.Year;

    private async Task OpenGeneratorDialogAsync()
    {
        if (Disabled) return;

        var parameters = new DialogParameters<PropertyNoGeneratorDialog>
        {
            { x => x.InitialYear, InitialYear }
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<PropertyNoGeneratorDialog>("Generate Property No.", parameters, options);
        var result = await dialog.Result;

        if (!result!.Canceled && result.Data is PropertyNoGeneratorDialog.PropertyNoResult data)
        {
            await ValueChanged.InvokeAsync(data.PropertyNo);
            if (OnCodeSelected.HasDelegate)
                await OnCodeSelected.InvokeAsync((data.ClassCode, data.ItemCode));
        }
    }
}

