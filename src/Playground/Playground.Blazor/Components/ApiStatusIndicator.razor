@using AMIS.Playground.Blazor.Services.Api
@implements IAsyncDisposable
@inject IApiHealthMonitor HealthMonitor

<div class="api-status-indicator">
    <MudTooltip Text="@StatusTooltip">
        <div class="status-dot @GetStatusClass()"></div>
    </MudTooltip>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        HealthMonitor.OnStatusChanged += OnHealthStatusChanged;
        await HealthMonitor.StartMonitoringAsync();
    }

    private void OnHealthStatusChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private string GetStatusClass()
    {
        return HealthMonitor.Status switch
        {
            ApiConnectionStatus.Healthy => "status-healthy",
            ApiConnectionStatus.Unhealthy => "status-unhealthy",
            _ => "status-unknown"
        };
    }

    private string StatusTooltip =>
        HealthMonitor.Status switch
        {
            ApiConnectionStatus.Healthy => "API: Connected",
            ApiConnectionStatus.Unhealthy => "API: Connection Lost",
            _ => "API: Checking..."
        };

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        HealthMonitor.OnStatusChanged -= OnHealthStatusChanged;
        HealthMonitor.StopMonitoring();
    }
}

<style>
    .api-status-indicator {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        transition: background-color 0.3s ease;
    }

    .status-healthy {
        background-color: #4caf50;
        box-shadow: 0 0 8px rgba(76, 175, 80, 0.6);
    }

    .status-unhealthy {
        background-color: #f44336;
        box-shadow: 0 0 8px rgba(244, 67, 54, 0.6);
    }

    .status-unknown {
        background-color: #ff9800;
        box-shadow: 0 0 8px rgba(255, 152, 0, 0.6);
    }
</style>
