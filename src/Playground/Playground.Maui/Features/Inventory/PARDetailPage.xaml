<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Playground.Maui.Features.Inventory"
             x:DataType="vm:PARDetailViewModel"
             x:Class="Playground.Maui.Features.Inventory.PARDetailPage"
             Title="PAR Detail">
    <VerticalStackLayout Padding="16" Spacing="8">
        <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" />
        <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Danger}"
               IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}" />
        <Label Text="{Binding Detail.PARNo}" FontAttributes="Bold" FontSize="18" />
        <Label Text="{Binding Detail.Date}" />
        <Label Text="{Binding Detail.PARType}" />
    </VerticalStackLayout>
</ContentPage>
