<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Playground.Maui.Features.Inventory"
             xmlns:svc="clr-namespace:Playground.Maui.Services"
             x:DataType="vm:InventoryViewModel"
             x:Class="Playground.Maui.Features.Inventory.InventoryPage"
             Title="My Inventory">
    <RefreshView IsRefreshing="{Binding IsLoading}" Command="{Binding LoadCommand}">
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="8">
                <Label Text="{Binding CacheNotice}"
                       IsVisible="{Binding CacheNotice, Converter={StaticResource IsNotNullConverter}}"
                       FontSize="12"
                       TextColor="{StaticResource Secondary}" />

                <Label Text="Inventory Custodian Slips (ICS)" FontAttributes="Bold" FontSize="16" />
                <CollectionView ItemsSource="{Binding IcsItems}" EmptyView="No ICS records found.">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="svc:ICSSummaryDto">
                            <Border Margin="0,4" Padding="12" StrokeShape="RoundRectangle 8">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <Label Grid.Row="0" Grid.Column="0" Text="{Binding ICSNo}" FontAttributes="Bold" />
                                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding Status}" />
                                    <Label Grid.Row="1" Grid.Column="0" Text="{Binding Date}" FontSize="12" />
                                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding ItemCount, StringFormat='{0} items'}" FontSize="12" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Property Acknowledgement Receipts (PAR)" FontAttributes="Bold" FontSize="16" Margin="0,16,0,0" />
                <CollectionView ItemsSource="{Binding ParItems}" EmptyView="No PAR records found.">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="svc:PARSummaryDto">
                            <Border Margin="0,4" Padding="12" StrokeShape="RoundRectangle 8">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <Label Grid.Row="0" Grid.Column="0" Text="{Binding PARNo}" FontAttributes="Bold" />
                                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding PARType}" />
                                    <Label Grid.Row="1" Grid.Column="0" Text="{Binding Date}" FontSize="12" />
                                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding ItemCount, StringFormat='{0} items'}" FontSize="12" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
