<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Playground.Maui.Features.Inventory"
             x:DataType="vm:ICSDetailViewModel"
             x:Class="Playground.Maui.Features.Inventory.ICSDetailPage"
             Title="ICS Detail"
             BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource OffBlack}}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Margin="0,24,0,16" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource Danger}"
                   FontSize="13"
                   Margin="20,16"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}" />

            <!-- Header card -->
            <Border Style="{StaticResource CardBorderStyle}" Margin="16,16,16,0" Padding="20">
                <VerticalStackLayout Spacing="8">
                    <Label Text="ICS NO." Style="{StaticResource FieldLabelStyle}" />
                    <Label Text="{Binding Detail.ICSNo}"
                           FontSize="22" FontAttributes="Bold" />
                    <Border Stroke="Transparent"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource Tertiary}}"
                            Padding="10,4"
                            HorizontalOptions="Start">
                        <Label Text="{Binding Detail.Status}"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Details card -->
            <Label Text="DOCUMENT DETAILS"
                   Style="{StaticResource SectionHeaderStyle}"
                   Margin="20,20,20,10" />

            <Border Style="{StaticResource CardBorderStyle}" Margin="16,0">
                <Grid Padding="16,14" ColumnDefinitions="*">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="DATE" Style="{StaticResource FieldLabelStyle}" />
                        <Label Text="{Binding Detail.Date}" FontSize="15" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
