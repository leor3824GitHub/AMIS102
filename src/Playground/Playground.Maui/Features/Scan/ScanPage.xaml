<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Playground.Maui.Features.Scan"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             xmlns:zxingcore="clr-namespace:ZXing.Net.Maui;assembly=ZXing.Net.MAUI"
             x:DataType="vm:ScanViewModel"
             x:Class="Playground.Maui.Features.Scan.ScanPage"
             Title="Scan Asset">

    <Grid RowDefinitions="*,Auto">

        <!-- Camera viewfinder fills available space -->
        <zxing:CameraBarcodeReaderView Grid.Row="0"
                                       x:Name="BarcodeReader"
                                       IsVisible="{Binding IsCameraAvailable}"
                                       IsDetecting="True"
                                       BarcodesDetected="OnBarcodeDetected">
            <zxing:CameraBarcodeReaderView.Options>
                <zxingcore:BarcodeReaderOptions Formats="QrCode,Code128,Code39,DataMatrix"
                                                AutoRotate="True"
                                                Multiple="False" />
            </zxing:CameraBarcodeReaderView.Options>
        </zxing:CameraBarcodeReaderView>

        <!-- No camera placeholder -->
        <VerticalStackLayout Grid.Row="0"
                             IsVisible="{Binding IsCameraAvailable, Converter={StaticResource InvertedBoolConverter}}"
                             VerticalOptions="Center" HorizontalOptions="Center"
                             Spacing="12" Padding="32">
            <Label Text="&#x1F4F7;"
                   FontSize="52"
                   HorizontalOptions="Center" />
            <Label Text="Camera not available on this device."
                   FontSize="14"
                   TextColor="{StaticResource Gray400}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
            <Label Text="Use the search box below to look up a property number."
                   FontSize="13"
                   TextColor="{StaticResource Gray400}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- Bottom panel: manual entry -->
        <Border Grid.Row="1"
                Stroke="Transparent"
                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}"
                Padding="20,16,20,24">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20,20,0,0" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-4" Radius="16" Opacity="0.06" />
            </Border.Shadow>

            <VerticalStackLayout Spacing="12">
                <Label Text="MANUAL ENTRY"
                       Style="{StaticResource SectionHeaderStyle}"
                       Margin="0,0,0,0" />

                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <Entry Grid.Column="0"
                           Placeholder="Property No. e.g. SPLV-2026-01-0001"
                           Text="{Binding ManualPropertyNo}"
                           ReturnCommand="{Binding SearchManualCommand}"
                           AutomationId="PropertyNoEntry" />
                    <Button Grid.Column="1"
                            Text="Search"
                            Command="{Binding SearchManualCommand}" />
                    <Button Grid.Column="2"
                            Text="Scan Text"
                            IsVisible="{Binding IsOcrSupported}"
                            IsEnabled="{Binding IsOcrBusy, Converter={StaticResource InvertedBoolConverter}}"
                            Command="{Binding ScanTextCommand}" />
                </Grid>

                <ActivityIndicator IsRunning="{Binding IsOcrBusy}"
                                   IsVisible="{Binding IsOcrBusy}"
                                   HorizontalOptions="Center" />

                <Label Text="{Binding ErrorMessage}"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                       TextColor="{StaticResource Danger}"
                       FontSize="13"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>
