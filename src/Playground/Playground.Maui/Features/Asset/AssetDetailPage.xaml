<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Playground.Maui.Features.Asset"
             x:DataType="vm:AssetDetailViewModel"
             x:Class="Playground.Maui.Features.Asset.AssetDetailPage"
             Title="Asset Detail">
    <VerticalStackLayout Padding="16" Spacing="8">
        <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" />
        <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Danger}"
               IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}" />
        <Label Text="{Binding PropertyNo}" FontSize="13" TextColor="{StaticResource Secondary}" />
        <Label Text="{Binding Item.ItemName}" FontAttributes="Bold" FontSize="20" />
        <Label Text="{Binding Item.Description}" />
        <Label Text="{Binding Item.AssetType}" />
        <Label Text="{Binding Item.UnitCost, StringFormat='Unit Cost: {0:C}'}" />
        <Label Text="{Binding Item.LinkedDocumentType}" />
        <Label Text="{Binding Item.LinkedDocumentNo}" />
    </VerticalStackLayout>
</ContentPage>
