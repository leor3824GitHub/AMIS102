<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Playground.Maui.Features.PhysicalCount"
             x:DataType="vm:PhysicalCountFoundAtStationViewModel"
             x:Class="Playground.Maui.Features.PhysicalCount.PhysicalCountFoundAtStationPage"
             Title="Found at Station">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" />

            <Label Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                   TextColor="{StaticResource Danger}"
                   FontSize="13" />

            <!-- Property number (pre-filled from scan, read-only display) -->
            <Border StrokeShape="RoundRectangle 8" Padding="14" BackgroundColor="{StaticResource Gray100}">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Property No." FontSize="11" TextColor="{StaticResource Gray500}" />
                    <Label Text="{Binding PropertyNo}" FontAttributes="Bold" FontSize="16" />
                </VerticalStackLayout>
            </Border>

            <Label Text="This asset is not on the pre-generated checklist. Fill in the details below."
                   FontSize="12"
                   TextColor="{StaticResource Gray500}" />

            <!-- Description (required) -->
            <VerticalStackLayout Spacing="4">
                <Label FontAttributes="Bold" FontSize="13">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Description" />
                            <Span Text=" *" TextColor="{StaticResource Danger}" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <Entry Text="{Binding Description}" Placeholder="e.g. Dell Laptop Model XYZ" />
            </VerticalStackLayout>

            <!-- Unit Cost -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Unit Cost (₱)" FontAttributes="Bold" FontSize="13" />
                <Entry Keyboard="Numeric"
                       Text="{Binding UnitCostText}"
                       Placeholder="0.00" />
            </VerticalStackLayout>

            <!-- Condition -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Condition" FontAttributes="Bold" FontSize="13" />
                <Picker ItemsSource="{Binding Conditions}"
                        SelectedIndex="{Binding SelectedConditionIndex}"
                        Title="Select condition" />
            </VerticalStackLayout>

            <!-- Remarks -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Remarks (optional)" FontAttributes="Bold" FontSize="13" />
                <Editor Text="{Binding Remarks}"
                        Placeholder="e.g. found in stock room, sticker missing"
                        HeightRequest="80"
                        AutoSize="TextChanges" />
            </VerticalStackLayout>

            <!-- Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0"
                        Text="Cancel"
                        Command="{Binding CancelCommand}"
                        BackgroundColor="{StaticResource Gray200}"
                        TextColor="{StaticResource Gray900}" />
                <Button Grid.Column="1"
                        Text="Add Entry"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
