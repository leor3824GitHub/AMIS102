<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Playground.Maui.Features.PhysicalCount"
             xmlns:svc="clr-namespace:Playground.Maui.Services"
             x:Name="ThisPage"
             x:DataType="vm:PhysicalCountSessionListViewModel"
             x:Class="Playground.Maui.Features.PhysicalCount.PhysicalCountSessionListPage"
             Title="Physical Count"
             BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource OffBlack}}">

    <RefreshView IsRefreshing="{Binding IsLoading}" Command="{Binding LoadCommand}">
        <VerticalStackLayout Padding="0,16,0,24" Spacing="0">

            <!-- Sync banner -->
            <Border IsVisible="{Binding HasPendingSync}"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 10"
                    BackgroundColor="{StaticResource Warning}"
                    Padding="14,10"
                    Margin="16,0,16,12">
                <Label Text="{Binding PendingSyncCount, StringFormat='{0} entry(s) pending sync — connect to upload.'}"
                       FontSize="12"
                       TextColor="White" />
            </Border>

            <!-- Error -->
            <Label Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                   TextColor="{StaticResource Danger}"
                   FontSize="13"
                   Margin="20,0,20,12" />

            <!-- Section header -->
            <Label Text="SESSIONS"
                   Style="{StaticResource SectionHeaderStyle}" />

            <!-- Sessions list -->
            <CollectionView ItemsSource="{Binding Sessions}"
                            SelectionMode="Single"
                            SelectionChanged="OnSessionSelected"
                            EmptyView="No physical count sessions found.">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="svc:PhysicalCountSessionSummaryDto">
                        <Border Style="{StaticResource CardBorderStyle}"
                                Margin="16,4" Padding="16,14">
                            <Grid ColumnDefinitions="*,Auto"
                                  RowDefinitions="Auto,Auto,Auto"
                                  RowSpacing="4">

                                <!-- SessionNo + Status badge -->
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding SessionNo}"
                                       FontFamily="InterSemiBold" FontSize="15" />
                                <Border Grid.Row="0" Grid.Column="1"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 10"
                                        BackgroundColor="{StaticResource Gray300}"
                                        Padding="8,3">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Open">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Warning}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Submitted">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Success}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label Text="{Binding Status}"
                                           TextColor="White"
                                           FontFamily="InterSemiBold" FontSize="11" />
                                </Border>

                                <!-- StationOffice + Scope -->
                                <Label Grid.Row="1" Grid.Column="0"
                                       Text="{Binding StationOffice}"
                                       FontSize="13"
                                       TextColor="{StaticResource Gray500}" />
                                <Label Grid.Row="1" Grid.Column="1"
                                       Text="{Binding Scope}"
                                       Style="{StaticResource CaptionStyle}" />

                                <!-- Date + Progress -->
                                <Label Grid.Row="2" Grid.Column="0"
                                       Text="{Binding CountDate}"
                                       Style="{StaticResource CaptionStyle}" />
                                <Label Grid.Row="2" Grid.Column="1"
                                       FontSize="11"
                                       TextColor="{StaticResource Gray400}">
                                    <Label.Text>
                                        <MultiBinding StringFormat="{}{0}/{1} verified">
                                            <Binding Path="Found" />
                                            <Binding Path="TotalEntries" />
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </RefreshView>
</ContentPage>
