<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Playground.Maui.Features.Auth"
             x:DataType="vm:SetPinViewModel"
             x:Class="Playground.Maui.Features.Auth.SetPinPage"
             Title="Set Up PIN"
             BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource OffBlack}}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <VerticalStackLayout Padding="32,40,32,28" Spacing="10" HorizontalOptions="Center">
                <Border StrokeShape="RoundRectangle 20"
                        Stroke="Transparent"
                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource Tertiary}}"
                        WidthRequest="64" HeightRequest="64"
                        HorizontalOptions="Center">
                    <Label Text="&#x1F510;"
                           FontSize="28"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Label Text="Set Up Offline PIN"
                       FontSize="22" FontAttributes="Bold"
                       HorizontalOptions="Center" />
                <Label Text="Create a PIN so you can log in without an internet connection."
                       FontSize="13"
                       TextColor="{StaticResource Gray400}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- PIN card -->
            <Border Style="{StaticResource CardBorderStyle}" Margin="20,0" Padding="20">
                <VerticalStackLayout Spacing="0">

                    <VerticalStackLayout Spacing="4" Padding="0,0,0,14">
                        <Label Text="NEW PIN (4–6 digits)" Style="{StaticResource FieldLabelStyle}" />
                        <Entry Placeholder="••••••"
                               Text="{Binding Pin}"
                               IsPassword="True"
                               Keyboard="Numeric"
                               MaxLength="6"
                               AutomationId="PinEntry" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray600}}" />

                    <VerticalStackLayout Spacing="4" Padding="0,14,0,0">
                        <Label Text="CONFIRM PIN" Style="{StaticResource FieldLabelStyle}" />
                        <Entry Placeholder="••••••"
                               Text="{Binding ConfirmPin}"
                               IsPassword="True"
                               Keyboard="Numeric"
                               MaxLength="6"
                               AutomationId="ConfirmPinEntry" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- Error -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource Danger}"
                   FontSize="13"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="20,14,20,0"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}" />

            <!-- Spinner -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               HorizontalOptions="Center"
                               Margin="0,16,0,0" />

            <!-- Set PIN -->
            <Button Text="Set PIN"
                    Command="{Binding SetPinCommand}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                    Margin="20,20,20,8" />

            <!-- Skip -->
            <Button Text="Skip for now"
                    Command="{Binding SkipCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                    Margin="20,0,20,40" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
