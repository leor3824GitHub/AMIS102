<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Playground.Maui.Features.Auth"
             x:DataType="vm:LoginViewModel"
             x:Class="Playground.Maui.Features.Auth.LoginPage"
             Title=""
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PrimaryLight}">

    <ScrollView>
        <VerticalStackLayout Padding="32,72,32,40" Spacing="0">

            <!-- Branding -->
            <VerticalStackLayout Spacing="12" HorizontalOptions="Center" Margin="0,0,0,48">
                <Border StrokeShape="RoundRectangle 20"
                        Stroke="Transparent"
                        BackgroundColor="{StaticResource Primary}"
                        WidthRequest="80" HeightRequest="80"
                        HorizontalOptions="Center">
                    <Label Text="A"
                           FontSize="36" FontAttributes="Bold"
                           TextColor="{StaticResource White}"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Label Text="AMIS Mobile"
                       FontSize="22" FontAttributes="Bold"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Tenant -->
            <Label Text="Tenant"
                   FontSize="13"
                   TextColor="{StaticResource Gray500}"
                   Margin="0,0,0,6" />
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="{StaticResource Gray100}"
                    BackgroundColor="{StaticResource White}"
                    Padding="16,0"
                    Margin="0,0,0,16">
                <Entry Placeholder="e.g. root"
                       Text="{Binding Tenant}"
                       AutomationId="TenantEntry" />
            </Border>

            <!-- Email -->
            <Label Text="Your email"
                   FontSize="13"
                   TextColor="{StaticResource Gray500}"
                   Margin="0,0,0,6" />
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="{StaticResource Gray100}"
                    BackgroundColor="{StaticResource White}"
                    Padding="16,0"
                    Margin="0,0,0,16">
                <Entry Placeholder="Enter your email"
                       Text="{Binding Email}"
                       Keyboard="Email"
                       AutomationId="EmailEntry" />
            </Border>

            <!-- Password -->
            <Label Text="Password"
                   FontSize="13"
                   TextColor="{StaticResource Gray500}"
                   Margin="0,0,0,6" />
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="{StaticResource Gray100}"
                    BackgroundColor="{StaticResource White}"
                    Padding="16,0"
                    Margin="0,0,0,32">
                <Grid ColumnDefinitions="*,44">
                    <Entry Grid.Column="0"
                           Placeholder="Enter your password"
                           Text="{Binding Password}"
                           IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InvertedBoolConverter}}"
                           AutomationId="PasswordEntry" />
                    <ImageButton Grid.Column="1"
                                 Source="eye.svg"
                                 Command="{Binding TogglePasswordVisibilityCommand}"
                                 BackgroundColor="Transparent"
                                 WidthRequest="24" HeightRequest="24"
                                 HorizontalOptions="Center" VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Error -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource Danger}"
                   FontSize="13"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,12"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}" />

            <!-- Spinner -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               HorizontalOptions="Center"
                               Margin="0,0,0,12" />

            <!-- Sign In -->
            <Button Text="Sign In"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                    HeightRequest="52"
                    CornerRadius="12"
                    FontSize="16"
                    FontAttributes="Bold"
                    Margin="0,0,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
