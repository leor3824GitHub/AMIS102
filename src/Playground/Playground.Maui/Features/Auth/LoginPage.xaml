<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Playground.Maui.Features.Auth"
             x:DataType="vm:LoginViewModel"
             x:Class="Playground.Maui.Features.Auth.LoginPage"
             Title="Sign In">
    <ScrollView>
        <VerticalStackLayout Padding="32" Spacing="16" VerticalOptions="Center">
            <Label Text="AMIS Mobile"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Entry Placeholder="Tenant"
                   Text="{Binding Tenant}"
                   AutomationId="TenantEntry" />

            <Entry Placeholder="Email"
                   Text="{Binding Email}"
                   Keyboard="Email"
                   AutomationId="EmailEntry" />

            <Entry Placeholder="Password"
                   Text="{Binding Password}"
                   IsPassword="True"
                   AutomationId="PasswordEntry" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource Danger}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}" />

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               HorizontalOptions="Center" />

            <Button Text="Sign In"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
