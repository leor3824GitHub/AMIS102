<?xml version="1.0" encoding="utf-8"?>
<Report ScriptLanguage="CSharp" ReportInfo.Created="05/17/2026 00:00:00" ReportInfo.Modified="05/17/2026 00:00:00" ReportInfo.CreatorVersion="2025.1.0">
  <Dictionary />
  <!--
    Data sources are registered at runtime via Report.RegisterData(IEnumerable, name).
    Do NOT predeclare them as <TableDataSource DataType="System.Data.DataTable"> here —
    that conflicts with the BusinessObjectDataSource created by RegisterData and causes
    "Table is not connected to the data" at PrepareAsync time.
  -->

  <!--
    Layout: A4 landscape (297 × 210 mm), 8 mm margins.
    Content width  = (297-16) × 3.7795 = 1062 units
    Content height = (210-16) × 3.7795 =  733 units

    Two identical PR copies side-by-side with a 2× margin gap for cutting:
      Left  copy : x = 0   … 500   (500 units ≈ 132.3 mm)
      Gap        : x = 500 … 562   ( 62 units ≈  16.4 mm)  ← cut here (≈ 2× the 8 mm margin)
      Right copy : x = 562 … 1062  (500 units ≈ 132.3 mm)

    Table column widths (each copy, total 500):
      Stock No  (10%)  :  50     x=0/562
      Unit       (8%)  :  40     x=50/612
      Description(51%) : 255     x=90/652
      Quantity   (9%)  :  45     x=345/907
      Unit Cost (11%)  :  55     x=390/952
      Total Cost(11%)  :  55     x=445/1007
  -->

  <ReportPage Name="Page1"
    Watermark.Font="Arial, 60pt"
    PaperWidth="297" PaperHeight="210"
    LeftMargin="8" TopMargin="8" RightMargin="8" BottomMargin="8"
    Landscape="true">

    <!-- ═══════════════════════════════════════════════════════════
         TITLE BAND  (appears once, height = 148 units)
         Contains: org header, PR title, PR form header, table col headers
         ═══════════════════════════════════════════════════════════ -->
