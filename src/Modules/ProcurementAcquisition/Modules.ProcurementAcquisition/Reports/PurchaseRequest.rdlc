<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df"
        xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition"
        xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner"
        xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Arial</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>

  <!-- ═══════════ DATA SOURCES ═══════════ -->
  <DataSources>
    <DataSource Name="PurchaseRequestDS">
      <ConnectionProperties><DataProvider>System.Object</DataProvider><ConnectString /></ConnectionProperties>
    </DataSource>
    <DataSource Name="LineItemsDS">
      <ConnectionProperties><DataProvider>System.Object</DataProvider><ConnectString /></ConnectionProperties>
    </DataSource>
    <DataSource Name="OrganizationProfileDS">
      <ConnectionProperties><DataProvider>System.Object</DataProvider><ConnectString /></ConnectionProperties>
    </DataSource>
  </DataSources>

  <!-- ═══════════ DATA SETS ═══════════ -->
  <DataSets>

    <DataSet Name="PurchaseRequestDS">
      <Query><DataSourceName>PurchaseRequestDS</DataSourceName><CommandText /></Query>
      <Fields>
        <Field Name="PrNumber"><DataField>PrNumber</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="PrDate"><DataField>PrDate</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="SaiNumber"><DataField>SaiNumber</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="SaiDate"><DataField>SaiDate</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="AlobsNumber"><DataField>AlobsNumber</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="AlobsDate"><DataField>AlobsDate</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="DepartmentName"><DataField>DepartmentName</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="ResponsibilityCenterCode"><DataField>ResponsibilityCenterCode</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Purpose"><DataField>Purpose</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Justification"><DataField>Justification</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="RequestedByName"><DataField>RequestedByName</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="ApprovedByName"><DataField>ApprovedByName</DataField><rd:TypeName>System.String</rd:TypeName></Field>
      </Fields>
    </DataSet>

    <DataSet Name="LineItemsDS">
      <Query><DataSourceName>LineItemsDS</DataSourceName><CommandText /></Query>
      <Fields>
        <Field Name="ItemNo"><DataField>ItemNo</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="UnitOfIssue"><DataField>UnitOfIssue</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="ItemDescription"><DataField>ItemDescription</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Quantity"><DataField>Quantity</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="EstimatedUnitCost"><DataField>EstimatedUnitCost</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="EstimatedTotalCost"><DataField>EstimatedTotalCost</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
      </Fields>
    </DataSet>

    <DataSet Name="OrganizationProfileDS">
      <Query><DataSourceName>OrganizationProfileDS</DataSourceName><CommandText /></Query>
      <Fields>
        <Field Name="Name"><DataField>Name</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Address"><DataField>Address</DataField><rd:TypeName>System.String</rd:TypeName></Field>
      </Fields>
    </DataSet>

  </DataSets>

  <!-- ═══════════ REPORT BODY ═══════════ -->
  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>

          <!-- ╔══════════════════════════════════════════════════════════╗ -->
          <!-- ║  MAIN LAYOUT TABLE — single-column flowing container    ║ -->
          <!-- ╚══════════════════════════════════════════════════════════╝ -->
          <Tablix Name="MainTable">
            <TablixBody>
              <TablixColumns>
                <TablixColumn><Width>7.5in</Width></TablixColumn>
              </TablixColumns>
              <TablixRows>

                <!-- ─── ROW A: AGENCY HEADER ─── -->
                <TablixRow>
                  <Height>0.7in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Rectangle Name="AgencyHeaderRect">
                          <ReportItems>
                            <Textbox Name="RepublicTxt">
                              <Value>Republic of the Philippines</Value>
                              <Top>0in</Top><Left>0in</Left><Width>7.5in</Width><Height>0.2in</Height>
                              <Style><FontSize>8pt</FontSize><TextAlign>Center</TextAlign></Style>
                            </Textbox>
                            <Textbox Name="AgencyNameTxt">
                              <Value>=First(Fields!Name.Value, "OrganizationProfileDS")</Value>
                              <Top>0.2in</Top><Left>0in</Left><Width>7.5in</Width><Height>0.27in</Height>
                              <Style><FontSize>12pt</FontSize><FontWeight>Bold</FontWeight><TextAlign>Center</TextAlign></Style>
                            </Textbox>
                            <Textbox Name="AgencyAddressTxt">
                              <Value>=First(Fields!Address.Value, "OrganizationProfileDS")</Value>
                              <Top>0.47in</Top><Left>0in</Left><Width>7.5in</Width><Height>0.18in</Height>
                              <Style><FontSize>8pt</FontSize><TextAlign>Center</TextAlign></Style>
                            </Textbox>
                          </ReportItems>
                          <Top>0in</Top><Left>0in</Left><Width>7.5in</Width><Height>0.7in</Height>
                          <Style />
                        </Rectangle>
                      </CellContents>
                    </TablixCell>
                  </TablixCells>
                </TablixRow>

                <!-- ─── ROW B: REPORT TITLE ─── -->
                <TablixRow>
                  <Height>0.4in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ReportTitleTxt">
                          <Value>PURCHASE REQUEST</Value>
                          <Style>
                            <FontSize>14pt</FontSize><FontWeight>Bold</FontWeight>
                            <TextAlign>Center</TextAlign><VerticalAlign>Middle</VerticalAlign>
                            <BorderStyle><Top>Solid</Top><Bottom>Solid</Bottom></BorderStyle>
                            <BorderWidth><Top>2pt</Top><Bottom>1pt</Bottom></BorderWidth>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                  </TablixCells>
                </TablixRow>

                <!-- ─── ROW C: HEADER INFO (4-col, 6-row nested table) ─── -->
                <TablixRow>
                  <Height>1.6in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Tablix Name="HeaderInfoTable">
                          <TablixBody>
                            <TablixColumns>
                              <TablixColumn><Width>1.3in</Width></TablixColumn>
                              <TablixColumn><Width>2.2in</Width></TablixColumn>
                              <TablixColumn><Width>1.2in</Width></TablixColumn>
                              <TablixColumn><Width>2.8in</Width></TablixColumn>
                            </TablixColumns>
                            <TablixRows>

                              <!-- Row 1: Department | PR No. -->
                              <TablixRow><Height>0.25in</Height><TablixCells>
                                <TablixCell><CellContents><Textbox Name="HiLblDept"><Value>Department:</Value><Style><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValDept"><Value>=First(Fields!DepartmentName.Value, "PurchaseRequestDS")</Value><Style><FontSize>8pt</FontSize><VerticalAlign>Middle</VerticalAlign><PaddingLeft>3pt</PaddingLeft><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiLblPrNo"><Value>PR No.:</Value><Style><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValPrNo"><Value>=First(Fields!PrNumber.Value, "PurchaseRequestDS")</Value><Style><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight><VerticalAlign>Middle</VerticalAlign><PaddingLeft>3pt</PaddingLeft><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                              </TablixCells></TablixRow>

                              <!-- Row 2: RC Code | PR Date -->
                              <TablixRow><Height>0.25in</Height><TablixCells>
                                <TablixCell><CellContents><Textbox Name="HiLblRc"><Value>RC Code:</Value><Style><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValRc"><Value>=First(Fields!ResponsibilityCenterCode.Value, "PurchaseRequestDS")</Value><Style><FontSize>8pt</FontSize><VerticalAlign>Middle</VerticalAlign><PaddingLeft>3pt</PaddingLeft><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiLblPrDate"><Value>PR Date:</Value><Style><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValPrDate"><Value>=First(Fields!PrDate.Value, "PurchaseRequestDS")</Value><Style><FontSize>8pt</FontSize><VerticalAlign>Middle</VerticalAlign><PaddingLeft>3pt</PaddingLeft><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                              </TablixCells></TablixRow>

                              <!-- Row 3: (empty) | SAI No. -->
                              <TablixRow><Height>0.25in</Height><TablixCells>
                                <TablixCell><CellContents><Textbox Name="HiLblE1"><Value /><Style><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValE1"><Value /><Style><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiLblSaiNo"><Value>SAI No.:</Value><Style><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></borderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValSaiNo"><Value>=First(Fields!SaiNumber.Value, "PurchaseRequestDS")</Value><Style><FontSize>8pt</FontSize><VerticalAlign>Middle</VerticalAlign><PaddingLeft>3pt</PaddingLeft><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                              </TablixCells></TablixRow>

                              <!-- Row 4: (empty) | SAI Date -->
                              <TablixRow><Height>0.25in</Height><TablixCells>
                                <TablixCell><CellContents><Textbox Name="HiLblE2"><Value /><Style><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValE2"><Value /><Style><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiLblSaiDate"><Value>SAI Date:</Value><Style><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValSaiDate"><Value>=First(Fields!SaiDate.Value, "PurchaseRequestDS")</Value><Style><FontSize>8pt</FontSize><VerticalAlign>Middle</VerticalAlign><PaddingLeft>3pt</PaddingLeft><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                              </TablixCells></TablixRow>

                              <!-- Row 5: (empty) | ALOBS No. -->
                              <TablixRow><Height>0.25in</Height><TablixCells>
                                <TablixCell><CellContents><Textbox Name="HiLblE3"><Value /><Style><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValE3"><Value /><Style><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiLblAlobsNo"><Value>ALOBS No.:</Value><Style><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValAlobsNo"><Value>=First(Fields!AlobsNumber.Value, "PurchaseRequestDS")</Value><Style><FontSize>8pt</FontSize><VerticalAlign>Middle</VerticalAlign><PaddingLeft>3pt</PaddingLeft><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                              </TablixCells></TablixRow>

                              <!-- Row 6: (empty) | ALOBS Date -->
                              <TablixRow><Height>0.25in</Height><TablixCells>
                                <TablixCell><CellContents><Textbox Name="HiLblE4"><Value /><Style><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValE4"><Value /><Style><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiLblAlobsDate"><Value>ALOBS Date:</Value><Style><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValAlobsDate"><Value>=First(Fields!AlobsDate.Value, "PurchaseRequestDS")</Value><Style><FontSize>8pt</FontSize><VerticalAlign>Middle</VerticalAlign><PaddingLeft>3pt</PaddingLeft><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>Gray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                              </TablixCells></TablixRow>

                            </TablixRows>
                          </TablixBody>
                          <TablixColumnHierarchy><TablixMembers><TablixMember /><TablixMember /><TablixMember /><TablixMember /></TablixMembers></TablixColumnHierarchy>
                          <TablixRowHierarchy><TablixMembers><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /></TablixMembers></TablixRowHierarchy>
                          <Top>0in</Top><Left>0in</Left><Width>7.5in</Width>
                        </Tablix>
                      </CellContents>
                    </TablixCell>
                  </TablixCells>
                </TablixRow>

                <!-- ─── ROW D: LINE ITEMS (nested Tablix, DataSet=LineItemsDS) ─── -->
                <TablixRow>
                  <Height>0.53in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Tablix Name="LineItemsTable">
                          <TablixBody>
                            <TablixColumns>
                              <TablixColumn><Width>0.35in</Width></TablixColumn>
                              <TablixColumn><Width>0.65in</Width></TablixColumn>
                              <TablixColumn><Width>3.5in</Width></TablixColumn>
                              <TablixColumn><Width>0.65in</Width></TablixColumn>
                              <TablixColumn><Width>1.15in</Width></TablixColumn>
                              <TablixColumn><Width>1.2in</Width></TablixColumn>
                            </TablixColumns>
                            <TablixRows>

                              <!-- HEADER ROW -->
                              <TablixRow><Height>0.28in</Height><TablixCells>
                                <TablixCell><CellContents><Textbox Name="LiHdrNo"><Value>Item No.</Value><Style><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight><TextAlign>Center</TextAlign><VerticalAlign>Middle</VerticalAlign><BackgroundColor>LightGray</BackgroundColor><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>DimGray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="LiHdrUnit"><Value>Unit</Value><Style><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight><TextAlign>Center</TextAlign><VerticalAlign>Middle</VerticalAlign><BackgroundColor>LightGray</BackgroundColor><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>DimGray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="LiHdrDesc"><Value>Description of Articles</Value><Style><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight><TextAlign>Center</TextAlign><VerticalAlign>Middle</VerticalAlign><BackgroundColor>LightGray</BackgroundColor><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>DimGray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="LiHdrQty"><Value>Qty</Value><Style><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight><TextAlign>Center</TextAlign><VerticalAlign>Middle</VerticalAlign><BackgroundColor>LightGray</BackgroundColor><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>DimGray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="LiHdrUnitCost"><Value>Est. Unit Cost</Value><Style><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight><TextAlign>Center</TextAlign><VerticalAlign>Middle</VerticalAlign><BackgroundColor>LightGray</BackgroundColor><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>DimGray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="LiHdrTotalCost"><Value>Est. Total Cost</Value><Style><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight><TextAlign>Center</TextAlign><VerticalAlign>Middle</VerticalAlign><BackgroundColor>LightGray</BackgroundColor><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>DimGray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                              </TablixCells></TablixRow>

                              <!-- DETAIL ROW -->
                              <TablixRow><Height>0.25in</Height><TablixCells>
                                <TablixCell><CellContents><Textbox Name="LiDetNo"><Value>=Fields!ItemNo.Value</Value><CanGrow>true</CanGrow><Style><FontSize>8pt</FontSize><TextAlign>Center</TextAlign><VerticalAlign>Middle</VerticalAlign><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>LightGray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="LiDetUnit"><Value>=Fields!UnitOfIssue.Value</Value><CanGrow>true</CanGrow><Style><FontSize>8pt</FontSize><TextAlign>Center</TextAlign><VerticalAlign>Middle</VerticalAlign><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>LightGray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="LiDetDesc"><Value>=Fields!ItemDescription.Value</Value><CanGrow>true</CanGrow><Style><FontSize>8pt</FontSize><TextAlign>Left</TextAlign><VerticalAlign>Middle</VerticalAlign><PaddingLeft>3pt</PaddingLeft><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>LightGray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="LiDetQty"><Value>=Fields!Quantity.Value</Value><CanGrow>true</CanGrow><Style><FontSize>8pt</FontSize><TextAlign>Center</TextAlign><VerticalAlign>Middle</VerticalAlign><Format>#,##0.##</Format><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>LightGray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="LiDetUnitCost"><Value>=Fields!EstimatedUnitCost.Value</Value><Style><FontSize>8pt</FontSize><TextAlign>Right</TextAlign><VerticalAlign>Middle</VerticalAlign><PaddingRight>3pt</PaddingRight><Format>#,##0.00</Format><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>LightGray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="LiDetTotalCost"><Value>=Fields!EstimatedTotalCost.Value</Value><Style><FontSize>8pt</FontSize><TextAlign>Right</TextAlign><VerticalAlign>Middle</VerticalAlign><PaddingRight>3pt</PaddingRight><Format>#,##0.00</Format><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>LightGray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                              </TablixCells></TablixRow>

                              <!-- FOOTER ROW: TOTAL -->
                              <TablixRow><Height>0.25in</Height><TablixCells>
                                <TablixCell><CellContents><Textbox Name="LiFtrE1"><Value /><Style><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>DimGray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="LiFtrE2"><Value /><Style><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>DimGray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="LiFtrE3"><Value /><Style><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>DimGray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="LiFtrE4"><Value /><Style><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>DimGray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="LiFtrTotalLbl"><Value>TOTAL:</Value><Style><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight><TextAlign>Right</TextAlign><VerticalAlign>Middle</VerticalAlign><PaddingRight>3pt</PaddingRight><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>DimGray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="LiFtrTotalVal"><Value>=Sum(Fields!EstimatedTotalCost.Value)</Value><Style><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight><TextAlign>Right</TextAlign><VerticalAlign>Middle</VerticalAlign><PaddingRight>3pt</PaddingRight><Format>#,##0.00</Format><BorderStyle><Default>Solid</Default></BorderStyle><BorderColor><Default>DimGray</Default></BorderColor></Style></Textbox></CellContents></TablixCell>
                              </TablixCells></TablixRow>

                            </TablixRows>
                          </TablixBody>
                          <TablixColumnHierarchy><TablixMembers><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /></TablixMembers></TablixColumnHierarchy>
                          <TablixRowHierarchy>
                            <TablixMembers>
                              <TablixMember>
                                <KeepWithGroup>After</KeepWithGroup>
                                <RepeatOnNewPage>true</RepeatOnNewPage>
                                <KeepTogether>true</KeepTogether>
                              </TablixMember>
                              <TablixMember>
                                <Group Name="LineItems_Detail">
                                  <GroupExpressions>
                                    <GroupExpression>=Fields!ItemNo.Value</GroupExpression>
                                  </GroupExpressions>
                                </Group>
                              </TablixMember>
                              <TablixMember>
                                <KeepWithGroup>Before</KeepWithGroup>
                              </TablixMember>
                            </TablixMembers>
                          </TablixRowHierarchy>
                          <DataSetName>LineItemsDS</DataSetName>
                          <Top>0in</Top><Left>0in</Left><Width>7.5in</Width>
                        </Tablix>
                      </CellContents>
                    </TablixCell>
                  </TablixCells>
                </TablixRow>

                <!-- ─── ROW E: PURPOSE / JUSTIFICATION ─── -->
                <TablixRow>
                  <Height>0.9in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Rectangle Name="PurposeRect">
                          <ReportItems>
                            <Textbox Name="PurposeLblTxt">
                              <Value>Purpose / Description of Project:</Value>
                              <Top>0in</Top><Left>0in</Left><Width>7.5in</Width><Height>0.22in</Height>
                              <Style><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight><VerticalAlign>Middle</VerticalAlign></Style>
                            </Textbox>
                            <Textbox Name="PurposeValTxt">
                              <Value>=First(Fields!Purpose.Value, "PurchaseRequestDS")</Value>
                              <CanGrow>true</CanGrow>
                              <Top>0.22in</Top><Left>0in</Left><Width>7.5in</Width><Height>0.65in</Height>
                              <Style>
                                <FontSize>8pt</FontSize><VerticalAlign>Top</VerticalAlign>
                                <PaddingLeft>3pt</PaddingLeft><PaddingTop>2pt</PaddingTop>
                                <BorderStyle><Default>Solid</Default></BorderStyle>
                                <BorderColor><Default>LightGray</Default></BorderColor>
                              </Style>
                            </Textbox>
                          </ReportItems>
                          <Top>0in</Top><Left>0in</Left><Width>7.5in</Width><Height>0.9in</Height>
                          <Style />
                        </Rectangle>
                      </CellContents>
                    </TablixCell>
                  </TablixCells>
                </TablixRow>

                <!-- ─── ROW F: SIGNATURE SECTION (3-col) ─── -->
                <TablixRow>
                  <Height>1.2in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Tablix Name="SignatureTable">
                          <TablixBody>
                            <TablixColumns>
                              <TablixColumn><Width>2.5in</Width></TablixColumn>
                              <TablixColumn><Width>2.5in</Width></TablixColumn>
                              <TablixColumn><Width>2.5in</Width></TablixColumn>
                            </TablixColumns>
                            <TablixRows>
                              <!-- Labels -->
                              <TablixRow><Height>0.25in</Height><TablixCells>
                                <TablixCell><CellContents><Textbox Name="SigLblReq"><Value>Requested By:</Value><Style><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight><VerticalAlign>Bottom</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="SigLblMid"><Value /><Style /></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="SigLblAppr"><Value>Approved By:</Value><Style><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight><VerticalAlign>Bottom</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                              </TablixCells></TablixRow>
                              <!-- Names with signature line -->
                              <TablixRow><Height>0.55in</Height><TablixCells>
                                <TablixCell><CellContents><Textbox Name="SigValReq"><Value>=First(Fields!RequestedByName.Value, "PurchaseRequestDS")</Value><Style><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><TextAlign>Center</TextAlign><VerticalAlign>Bottom</VerticalAlign><BorderStyle><Bottom>Solid</Bottom></BorderStyle></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="SigValMid"><Value /><Style /></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="SigValAppr"><Value>=First(Fields!ApprovedByName.Value, "PurchaseRequestDS")</Value><Style><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><TextAlign>Center</TextAlign><VerticalAlign>Bottom</VerticalAlign><BorderStyle><Bottom>Solid</Bottom></BorderStyle></Style></Textbox></CellContents></TablixCell>
                              </TablixCells></TablixRow>
                              <!-- Designations -->
                              <TablixRow><Height>0.22in</Height><TablixCells>
                                <TablixCell><CellContents><Textbox Name="SigDesReq"><Value>Requesting Officer / Designation</Value><Style><FontSize>7pt</FontSize><TextAlign>Center</TextAlign><VerticalAlign>Top</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="SigDesMid"><Value /><Style /></Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="SigDesAppr"><Value>Head of Agency / HOPE</Value><Style><FontSize>7pt</FontSize><TextAlign>Center</TextAlign><VerticalAlign>Top</VerticalAlign></Style></Textbox></CellContents></TablixCell>
                              </TablixCells></TablixRow>
                            </TablixRows>
                          </TablixBody>
                          <TablixColumnHierarchy><TablixMembers><TablixMember /><TablixMember /><TablixMember /></TablixMembers></TablixColumnHierarchy>
                          <TablixRowHierarchy><TablixMembers><TablixMember /><TablixMember /><TablixMember /></TablixMembers></TablixRowHierarchy>
                          <Top>0in</Top><Left>0in</Left><Width>7.5in</Width>
                        </Tablix>
                      </CellContents>
                    </TablixCell>
                  </TablixCells>
                </TablixRow>

              </TablixRows>
            </TablixBody>

            <!-- Outer table hierarchy (6 static rows, no dataset) -->
            <TablixColumnHierarchy><TablixMembers><TablixMember /></TablixMembers></TablixColumnHierarchy>
            <TablixRowHierarchy>
              <TablixMembers>
                <TablixMember /> <!-- A: Agency Header -->
                <TablixMember /> <!-- B: Title -->
                <TablixMember /> <!-- C: Header Info -->
                <TablixMember /> <!-- D: Line Items -->
                <TablixMember /> <!-- E: Purpose -->
                <TablixMember /> <!-- F: Signatures -->
              </TablixMembers>
            </TablixRowHierarchy>

            <Top>0in</Top><Left>0in</Left><Width>7.5in</Width>
          </Tablix>

        </ReportItems>
        <Height>9in</Height>
        <Style />
      </Body>
      <Width>7.5in</Width>
      <Page>
        <PageHeight>11in</PageHeight>
        <PageWidth>8.5in</PageWidth>
        <LeftMargin>0.5in</LeftMargin>
        <RightMargin>0.5in</RightMargin>
        <TopMargin>0.5in</TopMargin>
        <BottomMargin>0.5in</BottomMargin>
        <Style />
      </Page>
    </ReportSection>
  </ReportSections>

  <Language>en-PH</Language>
  <ConsumeContainerWhitespace>true</ConsumeContainerWhitespace>
