<?xml version="1.0" encoding="utf-8"?>
<Report ScriptLanguage="CSharp" ReportInfo.Created="05/18/2026 00:00:00" ReportInfo.Modified="05/18/2026 00:00:00" ReportInfo.CreatorVersion="2025.1.0">
  <Dictionary />
  <!--
    Data sources are registered at runtime via Report.RegisterData(...).

    Layout: A4 landscape (297 × 210 mm), 8 mm margins.
    Content width  = (297-16) × 3.7795 = 1062 units
    Content height = (210-16) × 3.7795 =  733 units

    Two identical IAR copies side-by-side with a 2× margin gap for cutting:
      Left  copy : x = 0   … 500   (500 units ≈ 132.3 mm)
      Gap        : x = 500 … 562   ( 62 units ≈  16.4 mm)  ← cut here (≈ 2× the 8 mm margin)
      Right copy : x = 562 … 1062  (500 units ≈ 132.3 mm)

    Table column widths (each copy, total 500):
      Stock/Property No (24%) : 120     x=0   / 562
      Description       (44%) : 220     x=120 / 682
      Unit              (10%) :  50     x=340 / 902
      Quantity          (22%) : 110     x=390 / 952

    Header order matches the Purchase Request template:
      Republic of the Philippines
      National Food Authority        (hardcoded, Bold)
      [IarDS.OrgName]                (regional office / agency line)
      [IarDS.OrgAddress]             (city / municipality)
  -->

  <ReportPage Name="Page1"
    PaperWidth="297" PaperHeight="210"
    LeftMargin="8" TopMargin="8" RightMargin="8" BottomMargin="8"
    Landscape="true">

    <!-- ═══════════════════════════════════════════════════════════
         TITLE BAND  (appears once)
         ═══════════════════════════════════════════════════════════ -->
    <ReportTitleBand Name="ReportTitle1" Width="1062" Height="220">

      <!-- ═══ LEFT COPY ════════════════════════════════════════ -->

      <!-- ── Appendix 62 (right-aligned) ─────────────────────── -->
      <TextObject Name="L_Appendix" Left="0" Top="0" Width="500" Height="12"
        Text="Appendix 62" HorzAlign="Right" VertAlign="Center"
        Font="Times New Roman, 8pt, style=Italic" />

      <!-- ── Organization Header (matches PR template) ────────── -->
      <TextObject Name="L_Republic" Left="0" Top="14" Width="500" Height="12"
        Text="Republic of the Philippines" HorzAlign="Center" VertAlign="Center"
        Font="Times New Roman, 9pt" />
      <TextObject Name="L_NFA" Left="0" Top="26" Width="500" Height="16"
        Text="National Food Authority" HorzAlign="Center" VertAlign="Center"
        Font="Times New Roman, 11pt, style=Bold" />
      <TextObject Name="L_OrgName" Left="0" Top="42" Width="500" Height="12"
        Text="[IarDS.OrgName]" HorzAlign="Center" VertAlign="Center"
        Font="Times New Roman, 9pt" />
      <TextObject Name="L_OrgAddress" Left="0" Top="54" Width="500" Height="12"
        Text="[IarDS.OrgAddress]" HorzAlign="Center" VertAlign="Center"
        Font="Times New Roman, 9pt" />

      <!-- ── Title ───────────────────────────────────────────── -->
      <TextObject Name="L_Title" Left="0" Top="80" Width="500" Height="18"
        Text="INSPECTION AND ACCEPTANCE REPORT" HorzAlign="Center" VertAlign="Center"
        Font="Times New Roman, 12pt, style=Bold" />
      <TextObject Name="L_TitleUL" Left="80" Top="98" Width="340" Height="1.1"
        Text="" Border.Lines="4" Border.Width="1" />

      <!-- ═══ Info Box: 5 rows × 4 cols (top=90, H=85) ═════════
           Left half  (0-250)   : labels (0-90)   + values (90-250)
           Right half (250-500) : labels (250-340) + values (340-500)
      -->

      <!-- Row 1: Entity Name | Fund Cluster -->
      <TextObject Name="L_EntLbl" Left="0" Top="114" Width="90" Height="17"
        Text="Entity Name :" Font="Times New Roman, 7pt" VertAlign="Center"
        Border.Lines="15" Border.Width="0.5" Padding="2,1,2,1" />
      <TextObject Name="L_EntVal" Left="90" Top="114" Width="160" Height="17"
        Text="[IarDS.OrgName]" Font="Times New Roman, 8pt, style=Bold" VertAlign="Center"
        Border.Lines="15" Border.Width="0.5" Padding="2,1,2,1" />
