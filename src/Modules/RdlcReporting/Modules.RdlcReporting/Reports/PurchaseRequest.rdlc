<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df"
        xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition"
        xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner"
        xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Arial</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>

  <!--
    Layout: Letter landscape (11 × 8.5 in), 0.5 in margins.
    Content width  = 10 in
    Two identical PR copies side-by-side with a 2× margin gap for cutting:
      Left  copy : Left=0in,    Width=4.5in
      Gap        : 4.5..5.5in   (1.0 in = 2× the 0.5 in margin) ← cut here
      Right copy : Left=5.5in,  Width=4.5in
  -->

  <!-- ═══════════ DATA SOURCES ═══════════ -->
  <DataSources>
    <DataSource Name="PurchaseRequestDS">
      <ConnectionProperties><DataProvider>System.Object</DataProvider><ConnectString /></ConnectionProperties>
    </DataSource>
    <DataSource Name="LineItemsDS">
      <ConnectionProperties><DataProvider>System.Object</DataProvider><ConnectString /></ConnectionProperties>
    </DataSource>
    <DataSource Name="LineItemsDS_R">
      <ConnectionProperties><DataProvider>System.Object</DataProvider><ConnectString /></ConnectionProperties>
    </DataSource>
    <DataSource Name="OrganizationProfileDS">
      <ConnectionProperties><DataProvider>System.Object</DataProvider><ConnectString /></ConnectionProperties>
    </DataSource>
  </DataSources>

  <!-- ═══════════ DATA SETS ═══════════ -->
  <DataSets>

    <DataSet Name="PurchaseRequestDS">
      <Query><DataSourceName>PurchaseRequestDS</DataSourceName><CommandText /></Query>
      <Fields>
        <Field Name="PrNumber"><DataField>PrNumber</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="PrDate"><DataField>PrDate</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="SaiNumber"><DataField>SaiNumber</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="SaiDate"><DataField>SaiDate</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="AlobsNumber"><DataField>AlobsNumber</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="AlobsDate"><DataField>AlobsDate</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="DepartmentName"><DataField>DepartmentName</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="ResponsibilityCenterCode"><DataField>ResponsibilityCenterCode</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Purpose"><DataField>Purpose</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Justification"><DataField>Justification</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="RequestedByName"><DataField>RequestedByName</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="ApprovedByName"><DataField>ApprovedByName</DataField><rd:TypeName>System.String</rd:TypeName></Field>
      </Fields>
    </DataSet>

    <DataSet Name="LineItemsDS">
      <Query><DataSourceName>LineItemsDS</DataSourceName><CommandText /></Query>
      <Fields>
        <Field Name="ItemNo"><DataField>ItemNo</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="UnitOfIssue"><DataField>UnitOfIssue</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="ItemDescription"><DataField>ItemDescription</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Quantity"><DataField>Quantity</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="EstimatedUnitCost"><DataField>EstimatedUnitCost</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="EstimatedTotalCost"><DataField>EstimatedTotalCost</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
      </Fields>
    </DataSet>

    <DataSet Name="LineItemsDS_R">
      <Query><DataSourceName>LineItemsDS_R</DataSourceName><CommandText /></Query>
      <Fields>
        <Field Name="ItemNo"><DataField>ItemNo</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="UnitOfIssue"><DataField>UnitOfIssue</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="ItemDescription"><DataField>ItemDescription</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Quantity"><DataField>Quantity</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="EstimatedUnitCost"><DataField>EstimatedUnitCost</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="EstimatedTotalCost"><DataField>EstimatedTotalCost</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
      </Fields>
    </DataSet>

    <DataSet Name="OrganizationProfileDS">
      <Query><DataSourceName>OrganizationProfileDS</DataSourceName><CommandText /></Query>
      <Fields>
        <Field Name="Name"><DataField>Name</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Address"><DataField>Address</DataField><rd:TypeName>System.String</rd:TypeName></Field>
      </Fields>
    </DataSet>

  </DataSets>

  <!-- ═══════════ REPORT BODY ═══════════ -->
  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>

          <!-- ════════════════════════════════════════════════════════════
               LEFT COPY  (Left=0in, Width=4.5in)
               ════════════════════════════════════════════════════════════ -->
          <Tablix Name="MainTable_L">
            <TablixBody>
              <TablixColumns>
                <TablixColumn><Width>4.5in</Width></TablixColumn>
              </TablixColumns>
              <TablixRows>

                <!-- ─── ROW A: AGENCY HEADER ─── -->
                <TablixRow>
                  <Height>0.6in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Rectangle Name="AgencyHeaderRect_L">
                          <ReportItems>
                            <Textbox Name="RepublicTxt_L">
                              <Paragraphs><Paragraph><TextRuns><TextRun>
                                <Value>Republic of the Philippines</Value>
                                <Style><FontSize>7pt</FontSize></Style>
                              </TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
                              <Top>0in</Top><Left>0in</Left><Width>4.5in</Width><Height>0.17in</Height>
                              <Style />
                            </Textbox>
                            <Textbox Name="AgencyNameTxt_L">
                              <Paragraphs><Paragraph><TextRuns><TextRun>
                                <Value>=First(Fields!Name.Value, "OrganizationProfileDS")</Value>
                                <Style><FontSize>10pt</FontSize><FontWeight>Bold</FontWeight></Style>
                              </TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
                              <Top>0.17in</Top><Left>0in</Left><Width>4.5in</Width><Height>0.25in</Height>
                              <Style />
                            </Textbox>
                            <Textbox Name="AgencyAddressTxt_L">
                              <Paragraphs><Paragraph><TextRuns><TextRun>
                                <Value>=First(Fields!Address.Value, "OrganizationProfileDS")</Value>
                                <Style><FontSize>7pt</FontSize></Style>
                              </TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
                              <Top>0.42in</Top><Left>0in</Left><Width>4.5in</Width><Height>0.16in</Height>
                              <Style />
                            </Textbox>
                          </ReportItems>
                          <Top>0in</Top><Left>0in</Left><Width>4.5in</Width><Height>0.6in</Height>
                          <Style />
                        </Rectangle>
                      </CellContents>
                    </TablixCell>
                  </TablixCells>
                </TablixRow>

                <!-- ─── ROW B: REPORT TITLE ─── -->
                <TablixRow>
                  <Height>0.3in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="ReportTitleTxt_L">
                          <Paragraphs><Paragraph><TextRuns><TextRun>
                            <Value>PURCHASE REQUEST</Value>
                            <Style><FontSize>12pt</FontSize><FontWeight>Bold</FontWeight></Style>
                          </TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
                          <Style>
                            <VerticalAlign>Middle</VerticalAlign>
                            <TopBorder><Style>Solid</Style><Width>2pt</Width></TopBorder>
                            <BottomBorder><Style>Solid</Style><Width>1pt</Width></BottomBorder>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
                  </TablixCells>
                </TablixRow>

                <!-- ─── ROW C: HEADER INFO ─── -->
                <TablixRow>
                  <Height>1.4in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Tablix Name="HeaderInfoTable_L">
                          <TablixBody>
                            <TablixColumns>
                              <TablixColumn><Width>0.8in</Width></TablixColumn>
                              <TablixColumn><Width>1.4in</Width></TablixColumn>
                              <TablixColumn><Width>0.8in</Width></TablixColumn>
                              <TablixColumn><Width>1.5in</Width></TablixColumn>
                            </TablixColumns>
                            <TablixRows>

                              <!-- Row 1: Department | PR No. -->
                              <TablixRow><Height>0.22in</Height><TablixCells>
                                <TablixCell><CellContents><Textbox Name="HiLblDept_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>Department:</Value><Style><FontSize>7pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValDept_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>=First(Fields!DepartmentName.Value, "PurchaseRequestDS")</Value><Style><FontSize>7pt</FontSize></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><PaddingLeft>3pt</PaddingLeft><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiLblPrNo_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>PR No.:</Value><Style><FontSize>7pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValPrNo_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>=First(Fields!PrNumber.Value, "PurchaseRequestDS")</Value><Style><FontSize>7pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><PaddingLeft>3pt</PaddingLeft><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                              </TablixCells></TablixRow>

                              <!-- Row 2: RC Code | PR Date -->
                              <TablixRow><Height>0.22in</Height><TablixCells>
                                <TablixCell><CellContents><Textbox Name="HiLblRc_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>RC Code:</Value><Style><FontSize>7pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValRc_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>=First(Fields!ResponsibilityCenterCode.Value, "PurchaseRequestDS")</Value><Style><FontSize>7pt</FontSize></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><PaddingLeft>3pt</PaddingLeft><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiLblPrDate_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>PR Date:</Value><Style><FontSize>7pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValPrDate_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>=First(Fields!PrDate.Value, "PurchaseRequestDS")</Value><Style><FontSize>7pt</FontSize></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><PaddingLeft>3pt</PaddingLeft><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                              </TablixCells></TablixRow>

                              <!-- Row 3: (empty) | SAI No. -->
                              <TablixRow><Height>0.22in</Height><TablixCells>
                                <TablixCell><CellContents><Textbox Name="HiLblE1_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value /><Style /></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValE1_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value /><Style /></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiLblSaiNo_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>SAI No.:</Value><Style><FontSize>7pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValSaiNo_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>=First(Fields!SaiNumber.Value, "PurchaseRequestDS")</Value><Style><FontSize>7pt</FontSize></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><PaddingLeft>3pt</PaddingLeft><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                              </TablixCells></TablixRow>

                              <!-- Row 4: (empty) | SAI Date -->
                              <TablixRow><Height>0.22in</Height><TablixCells>
                                <TablixCell><CellContents><Textbox Name="HiLblE2_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value /><Style /></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValE2_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value /><Style /></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiLblSaiDate_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>SAI Date:</Value><Style><FontSize>7pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValSaiDate_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>=First(Fields!SaiDate.Value, "PurchaseRequestDS")</Value><Style><FontSize>7pt</FontSize></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><PaddingLeft>3pt</PaddingLeft><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                              </TablixCells></TablixRow>

                              <!-- Row 5: (empty) | ALOBS No. -->
                              <TablixRow><Height>0.22in</Height><TablixCells>
                                <TablixCell><CellContents><Textbox Name="HiLblE3_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value /><Style /></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValE3_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value /><Style /></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiLblAlobsNo_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>ALOBS No.:</Value><Style><FontSize>7pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValAlobsNo_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>=First(Fields!AlobsNumber.Value, "PurchaseRequestDS")</Value><Style><FontSize>7pt</FontSize></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><PaddingLeft>3pt</PaddingLeft><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                              </TablixCells></TablixRow>

                              <!-- Row 6: (empty) | ALOBS Date -->
                              <TablixRow><Height>0.22in</Height><TablixCells>
                                <TablixCell><CellContents><Textbox Name="HiLblE4_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value /><Style /></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValE4_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value /><Style /></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiLblAlobsDate_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>ALOBS Date:</Value><Style><FontSize>7pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="HiValAlobsDate_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>=First(Fields!AlobsDate.Value, "PurchaseRequestDS")</Value><Style><FontSize>7pt</FontSize></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><PaddingLeft>3pt</PaddingLeft><Border><Style>Solid</Style><Color>Gray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                              </TablixCells></TablixRow>

                            </TablixRows>
                          </TablixBody>
                          <TablixColumnHierarchy><TablixMembers><TablixMember /><TablixMember /><TablixMember /><TablixMember /></TablixMembers></TablixColumnHierarchy>
                          <TablixRowHierarchy><TablixMembers><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /></TablixMembers></TablixRowHierarchy>
                          <DataSetName>PurchaseRequestDS</DataSetName>
                          <Top>0in</Top><Left>0in</Left><Width>4.5in</Width>
                        </Tablix>
                      </CellContents>
                    </TablixCell>
                  </TablixCells>
                </TablixRow>

                <!-- ─── ROW D: LINE ITEMS ─── -->
                <TablixRow>
                  <Height>0.53in</Height>
                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Tablix Name="LineItemsTable_L">
                          <TablixBody>
                            <TablixColumns>
                              <TablixColumn><Width>0.3in</Width></TablixColumn>
                              <TablixColumn><Width>0.4in</Width></TablixColumn>
                              <TablixColumn><Width>1.7in</Width></TablixColumn>
                              <TablixColumn><Width>0.4in</Width></TablixColumn>
                              <TablixColumn><Width>0.8in</Width></TablixColumn>
                              <TablixColumn><Width>0.9in</Width></TablixColumn>
                            </TablixColumns>
                            <TablixRows>

                              <!-- HEADER ROW -->
                              <TablixRow><Height>0.25in</Height><TablixCells>
                                <TablixCell><CellContents><Textbox Name="LiHdrNo_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>No.</Value><Style><FontSize>7pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><BackgroundColor>LightGray</BackgroundColor><Border><Style>Solid</Style><Color>DimGray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="LiHdrUnit_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>Unit</Value><Style><FontSize>7pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><BackgroundColor>LightGray</BackgroundColor><Border><Style>Solid</Style><Color>DimGray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="LiHdrDesc_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>Description</Value><Style><FontSize>7pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><BackgroundColor>LightGray</BackgroundColor><Border><Style>Solid</Style><Color>DimGray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="LiHdrQty_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>Qty</Value><Style><FontSize>7pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><BackgroundColor>LightGray</BackgroundColor><Border><Style>Solid</Style><Color>DimGray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="LiHdrUnitCost_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>Unit Cost</Value><Style><FontSize>7pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><BackgroundColor>LightGray</BackgroundColor><Border><Style>Solid</Style><Color>DimGray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                                <TablixCell><CellContents><Textbox Name="LiHdrTotalCost_L">
                                  <Paragraphs><Paragraph><TextRuns><TextRun><Value>Total Cost</Value><Style><FontSize>7pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs>
                                  <Style><VerticalAlign>Middle</VerticalAlign><BackgroundColor>LightGray</BackgroundColor><Border><Style>Solid</Style><Color>DimGray</Color></Border></Style>
                                </Textbox></CellContents></TablixCell>
                              </TablixCells></TablixRow>

                              <!-- DETAIL ROW -->
                              <TablixRow><Height>0.22in</Height><TablixCells>
